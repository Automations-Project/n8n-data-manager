# Bulk update multiple settings in a .n8n file
# Args: $1=file path, remaining args=key=value pairs
# Returns: 0 on success
wf_bulk_update_settings() {
    local file="$1"
    shift

    for pair in "$@"; do
        local key="${pair%%=*}"
        local value="${pair#*=}"
        wf_update_setting "$file" "$key" "$value" || return 1
    done
    return 0
}

