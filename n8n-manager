              [ -n "$f" ] && files_to_process+=("$f")
          done <<< "$selected"
      else
          while IFS='|' read -r wf_path _rest; do
              [ -n "$wf_path" ] && files_to_process+=("$wf_path")
          done <<< "$workflow_data"
      fi
  else
