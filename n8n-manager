n8n_manager_backup_command() {

  # src/backup_command.sh

  set -Eeuo pipefail
  IFS=$'\n\t'

  setup_globals

  ARG_CONTAINER="${args[--container]:-}"
  ARG_TOKEN="${args[--token]:-${ARG_TOKEN:-}}"
  ARG_REPO="${args[--repo]:-${ARG_REPO:-}}"
  ARG_BRANCH="${args[--branch]:-${ARG_BRANCH:-main}}"
  ARG_N8N_API_KEY="${args[--n8n-api-key]:-${ARG_N8N_API_KEY:-}}"
  ARG_N8N_API_URL="${args[--n8n-api-url]:-${ARG_N8N_API_URL:-}}"
  ARG_FORCE="${args[--force]:-}"
  ARG_BACKUP_TYPE="${args[--backup-type]:-${ARG_BACKUP_TYPE:-all}}"
  ARG_BACKUP_LAYOUT="${args[--backup-layout]:-${ARG_BACKUP_LAYOUT:-canonical}}"
  ARG_CREDENTIAL_EXPORT_MODE="${args[--credential-export-mode]:-${ARG_CREDENTIAL_EXPORT_MODE:-stubs}}"
  ARG_SEPARATE_FILES="${args[--separate-files]:-}"
  ARG_INCREMENTAL="${args[--incremental]:-}"
  ARG_WORKFLOW_ID="${args[--workflow-id]:-}"
  ARG_CREDENTIAL_ID="${args[--credential-id]:-}"
  ARG_INCLUDE_LINKED_CREDS="${args[--include-linked-creds]:-}"
  ARG_ONLY_NEW="${args[--only-new]:-}"
  ARG_IMPORT_AS_NEW="${args[--import-as-new]:-}"
  ARG_SELECT="${args[--select]:-}"
  ARG_TOKEN_FILE="${args[--token-file]:-}"
  ARG_TOKEN_STDIN="${args[--token-stdin]:-}"

  # Resolve token from --token-file or --token-stdin (D-08); overrides bare --token
  if [ -n "$ARG_TOKEN_FILE" ]; then
      if [ ! -f "$ARG_TOKEN_FILE" ]; then
          log ERROR "--token-file: file not found: $ARG_TOKEN_FILE"
          exit 1
      fi
      local _file_mode
      _file_mode=$(stat -c '%a' "$ARG_TOKEN_FILE" 2>/dev/null || stat -f '%A' "$ARG_TOKEN_FILE" 2>/dev/null || echo "unknown")
      if [ "$_file_mode" != "600" ]; then
          log ERROR "--token-file: file must have mode 600, got mode $_file_mode. Run: chmod 600 $ARG_TOKEN_FILE"
          exit 1
      fi
      ARG_TOKEN=$(cat "$ARG_TOKEN_FILE")
      [ -z "$ARG_TOKEN" ] && { log ERROR "--token-file: file is empty"; exit 1; }
  elif [ "${ARG_TOKEN_STDIN:-}" = "1" ]; then
      if [ ! -t 0 ]; then
          local _stdin_token
          _stdin_token=$(cat 2>/dev/null || echo "")
          [ -z "$_stdin_token" ] && { log ERROR "--token-stdin: stdin is empty or /dev/null — refusing to continue with empty PAT"; exit 1; }
          ARG_TOKEN="$_stdin_token"
      else
          printf 'GitHub PAT: ' >&2
          read -rs ARG_TOKEN
          printf '\n' >&2
          [ -z "$ARG_TOKEN" ] && { log ERROR "--token-stdin: empty token entered"; exit 1; }
      fi
  elif [ -n "${ARG_TOKEN:-}" ]; then
      # D-09: bare --token deprecation warning (once per session via sentinel)
      local _token_warn_sentinel="${XDG_DATA_HOME:-$HOME/.local/share}/n8n-manager/.token-flag-warned"
      if [ ! -f "$_token_warn_sentinel" ]; then
          printf 'WARNING: --token is deprecated; use --token-file or --token-stdin to avoid token leaks via /proc/cmdline.\n' >&2
          printf '   See https://github.com/Automations-Project/n8n-data-manager/blob/main/README.md#token-handling\n' >&2
          mkdir -p "$(dirname "$_token_warn_sentinel")" 2>/dev/null || true
          touch "$_token_warn_sentinel" 2>/dev/null || true
      fi
  fi

  local is_dry_run=false
  [[ "${ARG_DRY_RUN:-}" == "1" ]] && is_dry_run=true

  _backup_fail_conflict() {
      local message="$1"
      local fix_hint="$2"
      log ERROR "$message"
      [ -n "$fix_hint" ] && log ERROR "Fix: $fix_hint"
      return 1
  }

  _backup_validate_conflicts() {
      case "${ARG_BACKUP_LAYOUT:-canonical}" in
          canonical|combined|workflow-bundles) ;;
          *)
              _backup_fail_conflict \
                  "Invalid --backup-layout '${ARG_BACKUP_LAYOUT}'." \
                  "Use one of: canonical, combined, workflow-bundles."
              return 1
              ;;
      esac

      if [[ "${ARG_BACKUP_TYPE:-all}" == "full-db" && "${ARG_BACKUP_LAYOUT:-canonical}" != "canonical" ]]; then
          _backup_fail_conflict \
              "full-db mode does not support bundled output layouts." \
              "Use --backup-layout canonical with --backup-type full-db."
          return 1
      fi

      if [[ "${ARG_BACKUP_TYPE:-all}" == "enterprise" && "${ARG_BACKUP_LAYOUT:-canonical}" != "canonical" ]]; then
          _backup_fail_conflict \
              "Enterprise Compatible mode requires canonical source-control layout." \
              "Use --backup-layout canonical (or remove --backup-layout)."
          return 1
      fi

      if [[ "${ARG_BACKUP_LAYOUT:-canonical}" != "canonical" && "${ARG_INCREMENTAL:-}" == "1" ]]; then
          _backup_fail_conflict \
              "Incremental backups are only supported with canonical layout." \
              "Remove --incremental or switch to --backup-layout canonical."
          return 1
      fi

      if [[ "${ARG_BACKUP_LAYOUT:-canonical}" == "workflow-bundles" ]]; then
          if [[ "${ARG_BACKUP_TYPE:-all}" != "all" && "${ARG_BACKUP_TYPE:-all}" != "workflows" ]]; then
              _backup_fail_conflict \
                  "workflow-bundles layout only supports workflows/all backup types." \
                  "Use --backup-type workflows (or all) with --backup-layout workflow-bundles."
              return 1
          fi
          if [ -z "${ARG_WORKFLOW_ID:-}" ] && [[ "${ARG_SELECT:-}" != "1" ]]; then
              log WARN "workflow-bundles selected without explicit workflow IDs; bundles will be generated for all exported workflows."
          fi
          if [[ "${ARG_INCLUDE_LINKED_CREDS:-}" != "1" && "${ARG_INCLUDE_LINKED_CREDS:-}" != "true" ]]; then
              ARG_INCLUDE_LINKED_CREDS=1
              log INFO "workflow-bundles layout enabled linked credentials automatically."
          fi
      fi

      if [[ "${ARG_BACKUP_TYPE:-all}" == "enterprise" && "${ARG_CREDENTIAL_EXPORT_MODE:-stubs}" != "stubs" ]]; then
          log WARN "Credential export mode is ignored in enterprise backup type; forcing stubs."
          ARG_CREDENTIAL_EXPORT_MODE="stubs"
      fi

      if [[ "${ARG_SEPARATE_FILES:-}" == "1" && "${ARG_BACKUP_LAYOUT:-canonical}" != "canonical" ]]; then
          log WARN "--separate-files is ignored when bundled layout is selected."
      fi

      return 0
  }

  if [ -t 0 ]; then
      check_install_mode
      _show_backup_intro

      if [ -z "$ARG_CONTAINER" ]; then
          select_container
          ARG_CONTAINER="$SELECTED_CONTAINER_ID"
      fi

      if [ -z "$ARG_TOKEN" ] || [ -z "$ARG_REPO" ]; then
          get_github_config
          ARG_TOKEN="${ARG_TOKEN:-$GITHUB_TOKEN}"
          ARG_REPO="${ARG_REPO:-$GITHUB_REPO}"
          ARG_BRANCH="${ARG_BRANCH:-$GITHUB_BRANCH}"
      fi

      # Keep prior interactive UX: type picker + optional advanced options.
      if [ "$ARG_BACKUP_TYPE" = "all" ] && [ -z "$ARG_WORKFLOW_ID" ] && [ -z "$ARG_CREDENTIAL_ID" ]; then
          select_backup_type
      fi

      if [ "$ARG_BACKUP_TYPE" != "full-db" ]; then
          local offer_options=false
          [ -z "$ARG_SEPARATE_FILES" ] && [ -z "$ARG_INCREMENTAL" ] && offer_options=true
          if $offer_options; then
              if ui_confirm "Configure advanced backup options?" "Yes" "No, use defaults"; then
                  select_backup_options
                  [[ "${ARG_SEPARATE_FILES:-}" == "true" ]] && ARG_SEPARATE_FILES=1
                  [[ "${ARG_ONLY_NEW:-}" == "true" ]] && ARG_ONLY_NEW=1
                  [[ "${ARG_INCLUDE_LINKED_CREDS:-}" == "true" ]] && ARG_INCLUDE_LINKED_CREDS=1
                  [[ "${ARG_IMPORT_AS_NEW:-}" == "true" ]] && ARG_IMPORT_AS_NEW=1
                  [[ -n "${ARG_BACKUP_LAYOUT:-}" ]] || ARG_BACKUP_LAYOUT="canonical"
              fi
          fi
      fi

      # Restore previous interactive workflow selector behavior.
      if [[ "$ARG_BACKUP_TYPE" == "all" || "$ARG_BACKUP_TYPE" == "workflows" ]]; then
          if [ -t 0 ] && [[ "${ARG_SELECT}" != "1" ]] && [ -z "$ARG_WORKFLOW_ID" ] && [ "$ARG_BACKUP_TYPE" = "workflows" ]; then
              if ui_confirm "Select specific workflows to backup?" "Select specific" "Backup all"; then
                  ARG_SELECT=1
              fi
          fi

          if [[ "${ARG_SELECT}" == "1" ]] && [ -z "$ARG_WORKFLOW_ID" ]; then
              local wf_list
              wf_list=$(list_container_workflows "$ARG_CONTAINER" 2>/dev/null) || true
              if [ -n "$wf_list" ]; then
                  local selected_ids=""
                  local select_rc=0
                  selected_ids=$(select_workflows_interactive "$wf_list" "backup") || select_rc=$?

                  if [ $select_rc -ne 0 ]; then
                      log INFO "Backup cancelled — no workflows selected"
                      exit 0
                  fi

                  if [ -n "$selected_ids" ]; then
                      ARG_WORKFLOW_ID="$selected_ids"
                      log INFO "Will backup selected workflows: $ARG_WORKFLOW_ID"
                      if [ -z "${ARG_INCLUDE_LINKED_CREDS:-}" ] && [ "$ARG_BACKUP_TYPE" != "full-db" ]; then
                          if ui_confirm "Also include credentials linked to the selected workflows?" "Include linked creds" "Workflows only"; then
                              ARG_INCLUDE_LINKED_CREDS=1
                              log INFO "Linked credentials will be auto-included"
                          fi
                      fi
                  else
                      log INFO "Will backup all workflows"
                  fi
              else
                  log WARN "Could not list workflows — will export all"
              fi
          fi
      fi
  fi

  if [ -z "$ARG_CONTAINER" ]; then
      log ERROR "Container is required. Use --container or run interactively."
      exit 1
  fi
  if [ -z "$ARG_TOKEN" ]; then
      log ERROR "GitHub token is required. Use --token or configure in config file."
      exit 1
  fi
  if [ -z "$ARG_REPO" ]; then
      log ERROR "GitHub repository is required. Use --repo or configure in config file."
      exit 1
  fi

  _recording_write_repo_context "$ARG_TOKEN" "$ARG_REPO" "$ARG_BRANCH" || true

  if [[ "${ARG_SEPARATE_FILES:-}" == "1" ]]; then
      log INFO "Separate files mode is implicit in canonical source-control layout"
  fi
  if [[ "${ARG_INCREMENTAL:-}" == "1" ]]; then
      log WARN "Incremental mode is requested; canonical export currently applies full selected scope with only-new filtering"
  fi

  case "${ARG_CREDENTIAL_EXPORT_MODE:-stubs}" in
      stubs|encrypted|decrypted) ;;
      *)
          log WARN "Invalid --credential-export-mode '${ARG_CREDENTIAL_EXPORT_MODE}'. Falling back to 'stubs'."
          ARG_CREDENTIAL_EXPORT_MODE="stubs"
          ;;
  esac

  if ! _backup_validate_conflicts; then
      exit 1
  fi

  if [[ "${ARG_CREDENTIAL_EXPORT_MODE:-stubs}" == "decrypted" ]]; then
      log WARN "Credential export mode is 'decrypted'. Sensitive values will be stored in backup files."
  fi
  if [[ "${ARG_BACKUP_LAYOUT:-canonical}" != "canonical" ]]; then
      log WARN "Backup layout '${ARG_BACKUP_LAYOUT}' enabled; canonical export will be packed into bundle artifacts."
  fi

  ui_dashboard_header "Backup" "$THEME_WARNING"
  if $is_dry_run; then ui_notification "warning" "DRY RUN MODE" "No changes will be made"; fi

  ui_section_header "Validating" "🔐" "$THEME_WARNING"
  if ! check_github_access "$ARG_TOKEN" "$ARG_REPO" "$ARG_BRANCH" "backup"; then
      screen_error "backup" "GitHub access validation failed" "Repository: $ARG_REPO | Branch: $ARG_BRANCH" ""
      exit 1
  fi

  local tmp_dir
  tmp_dir=$(mktemp -d -t n8n-backup-XXXXXXXXXX)
  trap "rm -rf '$tmp_dir'" EXIT

  ui_section_header "Git Setup" "📂" "$THEME_INFO"
  if ! git_init_backup_repo "$tmp_dir" "$ARG_TOKEN" "$ARG_REPO" "$ARG_BRANCH"; then
      exit 1
  fi

  local backup_dir="$tmp_dir"

  if [[ "$ARG_BACKUP_TYPE" == "full-db" ]]; then
      ui_header "💾 Full Database Export"
      local fulldb_dir="$backup_dir"
      mkdir -p "$fulldb_dir"

      if ! export_full_database "$ARG_CONTAINER" "$fulldb_dir" "$is_dry_run"; then
          log ERROR "Full database export failed"
          exit 1
      fi

      if ! git_commit_and_push "$tmp_dir" "$ARG_BRANCH" "$fulldb_dir" "$ARG_CONTAINER" \
          "$ARG_BACKUP_TYPE" "$is_dry_run" "${ARG_FORCE:-false}"; then
          exit 1
      fi

      screen_completion "backup" "$ARG_CONTAINER" "$ARG_REPO" "$ARG_BRANCH" \
          "Type|full-db" "Status|Complete ✔" "Timestamp|$(date '+%Y-%m-%d %H:%M:%S')"
      cleanup_one_time
      exit 0
  fi

  ui_section_header "Exporting Data" "📦" "$THEME_SECONDARY"
  if ! sc_export_canonical_backup "$ARG_CONTAINER" "$backup_dir" "$ARG_BACKUP_TYPE" "$is_dry_run"; then
      log ERROR "Canonical backup export failed"
      exit 1
  fi

  if ! sc_export_finalize_layout_variant "$backup_dir" "$ARG_BACKUP_TYPE" "${ARG_BACKUP_LAYOUT:-canonical}" "$is_dry_run"; then
      log ERROR "Backup layout finalization failed"
      exit 1
  fi

  if ! git_commit_and_push "$tmp_dir" "$ARG_BRANCH" "$backup_dir" "$ARG_CONTAINER" \
      "$ARG_BACKUP_TYPE" "$is_dry_run" "${ARG_FORCE:-false}"; then
      exit 1
  fi

  screen_completion "backup" "$ARG_CONTAINER" "$ARG_REPO" "$ARG_BRANCH" \
      "Type|$ARG_BACKUP_TYPE" \
      "Container|$ARG_CONTAINER" \
      "Branch|$ARG_BRANCH" \
      "Layout|${ARG_BACKUP_LAYOUT:-canonical}" \
      "Format|canonical / .n8n.backup(s) depending on layout" \
      "Status|Complete ✔" \
      "Timestamp|$(date '+%Y-%m-%d %H:%M:%S')"

  if [ "$N8N_MANAGER_MODE" != "one-time" ]; then
      offer_save_settings
  fi

  cleanup_one_time

}

# :command.function
n8n_manager_restore_command() {

  # src/restore_command.sh

  set -Eeuo pipefail
  IFS=$'\n\t'

  setup_globals

  ARG_CONTAINER="${args[--container]:-}"
  ARG_TOKEN="${args[--token]:-${ARG_TOKEN:-}}"
  ARG_REPO="${args[--repo]:-${ARG_REPO:-}}"
  ARG_BRANCH="${args[--branch]:-${ARG_BRANCH:-main}}"
  ARG_N8N_API_KEY="${args[--n8n-api-key]:-${ARG_N8N_API_KEY:-}}"
  ARG_N8N_API_URL="${args[--n8n-api-url]:-${ARG_N8N_API_URL:-}}"
  ARG_FORCE="${args[--force]:-}"
  ARG_DELETE_MISSING="${args[--delete-missing]:-}"
  ARG_LEGACY_FALLBACK="${args[--legacy-fallback]:-}"
  ARG_ACCEPT_LEGACY_PARTIAL="${args[--accept-legacy-partial]:-}"
  ARG_RESTORE_TYPE="${args[--restore-type]:-${ARG_RESTORE_TYPE:-all}}"
  ARG_RESTORE_MODE="${args[--restore-mode]:-${ARG_RESTORE_MODE:-overwrite}}"
  ARG_SEPARATE_FILES="${args[--separate-files]:-}"
  ARG_IMPORT_AS_NEW="${args[--import-as-new]:-}"
  ARG_ONLY_NEW="${args[--only-new]:-}"
  ARG_WORKFLOW_ID="${args[--workflow-id]:-}"
  ARG_CREDENTIAL_ID="${args[--credential-id]:-}"
  ARG_USER_ID="${args[--user-id]:-}"
  ARG_PROJECT_ID="${args[--project-id]:-}"
  ARG_SELECT="${args[--select]:-}"
  ARG_TOKEN_FILE="${args[--token-file]:-}"
  ARG_TOKEN_STDIN="${args[--token-stdin]:-}"
  ARG_ALLOW_SCHEMA_DRIFT="${args[--allow-schema-drift]:-}"
  ARG_UNSAFE_DECRYPTED_CREDENTIALS="${args[--unsafe-decrypted-credentials]:-}"

  # Resolve token from --token-file or --token-stdin (D-08); overrides bare --token
  if [ -n "$ARG_TOKEN_FILE" ]; then
      if [ ! -f "$ARG_TOKEN_FILE" ]; then
          log ERROR "--token-file: file not found: $ARG_TOKEN_FILE"
          exit 1
      fi
      local _file_mode
      _file_mode=$(stat -c '%a' "$ARG_TOKEN_FILE" 2>/dev/null || stat -f '%A' "$ARG_TOKEN_FILE" 2>/dev/null || echo "unknown")
      if [ "$_file_mode" != "600" ]; then
          log ERROR "--token-file: file must have mode 600, got mode $_file_mode. Run: chmod 600 $ARG_TOKEN_FILE"
          exit 1
      fi
      ARG_TOKEN=$(cat "$ARG_TOKEN_FILE")
      [ -z "$ARG_TOKEN" ] && { log ERROR "--token-file: file is empty"; exit 1; }
  elif [ "${ARG_TOKEN_STDIN:-}" = "1" ]; then
      if [ ! -t 0 ]; then
          local _stdin_token
          _stdin_token=$(cat 2>/dev/null || echo "")
          [ -z "$_stdin_token" ] && { log ERROR "--token-stdin: stdin is empty or /dev/null — refusing to continue with empty PAT"; exit 1; }
          ARG_TOKEN="$_stdin_token"
      else
          printf 'GitHub PAT: ' >&2
          read -rs ARG_TOKEN
          printf '\n' >&2
          [ -z "$ARG_TOKEN" ] && { log ERROR "--token-stdin: empty token entered"; exit 1; }
      fi
  elif [ -n "${ARG_TOKEN:-}" ]; then
      # D-09: bare --token deprecation warning (once per session via sentinel)
      local _token_warn_sentinel="${XDG_DATA_HOME:-$HOME/.local/share}/n8n-manager/.token-flag-warned"
      if [ ! -f "$_token_warn_sentinel" ]; then
          printf 'WARNING: --token is deprecated; use --token-file or --token-stdin to avoid token leaks via /proc/cmdline.\n' >&2
          printf '   See https://github.com/Automations-Project/n8n-data-manager/blob/main/README.md#token-handling\n' >&2
          mkdir -p "$(dirname "$_token_warn_sentinel")" 2>/dev/null || true
          touch "$_token_warn_sentinel" 2>/dev/null || true
      fi
  fi

  local is_dry_run=false
  [[ "${ARG_DRY_RUN:-}" == "1" ]] && is_dry_run=true

  local restore_type="$ARG_RESTORE_TYPE"

  _restore_dir_has_layout() {
      local dir="$1"
      [ -d "$dir" ] || return 1

      local layout
      layout=$(sc_layout_detect "$dir" 2>/dev/null || echo "unknown")
      case "$layout" in
          canonical|bundle|legacy) return 0 ;;
          *) return 1 ;;
      esac
  }

  _restore_find_latest_dated_dir() {
      local download_dir="$1"
      find "$download_dir" -type d -name 'backup_*' 2>/dev/null | sort -r | head -n1
  }

  _restore_resolve_backup_source_dir() {
      local download_dir="$1"

      # Root-first (native source-control-like structure).
      if _restore_dir_has_layout "$download_dir"; then
          echo "$download_dir"
          return 0
      fi

      # New dated root structure.
      local newest_dated
      newest_dated=$(_restore_find_latest_dated_dir "$download_dir")
      if [ -n "$newest_dated" ] && _restore_dir_has_layout "$newest_dated"; then
          echo "$newest_dated"
          return 0
      fi

      # Legacy path fallback.
      if _restore_dir_has_layout "$download_dir/Backups/data"; then
          echo "$download_dir/Backups/data"
          return 0
      fi

      return 1
  }

  _restore_choose_backup_source_dir_interactive() {
      local download_dir="$1"
      local -a option_labels=()
      local -a option_paths=()

      # Root-first option to align with canonical source-control behavior.
      if _restore_dir_has_layout "$download_dir"; then
          local root_layout
          root_layout=$(sc_layout_detect "$download_dir" 2>/dev/null || echo "unknown")
          if [ "$root_layout" = "bundle" ]; then
              option_labels+=("📄  Repository root (bundle files)")
          elif [ "$root_layout" = "legacy" ]; then
              option_labels+=("📄  Repository root (legacy layout)")
          else
              option_labels+=("📄  Repository root (canonical)")
          fi
          option_paths+=("$download_dir")
      fi

      # Dated snapshots (new multi-backup mode).
      while IFS= read -r dated_dir; do
          [ -n "$dated_dir" ] || continue
          if _restore_dir_has_layout "$dated_dir"; then
              local dated_layout
              dated_layout=$(sc_layout_detect "$dated_dir" 2>/dev/null || echo "unknown")
              option_labels+=("📂  $(basename "$dated_dir") ($dated_layout)")
              option_paths+=("$dated_dir")
          fi
      done < <(find "$download_dir" -mindepth 1 -maxdepth 1 -type d -name 'backup_*' 2>/dev/null | sort -r)

      # Legacy fallback option.
      if _restore_dir_has_layout "$download_dir/Backups/data"; then
          option_labels+=("🗂  Legacy Backups/data")
          option_paths+=("$download_dir/Backups/data")
      fi

      [ "${#option_paths[@]}" -gt 0 ] || return 1
      if [ "${#option_paths[@]}" -eq 1 ]; then
          echo "${option_paths[0]}"
          return 0
      fi

      local selected_label
      selected_label=$(ui_choose "Select backup snapshot to restore" "${option_labels[@]}") || true
      if [ -z "$selected_label" ]; then
          echo "${option_paths[0]}"
          return 0
      fi

      local idx
      for idx in "${!option_labels[@]}"; do
          if [ "${option_labels[$idx]}" = "$selected_label" ]; then
              echo "${option_paths[$idx]}"
              return 0
          fi
      done

      echo "${option_paths[0]}"
      return 0
  }

  _restore_find_full_db_dir() {
      local download_dir="$1"

      # Root-first full-db paths.
      if [ -f "$download_dir/full-db/entities.zip" ]; then
          echo "$download_dir/full-db"
          return 0
      fi
      if [ -f "$download_dir/entities.zip" ]; then
          echo "$download_dir"
          return 0
      fi

      # Dated root/full-db paths.
      while IFS= read -r dated_dir; do
          [ -n "$dated_dir" ] || continue
          if [ -f "$dated_dir/full-db/entities.zip" ]; then
              echo "$dated_dir/full-db"
              return 0
          fi
          if [ -f "$dated_dir/entities.zip" ]; then
              echo "$dated_dir"
              return 0
          fi
      done < <(find "$download_dir" -type d -name 'backup_*' 2>/dev/null | sort -r)

      # Legacy fallback.
      if [ -f "$download_dir/Backups/data/full-db/entities.zip" ]; then
          echo "$download_dir/Backups/data/full-db"
          return 0
      fi
      if [ -f "$download_dir/Backups/data/entities.zip" ]; then
          echo "$download_dir/Backups/data"
          return 0
      fi

      return 1
  }

  if [ -t 0 ]; then
      check_install_mode
      _show_restore_intro

      if [ -z "$ARG_CONTAINER" ]; then
          select_container
          ARG_CONTAINER="$SELECTED_CONTAINER_ID"
      fi

      if [ -z "$ARG_TOKEN" ] || [ -z "$ARG_REPO" ]; then
          get_github_config
          ARG_TOKEN="${ARG_TOKEN:-$GITHUB_TOKEN}"
          ARG_REPO="${ARG_REPO:-$GITHUB_REPO}"
          ARG_BRANCH="${ARG_BRANCH:-$GITHUB_BRANCH}"
      fi

      # Keep prior restore UX for type/mode prompts when defaults are unchanged.
      if [ "$ARG_RESTORE_TYPE" = "all" ]; then
          select_restore_type
          restore_type="$ARG_RESTORE_TYPE"
      fi
      if [ "$restore_type" != "full-db" ] && [ "$ARG_RESTORE_MODE" = "overwrite" ]; then
          select_restore_mode
      fi
  fi

  if [ -z "$ARG_CONTAINER" ]; then
      log ERROR "Container is required. Use --container or run interactively."
      exit 1
  fi
  if [ -z "$ARG_TOKEN" ]; then
      log ERROR "GitHub token is required. Use --token or configure in config file."
      exit 1
  fi
  if [ -z "$ARG_REPO" ]; then
      log ERROR "GitHub repository is required. Use --repo or configure in config file."
      exit 1
  fi

  if [[ "${ARG_DELETE_MISSING:-}" == "1" ]] && [[ "${ARG_FORCE:-}" != "1" ]]; then
      log ERROR "--delete-missing requires --force"
      exit 1
  fi

  if [ -t 0 ] && ! $is_dry_run; then
      if [[ "${ARG_FORCE:-}" == "1" ]]; then
          ui_confirm_force_restore || exit 0
      fi
      if [[ "${ARG_DELETE_MISSING:-}" == "1" ]]; then
          ui_confirm_delete_missing || exit 0
      fi
  fi

  ui_dashboard_header "Restore" "$THEME_WARNING"
  if $is_dry_run; then ui_notification "warning" "DRY RUN MODE" "No changes will be made"; fi

  ui_section_header "Validating" "🔐" "$THEME_WARNING"
  if ! check_github_access "$ARG_TOKEN" "$ARG_REPO" "$ARG_BRANCH" "restore"; then
      screen_error "restore" "GitHub access validation failed" "Repository: $ARG_REPO | Branch: $ARG_BRANCH" ""
      exit 1
  fi

  if [[ "$restore_type" == "full-db" ]]; then
      ui_header "💾 Full Database Restore"

      local download_dir
      download_dir=$(mktemp -d -t n8n-download-XXXXXXXXXX)

      if ! git_clone_for_restore "$ARG_TOKEN" "$ARG_REPO" "$ARG_BRANCH" "$download_dir"; then
          rm -rf "$download_dir"
          exit 1
      fi

      local fulldb_dir=""
      fulldb_dir=$(_restore_find_full_db_dir "$download_dir" 2>/dev/null || true)

      if [ -z "$fulldb_dir" ]; then
          log ERROR "No full-db entities.zip found in backup repository"
          rm -rf "$download_dir"
          exit 1
      fi

      if ! import_full_database "$ARG_CONTAINER" "$fulldb_dir" "$is_dry_run" "true"; then
          rm -rf "$download_dir"
          exit 1
      fi

      rm -rf "$download_dir"
      screen_completion "restore" "$ARG_CONTAINER" "$ARG_REPO" "$ARG_BRANCH" \
          "Type|full-db" "Status|Complete ✔" "Timestamp|$(date '+%Y-%m-%d %H:%M:%S')"
      cleanup_one_time
      exit 0
  fi

  local pre_restore_dir
  pre_restore_dir=$(create_pre_restore_backup "$ARG_CONTAINER" "$restore_type" "$is_dry_run")
  # D-13: Register shred cleanup trap — fires on EXIT + INT + TERM (Phase 4 D-18 pattern)
  trap '_shred_dir "${pre_restore_dir:-}"' EXIT
  trap '_shred_dir "${pre_restore_dir:-}"' INT
  trap '_shred_dir "${pre_restore_dir:-}"' TERM

  ui_section_header "Fetching from GitHub" "📡" "$THEME_INFO"
  local download_dir
  download_dir=$(mktemp -d -t n8n-download-XXXXXXXXXX)

  if ! git_clone_for_restore "$ARG_TOKEN" "$ARG_REPO" "$ARG_BRANCH" "$download_dir"; then
      rm -rf "$download_dir"
      [ -n "$pre_restore_dir" ] && log WARN "Pre-restore backup kept at: $pre_restore_dir"
      exit 1
  fi

  local backup_source_dir="$download_dir"
  if [ -t 0 ]; then
      backup_source_dir=$(_restore_choose_backup_source_dir_interactive "$download_dir" 2>/dev/null || true)
  fi
  if [ -z "$backup_source_dir" ]; then
      backup_source_dir=$(_restore_resolve_backup_source_dir "$download_dir" 2>/dev/null || true)
  fi
  if [ -z "$backup_source_dir" ]; then
      log ERROR "No compatible backup layout found in repository."
      rm -rf "$download_dir"
      [ -n "$pre_restore_dir" ] && log WARN "Pre-restore backup kept at: $pre_restore_dir"
      exit 1
  fi

  # Optional interactive workflow picker for restore.
  if [[ "${ARG_SELECT}" == "1" ]] && [ -z "$ARG_WORKFLOW_ID" ]; then
      if [[ "$restore_type" == "all" || "$restore_type" == "workflows" ]]; then
          local wf_list
          wf_list=$(list_backup_workflows "$backup_source_dir" 2>/dev/null) || true

          if [ -n "$wf_list" ]; then
              local selected_ids=""
              local select_rc=0
              selected_ids=$(select_workflows_interactive "$wf_list" "restore") || select_rc=$?

              if [ $select_rc -ne 0 ]; then
                  log INFO "Restore cancelled — no workflows selected"
                  rm -rf "$download_dir"
                  exit 0
              fi

              if [ -n "$selected_ids" ]; then
                  ARG_WORKFLOW_ID="$selected_ids"
                  log INFO "Will restore selected workflows: $ARG_WORKFLOW_ID"
              else
                  log INFO "Will restore all workflows"
              fi
          else
              log WARN "Could not list workflows from backup — will import all"
          fi
      fi
  fi

  ui_section_header "Importing Data" "💾" "$THEME_SECONDARY"
  if perform_import "$ARG_CONTAINER" "$backup_source_dir" "$restore_type" "$is_dry_run" "$pre_restore_dir"; then
      rm -rf "$download_dir"
      if [ -n "$pre_restore_dir" ] && ! $is_dry_run; then
          rm -rf "$pre_restore_dir"
      fi

      screen_completion "restore" "$ARG_CONTAINER" "$ARG_REPO" "$ARG_BRANCH" \
          "Type|$restore_type" \
          "Mode|$ARG_RESTORE_MODE" \
          "Force|${ARG_FORCE:-0}" \
          "DeleteMissing|${ARG_DELETE_MISSING:-0}" \
          "Status|Complete ✔" \
          "Timestamp|$(date '+%Y-%m-%d %H:%M:%S')"

      if [ "$N8N_MANAGER_MODE" != "one-time" ]; then
          offer_save_settings
      fi
      cleanup_one_time
      exit 0
  fi

  log ERROR "Restore failed"
  local rollback_result=""
  if [ -n "$pre_restore_dir" ] && ! $is_dry_run; then
      if rollback_restore "$ARG_CONTAINER" "$pre_restore_dir" "$restore_type" "$is_dry_run"; then
          rollback_result="success"
      else
          rollback_result="failed"
      fi
  fi

  screen_error "restore" "Restore failed for type: $restore_type" \
      "Container: $ARG_CONTAINER | Repo: $ARG_REPO" "$rollback_result"

  rm -rf "$download_dir"
  cleanup_one_time
  exit 1

}

# :command.function
n8n_manager_import_url_command() {

  # src/import_url_command.sh

  set -Eeuo pipefail
  IFS=$'
  	'

  setup_globals

  ARG_URL="${args[--url]:-}"
  ARG_CONTAINER="${args[--container]:-}"
  ARG_N8N_API_KEY="${args[--n8n-api-key]:-${ARG_N8N_API_KEY:-}}"
  ARG_N8N_API_URL="${args[--n8n-api-url]:-${ARG_N8N_API_URL:-}}"
  ARG_FORCE="${args[--force]:-}"
  ARG_DELETE_MISSING="${args[--delete-missing]:-}"
  ARG_LEGACY_FALLBACK="${args[--legacy-fallback]:-}"
  ARG_ACCEPT_LEGACY_PARTIAL="${args[--accept-legacy-partial]:-}"
  ARG_RESTORE_TYPE="${args[--restore-type]:-${ARG_RESTORE_TYPE:-all}}"
  ARG_RESTORE_MODE="${args[--restore-mode]:-${ARG_RESTORE_MODE:-overwrite}}"
  ARG_SEPARATE_FILES="${args[--separate-files]:-}"
  ARG_IMPORT_AS_NEW="${args[--import-as-new]:-}"
  ARG_ONLY_NEW="${args[--only-new]:-}"
  ARG_USER_ID="${args[--user-id]:-}"
  ARG_PROJECT_ID="${args[--project-id]:-}"
  ARG_TOKEN_FILE="${args[--token-file]:-}"
  ARG_TOKEN_STDIN="${args[--token-stdin]:-}"
  ARG_ALLOW_SCHEMA_DRIFT="${args[--allow-schema-drift]:-}"
  ARG_UNSAFE_DECRYPTED_CREDENTIALS="${args[--unsafe-decrypted-credentials]:-}"

  # Resolve token from --token-file or --token-stdin (D-08)
  # import-url has no bare --token flag; file/stdin paths only
  if [ -n "$ARG_TOKEN_FILE" ]; then
      if [ ! -f "$ARG_TOKEN_FILE" ]; then
          log ERROR "--token-file: file not found: $ARG_TOKEN_FILE"
          exit 1
      fi
      local _file_mode
      _file_mode=$(stat -c '%a' "$ARG_TOKEN_FILE" 2>/dev/null || stat -f '%A' "$ARG_TOKEN_FILE" 2>/dev/null || echo "unknown")
      if [ "$_file_mode" != "600" ]; then
          log ERROR "--token-file: file must have mode 600, got mode $_file_mode. Run: chmod 600 $ARG_TOKEN_FILE"
          exit 1
      fi
      ARG_TOKEN=$(cat "$ARG_TOKEN_FILE")
      [ -z "$ARG_TOKEN" ] && { log ERROR "--token-file: file is empty"; exit 1; }
  elif [ "${ARG_TOKEN_STDIN:-}" = "1" ]; then
      if [ ! -t 0 ]; then
          local _stdin_token
          _stdin_token=$(cat 2>/dev/null || echo "")
          [ -z "$_stdin_token" ] && { log ERROR "--token-stdin: stdin is empty or /dev/null — refusing to continue with empty PAT"; exit 1; }
          ARG_TOKEN="$_stdin_token"
      else
          printf 'GitHub PAT: ' >&2
          read -rs ARG_TOKEN
          printf '\n' >&2
          [ -z "$ARG_TOKEN" ] && { log ERROR "--token-stdin: empty token entered"; exit 1; }
      fi
  fi

  local is_dry_run=false
  [[ "${ARG_DRY_RUN:-}" == "1" ]] && is_dry_run=true

  local restore_type="$ARG_RESTORE_TYPE"

  if [ -t 0 ]; then
      check_install_mode
      _show_import_intro

      if [ -z "$ARG_CONTAINER" ]; then
          select_container
          ARG_CONTAINER="$SELECTED_CONTAINER_ID"
      fi

      if [ -z "$ARG_URL" ]; then
          ARG_URL=$(ui_input "Backup file URL" "https://")
      fi

      if [ "$ARG_RESTORE_TYPE" = "all" ]; then
          select_restore_type
          restore_type="$ARG_RESTORE_TYPE"
      fi
      if [ "$restore_type" != "full-db" ] && [ "$ARG_RESTORE_MODE" = "overwrite" ]; then
          select_restore_mode
      fi
  fi

  if [ -z "$ARG_URL" ]; then
      log ERROR "URL is required. Use --url or run interactively."
      exit 1
  fi
  if [ -z "$ARG_CONTAINER" ]; then
      log ERROR "Container is required. Use --container or run interactively."
      exit 1
  fi
  if [[ "${ARG_DELETE_MISSING:-}" == "1" ]] && [[ "${ARG_FORCE:-}" != "1" ]]; then
      log ERROR "--delete-missing requires --force"
      exit 1
  fi

  if [ -t 0 ] && ! $is_dry_run; then
      if [[ "${ARG_FORCE:-}" == "1" ]]; then
          ui_confirm_force_restore || exit 0
      fi
      if [[ "${ARG_DELETE_MISSING:-}" == "1" ]]; then
          ui_confirm_delete_missing || exit 0
      fi
  fi

  ui_dashboard_header "Import" "$THEME_WARNING"
  if $is_dry_run; then ui_notification "warning" "DRY RUN MODE" "No changes will be made"; fi

  if [[ "$restore_type" == "full-db" ]]; then
      local download_dir
      download_dir=$(mktemp -d -t n8n-download-XXXXXXXXXX)

      if ! download_from_url "$ARG_URL" "$download_dir/entities.zip"; then
          rm -rf "$download_dir"
          exit 1
      fi

      if ! import_full_database "$ARG_CONTAINER" "$download_dir" "$is_dry_run" "true"; then
          rm -rf "$download_dir"
          exit 1
      fi

      rm -rf "$download_dir"
      screen_completion "import" "$ARG_CONTAINER" "$ARG_URL" "" \
          "Type|full-db" "Status|Complete ✔" "Timestamp|$(date '+%Y-%m-%d %H:%M:%S')"
      cleanup_one_time
      exit 0
  fi

  if ! validate_url "$ARG_URL"; then
      log ERROR "URL validation failed"
      exit 1
  fi

  local pre_restore_dir
  pre_restore_dir=$(create_pre_restore_backup "$ARG_CONTAINER" "$restore_type" "$is_dry_run")
  # D-13: Register shred cleanup trap — fires on EXIT + INT + TERM (Phase 4 D-18 pattern)
  trap '_shred_dir "${pre_restore_dir:-}"' EXIT
  trap '_shred_dir "${pre_restore_dir:-}"' INT
  trap '_shred_dir "${pre_restore_dir:-}"' TERM

  local download_dir
  download_dir=$(mktemp -d -t n8n-download-XXXXXXXXXX)

  if [[ "$ARG_URL" == *.zip ]]; then
      if ! download_from_url "$ARG_URL" "$download_dir/backup.zip"; then
          rm -rf "$download_dir"
          exit 1
      fi
      if [ "$is_dry_run" != "true" ] && [ "$is_dry_run" != "1" ]; then
          (cd "$download_dir" && unzip -q backup.zip) || {
              rm -rf "$download_dir"
              exit 1
          }
          rm -f "$download_dir/backup.zip"
      fi
  elif [[ "$ARG_URL" == *.json ]]; then
      if ! download_from_url "$ARG_URL" "$download_dir/$(basename "$ARG_URL")"; then
          rm -rf "$download_dir"
          exit 1
      fi
  else
      log ERROR "Unsupported file type. URL must end with .json or .zip"
      rm -rf "$download_dir"
      exit 1
  fi

  if perform_import "$ARG_CONTAINER" "$download_dir" "$restore_type" "$is_dry_run" "$pre_restore_dir"; then
      if [ "$is_dry_run" != "true" ] && [ "$is_dry_run" != "1" ]; then
          rm -rf "$download_dir"
          [ -n "$pre_restore_dir" ] && rm -rf "$pre_restore_dir"
      fi

      screen_completion "import" "$ARG_CONTAINER" "$ARG_URL" "" \
          "Type|$restore_type" \
          "Mode|$ARG_RESTORE_MODE" \
          "Force|${ARG_FORCE:-0}" \
          "DeleteMissing|${ARG_DELETE_MISSING:-0}" \
          "Status|Complete ✔" \
          "Timestamp|$(date '+%Y-%m-%d %H:%M:%S')"

      cleanup_one_time
      exit 0
  fi

  log ERROR "URL import failed"
  if [ -n "$pre_restore_dir" ] && [ "$is_dry_run" != "true" ] && [ "$is_dry_run" != "1" ]; then
      rollback_restore "$ARG_CONTAINER" "$pre_restore_dir" "$restore_type" "$is_dry_run" || true
  fi

  rm -rf "$download_dir"
  cleanup_one_time
  exit 1

}

# :command.function
n8n_manager_install_command() {

  # src/install_command.sh

  set -Eeuo pipefail
  IFS=$'
  	'

  # No Docker needed for install
  SKIP_DOCKER_CHECK=true

  # Initialize global flags (for gum availability)
  setup_globals

  local ARG_YES="${args[--yes]:-}"

  # D-19: --yes required when stdin is non-TTY
  if [ ! -t 0 ] && [ "${ARG_YES:-}" != "1" ]; then
      log ERROR "Non-interactive mode requires --yes"
      exit 1
  fi

  ui_banner "n8n-manager" "Install"

  # Detect if existing binary is v4 (D-06/D-07 pattern)
  _install_cmd_detect_v4() {
      local bp="$1" vo fl
      vo=$("$bp" --version 2>/dev/null || true)
      fl=$(printf '%s' "$vo" | head -1)
      if printf '%s' "$fl" | grep -qE '^[Vv]?4\.'; then echo "v4"; return; fi
      if printf '%s' "$fl" | grep -qE '^[Vv]?5\.'; then echo "v5"; return; fi
      if grep -qF 'n8n-manager v4' "$bp" 2>/dev/null; then echo "v4"; return; fi
      echo "unknown"
  }

  # Resolve the actual path of this running script
  local self_path
  self_path=$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")

  if [ ! -f "$self_path" ]; then
      echo "Error: Cannot resolve script path" >&2
      exit 1
  fi

  # Determine install directory
  local install_dir="/usr/local/bin"
  local use_sudo=true
  local target_name="n8n-manager"

  if [[ "${args[--user]:-}" == "1" ]]; then
      install_dir="$HOME/.local/bin"
      use_sudo=false
  elif [ -n "${args[--path]:-}" ]; then
      install_dir="${args[--path]}"
      # Only use sudo for system directories
      case "$install_dir" in
          /usr/*|/opt/*|/bin|/sbin) use_sudo=true ;;
          *) use_sudo=false ;;
      esac
  fi

  local target_path="${install_dir}/${target_name}"

  # Check if already installed at same location
  if [ -f "$target_path" ]; then
      local current_version installed_version
      current_version=$(grep -m1 'version=' "$self_path" 2>/dev/null | head -1 | sed 's/.*version="//;s/".*//')
      installed_version=$(grep -m1 'version=' "$target_path" 2>/dev/null | head -1 | sed 's/.*version="//;s/".*//')

      if [ "$self_path" = "$target_path" ]; then
          ui_info_box "n8n-manager is already installed at: $target_path"
          exit 0
      fi

      if [ -n "$installed_version" ]; then
          ui_label "Existing" "v${installed_version} at $target_path"
          ui_label "Upgrading to" "v${current_version:-unknown}"
          echo "" >&2
          if [ "${ARG_YES:-}" != "1" ] && [ -t 0 ]; then
              ui_confirm "Overwrite existing installation?" || exit 0
          elif [ "${ARG_YES:-}" != "1" ] && [ ! -t 0 ]; then
              log ERROR "Non-interactive mode requires --yes"
              exit 1
          fi
      fi
  fi

  # Check if existing binary at target is v4 (D-06/D-07)
  if [ -f "$target_path" ] && [ "$self_path" != "$target_path" ]; then
      local _existing_kind
      _existing_kind=$(_install_cmd_detect_v4 "$target_path" 2>/dev/null || echo "unknown")
      if [ "$_existing_kind" = "v4" ]; then
          log INFO "v4 binary detected at ${target_path} — this install will replace it"
          log INFO "  The v4 binary will be backed up to ${target_path}.v4.bak"
      fi
  fi

  # Create directory if needed
  if [ ! -d "$install_dir" ]; then
      if [ "$use_sudo" = "true" ]; then
          sudo mkdir -p "$install_dir" || { echo "Error: Cannot create $install_dir (try --user flag)" >&2; exit 1; }
      else
          mkdir -p "$install_dir" || { echo "Error: Cannot create $install_dir" >&2; exit 1; }
      fi
  fi

  # Copy script to install directory
  log INFO "Installing n8n-manager to: $target_path"

  if [ "$use_sudo" = "true" ]; then
      sudo cp "$self_path" "$target_path" && sudo chmod +x "$target_path"
  else
      cp "$self_path" "$target_path" && chmod +x "$target_path"
  fi

  if [ $? -ne 0 ]; then
      ui_error_box "Installation failed" "Try: n8n-manager install --user"
      exit 1
  fi

  ui_success_box "n8n-manager installed successfully!"
  ui_summary "Installation" \
      "Location" "$target_path" \
      "Command" "n8n-manager --help"

  # Check if install dir is in PATH
  case ":$PATH:" in
      *":${install_dir}:"*) ;;
      *)
          ui_warn_box \
              "$install_dir is not in your PATH." \
              "Add to your shell profile (~/.bashrc or ~/.zshrc):" \
              "" \
              "  export PATH=\"${install_dir}:\$PATH\""
          ;;
  esac

}

# :command.function
n8n_manager_update_command() {

  # src/update_command.sh

  set -Eeuo pipefail
  IFS=$'
  	'

  # No Docker needed for update
  SKIP_DOCKER_CHECK=true

  # Initialize global flags (for gum availability)
  setup_globals

  ui_banner "n8n-manager" "Update"

  # ── Configuration ────────────────────────────────

  local REPO_OWNER="Automations-Project"
  local REPO_NAME="n8n-data-manager"
  local REPO_API="https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}"
  local RAW_BASE="https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}"

  local CURRENT_VERSION="${version}"
  local CHECK_ONLY="${args[--check]:-}"
  local FORCE="${args[--force]:-}"
  local CHANNEL="${args[--channel]:-stable}"
  local ARG_ROLLBACK="${args[--rollback]:-}"
  local ARG_YES="${args[--yes]:-}"

  # ── Resolve current script location ──────────────

  local self_path
  self_path=$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")

  # ── v4 binary detection ──────────────────────────────────────────────
  # D-06 + D-07: returns "v4" / "v5" / "unknown"
  _update_detect_v4() {
      local bin_path="$1"
      local ver_out first_line
      ver_out=$("$bin_path" --version 2>/dev/null || true)
      first_line=$(printf '%s' "$ver_out" | head -1)
      if printf '%s' "$first_line" | grep -qE '^[Vv]?4\.'; then
          echo "v4"; return 0
      fi
      if printf '%s' "$first_line" | grep -qE '^[Vv]?5\.'; then
          echo "v5"; return 0
      fi
      if grep -qF 'n8n-manager v4' "$bin_path" 2>/dev/null; then
          echo "v4"; return 0
      fi
      echo "unknown"
  }

  # ── Atomic binary replace for update ────────────────────────────────
  # D-12 steps 6-8, D-11 collision guard, D-22 banner, D-25 error logging
  # Args: <new_binary_tmp> <install_path> <old_semver> <new_semver>
  _update_atomic_replace() {
      local new_tmp="$1" install_path="$2" old_ver="$3" new_ver="$4"
      local bak_base="${install_path}.v4.bak"

      # D-11: Timestamp existing .v4.bak if present
      # Example: n8n-manager.v4.bak.20260101-120000
      if [ -f "$bak_base" ]; then
          local ts
          ts=$(date -u '+%Y%m%d-%H%M%S')
          if ! mv "$bak_base" "${bak_base}.${ts}" 2>/dev/null; then
              log ERROR "Could not move existing .v4.bak to timestamped path. Aborting."
              return 1
          fi
      fi

      # D-12 step 7: Move current binary to .v4.bak
      if [ -f "$install_path" ]; then
          if ! mv "$install_path" "$bak_base" 2>/dev/null; then
              log ERROR "Could not back up ${install_path} to ${bak_base}."
              log ERROR "  Original binary at ${install_path} remains unchanged."
              log ERROR "  Temp file removed."
              return 1
          fi
      fi

      # D-12 step 8: Atomic rename new binary into place
      if ! mv "$new_tmp" "$install_path" 2>/dev/null; then
          # Restore from backup on failure
          if [ -f "$bak_base" ]; then
              mv "$bak_base" "$install_path" 2>/dev/null || true
          fi
          log ERROR "Could not install new binary to ${install_path}."
          log ERROR "  Restore from ${bak_base} attempted."
          log ERROR "  Original binary at ${install_path} remains unchanged."
          return 1
      fi
      chmod +x "$install_path"

      # D-22: Version-diff banner — v4.x.y → v5.X.Y
      log SUCCESS "n8n-manager: v${old_ver} → v${new_ver}"
      log INFO "  Backup at: ${bak_base}"
      log INFO "  Report issues: https://github.com/Automations-Project/n8n-data-manager/issues"
      return 0
  }

  # ── Version comparison helper ────────────────────
  # Returns: 0 if $1 > $2, 1 if equal, 2 if $1 < $2

  _version_compare() {
      if [ "$1" = "$2" ]; then return 1; fi

      local IFS=.
      local i ver1=($1) ver2=($2)

      # Fill empty positions with zeros
      for ((i=${#ver1[@]}; i<${#ver2[@]}; i++)); do ver1[i]=0; done
      for ((i=${#ver2[@]}; i<${#ver1[@]}; i++)); do ver2[i]=0; done

      for ((i=0; i<${#ver1[@]}; i++)); do
          local v1="${ver1[i]//[^0-9]/}"
          local v2="${ver2[i]//[^0-9]/}"
          v1=${v1:-0}; v2=${v2:-0}
          if ((v1 > v2)); then return 0; fi
          if ((v1 < v2)); then return 2; fi
      done
      return 1
  }

  # ── Non-interactive mode guard ────────────────────────────────────────
  # D-19: --yes required when stdin is non-TTY for update or rollback
  if [ ! -t 0 ] && [ "${ARG_YES:-}" != "1" ]; then
      log ERROR "Non-interactive mode requires --yes"
      exit 1
  fi

  # ── Rollback mode (--rollback flag) ──────────────────────────────────
  # D-14: Swap current binary with most-recent .v4.bak*
  if [ "${ARG_ROLLBACK:-}" = "1" ]; then
      ui_banner "n8n-manager" "Rollback"

      # Locate most-recent .v4.bak*
      local _bak_path=""
      if [ -f "${self_path}.v4.bak" ]; then
          _bak_path="${self_path}.v4.bak"
      else
          # Find highest-timestamped .v4.bak.YYYYMMDD-HHMMSS
          _bak_path=$(ls -t "${self_path}.v4.bak."* 2>/dev/null | head -1 || true)
      fi

      if [ -z "$_bak_path" ] || [ ! -f "$_bak_path" ]; then
          # Patch-15: expose the expected rollback file paths so the operator
          # knows exactly which file is missing. Phase 5 D-12 stamps these
          # during the v4→v5 atomic-replace upgrade.
          log ERROR "No rollback backup found — nothing to roll back to."
          log ERROR "  Expected one of:"
          log ERROR "    ${self_path}.v4.bak                       (most recent v4 binary)"
          log ERROR "    ${self_path}.v4.bak.YYYYMMDD-HHMMSS       (older timestamped backups)"
          log ERROR "  These .v4.bak files are created automatically by 'n8n-manager update'"
          log ERROR "  when upgrading from v4 to v5. If you installed v5 directly (no prior"
          log ERROR "  v4 binary) there is no .v4.bak to roll back to."
          exit 1
      fi

      # Verify rollback target is a valid bash script (D-12 steps 2-3, without SHA)
      if ! bash -n "$_bak_path" 2>/dev/null; then
          log ERROR "Backup file ${_bak_path} failed bash -n syntax check. Cannot roll back."
          exit 1
      fi

      local _rbk_ver
      _rbk_ver=$("$_bak_path" --version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || echo "unknown")
      local _cur_ver
      _cur_ver=$("$self_path" --version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || echo "unknown")

      if [ -t 0 ] && [ "${ARG_YES:-}" != "1" ]; then
          ui_confirm "Roll back from v${_cur_ver} to v${_rbk_ver} (${_bak_path})?" || exit 0
      fi

      # Atomic swap: backup → current (D-12 steps 7-8 without SHA)
      local _rbk_tmp
      _rbk_tmp=$(mktemp -t n8n-manager-rollback-XXXXXX)
      trap 'rm -f "${_rbk_tmp:-}" 2>/dev/null' EXIT INT TERM

      cp "$_bak_path" "$_rbk_tmp" && chmod +x "$_rbk_tmp"

      if mv "$self_path" "${self_path}.v5.bak.rollback" 2>/dev/null && \
         mv "$_rbk_tmp" "$self_path" 2>/dev/null; then
          chmod +x "$self_path"
          local _bak_ts
          _bak_ts=$(basename "$_bak_path" | grep -oE '[0-9]{8}-[0-9]{6}' || true)
          if [ -n "$_bak_ts" ]; then
              # Format: YYYYMMDD-HHMMSS → YYYY-MM-DD HH:MM:SS
              local _date_part _time_part
              _date_part="${_bak_ts:0:4}-${_bak_ts:4:2}-${_bak_ts:6:2}"
              _time_part="${_bak_ts:9:2}:${_bak_ts:11:2}:${_bak_ts:13:2}"
              log SUCCESS "Rolled back v5 → v4 (backup from ${_date_part} ${_time_part} UTC)"
          else
              log SUCCESS "Rolled back v5 → v4 (backup from ${_bak_path})"
          fi
          rm -f "${self_path}.v5.bak.rollback" 2>/dev/null || true
      else
          # Restore on failure
          mv "${self_path}.v5.bak.rollback" "$self_path" 2>/dev/null || true
          log ERROR "Rollback failed. Current binary remains at ${self_path}."
          log ERROR "  Original binary at ${self_path} remains unchanged."
          exit 1
      fi
      exit 0
  fi

  # ── Check for updates ────────────────────────────

  ui_label "Version" "v${CURRENT_VERSION}"
  echo "" >&2

  if ! command -v curl >/dev/null 2>&1; then
      ui_error_box "curl is required for update checks"
      exit 1
  fi

  local latest_version=""
  local download_url=""
  local release_notes=""
  local release_date=""

  if [ "$CHANNEL" = "stable" ]; then
      log INFO "Checking for updates (stable channel)..."

      local api_response
      api_response=$(curl -sf --max-time 10 "${REPO_API}/releases/latest" 2>/dev/null)

      if [ -z "$api_response" ]; then
          ui_error_box "Could not reach GitHub API" "Check your internet connection."
          exit 1
      fi

      # Parse release info — use node/python3 if available, else sed
      if command -v node >/dev/null 2>&1; then
          local parsed
          parsed=$(node -e '
  const d = JSON.parse(require("fs").readFileSync("/dev/stdin","utf8"));
  console.log([
      d.tag_name || "",
      (d.assets || []).find(a => a.name === "n8n-manager")?.browser_download_url || "",
      (d.body || "").split("\n").slice(0,5).join(" | "),
      d.published_at || ""
  ].join("\n"));
  ' <<< "$api_response" 2>/dev/null)
          latest_version=$(echo "$parsed" | sed -n '1p' | sed 's/^v//')
          download_url=$(echo "$parsed" | sed -n '2p')
          release_notes=$(echo "$parsed" | sed -n '3p')
          release_date=$(echo "$parsed" | sed -n '4p' | cut -dT -f1)
      elif command -v python3 >/dev/null 2>&1; then
          local parsed
          parsed=$(python3 -c "
  import json, sys
  d = json.load(sys.stdin)
  tag = (d.get('tag_name','') or '').lstrip('v')
  assets = d.get('assets',[])
  url = next((a['browser_download_url'] for a in assets if a.get('name')=='n8n-manager'), '')
  notes = ' | '.join((d.get('body','') or '').split('\n')[:5])
  date = (d.get('published_at','') or '').split('T')[0]
  print(f'{tag}\n{url}\n{notes}\n{date}')
  " <<< "$api_response" 2>/dev/null)
          latest_version=$(echo "$parsed" | sed -n '1p')
          download_url=$(echo "$parsed" | sed -n '2p')
          release_notes=$(echo "$parsed" | sed -n '3p')
          release_date=$(echo "$parsed" | sed -n '4p')
      else
          # sed fallback for tag_name
          latest_version=$(echo "$api_response" | sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1 | sed 's/^v//')
          download_url=$(echo "$api_response" | sed -n 's/.*"browser_download_url"[[:space:]]*:[[:space:]]*"\([^"]*n8n-manager[^"]*\)".*/\1/p' | head -1)
          release_date=$(echo "$api_response" | sed -n 's/.*"published_at"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1 | cut -dT -f1)
      fi

      # If no release asset, fall back to raw file from tag
      if [ -z "$download_url" ] && [ -n "$latest_version" ]; then
          download_url="${RAW_BASE}/v${latest_version}/v5/n8n-manager"
      fi
  else
      # Dev channel — get latest from main branch
      log INFO "Checking for updates (dev channel — main branch)..."

      # Get the latest commit SHA for version comparison
      local commit_info
      commit_info=$(curl -sf --max-time 10 "${REPO_API}/commits/main" 2>/dev/null)

      if [ -z "$commit_info" ]; then
          ui_error_box "Could not reach GitHub API"
          exit 1
      fi

      if command -v node >/dev/null 2>&1; then
          latest_version=$(node -e 'const d=JSON.parse(require("fs").readFileSync("/dev/stdin","utf8"));console.log(d.sha?.slice(0,7)||"")' <<< "$commit_info" 2>/dev/null)
          release_date=$(node -e 'const d=JSON.parse(require("fs").readFileSync("/dev/stdin","utf8"));console.log((d.commit?.committer?.date||"").split("T")[0])' <<< "$commit_info" 2>/dev/null)
      else
          latest_version=$(echo "$commit_info" | sed -n 's/.*"sha"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1 | cut -c1-7)
          release_date=$(echo "$commit_info" | sed -n 's/.*"date"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1 | cut -dT -f1)
      fi

      download_url="${RAW_BASE}/main/v5/n8n-manager"
      # Dev channel always shows as "update available" since we compare commit hashes
  fi

  if [ -z "$latest_version" ]; then
      ui_warn_box "Could not determine latest version"
      exit 1
  fi

  # ── Compare versions ─────────────────────────────

  local needs_update=false

  if [ "$CHANNEL" = "stable" ]; then
      echo "" >&2
      ui_label "Current" "v${CURRENT_VERSION}"
      ui_label "Latest" "v${latest_version}${release_date:+ ($release_date)}"

      local cmp=0
      _version_compare "$latest_version" "$CURRENT_VERSION" && cmp=0 || cmp=$?
      if [ "$cmp" -eq 0 ]; then
          needs_update=true
          echo "" >&2
          ui_info_box "Update available: v${CURRENT_VERSION} → v${latest_version}"
          [ -n "$release_notes" ] && log INFO "Notes: ${release_notes:0:200}"
      elif [ "$cmp" -eq 1 ]; then
          ui_success_box "You are on the latest version"
      else
          ui_success_box "You are ahead of the latest release"
      fi
  else
      echo "" >&2
      ui_label "Current" "v${CURRENT_VERSION}"
      ui_label "Latest" "main@${latest_version}${release_date:+ ($release_date)}"
      needs_update=true
      echo "" >&2
      ui_info_box "Dev channel — will pull latest from main branch"
  fi

  # ── Check-only mode ──────────────────────────────

  if [[ "$CHECK_ONLY" == "1" ]]; then
      if [ "$needs_update" = "true" ]; then
          exit 1  # Signal that update is available (useful for scripts)
      fi
      exit 0
  fi

  # ── Perform update ───────────────────────────────

  if [ "$needs_update" = "false" ] && [[ "$FORCE" != "1" ]]; then
      exit 0
  fi

  if [ "$needs_update" = "false" ] && [[ "$FORCE" == "1" ]]; then
      log INFO "Forcing reinstall of current version..."
  fi

  # Confirm before updating (interactive only, unless --yes given)
  if [ "${ARG_YES:-}" != "1" ] && [ -t 0 ]; then
      ui_confirm "Proceed with update?" || exit 0
  fi

  echo "" >&2

  # Determine where the binary lives
  local install_path="$self_path"

  # Download to temp file first
  local tmp_file
  tmp_file=$(mktemp "${TMPDIR:-/tmp}/n8n-manager-update.XXXXXX")

  # D-13: Cleanup on exit — independent EXIT INT TERM handlers
  _update_tmp="$tmp_file"
  trap 'rm -f "${_update_tmp:-}" 2>/dev/null' EXIT INT TERM

  log INFO "Downloading from: ${download_url}"
  if $HAS_GUM; then
      gum spin --spinner $THEME_SPINNER --spinner.foreground $THEME_SPINNER_COLOR \
          --title "Downloading update..." \
          -- curl -fSL --max-time 60 -o "$tmp_file" "$download_url" 2>/dev/null
  else
      curl -fSL --max-time 60 --progress-bar -o "$tmp_file" "$download_url" 2>&1
  fi

  if [ $? -ne 0 ] || [ ! -s "$tmp_file" ]; then
      ui_error_box "Download failed"
      rm -f "$tmp_file"
      exit 1
  fi

  # Verify it's a valid bash script
  if ! head -1 "$tmp_file" | grep -q '#!/.*bash'; then
      ui_error_box "Downloaded file is not a valid bash script"
      rm -f "$tmp_file"
      exit 1
  fi

  # Verify it contains n8n-manager signature
  if ! grep -q 'n8n-manager' "$tmp_file" 2>/dev/null; then
      ui_error_box "Downloaded file does not appear to be n8n-manager"
      rm -f "$tmp_file"
      exit 1
  fi

  # Determine old version for banner (D-22)
  local _old_semver
  _old_semver=$("$self_path" --version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || echo "$CURRENT_VERSION")
  local _existing_kind
  _existing_kind=$(_update_detect_v4 "$self_path" 2>/dev/null || echo "unknown")

  # D-12 steps 2-3: Verify downloaded binary (bash -n + --version check)
  if ! bash -n "$tmp_file" 2>/dev/null; then
      log ERROR "Downloaded file failed bash -n syntax check."
      log ERROR "  Original binary at ${install_path} remains unchanged."
      log ERROR "  Temp file removed."
      rm -f "$tmp_file" 2>/dev/null
      exit 1
  fi

  if ! "$tmp_file" --version 2>/dev/null | head -1 | grep -qE '^[Vv]?5\.'; then
      log ERROR "Downloaded binary does not report v5.x (D-12 step 3 check)."
      log ERROR "  Original binary at ${install_path} remains unchanged."
      log ERROR "  Temp file removed."
      rm -f "$tmp_file" 2>/dev/null
      exit 1
  fi

  local _new_semver
  _new_semver=$("$tmp_file" --version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || echo "${latest_version}")

  chmod +x "$tmp_file"

  # Check if upgrading from v4 (use atomic replace + .v4.bak)
  if [ "$_existing_kind" = "v4" ]; then
      log INFO "v4 binary detected at ${install_path} — using atomic replace with .v4.bak backup"
      if [ -t 0 ] && [ "${ARG_YES:-}" != "1" ]; then
          ui_confirm "Upgrade v4 → v5 at ${install_path}?" || exit 0
      fi
      if ! _update_atomic_replace "$tmp_file" "$install_path" "$_old_semver" "$_new_semver"; then
          exit 1
      fi
  else
      # Standard update: existing binary is v5 (or unknown) — replace in place
      log INFO "Updating: $install_path"

      if [ -w "$install_path" ]; then
          cp "$tmp_file" "$install_path"
      elif [ -w "$(dirname "$install_path")" ]; then
          cp "$tmp_file" "$install_path"
      else
          sudo cp "$tmp_file" "$install_path" && sudo chmod +x "$install_path"
      fi

      if [ $? -ne 0 ]; then
          ui_error_box "Could not replace $install_path" "Try: sudo n8n-manager update"
          rm -f "$tmp_file"
          exit 1
      fi
      chmod +x "$install_path"
      log SUCCESS "n8n-manager: v${_old_semver} → v${_new_semver}"
  fi

  rm -f "$tmp_file" 2>/dev/null || true

  ui_success_box "n8n-manager updated successfully!"
  log INFO "Verify: n8n-manager --version"

}

# :command.function
n8n_manager_uninstall_command() {

  # src/uninstall_command.sh

  set -Eeuo pipefail
  IFS=$'
  	'

  # No Docker needed for uninstall
  SKIP_DOCKER_CHECK=true

  # Initialize global flags (for gum availability)
  setup_globals

  ui_banner "n8n-manager" "Uninstall"

  local target_name="n8n-manager"
  local removed=false

  # Custom path provided
  if [ -n "${args[--path]:-}" ]; then
      local target="${args[--path]}/${target_name}"
      if [ -f "$target" ]; then
          if [ -t 0 ]; then
              ui_confirm "Remove $target?" || exit 0
          fi
          sudo rm -f "$target" 2>/dev/null || rm -f "$target"
          log SUCCESS "Removed: $target"
          removed=true
      else
          log WARN "Not found: $target"
      fi
  else
      # Check common locations
      local locations=(
          "/usr/local/bin/${target_name}"
          "$HOME/.local/bin/${target_name}"
      )

      for loc in "${locations[@]}"; do
          if [ -f "$loc" ]; then
              log INFO "Found: $loc"
              if [ -t 0 ]; then
                  ui_confirm "Remove $loc?" || continue
              fi
              if [[ "$loc" == /usr/* ]] || [[ "$loc" == /opt/* ]]; then
                  sudo rm -f "$loc"
              else
                  rm -f "$loc"
              fi
              log SUCCESS "Removed: $loc"
              removed=true
          fi
      done
  fi

  echo "" >&2
  if [ "$removed" = "true" ]; then
      ui_success_box "n8n-manager uninstalled"
  else
      ui_info_box \
          "No n8n-manager installation found in standard locations." \
          "If installed elsewhere, use:" \
          "  n8n-manager uninstall --path /your/install/dir"
  fi

}

# :command.function
n8n_manager_workflow_graph_command() {

  # src/workflow_graph_command.sh

  set -Eeuo pipefail
  IFS=$'
  	'

  # Workflow commands don't need Docker — skip Docker/git dependency checks
  SKIP_DOCKER_CHECK=true

  # Initialize global flags from parsed args
  setup_globals

  ui_banner "n8n-manager" "Workflow Graph"

  # Map command args
  ARG_WORKFLOWS_DIR="${args[--workflows-dir]:-${ARG_WORKFLOWS_DIR:-}}"
  ARG_FORMAT="${args[--format]:-excalidraw}"
  ARG_OUTPUT="${args[--output]:-}"
  ARG_FILTER="${args[--filter]:-}"
  ARG_NO_UPLOAD="${args[--no-upload]:-}"
  ARG_OPEN="${args[--open]:-}"

  # ── Resolve workflows directory ──────────────────

  if [ -z "$ARG_WORKFLOWS_DIR" ]; then
      if [ -t 0 ]; then
          # Interactive: ask user
          log INFO "No --workflows-dir specified"
          ARG_WORKFLOWS_DIR=$(ui_input "Path to .n8n workflow files directory" "")
      fi
  fi

  if [ -z "$ARG_WORKFLOWS_DIR" ] || [ ! -d "$ARG_WORKFLOWS_DIR" ]; then
      log ERROR "Workflows directory not found: ${ARG_WORKFLOWS_DIR:-<not specified>}"
      log INFO "Usage: n8n-manager workflow graph --workflows-dir /path/to/n8n-workflows"
      exit 1
  fi

  log DEBUG "[GRAPH] Workflows directory: $ARG_WORKFLOWS_DIR"

  # ── Discover workflow files ──────────────────────

  local workflow_files
  workflow_files=$(wf_discover_files "$ARG_WORKFLOWS_DIR")

  if [ -z "$workflow_files" ]; then
      log ERROR "No .n8n files found in: $ARG_WORKFLOWS_DIR"
      exit 1
  fi

  local file_count
  file_count=$(echo "$workflow_files" | wc -l | xargs)
  log INFO "Found $file_count workflow file(s)"

  # ── Build dependency graph ───────────────────────

  declare -A WF_GRAPH_CALLS_TO
  declare -A WF_GRAPH_CALLED_BY
  declare -A WF_GRAPH_NAMES
  declare -A WF_GRAPH_FILES

  wf_build_dep_graph "$ARG_WORKFLOWS_DIR"

  # ── Show stats ───────────────────────────────────

  local stats
  stats=$(wf_graph_stats)
  local total edges entry middle leaf standalone
  IFS='|' read -r total edges entry middle leaf standalone <<< "$stats"

  ui_summary "Workflow Dependency Graph" \
      "Workflows" "$total" \
      "Dependencies" "$edges" \
      "Entry points" "$entry" \
      "Middle-tier" "$middle" \
      "Leaves" "$leaf" \
      "Standalone" "$standalone"

  # ── Interactive format selection ─────────────────

  local format="$ARG_FORMAT"

  if [ -t 0 ] && [ -z "${args[--format]:-}" ]; then
      # Interactive mode — let user choose
      local chosen_format
      chosen_format=$(wf_graph_interactive "$ARG_WORKFLOWS_DIR")
      if [ -n "$chosen_format" ]; then
          format="$chosen_format"
      fi
  fi

  # ── Set default output path ──────────────────────

  local output_file="$ARG_OUTPUT"
  if [ -z "$output_file" ]; then
      case "$format" in
          excalidraw) output_file="workflow-dependencies.excalidraw" ;;
          mermaid)    output_file="workflow-dependencies.md" ;;
      esac
  fi

  log DEBUG "[GRAPH] Format: $format | Output: $output_file"

  # ── Generate graph ───────────────────────────────

  case "$format" in
      excalidraw)
          if ! command_exists node; then
              log WARN "Node.js not available — falling back to Mermaid format"
              format="mermaid"
              output_file="${output_file%.excalidraw}.md"
              wf_generate_mermaid "$output_file"
          else
              wf_generate_excalidraw "$ARG_WORKFLOWS_DIR" "$output_file"

              if [ $? -eq 0 ] && [ -f "$output_file" ]; then
                  # Upload to Excalidraw for shareable link
                  if [[ "${ARG_NO_UPLOAD}" != "1" ]]; then
                      local shareable_url
                      shareable_url=$(wf_upload_excalidraw "$output_file")

                      if [ -n "$shareable_url" ]; then
                          echo "" >&2
                          ui_success_box "Excalidraw diagram ready!"
                          ui_summary "Shareable Link" \
                              "URL" "$shareable_url" \
                              "Local file" "$output_file"

                          # Try to copy to clipboard
                          if command_exists xclip; then
                              echo -n "$shareable_url" | xclip -selection clipboard 2>/dev/null && \
                                  log INFO "Link copied to clipboard"
                          elif command_exists xsel; then
                              echo -n "$shareable_url" | xsel --clipboard 2>/dev/null && \
                                  log INFO "Link copied to clipboard"
                          elif command_exists pbcopy; then
                              echo -n "$shareable_url" | pbcopy 2>/dev/null && \
                                  log INFO "Link copied to clipboard"
                          fi

                          # Open in browser if requested
                          if [[ "${ARG_OPEN}" == "1" ]]; then
                              if command_exists xdg-open; then
                                  xdg-open "$shareable_url" 2>/dev/null &
                              elif command_exists open; then
                                  open "$shareable_url" 2>/dev/null &
                              fi
                          fi
                      else
                          echo "" >&2
                          log SUCCESS "Excalidraw file saved: $output_file"
                          log INFO "Open at: https://excalidraw.com/ (import file)"
                      fi
                  else
                      echo "" >&2
                      log SUCCESS "Excalidraw file saved: $output_file"
                      log INFO "Open at: https://excalidraw.com/ (import file)"
                  fi
              fi
          fi
          ;;
      mermaid)
          wf_generate_mermaid "$output_file"
          ;;
      *)
          log ERROR "Unknown format: $format (use excalidraw or mermaid)"
          exit 1
          ;;
  esac

  echo "" >&2
  log SUCCESS "Graph generation complete"

}

# :command.function
n8n_manager_workflow_report_command() {

  # src/workflow_report_command.sh

  set -Eeuo pipefail
  IFS=$'
  	'

  # Workflow commands don't need Docker — skip Docker/git dependency checks
  SKIP_DOCKER_CHECK=true

  # Initialize global flags from parsed args
  setup_globals

  ui_banner "n8n-manager" "Workflow Report"

  # Map command args
  ARG_WORKFLOWS_DIR="${args[--workflows-dir]:-${ARG_WORKFLOWS_DIR:-}}"
  ARG_FORMAT="${args[--format]:-console}"
  ARG_OUTPUT="${args[--output]:-}"
  ARG_IMPACT="${args[--impact]:-}"
  ARG_ORPHANS="${args[--orphans]:-}"
  ARG_CYCLES="${args[--cycles]:-}"
  ARG_MISSING="${args[--missing]:-}"
  ARG_SUMMARY="${args[--summary]:-}"

  # ── Resolve workflows directory ──────────────────

  if [ -z "$ARG_WORKFLOWS_DIR" ]; then
      if [ -t 0 ]; then
          log INFO "No --workflows-dir specified"
          ARG_WORKFLOWS_DIR=$(ui_input "Path to .n8n workflow files directory" "")
      fi
  fi

  if [ -z "$ARG_WORKFLOWS_DIR" ] || [ ! -d "$ARG_WORKFLOWS_DIR" ]; then
      log ERROR "Workflows directory not found: ${ARG_WORKFLOWS_DIR:-<not specified>}"
      log INFO "Usage: n8n-manager workflow report --workflows-dir /path/to/n8n-workflows"
      exit 1
  fi

  # ── Discover and build graph ─────────────────────

  local workflow_files
  workflow_files=$(wf_discover_files "$ARG_WORKFLOWS_DIR")

  if [ -z "$workflow_files" ]; then
      log ERROR "No .n8n files found in: $ARG_WORKFLOWS_DIR"
      exit 1
  fi

  local file_count
  file_count=$(echo "$workflow_files" | wc -l | xargs)
  log INFO "Scanning $file_count workflow file(s)..."

  declare -A WF_GRAPH_CALLS_TO
  declare -A WF_GRAPH_CALLED_BY
  declare -A WF_GRAPH_NAMES
  declare -A WF_GRAPH_FILES

  wf_build_dep_graph "$ARG_WORKFLOWS_DIR"

  # ── Determine report mode ────────────────────────

  local is_specific_mode=false
  if [ -n "$ARG_IMPACT" ] || [[ "$ARG_ORPHANS" == "1" ]] || \
     [[ "$ARG_CYCLES" == "1" ]] || [[ "$ARG_MISSING" == "1" ]]; then
      is_specific_mode=true
  fi

  # ── Specific analysis modes ──────────────────────

  if [ "$is_specific_mode" = "true" ]; then

      # Impact analysis
      if [ -n "$ARG_IMPACT" ]; then
          ui_header "Impact Analysis: $ARG_IMPACT"
          echo "" >&2

          local impact
          impact=$(wf_impact_analysis "$ARG_IMPACT")

          if [ -z "$impact" ]; then
              log INFO "No upstream or downstream dependencies found"
          else
              local upstream_count=0 downstream_count=0

              log HEADER "Upstream (callers affected by changes)"
              while IFS='|' read -r wf_id wf_name direction depth; do
                  if [ "$direction" = "upstream" ]; then
                      local indent=""
                      for ((i=1; i<depth; i++)); do indent="  $indent"; done
                      log INFO "  ${indent}↑ $wf_name ($wf_id) — depth $depth"
                      upstream_count=$((upstream_count + 1))
                  fi
              done <<< "$impact"
              [ "$upstream_count" -eq 0 ] && log INFO "  (none)"

              echo "" >&2
              log HEADER "Downstream (dependencies)"
              while IFS='|' read -r wf_id wf_name direction depth; do
                  if [ "$direction" = "downstream" ]; then
                      local indent=""
                      for ((i=1; i<depth; i++)); do indent="  $indent"; done
                      log INFO "  ${indent}↓ $wf_name ($wf_id) — depth $depth"
                      downstream_count=$((downstream_count + 1))
                  fi
              done <<< "$impact"
              [ "$downstream_count" -eq 0 ] && log INFO "  (none)"

              echo "" >&2
              log SUCCESS "Total impact: $upstream_count upstream + $downstream_count downstream"
          fi
      fi

      # Orphans only
      if [[ "$ARG_ORPHANS" == "1" ]]; then
          ui_header "Orphan Workflows"
          local orphans
          orphans=$(wf_find_orphan_workflows)
          if [ -z "$orphans" ]; then
              log SUCCESS "All workflows are connected"
          else
              local count=0
              while IFS='|' read -r oid oname; do
                  log INFO "  ⚪ $oname ($oid)"
                  count=$((count + 1))
              done <<< "$orphans"
              log INFO "Total orphans: $count"
          fi
      fi

      # Cycles only
      if [[ "$ARG_CYCLES" == "1" ]]; then
          ui_header "Circular Dependencies"
          local cycles
          cycles=$(wf_find_circular_deps)
          if [ -z "$cycles" ]; then
              log SUCCESS "No circular dependencies found"
          else
              while IFS= read -r cycle; do
                  local display=""
                  local IFS_BAK="$IFS"
                  IFS='|'
                  for cid in $cycle; do
                      local cname="${WF_GRAPH_NAMES[$cid]:-$cid}"
                      display="${display:+$display → }$cname"
                  done
                  IFS="$IFS_BAK"
                  log WARN "  ↻ $display"
              done <<< "$cycles"
          fi
      fi

      # Missing only
      if [[ "$ARG_MISSING" == "1" ]]; then
          ui_header "Missing Dependencies"
          local missing
          missing=$(wf_find_missing_deps)
          if [ -z "$missing" ]; then
              log SUCCESS "No missing dependencies"
          else
              local count=0
              while IFS='|' read -r src_id src_name target_id; do
                  log WARN "  $src_name → $target_id (not found in directory)"
                  count=$((count + 1))
              done <<< "$missing"
              log INFO "Total missing: $count"
          fi
      fi

      exit 0
  fi

  # ── Full report mode ─────────────────────────────

  wf_generate_report "$ARG_FORMAT" "$ARG_OUTPUT"

  echo "" >&2
  ui_success_box "Report complete"

}

# :command.function
n8n_manager_workflow_clean_pins_command() {

  # src/workflow_clean_pins_command.sh

  set -Eeuo pipefail
  IFS=$'\n\t'

  # Workflow commands don't need Docker — skip Docker/git dependency checks
  SKIP_DOCKER_CHECK=true

  # Initialize global flags from parsed args
  setup_globals

  ui_banner "n8n-manager" "Clean Pin Data"

  # Map command args
  ARG_WORKFLOWS_DIR="${args[--workflows-dir]:-${ARG_WORKFLOWS_DIR:-}}"
  ARG_FILE="${args[--file]:-}"
  ARG_ALL="${args[--all]:-}"
  ARG_SELECT="${args[--select]:-}"
  ARG_CHECK_ONLY="${args[--check-only]:-}"

  # ── Resolve target files ─────────────────────────

  local files_to_process=()

  if [ -n "$ARG_FILE" ]; then
      # Single file mode
      if [ ! -f "$ARG_FILE" ]; then
          log ERROR "File not found: $ARG_FILE"
          exit 1
      fi
      files_to_process+=("$ARG_FILE")

  elif [[ "$ARG_ALL" == "1" ]] || [[ "$ARG_SELECT" == "1" ]]; then
      # Directory mode — need workflows-dir
      if [ -z "$ARG_WORKFLOWS_DIR" ]; then
          if [ -t 0 ]; then
              ARG_WORKFLOWS_DIR=$(ui_input "Path to .n8n workflow files directory" "")
          fi
      fi

      if [ -z "$ARG_WORKFLOWS_DIR" ] || [ ! -d "$ARG_WORKFLOWS_DIR" ]; then
          log ERROR "Workflows directory not found: ${ARG_WORKFLOWS_DIR:-<not specified>}"
          exit 1
      fi

      local workflow_data
      workflow_data=$(wf_discover_files "$ARG_WORKFLOWS_DIR")
      if [ -z "$workflow_data" ]; then
          log ERROR "No .n8n files found in: $ARG_WORKFLOWS_DIR"
          exit 1
      fi

      if [[ "$ARG_SELECT" == "1" ]]; then
          # Interactive selection
          local selected
          selected=$(wf_select_interactive "$workflow_data" "clean pins from")
          if [ -z "$selected" ]; then
              log WARN "No workflows selected"
              exit 0
          fi
          while IFS= read -r f; do
              [ -n "$f" ] && files_to_process+=("$f")
          done <<< "$selected"
      else
          # All files
          while IFS='|' read -r wf_path _rest; do
              [ -n "$wf_path" ] && files_to_process+=("$wf_path")
          done <<< "$workflow_data"
      fi
  else
      # Interactive: prompt for mode
      if [ -t 0 ]; then
          local mode
          mode=$(ui_choose "Select clean-pins mode" \
              "Single file" \
              "All files in directory" \
              "Select specific files")

          case "$mode" in
              "Single"*)
                  ARG_FILE=$(ui_input "Path to .n8n file" "")
                  if [ -z "$ARG_FILE" ] || [ ! -f "$ARG_FILE" ]; then
                      log ERROR "File not found: ${ARG_FILE:-<not specified>}"
                      exit 1
                  fi
                  files_to_process+=("$ARG_FILE")
                  ;;
              "All"*)
                  ARG_WORKFLOWS_DIR=$(ui_input "Path to .n8n workflow files directory" "")
                  if [ -z "$ARG_WORKFLOWS_DIR" ] || [ ! -d "$ARG_WORKFLOWS_DIR" ]; then
                      log ERROR "Directory not found: ${ARG_WORKFLOWS_DIR:-<not specified>}"
                      exit 1
                  fi
                  for f in "$ARG_WORKFLOWS_DIR"/*.n8n; do
                      [ -f "$f" ] && files_to_process+=("$f")
                  done
                  ;;
              "Select"*)
                  ARG_WORKFLOWS_DIR=$(ui_input "Path to .n8n workflow files directory" "")
                  local wd
                  wd=$(wf_discover_files "$ARG_WORKFLOWS_DIR")
                  local sel
                  sel=$(wf_select_interactive "$wd" "clean pins from")
                  while IFS= read -r f; do
                      [ -n "$f" ] && files_to_process+=("$f")
                  done <<< "$sel"
                  ;;
          esac
      else
          log ERROR "Specify --file, --all, or --select"
          log INFO "Usage: n8n-manager workflow clean-pins --file path.n8n"
          log INFO "       n8n-manager workflow clean-pins --all --workflows-dir ./workflows"
          exit 1
      fi
  fi

  if [ ${#files_to_process[@]} -eq 0 ]; then
      log ERROR "No files to process"
      exit 1
  fi

  # ── Confirm before destructive operation ───────

  if [[ "$ARG_CHECK_ONLY" != "1" ]] && [[ "${ARG_DRY_RUN:-}" != "1" ]]; then
      if [ -t 0 ] && [ ${#files_to_process[@]} -gt 1 ]; then
          ui_confirm "Remove pin data from ${#files_to_process[@]} file(s)?" || exit 0
      fi
  fi

  # ── Process files ────────────────────────────────

  ui_header "Clean Pin Data"
  echo "" >&2

  local total_cleaned=0
  local total_bytes_saved=0
  local total_files=${#files_to_process[@]}
  local files_with_pins=0

  for file in "${files_to_process[@]}"; do
      local basename_file
      basename_file=$(basename "$file")

      # Check for pinData using available JSON parser
      local has_pins=false
      local pin_size=0

      if command_exists node; then
          local result
          result=$(node -e '
  const fs = require("fs");
  try {
      const d = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
      const pinData = d.pinData;
      if (pinData && typeof pinData === "object" && Object.keys(pinData).length > 0) {
          const pinStr = JSON.stringify(pinData);
          console.log("yes|" + Object.keys(pinData).length + "|" + pinStr.length);
      } else {
          console.log("no|0|0");
      }
  } catch(e) { console.log("no|0|0"); }
  ' "$file" 2>/dev/null)
          local has pin_count pin_bytes
          IFS='|' read -r has pin_count pin_bytes <<< "$result"
          if [ "$has" = "yes" ]; then
              has_pins=true
              pin_size=$pin_bytes
          fi
      elif command_exists python3; then
          local result
          result=$(python3 -c "
  import json, sys
  try:
      with open(sys.argv[1]) as f: d = json.load(f)
      pd = d.get('pinData', {})
      if pd and isinstance(pd, dict) and len(pd) > 0:
          print(f'yes|{len(pd)}|{len(json.dumps(pd))}')
      else:
          print('no|0|0')
  except: print('no|0|0')
  " "$file" 2>/dev/null)
          local has pin_count pin_bytes
          IFS='|' read -r has pin_count pin_bytes <<< "$result"
          if [ "$has" = "yes" ]; then
              has_pins=true
              pin_size=$pin_bytes
          fi
      else
          # grep fallback
          if grep -q '"pinData"' "$file" 2>/dev/null; then
              has_pins=true
              pin_size=0
          fi
      fi

      if [ "$has_pins" = "false" ]; then
          log DEBUG "  ⏭ $basename_file — no pin data"
          continue
      fi

      files_with_pins=$((files_with_pins + 1))

      if [[ "$ARG_CHECK_ONLY" == "1" ]]; then
          log INFO "  📌 $basename_file — has pin data (~$pin_size bytes)"
          continue
      fi

      # Remove pinData
      if [[ "${ARG_DRY_RUN:-}" == "1" ]]; then
          log DRYRUN "  Would clean $basename_file (~$pin_size bytes)"
          total_cleaned=$((total_cleaned + 1))
          total_bytes_saved=$((total_bytes_saved + pin_size))
          continue
      fi

      if command_exists node; then
          node -e '
  const fs = require("fs");
  try {
      const file = process.argv[1];
      const d = JSON.parse(fs.readFileSync(file, "utf8"));
      delete d.pinData;
      fs.writeFileSync(file, JSON.stringify(d, null, 2));
      console.log("ok");
  } catch(e) { console.error(e.message); process.exit(1); }
  ' "$file" 2>/dev/null
      elif command_exists python3; then
          python3 -c "
  import json, sys
  try:
      with open(sys.argv[1]) as f: d = json.load(f)
      d.pop('pinData', None)
      with open(sys.argv[1], 'w') as f: json.dump(d, f, indent=2)
  except Exception as e: print(f'Error: {e}', file=sys.stderr); sys.exit(1)
  " "$file" 2>/dev/null
      else
          log WARN "  ⚠ $basename_file — need node or python3 to clean pinData"
          continue
      fi

      if [ $? -eq 0 ]; then
          total_cleaned=$((total_cleaned + 1))
          total_bytes_saved=$((total_bytes_saved + pin_size))
          log SUCCESS "  ✔ $basename_file — cleaned (~$pin_size bytes saved)"
      else
          log ERROR "  ✖ $basename_file — failed to clean"
      fi
  done

  # ── Summary ──────────────────────────────────────

  echo "" >&2
  if [[ "$ARG_CHECK_ONLY" == "1" ]]; then
      ui_summary "Pin Data Check" \
          "Files scanned" "$total_files" \
          "Files with pins" "$files_with_pins"
  else
      local bytes_display="$total_bytes_saved bytes"
      if [ "$total_bytes_saved" -gt 1048576 ]; then
          bytes_display="$((total_bytes_saved / 1048576)) MB"
      elif [ "$total_bytes_saved" -gt 1024 ]; then
          bytes_display="$((total_bytes_saved / 1024)) KB"
      fi
      ui_summary "Clean Pins Complete" \
          "Files cleaned" "$total_cleaned of $total_files" \
          "Space saved" "~$bytes_display"
  fi

}

