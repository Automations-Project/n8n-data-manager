                  log INFO "No settings defined"
              else
                  while IFS= read -r line; do
                      log INFO "  $line"
                  done <<< "$settings"
              fi
              exit 0
              ;;
          "Update"*)
              setting_key=$(ui_input "Setting key (e.g. executionOrder)" "")
              setting_value=$(ui_input "Setting value" "")
              is_update=true
              ;;
          "Enable MCP"*)
              # MCP enable mode
              for file in "${files_to_process[@]}"; do
                  local basename_file
                  basename_file=$(basename "$file")
                  ui_header "Enable MCP: $basename_file"
                  wf_mcp_enable "$file"
                  if [ $? -eq 0 ]; then
                      log SUCCESS "MCP enabled on $basename_file"
                  else
                      log ERROR "Failed to enable MCP on $basename_file"
                  fi
              done
              exit 0
              ;;
          "Disable MCP"*)
              # MCP disable mode
              for file in "${files_to_process[@]}"; do
                  local basename_file
                  basename_file=$(basename "$file")
                  ui_header "Disable MCP: $basename_file"
                  wf_mcp_disable "$file"
                  if [ $? -eq 0 ]; then
                      log SUCCESS "MCP disabled on $basename_file"
                  else
                      log ERROR "Failed to disable MCP on $basename_file"
                  fi
              done
              exit 0
              ;;
      esac
  fi

  # ── View or update settings ──────────────────────

  if [ "$is_update" = "false" ]; then
      # View mode
      for file in "${files_to_process[@]}"; do
          local basename_file
          basename_file=$(basename "$file")
          ui_header "Settings: $basename_file"
          local settings
          settings=$(wf_list_settings "$file")
          if [ -z "$settings" ]; then
              log INFO "  No settings defined"
          else
              while IFS= read -r line; do
                  log INFO "  $line"
              done <<< "$settings"
          fi
          echo "" >&2
      done
  else
      # Update mode
      ui_header "Update Settings"
      echo "" >&2

      # Special handling for mcpEnabled
      if [ "$setting_key" = "mcpEnabled" ]; then
          for file in "${files_to_process[@]}"; do
              local basename_file
              basename_file=$(basename "$file")
              if [ "$setting_value" = "true" ]; then
                  wf_mcp_enable "$file"
                  if [ $? -eq 0 ]; then
                      log SUCCESS "  $basename_file — MCP enabled"
                  else
                      log ERROR "  $basename_file — failed to enable MCP"
                  fi
              else
                  wf_mcp_disable "$file"
                  if [ $? -eq 0 ]; then
                      log SUCCESS "  $basename_file — MCP disabled"
                  else
                      log ERROR "  $basename_file — failed to disable MCP"
                  fi
              fi
          done
      else
          # Regular setting update
          local updated=0
          for file in "${files_to_process[@]}"; do
              local basename_file
              basename_file=$(basename "$file")
              wf_update_setting "$file" "$setting_key" "$setting_value"
              if [ $? -eq 0 ]; then
                  log SUCCESS "  $basename_file — $setting_key=$setting_value"
                  updated=$((updated + 1))
              else
                  log ERROR "  $basename_file — failed to update"
              fi
          done
          echo "" >&2
          log SUCCESS "Updated $updated of ${#files_to_process[@]} file(s)"
      fi
  fi

}

