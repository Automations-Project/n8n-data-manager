# Validate a URL format
validate_url() {
    local url="$1"
    log DEBUG "[URL] Validating URL: $url"

    if [[ "$url" =~ ^https?:// ]]; then
        log DEBUG "[URL] URL format is valid"
        return 0
    else
        log ERROR "Invalid URL format: $url"
        log INFO "URL must start with http:// or https://"
        return 1
    fi
}

# Download a file from URL to a local path
download_from_url() {
    local url="$1"
    local output_path="$2"

    log DEBUG "[DOWNLOAD] Downloading from: $url"
    log DEBUG "[DOWNLOAD] Output path: $output_path"

    if ! validate_url "$url"; then
        return 1
    fi

    log INFO "Downloading from URL..."
    local http_code
    http_code=$(curl -sSL -o "$output_path" -w "%{http_code}" "$url")

    if [ "$http_code" != "200" ]; then
        log ERROR "Download failed (HTTP $http_code) from: $url"
        rm -f "$output_path"
        return 1
    fi

    if [ ! -f "$output_path" ] || [ ! -s "$output_path" ]; then
        log ERROR "Downloaded file is empty or missing: $output_path"
        return 1
    fi

    log SUCCESS "Download completed: $output_path"
    return 0
}

