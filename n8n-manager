# Internal Helpers
# ═══════════════════════════════════════════════════════════

# Extract enterprise JSONL files from entities.zip
# Args: $1=zip_file $2=output_dir
_extract_enterprise_entities() {
    local zip_file="$1"
    local output_dir="$2"

    for entity_file in "${ENTERPRISE_ENTITY_FILES[@]}"; do
        if unzip -o -j "$zip_file" "$entity_file" -d "$output_dir" 2>/dev/null; then
            local count
            count=$(parse_jsonl_count "$output_dir/$entity_file")
            log DEBUG "[ENTITIES] Extracted $entity_file ($count entities)"
        else
            log DEBUG "[ENTITIES] $entity_file not found in zip (may not exist in this n8n instance)"
        fi
    done

    return 0
}

# Import a single entity type via import:entities
# Creates a temporary zip with just that one JSONL file
# Args: $1=container_id $2=entities_dir $3=entity_filename
_import_single_entity() {
    local container="$1"
    local entities_dir="$2"
    local entity_file="$3"

    # D-13: Use _safe_mktemp_dir for temp dirs holding credential material (mode 0700)
    local tmp_import_dir
    tmp_import_dir=$(_safe_mktemp_dir "n8n-entity-creds") || {
        log ERROR "_import_single_entity: failed to create safe temp dir for $entity_file"
        return 1
    }
    # D-13: Shred cleanup on EXIT + INT + TERM (Phase 4 D-18 pattern)
    trap '_shred_dir "${tmp_import_dir:-}"' EXIT
    trap '_shred_dir "${tmp_import_dir:-}"' INT
    trap '_shred_dir "${tmp_import_dir:-}"' TERM

    # Copy the single JSONL file
    cp "$entities_dir/$entity_file" "$tmp_import_dir/"

    # Also copy migrations.jsonl if available (needed for compatibility)
    if [ -f "$entities_dir/$ENTITY_MIGRATIONS" ]; then
        cp "$entities_dir/$ENTITY_MIGRATIONS" "$tmp_import_dir/"
    fi

    # Create entities.zip (import:entities expects a zip)
    local tmp_zip="$tmp_import_dir/entities.zip"
    (cd "$tmp_import_dir" && zip -q "$tmp_zip" *.jsonl 2>/dev/null)

    if [ ! -f "$tmp_zip" ]; then
        log ERROR "Failed to create entities.zip for $entity_file"
        _shred_dir "$tmp_import_dir"
        return 1
    fi

    # Copy zip to container
    local container_import_dir="/tmp/n8n-entity-import"
    dockExec "$container" "rm -rf $container_import_dir && mkdir -p $container_import_dir" 2>/dev/null || true

    if ! docker cp "$tmp_zip" "$container:$container_import_dir/entities.zip"; then
        log ERROR "Failed to copy entity zip to container"
        _shred_dir "$tmp_import_dir"
        return 1
    fi

    # Run import:entities with truncateTables for this specific entity
    if ! dockExec "$container" "n8n import:entities --inputDir=$container_import_dir --truncateTables true"; then
        log WARN "import:entities failed for $entity_file"
        dockExec "$container" "rm -rf $container_import_dir" 2>/dev/null || true
        _shred_dir "$tmp_import_dir"
        return 1
    fi

    # Clean up
    dockExec "$container" "rm -rf $container_import_dir" 2>/dev/null || true
    _shred_dir "$tmp_import_dir"
    # D-13: Clear the EXIT trap now that we've explicitly cleaned up
    trap - EXIT INT TERM

    return 0
}

# Check migration compatibility between backup and target instance
# Args: $1=container_id $2=migrations_jsonl_file
_check_migration_compatibility() {
    local container="$1"
    local migrations_file="$2"

    log DEBUG "[ENTITIES] Checking migration compatibility..."

    # Get the last migration name from the backup
    local backup_last_migration
    backup_last_migration=$(tail -1 "$migrations_file" 2>/dev/null | grep -o '"name":"[^"]*"' | head -1 | sed 's/"name":"//;s/"//')

    if [ -z "$backup_last_migration" ]; then
        log DEBUG "[ENTITIES] Could not parse migration version from backup"
        return 0
    fi

    log DEBUG "[ENTITIES] Backup migration: $backup_last_migration"

    # Get the current n8n version from the container
    local n8n_version
    n8n_version=$(dockExec "$container" "n8n --version" 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -n1)

    if [ -n "$n8n_version" ]; then
        log DEBUG "[ENTITIES] Target n8n version: $n8n_version"
        log INFO "Backup migration: $backup_last_migration"
        log INFO "Target n8n version: v$n8n_version"
    fi

    # If we can export entities from the target, compare migration states
    local container_check_dir="/tmp/n8n-migration-check"
    dockExec "$container" "rm -rf $container_check_dir" 2>/dev/null || true

    if dockExec "$container" "n8n export:entities --outputDir=$container_check_dir" 2>/dev/null; then
        local container_zip="$container_check_dir/entities.zip"
        local tmp_check_dir
        tmp_check_dir=$(_safe_mktemp_dir "n8n-migration-check") || {
            log WARN "[ENTITIES] Could not create safe temp dir for migration check — skipping"
            dockExec "$container" "rm -rf $container_check_dir" 2>/dev/null || true
            return 0
        }

        if docker cp "$container:$container_zip" "$tmp_check_dir/entities.zip" 2>/dev/null; then
            if unzip -o -j "$tmp_check_dir/entities.zip" "$ENTITY_MIGRATIONS" -d "$tmp_check_dir" 2>/dev/null; then
                local target_last_migration
                target_last_migration=$(tail -1 "$tmp_check_dir/$ENTITY_MIGRATIONS" 2>/dev/null | grep -o '"name":"[^"]*"' | head -1 | sed 's/"name":"//;s/"//')

                log DEBUG "[ENTITIES] Target migration: $target_last_migration"

                if [ "$backup_last_migration" != "$target_last_migration" ]; then
                    log WARN "Migration mismatch: backup=$backup_last_migration target=$target_last_migration"
                    _shred_dir "$tmp_check_dir"
                    dockExec "$container" "rm -rf $container_check_dir" 2>/dev/null || true
                    return 1
                else
                    log SUCCESS "Migration versions match"
                fi
            fi
        fi

        _shred_dir "$tmp_check_dir"
    fi

    dockExec "$container" "rm -rf $container_check_dir" 2>/dev/null || true
    return 0
}

# Display summary of exported entity files as a styled table
# Args: $1=entities_dir
_show_entity_export_summary() {
    local entities_dir="$1"
    local has_data=false
    local csv_data="Entity,Count,Status"

    for entity_file in "${ENTERPRISE_ENTITY_FILES[@]}"; do
        local entity_name="${entity_file%.jsonl}"
        if [ -f "$entities_dir/$entity_file" ]; then
            local count
            count=$(parse_jsonl_count "$entities_dir/$entity_file")
            if [ "$count" -gt 0 ]; then
                csv_data="$csv_data
$entity_name,$count,✔ exported"
                has_data=true
            else
                csv_data="$csv_data
$entity_name,0,— empty"
            fi
        else
            csv_data="$csv_data
$entity_name,—,⊘ not found"
        fi
    done

    if $has_data; then
        log INFO "Enterprise entities exported:"
        echo "$csv_data" | ui_table
    else
        log INFO "No enterprise entities found in this n8n instance"
    fi
}

