# Analyze changes since last backup for incremental mode
get_incremental_changes() {
    local git_repo_path="$1"
    local temp_export_path="$2"
    local changes_list=""

    log DEBUG "[INCREMENTAL] Analyzing incremental changes in: $git_repo_path"
    log DEBUG "[INCREMENTAL] Temp export path: $temp_export_path"

    # Check if we're in a git repository
    if [ ! -d "$git_repo_path/.git" ]; then
        log WARN "[INCREMENTAL] Not a git repository - performing full backup"
        return 1
    fi

    local original_pwd
    original_pwd=$(pwd)
    cd "$git_repo_path" || {
        log ERROR "[INCREMENTAL] Failed to change to git repository: $git_repo_path"
        return 1
    }

    # Get last backup commit
    local last_backup_commit
    last_backup_commit=$(git log --oneline --grep="n8n Backup" --grep="🔄" -1 --format="%H" 2>/dev/null || echo "")

    if [ -z "$last_backup_commit" ]; then
        log INFO "[INCREMENTAL] No previous backup found - performing full backup"
        cd "$original_pwd"
        return 1
    fi

    log DEBUG "[INCREMENTAL] Last backup commit: $last_backup_commit"

    if [ "${ARG_SEPARATE_FILES:-}" = "true" ] || [ "${ARG_SEPARATE_FILES:-}" = "1" ]; then
        log DEBUG "[INCREMENTAL] Using separate files mode for incremental analysis"
        # Compare individual workflow files
        if [ -d "$temp_export_path/workflows" ]; then
            for workflow_file in "$temp_export_path"/workflows/*.json; do
                [ -f "$workflow_file" ] || continue
                local basename
                basename=$(basename "$workflow_file")

                if ! git show "$last_backup_commit:workflows/$basename" >/dev/null 2>&1; then
                    changes_list="$changes_list workflows/$basename"
                    log DEBUG "[INCREMENTAL] New workflow detected: $basename"
                elif ! git diff --quiet "$last_backup_commit" HEAD -- "workflows/$basename" 2>/dev/null; then
                    if [ -f "workflows/$basename" ]; then
                        changes_list="$changes_list workflows/$basename"
                        log DEBUG "[INCREMENTAL] Modified workflow detected: $basename"
                    fi
                fi
            done
        fi

        # Compare individual credential files
        if [ -d "$temp_export_path/credentials" ]; then
            for cred_file in "$temp_export_path"/credentials/*.json; do
                [ -f "$cred_file" ] || continue
                local basename
                basename=$(basename "$cred_file")

                if ! git show "$last_backup_commit:credentials/$basename" >/dev/null 2>&1; then
                    changes_list="$changes_list credentials/$basename"
                    log DEBUG "[INCREMENTAL] New credential detected: $basename"
                elif ! git diff --quiet "$last_backup_commit" HEAD -- "credentials/$basename" 2>/dev/null; then
                    if [ -f "credentials/$basename" ]; then
                        changes_list="$changes_list credentials/$basename"
                        log DEBUG "[INCREMENTAL] Modified credential detected: $basename"
                    fi
                fi
            done
        fi
    else
        log DEBUG "[INCREMENTAL] Using single file mode for incremental analysis"
        for file in workflows.json credentials.json; do
            if [ -f "$temp_export_path/$file" ]; then
                if ! git show "$last_backup_commit:$file" >/dev/null 2>&1; then
                    changes_list="$changes_list $file"
                    log DEBUG "[INCREMENTAL] New file detected: $file"
                elif ! cmp -s "$temp_export_path/$file" <(git show "$last_backup_commit:$file" 2>/dev/null); then
                    changes_list="$changes_list $file"
                    log DEBUG "[INCREMENTAL] Modified file detected: $file"
                fi
            fi
        done
    fi

    cd "$original_pwd"

    changes_list=$(echo "$changes_list" | xargs) # Clean whitespace

    if [ -n "$changes_list" ]; then
        local change_count
        change_count=$(echo "$changes_list" | wc -w)
        log SUCCESS "[INCREMENTAL] Incremental changes detected: $change_count files"
        echo "$changes_list"
        return 0
    else
        log INFO "[INCREMENTAL] No changes detected since last backup"
        return 2 # Special return code for "no changes"
    fi
}

