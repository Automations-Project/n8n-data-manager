    [ -n "${ARG_PROJECT_ID:-}" ] && cmd="$cmd --projectId=$ARG_PROJECT_ID"

    if ! dockExec "$container" "$cmd"; then
        log WARN "[SC-IMPORT] credential stub import had unresolved items"
        if [ -n "$report_file" ]; then
            cat > "$report_file" <<EOF
{
  "credentials": {
    "status": "partial",
    "reason": "credential stubs cannot always be fully materialized without secrets"
  }
}
EOF
        fi
    fi

    dockExec "$container" "rm -rf /tmp/import_credentials" 2>/dev/null || true
    rm -rf "$temp"
    return 0
}

_sc_import_metadata_offline() {
    local container="$1"
    local source_dir="$2"
    local delete_missing="$3"
    local is_dry_run="$4"
    local report_file="$5"

    local delete_flag=false
    [ "$delete_missing" = "true" ] && delete_flag=true

    if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
        log DRYRUN "Would run offline metadata phase (stop/apply/start)"
        return 0
    fi

    if [ -t 0 ]; then
        if ! ui_confirm_offline_metadata_phase; then
            log INFO "Offline metadata phase cancelled by user"
            return 1
        fi
    fi

    log WARN "[SC-IMPORT] entering offline metadata phase"
    docker stop "$container" >/dev/null || {
        log ERROR "Failed to stop container for offline metadata phase"
        return 1
    }

    local apply_ok=false
    if [ "${N8N_PROBE_DB_BACKEND:-sqlite}" = "sqlite" ]; then
        if db_sqlite_apply_metadata "$container" "$source_dir" "$delete_flag" "false" "$report_file"; then
            apply_ok=true
        fi
    else
        if db_pg_apply_metadata "$container" "$source_dir" "$delete_flag" "false" "$report_file"; then
            apply_ok=true
        fi
    fi

    docker start "$container" >/dev/null || {
        log ERROR "Failed to restart container after metadata phase"
        return 1
    }

    if ! $apply_ok; then
        log ERROR "Metadata fallback apply failed"
        return 1
    fi

    # Verification pass — uses dockExec (sh -c sufficient; n8n --version is a read-only probe)
    if ! dockExec "$container" "n8n --version >/dev/null 2>&1"; then
        log WARN "[SC-IMPORT] post-restore verification failed"
    fi

    return 0
}

_sc_import_expand_bundle_source() {
    local source_dir="$1"
    local output_dir="$2"

    if ! command_exists python3; then
        log ERROR "python3 is required to import .n8n.backup/.n8n.backups files"
        return 1
    fi

    python3 - "$source_dir" "$output_dir" <<'PY'
import json
import sys
from pathlib import Path

source = Path(sys.argv[1])
out = Path(sys.argv[2])

bundle_files = sorted(list(source.glob("*.n8n.backups")) + list(source.glob("*.n8n.backup")))
if not bundle_files:
    raise SystemExit(1)

workflows = {}
credentials = {}
credential_stubs = {}
projects = {}
datatables = {}
tags = {}
mappings = {}
variables = []
folders = {}
workflow_owners = {}

def to_list(v):
    if isinstance(v, list):
        return v
    if isinstance(v, dict):
        for c in v.values():
            if isinstance(c, list):
                return c
    return []

def add_map(store, items):
    for item in items:
        if not isinstance(item, dict):
            continue
        iid = item.get("id")
        if iid is None:
            continue
        store[str(iid)] = item

def add_mapping_items(items):
    for m in items:
        if not isinstance(m, dict):
            continue
        wf = str(m.get("workflowId") or m.get("workflow_id") or "")
        tg = str(m.get("tagId") or m.get("tag_id") or "")
        key = f"{wf}:{tg}:{json.dumps(m, sort_keys=True)}"
        mappings[key] = m

def add_owner_items(items):
    for row in items:
        if not isinstance(row, dict):
            continue
        key = json.dumps(row, sort_keys=True)
        workflow_owners[key] = row

def ingest(payload):
    if not isinstance(payload, dict):
        return
    data = payload.get("data") if isinstance(payload.get("data"), dict) else payload

    add_map(workflows, to_list(data.get("workflows", [])))
    add_map(credentials, to_list(data.get("credentials", [])))
    add_map(credential_stubs, to_list(data.get("credentialStubs", data.get("credential_stubs", []))))
    add_map(projects, to_list(data.get("projects", [])))
    add_map(datatables, to_list(data.get("datatables", [])))

    tags_doc = data.get("tags", {})
    if isinstance(tags_doc, dict):
        add_map(tags, to_list(tags_doc.get("tags", [])))
        add_mapping_items(to_list(tags_doc.get("mappings", [])))
    elif isinstance(tags_doc, list):
        add_map(tags, tags_doc)

    variables_doc = data.get("variableStubs", data.get("variable_stubs", data.get("variables", [])))
    if isinstance(variables_doc, list):
        variables.extend([v for v in variables_doc if isinstance(v, dict)])

    folders_doc = data.get("folders", {})
    if isinstance(folders_doc, dict):
        add_map(folders, to_list(folders_doc.get("folders", [])))
    elif isinstance(folders_doc, list):
        add_map(folders, folders_doc)

    owners_doc = data.get("workflowOwners", data.get("workflow_owners", {}))
    if isinstance(owners_doc, dict):
        add_owner_items(to_list(owners_doc.get("workflowOwners", [])))
    elif isinstance(owners_doc, list):
        add_owner_items(owners_doc)

for bf in bundle_files:
    try:
        payload = json.loads(bf.read_text(encoding="utf-8"))
    except Exception:
        continue
    ingest(payload)

(out / "workflows").mkdir(parents=True, exist_ok=True)
(out / "credential_stubs").mkdir(parents=True, exist_ok=True)
(out / "credentials").mkdir(parents=True, exist_ok=True)
(out / "projects").mkdir(parents=True, exist_ok=True)
(out / "datatables").mkdir(parents=True, exist_ok=True)
(out / ".n8n-manager").mkdir(parents=True, exist_ok=True)

for wid, w in workflows.items():
    (out / "workflows" / f"{wid}.json").write_text(json.dumps(w, indent=2), encoding="utf-8")
for cid, c in credentials.items():
    (out / "credentials" / f"{cid}.json").write_text(json.dumps(c, indent=2), encoding="utf-8")
for cid, c in credential_stubs.items():
    (out / "credential_stubs" / f"{cid}.json").write_text(json.dumps(c, indent=2), encoding="utf-8")
for pid, p in projects.items():
    (out / "projects" / f"{pid}.json").write_text(json.dumps(p, indent=2), encoding="utf-8")
for did, d in datatables.items():
    (out / "datatables" / f"{did}.json").write_text(json.dumps(d, indent=2), encoding="utf-8")

(out / "tags.json").write_text(
    json.dumps({"tags": list(tags.values()), "mappings": list(mappings.values())}, indent=2),
    encoding="utf-8",
)
(out / "variable_stubs.json").write_text(json.dumps(variables, indent=2), encoding="utf-8")
(out / "folders.json").write_text(json.dumps({"folders": list(folders.values())}, indent=2), encoding="utf-8")
(out / "workflow_owners.json").write_text(
    json.dumps({"workflowOwners": list(workflow_owners.values())}, indent=2),
    encoding="utf-8",
)
PY
}

sc_import_bundle() {
    local container="$1"
    local source_dir="$2"
    local restore_type="$3"
    local is_dry_run="$4"

    if [[ "$restore_type" == "enterprise" ]]; then
        log ERROR "Enterprise-only restore requires canonical source-control layout, not bundle files."
        log ERROR "Fix: restore from canonical backup (--backup-layout canonical)."
        return 1
    fi

    local tmp_dir
    tmp_dir=$(mktemp -d -t n8n-sc-bundle-import-XXXXXXXXXX)

    if ! _sc_import_expand_bundle_source "$source_dir" "$tmp_dir"; then
        rm -rf "$tmp_dir"
        log ERROR "Failed to parse backup bundle files"
        return 1
    fi

    local rc=0
    sc_import_canonical "$container" "$tmp_dir" "$restore_type" "$is_dry_run" || rc=$?
    rm -rf "$tmp_dir"
    return $rc
}

sc_import_canonical() {
    local container="$1"
    local source_dir="$2"
    local restore_type="$3"
    local is_dry_run="$4"

    n8n_probe_runtime "$container" "${ARG_N8N_API_KEY:-}" "${ARG_N8N_API_URL:-}"

    local force_flag=false
    local delete_missing=false
    local import_as_new=false
    [ "${ARG_FORCE:-}" = "1" ] && force_flag=true
    [ "${ARG_DELETE_MISSING:-}" = "1" ] && delete_missing=true
    _sc_import_is_import_as_new_mode && import_as_new=true

    local desired_json existing_json
    desired_json=$(mktemp -t n8n-sc-desired-XXXXXXXXXX.json)
    existing_json=$(mktemp -t n8n-sc-existing-XXXXXXXXXX.json)

    _sc_import_write_desired_state "$source_dir" "$desired_json" || {
        rm -f "$desired_json" "$existing_json"
        return 1
    }
    _sc_import_write_existing_state "$container" "$existing_json" || {
        rm -f "$desired_json" "$existing_json"
        return 1
    }

    local conflict_output
    conflict_output=$(_sc_import_conflict_check "$desired_json" "$existing_json" "$restore_type" "$force_flag" "$delete_missing" "$import_as_new" 2>&1)
    local conflict_rc=$?
    if [ $conflict_rc -ne 0 ]; then
        rm -f "$desired_json" "$existing_json"
        if [ $conflict_rc -eq 2 ] && [ -n "$conflict_output" ]; then
            log ERROR "Conflicts detected. Re-run with --force to override."
            log ERROR "$conflict_output"
        else
            log ERROR "$conflict_output"
        fi
        return 1
    fi

    rm -f "$desired_json" "$existing_json"

    local report_file
    report_file="$(sc_layout_report_path "$source_dir")"

    if [[ "$restore_type" == "all" || "$restore_type" == "workflows" ]]; then
        _sc_import_workflows_cli "$container" "$source_dir" "$is_dry_run" || return 1
    fi

    if [[ "$restore_type" == "all" || "$restore_type" == "credentials" ]]; then
        local credentials_source
        credentials_source=$(_sc_import_detect_credentials_source "$source_dir")
        case "$credentials_source" in
            full)
                log INFO "[SC-IMPORT] full credentials payload detected"
                _sc_import_credentials_full_cli "$container" "$source_dir" "$is_dry_run" || return 1
                ;;
            stubs)
                log INFO "[SC-IMPORT] credential stubs payload detected"
                _sc_import_credentials_stubs_cli "$container" "$source_dir" "$is_dry_run" "$report_file" || return 1
                ;;
            *)
                log INFO "[SC-IMPORT] no credential payload found in canonical layout"
                ;;
        esac
    fi

    if [[ "$restore_type" == "all" || "$restore_type" == "enterprise" ]]; then
        _sc_import_metadata_offline "$container" "$source_dir" "$delete_missing" "$is_dry_run" "$report_file" || return 1
    elif [ "$delete_missing" = "true" ]; then
        log WARN "--delete-missing currently applies to metadata resources only"
    fi

    return 0
}

# Phase 3 D-07 + D-08 + D-12 — adapter-driven legacy import.
# Creates a staging dir via mktemp -d, calls v4_adapter_to_canonical_staging,
# then dispatches sc_import_canonical against the staging dir. Hard-fails on
# adapter return 1 with the D-12 actionable error.
_sc_import_via_v4_adapter() {
    local container="$1"
    local source_dir="$2"
    local restore_type="$3"
    local is_dry_run="$4"
    local pre_restore_dir="$5"

    if ! declare -F v4_adapter_to_canonical_staging >/dev/null 2>&1; then
        log ERROR "v4 adapter not available at runtime (src/lib/v4_shape_adapter.sh missing or not sourced)"
        return 1
    fi

    local v4_stage
    v4_stage=$(mktemp -d -t n8n-v4-stage-XXXXXX) || {
        log ERROR "[SC-IMPORT] failed to create temp staging dir"
        return 1
    }
    # Project cleanup policy + D-08: trap on every exit path including signals (EXIT SIGINT SIGTERM).
    trap 'rm -rf "$v4_stage" 2>/dev/null || true' EXIT SIGINT SIGTERM

    if ! v4_adapter_to_canonical_staging "$source_dir" "$v4_stage"; then
        log ERROR "v4 adapter failed on $source_dir."
        log ERROR "Try (a) re-run with --legacy-fallback for the pre-v5 import path"
        log ERROR "        (reduced validation; emergency-restore semantics), or"
        log ERROR "    (b) manually inspect $source_dir and fix the source repo."
        return 1
    fi

    log INFO "[SC-IMPORT] v4 adapter staged canonical layout at $v4_stage"
    log INFO "[SC-IMPORT] dispatching canonical import against staging dir"

    sc_import_canonical "$container" "$v4_stage" "$restore_type" "$is_dry_run"
    local rc=$?

    # D-18 — gentle migrate nudge on successful adapter completion (legacy shape only,
    # not legacy-partial which already has its own banner upstream).
    if [ "$rc" = "0" ]; then
        log INFO "Tip: 'n8n-manager migrate --source $source_dir' upgrades the source repo to canonical layout for cleaner future state."
    fi

    return $rc
}

sc_import_dispatch() {
    local container="$1"
    local source_dir="$2"
    local restore_type="$3"
    local is_dry_run="$4"
    local pre_restore_dir="$5"

    local layout
    layout=$(sc_layout_detect "$source_dir" 2>/dev/null || echo "unknown")

    case "$layout" in
        canonical)
            log INFO "[SC-IMPORT] canonical source-control layout detected"
            sc_import_canonical "$container" "$source_dir" "$restore_type" "$is_dry_run"
            return $?
            ;;
        bundle)
            log INFO "[SC-IMPORT] bundle layout detected (*.n8n.backup / *.n8n.backups)"
            sc_import_bundle "$container" "$source_dir" "$restore_type" "$is_dry_run"
            return $?
            ;;
        legacy-partial)
            # Phase 3 D-03 + D-04 — mixed v4/v5 source.
            if [ "${ARG_ACCEPT_LEGACY_PARTIAL:-}" = "1" ]; then
                log INFO "⚠ legacy-partial source detected; using v4 adapter; ignoring partial canonical files."
                _sc_import_via_v4_adapter "$container" "$source_dir" "$restore_type" "$is_dry_run" "$pre_restore_dir"
                return $?
            fi
            log ERROR "Source repo has mixed v4/v5 shape. To proceed:"
            log ERROR "  (a) run 'n8n-manager migrate --source $source_dir' first, or"
            log ERROR "  (b) re-run with --accept-legacy-partial to use the v4-shape adapter"
            log ERROR "      and ignore the partial canonical files."
            return 1
            ;;
        legacy)
            # Phase 3 D-13 + D-18 — adapter is default; --legacy-fallback opts into the pre-v5 path.
            if [ "${ARG_LEGACY_FALLBACK:-}" = "1" ]; then
                log WARN "⚠ Using legacy fallback path; skipping v4-shape adapter normalization."
                log WARN "  Consider running 'n8n-manager migrate --source $source_dir' to upgrade the source repo."
                perform_import_legacy "$container" "$source_dir" "$restore_type" "$is_dry_run" "$pre_restore_dir"
                return $?
            fi
            log INFO "[SC-IMPORT] legacy backup layout detected — routing through v4 adapter"
            _sc_import_via_v4_adapter "$container" "$source_dir" "$restore_type" "$is_dry_run" "$pre_restore_dir"
            return $?
            ;;
        full-db)
            log INFO "[SC-IMPORT] full-db layout detected"
            perform_import_legacy "$container" "$source_dir" "$restore_type" "$is_dry_run" "$pre_restore_dir"
            return $?
            ;;
        *)
            # Phase 3 D-14 — pre-Phase-3 silent fallthrough is gone; opt-in only.
            if [ "${ARG_LEGACY_FALLBACK:-}" = "1" ]; then
                log WARN "⚠ Source layout unrecognized; --legacy-fallback opt-in to pre-v5 importer."
                log WARN "  Consider running 'n8n-manager migrate --source $source_dir' for a guided upgrade."
                perform_import_legacy "$container" "$source_dir" "$restore_type" "$is_dry_run" "$pre_restore_dir"
                return $?
            fi
            log ERROR "Could not detect backup layout in: $source_dir"
            log ERROR "  (a) confirm the source contains workflows.json, workflows/, or *.n8n.backup files; or"
            log ERROR "  (b) re-run with --legacy-fallback for the pre-v5 import path; or"
            log ERROR "  (c) run 'n8n-manager migrate --source $source_dir' for guided repair."
            return 1
            ;;
    esac
}

# src/lib/source_control_layout.sh

set -Eeuo pipefail
IFS=$'
	'

SC_LAYOUT_META_DIR=".n8n-manager"
SC_LAYOUT_MANIFEST_FILE="manifest.json"
SC_LAYOUT_CAPABILITIES_FILE="capabilities.json"
SC_LAYOUT_CHECKSUMS_FILE="checksums.json"
SC_LAYOUT_GAPS_FILE="gaps.json"
SC_LAYOUT_REPORT_FILE="restore-report.json"

sc_layout_prepare_root() {
    local root_dir="$1"

    mkdir -p "$root_dir"
    mkdir -p "$root_dir/workflows"
    mkdir -p "$root_dir/credential_stubs"
    mkdir -p "$root_dir/projects"
    mkdir -p "$root_dir/datatables"
    mkdir -p "$root_dir/$SC_LAYOUT_META_DIR"

    sc_layout_init_gaps "$root_dir"
}

sc_layout_detect() {
    local source_dir="$1"

    # ── Phase 3 D-01: legacy-partial detection.
    # Fires ONLY when BOTH a legacy marker (workflows.json | credentials.json | .env at root,
    # OR a backup_YYYY-MM-DD[_HH-MM-SS]/ subdir containing workflows.json | credentials.json)
    # AND a canonical marker (workflows/ | credential_stubs/ | credentials/ | projects/ |
    # tags.json | variable_stubs.json | folders.json | workflow_owners.json | datatables/ |
    # .n8n-manager/manifest.json) coexist in the same source dir.
    # Inserted as a surgical early-return BEFORE the existing canonical branch so:
    #   - canonical-only repos still hit the (untouched) canonical branch below
    #   - pure-v4 repos still fall through to the (untouched) legacy branch below
    #   - bundle / full-db detection is unchanged
    local has_legacy_marker=false
    if [ -f "$source_dir/workflows.json" ] || \
       [ -f "$source_dir/credentials.json" ] || \
       [ -f "$source_dir/.env" ]; then
        has_legacy_marker=true
    fi
    if [ "$has_legacy_marker" = "false" ]; then
        local _dated_subdir
        _dated_subdir=$(find "$source_dir" -maxdepth 1 -type d \
            \( -name 'backup_????-??-??_??-??-??' -o -name 'backup_????-??-??' \) \
            2>/dev/null | head -n 1)
        if [ -n "$_dated_subdir" ] && \
           { [ -f "$_dated_subdir/workflows.json" ] || [ -f "$_dated_subdir/credentials.json" ]; }; then
            has_legacy_marker=true
        fi
    fi

    local has_canonical_marker=false
    if [ -d "$source_dir/workflows" ] || \
       [ -d "$source_dir/credential_stubs" ] || \
       [ -d "$source_dir/credentials" ] || \
       [ -d "$source_dir/projects" ] || \
       [ -f "$source_dir/tags.json" ] || \
       [ -f "$source_dir/variable_stubs.json" ] || \
       [ -f "$source_dir/folders.json" ] || \
       [ -f "$source_dir/workflow_owners.json" ] || \
       [ -d "$source_dir/datatables" ] || \
       [ -f "$source_dir/$SC_LAYOUT_META_DIR/$SC_LAYOUT_MANIFEST_FILE" ]; then
        has_canonical_marker=true
    fi

    if [ "$has_legacy_marker" = "true" ] && [ "$has_canonical_marker" = "true" ]; then
        echo "legacy-partial"
        return 0
    fi

    if [ -d "$source_dir/workflows" ] || \
       [ -d "$source_dir/credential_stubs" ] || \
       [ -d "$source_dir/credentials" ] || \
       [ -d "$source_dir/projects" ] || \
       [ -f "$source_dir/tags.json" ] || \
       [ -f "$source_dir/variable_stubs.json" ] || \
       [ -f "$source_dir/folders.json" ] || \
       [ -f "$source_dir/workflow_owners.json" ] || \
       [ -d "$source_dir/datatables" ]; then
        echo "canonical"
        return 0
    fi

    if find "$source_dir" -maxdepth 1 -type f \( -name '*.n8n.backup' -o -name '*.n8n.backups' \) | grep -q .; then
        echo "bundle"
        return 0
    fi

    if [ -f "$source_dir/full-db/entities.zip" ] || \
       [ -f "$source_dir/entities.zip" ] || \
       [ -d "$source_dir/full-db" ]; then
        echo "full-db"
        return 0
    fi

    if [ -f "$source_dir/workflows.json" ] || \
       [ -f "$source_dir/credentials.json" ] || \
       [ -d "$source_dir/workflows" ] || \
       [ -d "$source_dir/credentials" ] || \
       [ -d "$source_dir/entities" ]; then
        echo "legacy"
        return 0
    fi

    echo "unknown"
    return 1
}

sc_layout_manifest_path() {
    local root_dir="$1"
    echo "$root_dir/$SC_LAYOUT_META_DIR/$SC_LAYOUT_MANIFEST_FILE"
}

sc_layout_capabilities_path() {
    local root_dir="$1"
    echo "$root_dir/$SC_LAYOUT_META_DIR/$SC_LAYOUT_CAPABILITIES_FILE"
}

sc_layout_checksums_path() {
    local root_dir="$1"
    echo "$root_dir/$SC_LAYOUT_META_DIR/$SC_LAYOUT_CHECKSUMS_FILE"
}

sc_layout_gaps_path() {
    local root_dir="$1"
    echo "$root_dir/$SC_LAYOUT_META_DIR/$SC_LAYOUT_GAPS_FILE"
}

sc_layout_report_path() {
    local root_dir="$1"
    echo "$root_dir/$SC_LAYOUT_META_DIR/$SC_LAYOUT_REPORT_FILE"
}

sc_layout_init_gaps() {
    local root_dir="$1"
    local gaps_file
    gaps_file=$(sc_layout_gaps_path "$root_dir")
    mkdir -p "$(dirname "$gaps_file")"
    if [ ! -f "$gaps_file" ]; then
        echo "[]" > "$gaps_file"
    fi
}

sc_layout_add_gap() {
    local root_dir="$1"
    local resource="$2"
    local reason="$3"
    local severity="${4:-warning}"

    local gaps_file
    gaps_file=$(sc_layout_gaps_path "$root_dir")
    sc_layout_init_gaps "$root_dir"

    if command_exists python3; then
        python3 - "$gaps_file" "$resource" "$reason" "$severity" <<'PY'
import json
import sys
from datetime import datetime, timezone

path, resource, reason, severity = sys.argv[1:5]
try:
    with open(path, "r", encoding="utf-8") as f:
        data = json.load(f)
except Exception:
    data = []

if not isinstance(data, list):
    data = []

data.append(
    {
        "resource": resource,
        "reason": reason,
        "severity": severity,
        "timestamp": datetime.now(timezone.utc).isoformat(),
    }
)

with open(path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2)
PY
    else
        log WARN "[LAYOUT] python3 missing, could not append gap record"
    fi
}

sc_layout_write_manifest() {
    local root_dir="$1"
    local backup_type="$2"
    local container="$3"
    local engine_order="$4"

    local manifest
    manifest=$(sc_layout_manifest_path "$root_dir")

    cat > "$manifest" <<EOF
{
  "formatVersion": 1,
  "createdAt": "$(date -u +'%Y-%m-%dT%H:%M:%SZ')",
  "backupType": "${backup_type}",
  "container": "${container}",
  "n8nVersion": "${N8N_PROBE_VERSION:-unknown}",
  "dbBackend": "${N8N_PROBE_DB_BACKEND:-unknown}",
  "engineOrder": "${engine_order}"
}
EOF
}

sc_layout_hash_file() {
    local file_path="$1"

    if command_exists sha256sum; then
        sha256sum "$file_path" | awk '{print $1}'
        return 0
    fi
    if command_exists shasum; then
        shasum -a 256 "$file_path" | awk '{print $1}'
        return 0
    fi

    echo ""
    return 1
}

sc_layout_write_checksums() {
    local root_dir="$1"
    local checksums_file
    checksums_file=$(sc_layout_checksums_path "$root_dir")

    local tmp
    tmp=$(mktemp -t n8n-checksums-XXXXXXXXXX)
    echo "{" > "$tmp"
    echo "  \"generatedAt\": \"$(date -u +'%Y-%m-%dT%H:%M:%SZ')\"," >> "$tmp"
    echo "  \"files\": {" >> "$tmp"

    local first=true
    while IFS= read -r file; do
        local rel
        rel="${file#"$root_dir/"}"
        [ "$rel" = "$SC_LAYOUT_META_DIR/$SC_LAYOUT_CHECKSUMS_FILE" ] && continue

        local hash
        hash=$(sc_layout_hash_file "$file")
        [ -z "$hash" ] && continue

        if $first; then
            first=false
        else
            echo "," >> "$tmp"
        fi
        printf '    "%s": "%s"' "$rel" "$hash" >> "$tmp"
    done < <(find "$root_dir" -type f | sort)

    echo "" >> "$tmp"
    echo "  }" >> "$tmp"
    echo "}" >> "$tmp"

    mv "$tmp" "$checksums_file"
}

