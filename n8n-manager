# ═══════════════════════════════════════════════════════════
# .n8n File Discovery
# ═══════════════════════════════════════════════════════════

# Scan a directory for .n8n files and return metadata
# Args: $1=directory path
# Output: pipe-delimited lines to stdout: path|name|id|active|nodeCount
# Returns: 0 on success, 1 if no files found
wf_discover_files() {
    local dir="$1"

    if [ ! -d "$dir" ]; then
        log ERROR "[WF_FILES] Directory not found: $dir"
        return 1
    fi

    log DEBUG "[WF_FILES] Scanning for .n8n files in: $dir"

    local count=0
    local results=""

    for f in "$dir"/*.n8n; do
        [ -f "$f" ] || continue

        local meta
        meta=$(_wf_extract_metadata "$f") || continue
        if [ -n "$meta" ]; then
            results="${results}${results:+$'\n'}${f}|${meta}"
            count=$((count + 1))
        fi
    done

    if [ "$count" -eq 0 ]; then
        log DEBUG "[WF_FILES] No .n8n files found in: $dir"
        return 1
    fi

    log DEBUG "[WF_FILES] Found $count .n8n file(s)"
    echo "$results"
    return 0
}

# Extract metadata from a single .n8n file
# Args: $1=file path
# Output: name|id|active|nodeCount
_wf_extract_metadata() {
    local file="$1"

    if command_exists node; then
        node -e '
const fs = require("fs");
try {
    const d = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    const name = (d.name || "Untitled").replace(/\|/g, "-").replace(/,/g, " ");
    const id = d.id || "unknown";
    const active = d.active ? "Active" : "Inactive";
    const nodes = Array.isArray(d.nodes) ? d.nodes.length : 0;
    console.log([name, id, active, nodes].join("|"));
} catch(e) { process.exit(1); }
' "$file" 2>/dev/null
    elif command_exists python3; then
        python3 -c "
import json, sys
try:
    with open(sys.argv[1], 'r') as f:
        d = json.load(f)
    name = (d.get('name') or 'Untitled').replace('|', '-').replace(',', ' ')
    wid = d.get('id') or 'unknown'
    active = 'Active' if d.get('active') else 'Inactive'
    nodes = len(d.get('nodes') or [])
    print(f'{name}|{wid}|{active}|{nodes}')
except: sys.exit(1)
" "$file" 2>/dev/null
    else
        # sed/awk fallback — works on busybox/Alpine (no grep -oP)
        local wf_name wf_id wf_active="Unknown"
        wf_id=$(sed -n 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$file" 2>/dev/null | head -1)
        wf_name=$(sed -n 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$file" 2>/dev/null | head -1)
        # Sanitize pipe/comma from name
        wf_name=$(echo "$wf_name" | sed 's/|/-/g; s/,/ /g')
        if grep -q '"active".*true' "$file" 2>/dev/null; then
            wf_active="Active"
        elif grep -q '"active".*false' "$file" 2>/dev/null; then
            wf_active="Inactive"
        fi
        echo "${wf_name:-Untitled}|${wf_id:-unknown}|${wf_active}|0"
    fi
}

# ═══════════════════════════════════════════════════════════
# JSON Loading and Writing
# ═══════════════════════════════════════════════════════════

# Read and validate a .n8n file — outputs raw JSON to stdout
# Args: $1=file path
# Returns: 0 on success, 1 on invalid JSON
wf_load_json() {
    local file="$1"

    if [ ! -f "$file" ]; then
        log ERROR "[WF_LOAD] File not found: $file"
        return 1
    fi

    # Validate JSON
    if command_exists node; then
        node -e 'try { JSON.parse(require("fs").readFileSync(process.argv[1],"utf8")); } catch(e) { process.exit(1); }' "$file" 2>/dev/null || {
            log ERROR "[WF_LOAD] Invalid JSON: $file"
            return 1
        }
    elif command_exists python3; then
        python3 -c "import json,sys; json.load(open(sys.argv[1]))" "$file" 2>/dev/null || {
            log ERROR "[WF_LOAD] Invalid JSON: $file"
            return 1
        }
    fi

    cat "$file"
    return 0
}

# Write JSON content to a .n8n file (with backup)
# Args: $1=file path, stdin=JSON content
# Returns: 0 on success
wf_write_json() {
    local file="$1"
    local content
    content=$(cat)

    if [ -z "$content" ]; then
        log ERROR "[WF_WRITE] Empty content — refusing to write: $file"
        return 1
    fi

    # Dry-run check
    if [[ "${ARG_DRY_RUN:-}" == "1" ]]; then
        log DRYRUN "Would write to: $file"
        return 0
    fi

    # Backup original
    if [ -f "$file" ]; then
        cp "$file" "${file}.bak" 2>/dev/null || true
    fi

    echo "$content" > "$file"
    log DEBUG "[WF_WRITE] Written: $file"
    return 0
}

# ═══════════════════════════════════════════════════════════
# JSON Field Access (top-level fields)
# ═══════════════════════════════════════════════════════════

# Extract a top-level JSON field from a .n8n file
# Args: $1=file path, $2=field name
# Output: field value to stdout (JSON-encoded for objects/arrays)
wf_get_field() {
    local file="$1"
    local field="$2"

    if command_exists node; then
        node -e '
const fs = require("fs");
try {
    const d = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    const v = d[process.argv[2]];
    if (v === undefined) process.exit(1);
    console.log(typeof v === "object" ? JSON.stringify(v) : String(v));
} catch(e) { process.exit(1); }
' "$file" "$field" 2>/dev/null
    elif command_exists python3; then
        python3 -c "
import json, sys
try:
    with open(sys.argv[1]) as f: d = json.load(f)
    v = d.get(sys.argv[2])
    if v is None: sys.exit(1)
    print(json.dumps(v) if isinstance(v, (dict, list)) else str(v))
except: sys.exit(1)
" "$file" "$field" 2>/dev/null
    else
        log ERROR "[WF_FIELD] No JSON parser available (need node or python3)"
        return 1
    fi
}

# Set a top-level JSON field in a .n8n file
# Args: $1=file path, $2=field name, $3=value (JSON-encoded for objects/arrays, raw for strings/numbers/booleans)
# Returns: 0 on success
wf_set_field() {
    local file="$1"
    local field="$2"
    local value="$3"

    if [[ "${ARG_DRY_RUN:-}" == "1" ]]; then
        log DRYRUN "Would set $field in: $file"
        return 0
    fi

    if command_exists node; then
        node -e '
const fs = require("fs");
try {
    const file = process.argv[1];
    const field = process.argv[2];
    const rawVal = process.argv[3];
    const d = JSON.parse(fs.readFileSync(file, "utf8"));
    try { d[field] = JSON.parse(rawVal); } catch { d[field] = rawVal; }
    fs.writeFileSync(file, JSON.stringify(d, null, 2));
} catch(e) { console.error(e.message); process.exit(1); }
' "$file" "$field" "$value" 2>/dev/null
    elif command_exists python3; then
        python3 -c "
import json, sys
try:
    file, field, raw = sys.argv[1], sys.argv[2], sys.argv[3]
    with open(file) as f: d = json.load(f)
    try: d[field] = json.loads(raw)
    except: d[field] = raw
    with open(file, 'w') as f: json.dump(d, f, indent=2)
except Exception as e: print(f'Error: {e}', file=sys.stderr); sys.exit(1)
" "$file" "$field" "$value" 2>/dev/null
    else
        log ERROR "[WF_FIELD] No JSON parser available (need node or python3)"
        return 1
    fi
}

# ═══════════════════════════════════════════════════════════
# Interactive Selection
# ═══════════════════════════════════════════════════════════

# Interactive workflow file picker
# Args: $1=pipe-delimited workflow data (from wf_discover_files)
#        $2=context label
# Output: selected file paths to stdout (newline-separated)
# Returns: 0 if selected, 1 if cancelled
wf_select_interactive() {
    local workflow_data="$1"
    local context="${2:-select}"

    if [ -z "$workflow_data" ]; then
        log WARN "No workflow files available for selection"
        return 1
    fi

    local total_count
    total_count=$(echo "$workflow_data" | wc -l | xargs)

    # Build display items
    local display_items=()
    local file_map=()

    while IFS='|' read -r wf_path wf_name wf_id wf_active wf_nodes; do
        [ -z "$wf_path" ] && continue
        local status_icon="⏸"
        [ "$wf_active" = "Active" ] && status_icon="🟢"
        local basename_file
        basename_file=$(basename "$wf_path")
        display_items+=("${basename_file} — ${wf_name} (${status_icon} ${wf_active}, ${wf_nodes} nodes)")
        file_map+=("$wf_path")
    done <<< "$workflow_data"

    if [ ${#display_items[@]} -eq 0 ]; then
        log WARN "No workflows to select"
        return 1
    fi

    # Multi-select
    local selected
    selected=$(ui_multi_select "Select workflows to $context" "${display_items[@]}")

    if [ -z "$selected" ]; then
        log WARN "No workflows selected"
        return 1
    fi

    # Map display strings back to file paths
    while IFS= read -r line; do
        local sel_file
        sel_file=$(echo "$line" | cut -d' ' -f1)
        # Find matching path
        for i in "${!display_items[@]}"; do
            local item_file
            item_file=$(echo "${display_items[$i]}" | cut -d' ' -f1)
            if [ "$sel_file" = "$item_file" ]; then
                echo "${file_map[$i]}"
                break
            fi
        done
    done <<< "$selected"

    return 0
}

