# Interactive workflow picker — shows styled table + multi-select
# Args: $1=pipe-delimited workflow data (from list_container_workflows or list_backup_workflows)
#        $2=context label ("backup" or "restore")
# Output: comma-separated workflow IDs to stdout
# Returns: 0 if workflows selected, 1 if cancelled/empty
_wf_trim_cell() {
    local value="$1"
    local width="$2"
    if [ "${#value}" -le "$width" ]; then
        printf '%s' "$value"
        return 0
    fi
    if [ "$width" -le 1 ]; then
        printf '%s' "${value:0:1}"
        return 0
    fi
    printf '%s…' "${value:0:$((width - 1))}"
}

_render_workflow_discovery_table() {
    local workflow_data="$1"

    # Keep existing non-gum fallback behavior.
    if ! $HAS_GUM; then
        local csv_header="ID,Name,Status,Updated,Nodes"
        local csv_data="$csv_header"
        while IFS='|' read -r wf_id wf_name wf_active wf_updated wf_nodes; do
            [ -z "$wf_id" ] && continue
            wf_name="${wf_name//,/ }"
            csv_data="${csv_data}
${wf_id},${wf_name},${wf_active},${wf_updated},${wf_nodes}"
        done <<< "$workflow_data"
        echo "$csv_data" | ui_table
        return 0
    fi

    local term_w
    term_w=$(tput cols 2>/dev/null || echo 120)
    [ "$term_w" -gt 140 ] && term_w=140
    [ "$term_w" -lt 90 ] && term_w=90

    local cw_id=24 cw_status=10 cw_updated=19 cw_nodes=5
    local cw_name=$((term_w - (cw_id + cw_status + cw_updated + cw_nodes) - 16))
    [ "$cw_name" -lt 20 ] && cw_name=20
    [ "$cw_name" -gt 72 ] && cw_name=72

    local _tb=$'\033[38;5;'"$THEME_BORDER"'m'
    local _th=$'\033[1;38;5;'"$THEME_INFO"'m'
    local _tc=$'\033[38;5;'"$THEME_TEXT"'m'
    local _ts_active=$'\033[1;38;5;'"$THEME_SUCCESS"'m'
    local _ts_inactive=$'\033[1;38;5;'"$THEME_INFO"'m'
    local _tr=$'\033[0m'

    local _hl_id _hl_name _hl_status _hl_updated _hl_nodes
    _hl_id=$(printf '─%.0s' $(seq 1 $((cw_id + 2))))
    _hl_name=$(printf '─%.0s' $(seq 1 $((cw_name + 2))))
    _hl_status=$(printf '─%.0s' $(seq 1 $((cw_status + 2))))
    _hl_updated=$(printf '─%.0s' $(seq 1 $((cw_updated + 2))))
    _hl_nodes=$(printf '─%.0s' $(seq 1 $((cw_nodes + 2))))

    {
        printf '%s╭%s┬%s┬%s┬%s┬%s╮%s\n' "$_tb" "$_hl_id" "$_hl_name" "$_hl_status" "$_hl_updated" "$_hl_nodes" "$_tr"
        printf '%s│ %s%-*s %s│ %s%-*s %s│ %s%-*s %s│ %s%-*s %s│ %s%-*s %s│%s\n' \
            "$_tb" "$_th" "$cw_id" "ID" \
            "$_tb" "$_th" "$cw_name" "Name" \
            "$_tb" "$_th" "$cw_status" "Status" \
            "$_tb" "$_th" "$cw_updated" "Updated" \
            "$_tb" "$_th" "$cw_nodes" "Nodes" "$_tb" "$_tr"
        printf '%s├%s┼%s┼%s┼%s┼%s┤%s\n' "$_tb" "$_hl_id" "$_hl_name" "$_hl_status" "$_hl_updated" "$_hl_nodes" "$_tr"

        while IFS='|' read -r wf_id wf_name wf_active wf_updated wf_nodes; do
            [ -z "$wf_id" ] && continue
            wf_name="${wf_name//,/ }"
            wf_id=$(_wf_trim_cell "$wf_id" "$cw_id")
            wf_name=$(_wf_trim_cell "$wf_name" "$cw_name")
            wf_updated=$(_wf_trim_cell "$wf_updated" "$cw_updated")
            wf_nodes=$(_wf_trim_cell "$wf_nodes" "$cw_nodes")

            local status_color="$_ts_inactive"
            if [ "$wf_active" = "Active" ]; then
                status_color="$_ts_active"
            fi
            wf_active=$(_wf_trim_cell "$wf_active" "$cw_status")

            printf '%s│ %s%-*s %s│ %s%-*s %s│ %s%-*s %s│ %s%-*s %s│ %s%-*s %s│%s\n' \
                "$_tb" "$_tc" "$cw_id" "$wf_id" \
                "$_tb" "$_tc" "$cw_name" "$wf_name" \
                "$_tb" "$status_color" "$cw_status" "$wf_active" \
                "$_tb" "$_tc" "$cw_updated" "$wf_updated" \
                "$_tb" "$_tc" "$cw_nodes" "$wf_nodes" "$_tb" "$_tr"
        done <<< "$workflow_data"

        printf '%s╰%s┴%s┴%s┴%s┴%s╯%s\n' "$_tb" "$_hl_id" "$_hl_name" "$_hl_status" "$_hl_updated" "$_hl_nodes" "$_tr"
    } >&2
