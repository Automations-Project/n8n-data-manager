# Write — Multi-line text editor (gum write)
# ═══════════════════════════════════════════════════════════

# Multi-line text input — returns the entered text
# Usage: text=$(ui_write "Enter description" ["default text"] [char_limit])
ui_write() {
    local title="${1:-Enter text}"
    local default_val="${2:-}"
    local char_limit="${3:-0}"

    if $HAS_GUM; then
        local flags=(
            --header "$title"
            --header.foreground $THEME_INFO
            --cursor.foreground $THEME_CURSOR
            --prompt.foreground $THEME_PRIMARY
            --placeholder "Type here... (Ctrl+D to finish)"
            --char-counter.foreground $THEME_TEXT_DIM
            --width 60
            --height 8
        )
        [ -n "$default_val" ] && flags+=(--value "$default_val")
        [ "$char_limit" -gt 0 ] 2>/dev/null && flags+=(--char-limit "$char_limit")
        gum write "${flags[@]}"
    else
        echo "$title (Ctrl+D to finish):" >&2
        if [ -n "$default_val" ]; then
            echo "  Default: $default_val" >&2
        fi
        local result=""
        while IFS= read -r line; do
            result="${result:+$result
}$line"
        done
        result="${result:-$default_val}"
        echo "$result"
    fi
}

