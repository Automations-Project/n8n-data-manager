        scope_line=$(gum style --foreground "$THEME_TEXT" '  read/write your backup repository on your behalf.')

        local scope_detail
        scope_detail=$(gum join --horizontal \
            "$(gum style --foreground "$THEME_TEXT_DIM" '  Required scope:')" " " \
            "$(gum style --foreground "$THEME_PRIMARY" --bold 'repo')" " " \
            "$(gum style --foreground "$THEME_TEXT_DIM" '(full access to private repositories)')")

        local body
        body=$(printf '%s\n%s\n%s' "$info_line" "$scope_line" "$scope_detail")

        gum style --border rounded --border-foreground "$THEME_BORDER" \
            --padding "0 2" --margin "0 0" "$body" >&2
    else
        echo "  ℹ A GitHub Personal Access Token (PAT) lets n8n-manager" >&2
        echo "    read/write your backup repository on your behalf." >&2
        echo "    Required scope: repo (full access to private repos)" >&2
    fi
    echo "" >&2
}

