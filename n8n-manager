# ═══════════════════════════════════════════════════════════
# Core API — low-level authenticated request wrapper
# ═══════════════════════════════════════════════════════════

# Generic GitHub API GET request
# Args: $1=token $2=endpoint (e.g. "/user") [$3=accept_header]
# Returns: JSON body on stdout, HTTP code on fd3
_github_api() {
    local token="$1"
    local endpoint="$2"
    local accept="${3:-application/vnd.github.v3+json}"
    local url="https://api.github.com${endpoint}"

    curl -s -w "\n%{http_code}" \
        -H "Authorization: token $token" \
        -H "Accept: $accept" \
        "$url" 2>/dev/null
}

# Parse HTTP code from _github_api response (last line)
_github_http_code() {
    echo "$1" | tail -1
}

# Parse JSON body from _github_api response (all but last line)
_github_body() {
    echo "$1" | sed '$d'
}

# ═══════════════════════════════════════════════════════════
# User — Fetch authenticated user info
# ═══════════════════════════════════════════════════════════

# Get authenticated user's login name from token
# Args: $1=token
# Output: username on stdout
# Returns: 0=success 1=failure
github_get_username() {
    local token="$1"
    local response
    response=$(_github_api "$token" "/user")
    local code
    code=$(_github_http_code "$response")

    if [ "$code" != "200" ]; then
        log DEBUG "[GITHUB_API] /user failed (HTTP $code)"
        return 1
    fi

    local body
    body=$(_github_body "$response")

    # Extract login field — try node, python, grep fallbacks
    local username=""
    if command -v node >/dev/null 2>&1; then
        username=$(echo "$body" | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{console.log(JSON.parse(d).login)}catch(e){}})" 2>/dev/null)
    elif command -v python3 >/dev/null 2>&1; then
        username=$(echo "$body" | python3 -c "import sys,json;print(json.load(sys.stdin).get('login',''))" 2>/dev/null)
    else
        username=$(echo "$body" | grep -o '"login"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"login"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')
    fi

    if [ -z "$username" ]; then
        return 1
    fi

    echo "$username"
    return 0
}

# Get authenticated user's full profile (login, name, email)
# Args: $1=token
# Output: pipe-delimited: login|name|email
github_get_user_info() {
    local token="$1"
    local response
    response=$(_github_api "$token" "/user")
    local code
    code=$(_github_http_code "$response")

    if [ "$code" != "200" ]; then
        return 1
    fi

    local body
    body=$(_github_body "$response")

    if command -v node >/dev/null 2>&1; then
        echo "$body" | node -e "
            let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{
                try{const u=JSON.parse(d);console.log([u.login||'',u.name||'',u.email||''].join('|'))}catch(e){}
            })" 2>/dev/null
    elif command -v python3 >/dev/null 2>&1; then
        echo "$body" | python3 -c "
import sys,json
u=json.load(sys.stdin)
print('|'.join([u.get('login',''),u.get('name',''),u.get('email','')]))" 2>/dev/null
    else
        local login
        login=$(echo "$body" | grep -o '"login"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"\([^"]*\)".*/\1/')
        echo "${login}||"
    fi
    return 0
}

# ═══════════════════════════════════════════════════════════
# Repositories — List and create
# ═══════════════════════════════════════════════════════════

# List user's repos (owned, sorted by recently pushed)
# Args: $1=token [$2=per_page] [$3=type: all|owner|member]
# Output: pipe-delimited lines: full_name|description|private|updated_at
github_list_repos() {
    local token="$1"
    local per_page="${2:-50}"
    local repo_type="${3:-owner}"

    local response
    response=$(_github_api "$token" "/user/repos?type=${repo_type}&sort=pushed&direction=desc&per_page=${per_page}")
    local code
    code=$(_github_http_code "$response")

    if [ "$code" != "200" ]; then
        log DEBUG "[GITHUB_API] /user/repos failed (HTTP $code)"
        return 1
    fi

    local body
    body=$(_github_body "$response")

    if command -v node >/dev/null 2>&1; then
        echo "$body" | node -e "
            let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{
                try{
                    const repos=JSON.parse(d);
                    if(!Array.isArray(repos)){process.exit(1)}
                    repos.forEach(r=>{
                        const name=r.full_name||'';
                        const desc=(r.description||'').replace(/\|/g,'-').replace(/,/g,' ').substring(0,60);
                        const priv=r.private?'Private':'Public';
                        const updated=(r.pushed_at||r.updated_at||'').substring(0,10);
                        console.log([name,desc,priv,updated].join('|'));
                    });
                }catch(e){process.exit(1)}
            })" 2>/dev/null
    elif command -v python3 >/dev/null 2>&1; then
        echo "$body" | python3 -c "
import sys,json
repos=json.load(sys.stdin)
for r in repos:
    name=r.get('full_name','')
    desc=(r.get('description','') or '')[:60].replace('|','-').replace(',', ' ')
    priv='Private' if r.get('private') else 'Public'
    updated=(r.get('pushed_at','') or r.get('updated_at',''))[:10]
    print(f'{name}|{desc}|{priv}|{updated}')" 2>/dev/null
    else
        # grep fallback — extract full_name fields
        echo "$body" | grep -o '"full_name"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"\([^"]*\)".*/\1|||/'
    fi
    return 0
}

# Check if a specific repo exists and is accessible
# Args: $1=token $2=owner/repo
# Returns: 0=exists 1=not found 2=error
github_repo_exists() {
    local token="$1"
    local repo="$2"

    local response
    response=$(_github_api "$token" "/repos/$repo")
    local code
    code=$(_github_http_code "$response")

    case "$code" in
        200) return 0 ;;
        404) return 1 ;;
        *)   return 2 ;;
    esac
}

# Create a new private repository
# Args: $1=token $2=repo_name [$3=description] [$4=private (true/false)]
# Output: full_name on stdout
github_create_repo() {
    local token="$1"
    local repo_name="$2"
    local description="${3:-n8n backup repository managed by n8n-manager}"
    local is_private="${4:-true}"

    local payload
    payload=$(printf '{"name":"%s","description":"%s","private":%s,"auto_init":true}' \
        "$repo_name" "$description" "$is_private")

    local response
    response=$(curl -s -w "\n%{http_code}" \
        -X POST \
        -H "Authorization: token $token" \
        -H "Accept: application/vnd.github.v3+json" \
        -d "$payload" \
        "https://api.github.com/user/repos" 2>/dev/null)

    local code
    code=$(_github_http_code "$response")

    if [ "$code" != "201" ]; then
        log DEBUG "[GITHUB_API] create repo failed (HTTP $code)"
        return 1
    fi

    local body
    body=$(_github_body "$response")

    # Extract full_name
    if command -v node >/dev/null 2>&1; then
        echo "$body" | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{console.log(JSON.parse(d).full_name)}catch(e){}})" 2>/dev/null
    else
        echo "$body" | grep -o '"full_name"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"\([^"]*\)".*/\1/'
    fi
    return 0
}

# ═══════════════════════════════════════════════════════════
# Branches — List repo branches
# ═══════════════════════════════════════════════════════════

# List branches for a repository
# Args: $1=token $2=owner/repo [$3=per_page]
# Output: one branch name per line
github_list_branches() {
    local token="$1"
    local repo="$2"
    local per_page="${3:-30}"

    local response
    response=$(_github_api "$token" "/repos/$repo/branches?per_page=${per_page}")
    local code
    code=$(_github_http_code "$response")

    if [ "$code" != "200" ]; then
        log DEBUG "[GITHUB_API] /repos/$repo/branches failed (HTTP $code)"
        return 1
    fi

    local body
    body=$(_github_body "$response")

    if command -v node >/dev/null 2>&1; then
        echo "$body" | node -e "
            let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{
                try{JSON.parse(d).forEach(b=>console.log(b.name))}catch(e){}
            })" 2>/dev/null
    elif command -v python3 >/dev/null 2>&1; then
        echo "$body" | python3 -c "import sys,json;[print(b['name']) for b in json.load(sys.stdin)]" 2>/dev/null
    else
        echo "$body" | grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"\([^"]*\)".*/\1/'
    fi
    return 0
}

# Get default branch name for a repo
# Args: $1=token $2=owner/repo
# Output: branch name on stdout
github_get_default_branch() {
    local token="$1"
    local repo="$2"

    local response
    response=$(_github_api "$token" "/repos/$repo")
    local code
    code=$(_github_http_code "$response")

    if [ "$code" != "200" ]; then
        echo "main"
        return 1
    fi

    local body
    body=$(_github_body "$response")

    local branch=""
    if command -v node >/dev/null 2>&1; then
        branch=$(echo "$body" | node -e "let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{console.log(JSON.parse(d).default_branch||'main')}catch(e){console.log('main')}})" 2>/dev/null)
    else
        branch=$(echo "$body" | grep -o '"default_branch"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"\([^"]*\)".*/\1/')
    fi

    echo "${branch:-main}"
    return 0
}

