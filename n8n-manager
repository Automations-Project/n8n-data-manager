_sc_export_collect_existing_ids() {
    local repo_root="$1"
    local resource_dir="$2"

    if [ ! -d "$repo_root" ]; then
        echo ""
        return 0
    fi

    find "$repo_root" -path "$repo_root/.git" -prune -o -type f -path "*/$resource_dir/*.json" -print 2>/dev/null | \
        xargs -r -n1 basename 2>/dev/null | \
        sed 's/\.json$//' | sort -u | paste -sd, -
}

_sc_export_filter_dir_by_allowed_ids() {
    local dir="$1"
    local ids_csv="$2"
    local label="$3"
    [ -d "$dir" ] || return 0
    [ -n "$ids_csv" ] || return 0

    local ids_file
    ids_file=$(mktemp -t n8n-sc-ids-XXXXXXXXXX)
    _sc_export_split_csv_ids "$ids_csv" | sort -u > "$ids_file"

    local kept=0 removed=0
    shopt -s nullglob
    local f
    for f in "$dir"/*.json; do
        local id
        id=$(basename "$f" .json)
        if grep -Fxq "$id" "$ids_file"; then
            kept=$((kept + 1))
        else
            rm -f "$f"
            removed=$((removed + 1))
        fi
    done
    shopt -u nullglob
    rm -f "$ids_file"

    log INFO "[SC-EXPORT] filtered $label by explicit IDs: kept=$kept removed=$removed"
}

_sc_export_filter_dir_only_new() {
