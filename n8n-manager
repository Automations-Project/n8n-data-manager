# ═══════════════════════════════════════════════════════════
# Core UI Primitives
# ═══════════════════════════════════════════════════════════

# Display a styled banner/header with double border
ui_banner() {
    if $HAS_GUM; then
        local content
        content=$(printf '%s\n' "$@")
        gum style \
            --foreground $THEME_PRIMARY --bold \
            --border double --border-foreground $THEME_PRIMARY \
            --align center --width 56 --padding "1 4" \
            "$content" >&2
    else
        echo "" >&2
        echo "╔══════════════════════════════════════════════╗" >&2
        for line in "$@"; do printf "║  %-44s║\n" "$line" >&2; done
        echo "╚══════════════════════════════════════════════╝" >&2
    fi
}

# Section header — lighter than banner, used between steps
ui_header() {
    if $HAS_GUM; then
        gum style \
            --foreground $THEME_HEADER --bold \
            --border normal --border-foreground $THEME_BORDER \
            --padding "0 2" --margin "1 0" \
            "$*" >&2
    else
        echo "" >&2
        echo "── $* ──" >&2
    fi
}

# Styled inline label with value
ui_label() {
    local label="$1"
    local value="$2"
    if $HAS_GUM; then
        local styled_label styled_value
        styled_label=$(gum style --foreground $THEME_TEXT_DIM "$label")
        styled_value=$(gum style --foreground $THEME_TEXT --bold "$value")
        gum join --horizontal "$styled_label" " " "$styled_value" >&2
    else
        echo "  $label $value" >&2
    fi
}

# Interactive choice menu — returns the selected option string
ui_choose() {
    local prompt="$1"; shift
    if $HAS_GUM; then
        gum choose \
            --header "$prompt" \
            --header.foreground $THEME_INFO \
            --cursor.foreground $THEME_CURSOR \
            --selected.foreground $THEME_PRIMARY \
            --item.foreground $THEME_TEXT \
            "$@"
    else
        echo "$prompt" >&2
        local i=1
        for opt in "$@"; do echo "  $i) $opt" >&2; i=$((i+1)); done
        printf "Select [1-%d]: " "$(($i-1))" >&2
        local choice
        read -r choice
        local j=1
        for opt in "$@"; do
            if [ "$j" = "$choice" ]; then echo "$opt"; return 0; fi
            j=$((j+1))
        done
        local first="$1"
        echo "$first"
    fi
}

# Multi-select menu — returns newline-separated selected items
# Usage: selected=$(ui_multi_select "Pick workflows" "item1" "item2" "item3")
# Supports --selected="item" to pre-select items, --limit=N to cap selections
ui_multi_select() {
    local prompt="$1"; shift
    if $HAS_GUM; then
        if gum filter --help 2>&1 | grep -q -- "--no-limit"; then
            # Some gum builds do not support --header on filter.
            [ -n "$prompt" ] && gum style --foreground $THEME_INFO --bold "◌ $prompt" >&2
            printf '%s\n' "$@" | gum filter --no-limit \
                --placeholder "Type to search..." \
                --indicator "▸" \
                --indicator.foreground $THEME_PRIMARY \
                --match.foreground $THEME_TEXT \
                --prompt.foreground $THEME_PRIMARY \
                --text.foreground $THEME_TEXT \
                --cursor-text.foreground $THEME_CURSOR
        else
            gum choose --no-limit \
                --header "$prompt" \
                --header.foreground $THEME_INFO \
                --cursor.foreground $THEME_CURSOR \
                --selected.foreground $THEME_SUCCESS --selected.bold \
                --item.foreground $THEME_TEXT \
                --cursor-prefix "[ ] " \
                --selected-prefix "[✔] " \
                --unselected-prefix "[ ] " \
                "$@"
        fi
    else
        echo "$prompt" >&2
        local items=("$@")
        local i=1
        for opt in "${items[@]}"; do echo "  $i) $opt" >&2; i=$((i+1)); done
        echo "" >&2
        printf "Enter numbers (comma-separated, or 'all'): " >&2
        local choice
        read -r choice
        if [[ "${choice,,}" == "all" ]]; then
            printf '%s\n' "${items[@]}"
        else
            IFS=',' read -ra selections <<< "$choice"
            for sel in "${selections[@]}"; do
                sel=$(echo "$sel" | xargs)
                if [[ "$sel" =~ ^[0-9]+$ ]] && [ "$sel" -ge 1 ] && [ "$sel" -le "${#items[@]}" ]; then
                    echo "${items[$((sel-1))]}"
                fi
            done
        fi
    fi
}

# Confirmation prompt — returns 0 (yes) or 1 (no)
ui_confirm() {
    local prompt="$1"
    local affirmative="${2:-Yes}"
    local negative="${3:-No}"
    if $HAS_GUM; then
        gum confirm \
            --prompt.foreground $THEME_INFO \
            --selected.background $THEME_PRIMARY \
            --selected.foreground $THEME_BG_TERTIARY \
            --unselected.foreground $THEME_TEXT_DIM \
            --affirmative "$affirmative" --negative "$negative" \
            "$prompt"
    else
        printf "%s (%s/%s): " "$prompt" "$affirmative" "$negative" >&2
        local answer
        read -r answer
        [[ "${answer,,}" == "yes" || "${answer,,}" == "y" ]]
    fi
}

# Text input — returns the entered value
ui_input() {
    local prompt="$1"
    local placeholder="${2:-}"
    local is_password="${3:-false}"

    local result=""
    if $HAS_GUM; then
        local flags=(
            --header "$prompt"
            --header.foreground $THEME_INFO
            --cursor.foreground $THEME_CURSOR
            --prompt.foreground $THEME_PRIMARY
            --width 50
        )
        if [ "$is_password" = "true" ]; then
            flags+=(--password)
            [ -n "$placeholder" ] && flags+=(--placeholder "$placeholder")
        else
            [ -n "$placeholder" ] && flags+=(--value "$placeholder")
        fi
        result=$(gum input "${flags[@]}")
        # Fall back to placeholder if user cleared the field
        result="${result:-$placeholder}"
        echo "$result"
    else
        if [ "$is_password" = "true" ]; then
            printf "%s: " "$prompt" >&2
            local answer
            read -r -s answer
            echo >&2
            echo "$answer"
        else
            printf "%s [%s]: " "$prompt" "$placeholder" >&2
            local answer
            read -r answer
            answer="${answer:-$placeholder}"
            echo "$answer"
        fi
    fi
}

# Fuzzy filter — pipe list to stdin, returns selected item
ui_filter() {
    local prompt="${1:-Filter...}"
    if $HAS_GUM; then
        gum filter \
            --placeholder "$prompt" \
            --indicator "▸" \
            --indicator.foreground $THEME_PRIMARY \
            --match.foreground $THEME_PRIMARY \
            --header.foreground $THEME_INFO \
            --prompt.foreground $THEME_PRIMARY \
            --text.foreground $THEME_TEXT \
            --cursor-text.foreground $THEME_CURSOR
    else
        local items=()
        while IFS= read -r line; do items+=("$line"); done
        echo "$prompt" >&2
        local i=1
        for item in "${items[@]}"; do echo "  $i) $item" >&2; i=$((i+1)); done
        printf "Select [1-%d]: " "${#items[@]}" >&2
        local choice
        read -r choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#items[@]}" ]; then
            echo "${items[$((choice-1))]}"
        else
            echo "${items[0]}"
        fi
    fi
}

# Spinner — show animated spinner while command runs
ui_spin() {
    local title="$1"; shift
    if $HAS_GUM; then
        local spinner
        spinner="$(_ui_resolve_spinner)"
        gum spin \
            --spinner "$spinner" \
            --spinner.foreground $THEME_SPINNER_COLOR \
            --title.foreground $THEME_INFO \
            --title "$title" \
            -- "$@"
    else
        echo "⏳ $title" >&2
        "$@"
    fi
}

# Spinner with custom message — runs a function by name
ui_step() {
    local step_num="$1"
    local title="$2"
    shift 2
    if $HAS_GUM; then
        local spinner
        spinner="$(_ui_resolve_spinner)"
        local styled_step
        styled_step=$(gum style --foreground $THEME_PRIMARY --bold "[$step_num]")
        local styled_title
        styled_title=$(gum style --foreground $THEME_INFO "$title")
        gum join --horizontal "$styled_step" " " "$styled_title" >&2
        gum spin \
            --spinner "$spinner" \
            --spinner.foreground $THEME_SPINNER_COLOR \
            --title "  Working..." \
            -- "$@"
    else
        echo "[$step_num] $title" >&2
        "$@"
    fi
}

