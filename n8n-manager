# Parse workflow metadata using Node.js on the host
_parse_workflows_json_node() {
    local json_file="$1"

    node -e '
const fs = require("fs");
try {
    let data = JSON.parse(fs.readFileSync("'"$json_file"'", "utf8"));
    if (!Array.isArray(data)) data = [data];
    data.forEach(w => {
        const id = w.id || "unknown";
        const name = (w.name || "Untitled").replace(/\|/g, "-");
        const active = w.active ? "Active" : "Inactive";
        const updated = (w.updatedAt || w.createdAt || "").substring(0, 19).replace("T", " ");
        const nodes = Array.isArray(w.nodes) ? w.nodes.length : 0;
        console.log([id, name, active, updated, nodes].join("|"));
    });
} catch(e) { console.error(e.message); process.exit(1); }
' 2>/dev/null
}

# Parse workflow metadata using grep/sed (fallback when no node/python)
_parse_workflows_json_grep() {
    local json_file="$1"

    # Basic grep-based extraction — less reliable but works without node/python
    # Extracts id and name pairs from the JSON array
    local ids names
    ids=$(grep -oP '"id"\s*:\s*"[^"]*"' "$json_file" 2>/dev/null | sed 's/"id"\s*:\s*"//;s/"$//' || true)
    names=$(grep -oP '"name"\s*:\s*"[^"]*"' "$json_file" 2>/dev/null | sed 's/"name"\s*:\s*"//;s/"$//' || true)

    if [ -z "$ids" ]; then return 1; fi

    # Merge into pipe-delimited output
    paste -d'|' <(echo "$ids") <(echo "$names") | while IFS='|' read -r wf_id wf_name; do
        echo "${wf_id}|${wf_name:-Untitled}|Unknown||0"
    done
}

# Parse a single workflow JSON file for metadata
_parse_workflow_metadata_basic() {
    local json_file="$1"

    local wf_id wf_name wf_active
    wf_id=$(grep -oP '"id"\s*:\s*"[^"]*"' "$json_file" 2>/dev/null | head -1 | sed 's/"id"\s*:\s*"//;s/"$//')
    wf_name=$(grep -oP '"name"\s*:\s*"[^"]*"' "$json_file" 2>/dev/null | head -1 | sed 's/"name"\s*:\s*"//;s/"$//')
    wf_active="Unknown"
    if grep -q '"active"\s*:\s*true' "$json_file" 2>/dev/null; then
        wf_active="Active"
    elif grep -q '"active"\s*:\s*false' "$json_file" 2>/dev/null; then
        wf_active="Inactive"
    fi

    # Fallback ID from filename if not found in JSON
    if [ -z "$wf_id" ]; then
        wf_id=$(basename "$json_file" .json)
    fi

    echo "${wf_id}|${wf_name:-Untitled}|${wf_active}||0"
}

# :command.command_functions
