# Excalidraw Upload — Shareable Link Generation
# ═══════════════════════════════════════════════════════════

# Upload an Excalidraw file and return a shareable link
# Args: $1=excalidraw file path
# Output: shareable URL to stdout
# Returns: 0 on success, 1 on failure
wf_upload_excalidraw() {
    local file="$1"

    if ! command_exists node; then
        log WARN "Node.js required for Excalidraw upload"
        return 1
    fi

    if [ ! -f "$file" ]; then
        log ERROR "Excalidraw file not found: $file"
        return 1
    fi

    log INFO "Uploading to Excalidraw..."

    local tmp_upload_script
    tmp_upload_script=$(mktemp /tmp/wf_upload_XXXXXX.mjs)

    cat > "$tmp_upload_script" << 'UPLOADSCRIPT'
import { readFileSync } from "fs";
import { webcrypto } from "crypto";

const subtle = webcrypto.subtle;

async function main() {
    const filePath = process.argv[2];
    const content = readFileSync(filePath, "utf8");
    const data = new TextEncoder().encode(content);

    // Generate AES-GCM 128-bit key
    const key = await subtle.generateKey(
        { name: "AES-GCM", length: 128 },
        true,
        ["encrypt", "decrypt"]
    );

    // Encrypt (iv=zeros since key is single-use)
    const iv = new Uint8Array(12);
    const encrypted = await subtle.encrypt(
        { name: "AES-GCM", iv },
        key,
        data
    );

    // Upload encrypted blob
    const response = await fetch("https://json.excalidraw.com/api/v2/post/", {
        method: "POST",
        body: new Uint8Array(encrypted),
    });

    if (!response.ok) {
        console.error(`Upload failed: ${response.status} ${response.statusText}`);
        process.exit(1);
    }

    const result = await response.json();
    const docId = result.id;

    if (!docId) {
        console.error("No document ID in response");
        process.exit(1);
    }

    // Export key as JWK to get the base64 k value
    const jwk = await subtle.exportKey("jwk", key);
    const keyStr = jwk.k;

    // Build shareable URL
    const url = `https://excalidraw.com/#json=${docId},${keyStr}`;
    console.log(url);
}

main().catch(e => { console.error(e.message); process.exit(1); });
UPLOADSCRIPT

    local url
    url=$(node "$tmp_upload_script" "$file" 2>/dev/null)
    local exit_code=$?

    rm -f "$tmp_upload_script" 2>/dev/null

    if [ $exit_code -ne 0 ] || [ -z "$url" ]; then
        log WARN "Excalidraw upload failed — file saved locally"
        return 1
    fi

    echo "$url"
    return 0
}

