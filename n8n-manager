_sc_export_collect_linked_credential_ids() {
    local workflows_dir="$1"
    [ -d "$workflows_dir" ] || {
        echo ""
        return 0
    }

    if command_exists python3; then
        local linked_csv
        linked_csv=$(python3 - "$workflows_dir" <<'PY'
import json
import sys
from pathlib import Path

workflow_dir = Path(sys.argv[1])
cred_ids = set()

for wf_file in workflow_dir.glob("*.json"):
    try:
        payload = json.loads(wf_file.read_text(encoding="utf-8"))
    except Exception:
        continue

    if isinstance(payload, list):
        workflows = payload
    elif isinstance(payload, dict) and isinstance(payload.get("workflows"), list):
        workflows = payload["workflows"]
    else:
        workflows = [payload]

    for workflow in workflows:
        if not isinstance(workflow, dict):
            continue
        nodes = workflow.get("nodes")
        if not isinstance(nodes, list):
            continue
        for node in nodes:
            if not isinstance(node, dict):
                continue
            credentials = node.get("credentials")
            if not isinstance(credentials, dict):
                continue
            for cred_info in credentials.values():
                if not isinstance(cred_info, dict):
                    continue
                cred_id = cred_info.get("id")
                if cred_id is None:
                    continue
                cred_id = str(cred_id).strip()
                if cred_id:
                    cred_ids.add(cred_id)

print(",".join(sorted(cred_ids)))
PY
)
        if [ $? -eq 0 ]; then
            echo "$linked_csv"
            return 0
        fi
    fi

    local linked_space=""
    shopt -s nullglob
    local wf_file
    for wf_file in "$workflows_dir"/*.json; do
        local discovered
        discovered=$(discover_linked_credentials "$wf_file" 2>/dev/null || true)
        [ -n "$discovered" ] && linked_space="$linked_space $discovered"
    done
    shopt -u nullglob

    _sc_export_space_ids_to_csv "$linked_space"
