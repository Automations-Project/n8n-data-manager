_sc_export_split_csv_ids() {
    local csv="$1"
    printf '%s' "$csv" | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | sed '/^$/d'
}

_sc_export_is_enabled() {
    local v="$1"
    [[ "$v" == "1" || "$v" == "true" ]]
}

_sc_export_csv_ids_to_space() {
    local csv="$1"
    _sc_export_split_csv_ids "$csv" | tr '\n' ' ' | xargs
}

_sc_export_space_ids_to_csv() {
    local ids_space="$1"
    printf '%s' "$ids_space" | tr ' ' '\n' | sed '/^$/d' | sort -u | paste -sd, -
}

_sc_export_merge_csv_ids() {
    local a="$1"
    local b="$2"
    {
        _sc_export_split_csv_ids "$a"
