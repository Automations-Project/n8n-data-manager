      local operation
      operation=$(ui_choose "What would you like to do?" \
          "View current settings" \
          "Update a setting" \
          "Enable MCP access" \
          "Disable MCP access")

      case "$operation" in
          "View"*)
              # Show settings and exit
              ui_header "Settings: $(basename "${files_to_process[0]}")"
              local settings
              settings=$(wf_list_settings "${files_to_process[0]}")
