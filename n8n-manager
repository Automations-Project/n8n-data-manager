set -Eeuo pipefail
IFS=$'\n\t'

# --- ANSI Color Codes (fallback when gum is not available) ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
GRAY='\033[0;90m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# --- PAT Redaction Filter (D-06) ---
# Scrubs sensitive credential patterns before any log output.
# Called by log() on every message. Uses sed -E pipeline.
# Patterns: ghp_/gho_/github_pat_/Bearer/https-with-token
_log_redact() {
    local _msg="$1"
    printf '%s' "$_msg" | sed -E \
        -e 's|https://[^/@]*@github\.com|https://***@github.com|g' \
        -e 's|Bearer [A-Za-z0-9_-]+|Bearer ***|g' \
        -e 's|ghp_[A-Za-z0-9]{36,}|ghp_***|g' \
        -e 's|gho_[A-Za-z0-9]{36,}|gho_***|g' \
        -e 's|github_pat_[A-Za-z0-9_]+|github_pat_***|g'
}

# --- Map our log levels to gum log levels ---
# gum log supports: debug, info, warn, error, fatal
# Our custom levels: DEBUG, INFO, WARN, ERROR, SUCCESS, HEADER, DRYRUN
_gum_log_level() {
    case "$1" in
        DEBUG)   echo "debug" ;;
        INFO)    echo "info" ;;
        WARN)    echo "warn" ;;
        ERROR)   echo "error" ;;
        SUCCESS) echo "info" ;;
        HEADER)  echo "info" ;;
        DRYRUN)  echo "info" ;;
        *)       echo "info" ;;
    esac
}

# --- Logging Function ---
log() {
    local level="$1"
    shift
    local message="$*"
    message=$(_log_redact "$message")
    local timestamp
    timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    local prefix=""
    local icon=""
    local color=""
    local gum_fg=""

    case "$level" in
        DEBUG)
            if [[ "${ARG_VERBOSE:-}" != "1" ]]; then return; fi
            color="$GRAY"; prefix="[DEBUG]"; icon="·"; gum_fg="${THEME_TEXT_DIM:-243}"
            ;;
        INFO)
            color="$CYAN"; prefix="[INFO]"; icon="ℹ"; gum_fg="${THEME_INFO:-81}"
            ;;
        WARN)
            color="$YELLOW"; prefix="[WARN]"; icon="⚠"; gum_fg="${THEME_WARNING:-214}"
            ;;
        ERROR)
            color="$RED"; prefix="[ERROR]"; icon="✖"; gum_fg="${THEME_ERROR:-196}"
            ;;
        SUCCESS)
            color="$GREEN"; prefix="[SUCCESS]"; icon="✔"; gum_fg="${THEME_SUCCESS:-76}"
            ;;
        HEADER)
            color="$MAGENTA$BOLD"; prefix="━━▶"; icon=""; gum_fg="${THEME_HEADER:-204}"
            ;;
        DRYRUN)
            color="$BLUE"; prefix="[DRY-RUN]"; icon="⏭"; gum_fg="${THEME_INFO:-81}"
            ;;
        *)
            color="$NC"; prefix="[$level]"; icon=""; gum_fg="${THEME_TEXT:-255}"
            ;;
    esac

    if ${HAS_GUM:-false} && [ -n "$gum_fg" ]; then
        # Terminal output: gum style + gum join for polished display
        if [ "$level" = "HEADER" ]; then
            gum style --foreground "$gum_fg" --bold -- "$prefix $message" >&2
        else
            local styled_prefix styled_msg
            styled_prefix=$(gum style --foreground "$gum_fg" --bold -- "$icon $prefix")
            styled_msg=$(gum style --foreground "${THEME_TEXT:-255}" -- "$message")
            gum join --horizontal "$styled_prefix" " " "$styled_msg" >&2
        fi
    else
        echo -e "${color}${prefix}${NC} ${message}" >&2
    fi

    # Log to file if configured (uses gum log --file when available)
    if [ -n "${ARG_LOG_FILE:-}" ]; then
        if ${HAS_GUM:-false}; then
            local gum_level
            gum_level=$(_gum_log_level "$level")
            gum log --level "$gum_level" \
                --prefix "$prefix" \
                --time "2006-01-02 15:04:05" \
                --formatter logfmt \
                --file "$ARG_LOG_FILE" \
                "$message" 2>/dev/null || \
                echo "[$timestamp] $prefix $message" >> "$ARG_LOG_FILE"
        else
            echo "[$timestamp] $prefix $message" >> "$ARG_LOG_FILE"
        fi
    fi

    # Debug trace mode
    if [ "${DEBUG_TRACE:-false}" = "true" ] && [ "$level" = "DEBUG" ]; then
        echo "[$timestamp] TRACE: $prefix $message" >&2
    fi
}

# --- Structured Logging (key-value pairs) ---
# Usage: log_structured "level" "message" "key1=val1" "key2=val2" ...
# gum log --structured expects alternating: key value key value
# We accept key=value format and split them for gum
log_structured() {
    local level="$1"
    local message="$2"
    shift 2

    if [[ "$level" == "DEBUG" ]] && [[ "${ARG_VERBOSE:-}" != "1" ]]; then return; fi

    if ${HAS_GUM:-false}; then
        local gum_level gum_fg
        gum_level=$(_gum_log_level "$level")
        case "$level" in
            DEBUG)   gum_fg="${THEME_TEXT_DIM:-243}" ;;
            INFO)    gum_fg="${THEME_INFO:-81}" ;;
            WARN)    gum_fg="${THEME_WARNING:-214}" ;;
            ERROR)   gum_fg="${THEME_ERROR:-196}" ;;
            SUCCESS) gum_fg="${THEME_SUCCESS:-76}" ;;
            *)       gum_fg="${THEME_TEXT:-255}" ;;
        esac

        # Split key=value pairs into alternating key value args for gum log
        local kv_args=()
        for pair in "$@"; do
            local key="${pair%%=*}"
            local val="${pair#*=}"
            kv_args+=("$key" "$val")
        done

        gum log --level "$gum_level" --structured \
            --level.foreground "$gum_fg" --level.bold \
            --key.foreground "${THEME_TEXT_DIM:-243}" \
            --value.foreground "${THEME_TEXT:-255}" --value.bold \
            --separator.foreground "${THEME_BORDER:-240}" \
            --time "" \
            "$message" "${kv_args[@]}" >&2
    else
        local kv_str=""
        for pair in "$@"; do kv_str="$kv_str $pair"; done
        log "$level" "$message$kv_str"
    fi
}

