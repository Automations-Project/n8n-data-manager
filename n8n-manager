# ═══════════════════════════════════════════════════════════
# Full Workflow Comparison
# ═══════════════════════════════════════════════════════════

# Compare two .n8n files and output a structured diff
# Args: $1=file A (base), $2=file B (target)
# Output: pipe-delimited diff lines: section|status|detail
#   status: added|deleted|modified|unchanged
# Returns: 0 if identical, 1 if differences found
wf_compare_files() {
    local file_a="$1"
    local file_b="$2"

    if command_exists node; then
        node -e '
const fs = require("fs");

function deepEqual(a, b) {
    if (a === b) return true;
    if (typeof a !== typeof b) return false;
    if (typeof a !== "object" || a === null || b === null) return false;
    const keysA = Object.keys(a), keysB = Object.keys(b);
    if (keysA.length !== keysB.length) return false;
    return keysA.every(k => deepEqual(a[k], b[k]));
}

function compareNodes(baseNodes, targetNodes) {
    const baseMap = new Map(baseNodes.map(n => [n.id, n]));
    const targetMap = new Map(targetNodes.map(n => [n.id, n]));
    const results = [];

    for (const [id, node] of baseMap) {
        if (!targetMap.has(id)) {
            results.push("nodes|deleted|" + (node.name || id));
        } else {
            const tNode = targetMap.get(id);
            // Compare ignoring position
            const bCopy = {...node}; delete bCopy.position;
            const tCopy = {...tNode}; delete tCopy.position;
            if (!deepEqual(bCopy, tCopy)) {
                // Find what changed
                const changes = [];
                if (node.name !== tNode.name) changes.push("name");
                if (node.type !== tNode.type) changes.push("type");
                if (!deepEqual(node.parameters, tNode.parameters)) changes.push("parameters");
                if (node.disabled !== tNode.disabled) changes.push("disabled");
                if (!deepEqual(node.credentials, tNode.credentials)) changes.push("credentials");
                results.push("nodes|modified|" + (node.name || id) + " [" + changes.join(", ") + "]");
            }
        }
    }
    for (const [id, node] of targetMap) {
        if (!baseMap.has(id)) {
            results.push("nodes|added|" + (node.name || id));
        }
    }
    return results;
}

function compareConnections(baseConns, targetConns) {
    const results = [];
    const baseStr = JSON.stringify(baseConns || {});
    const targetStr = JSON.stringify(targetConns || {});
    if (baseStr !== targetStr) {
        const baseKeys = Object.keys(baseConns || {});
        const targetKeys = Object.keys(targetConns || {});
        const allKeys = new Set([...baseKeys, ...targetKeys]);
        for (const key of allKeys) {
            if (!baseConns[key]) results.push("connections|added|" + key);
            else if (!targetConns[key]) results.push("connections|deleted|" + key);
            else if (JSON.stringify(baseConns[key]) !== JSON.stringify(targetConns[key])) {
                results.push("connections|modified|" + key);
            }
        }
    }
    return results;
}

function compareSettings(baseSettings, targetSettings) {
    const results = [];
    const base = baseSettings || {};
    const target = targetSettings || {};
    const allKeys = new Set([...Object.keys(base), ...Object.keys(target)]);
    for (const key of allKeys) {
        if (!(key in base)) results.push("settings|added|" + key + "=" + JSON.stringify(target[key]));
        else if (!(key in target)) results.push("settings|deleted|" + key);
        else if (!deepEqual(base[key], target[key])) {
            results.push("settings|modified|" + key + ": " + JSON.stringify(base[key]) + " → " + JSON.stringify(target[key]));
        }
    }
    return results;
}

try {
    const a = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    const b = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));

    // Meta comparison
    if (a.name !== b.name) console.log("meta|modified|name: " + a.name + " → " + b.name);
    if (String(a.active) !== String(b.active)) console.log("meta|modified|active: " + a.active + " → " + b.active);

    // Nodes
    const nodeDiffs = compareNodes(a.nodes || [], b.nodes || []);
    nodeDiffs.forEach(d => console.log(d));

    // Connections
    const connDiffs = compareConnections(a.connections, b.connections);
    connDiffs.forEach(d => console.log(d));

    // Settings
    const settingDiffs = compareSettings(a.settings, b.settings);
    settingDiffs.forEach(d => console.log(d));

    // Pin data
    const basePins = Object.keys(a.pinData || {}).length;
    const targetPins = Object.keys(b.pinData || {}).length;
    if (basePins !== targetPins) {
        console.log("pinData|modified|" + basePins + " pinned nodes → " + targetPins + " pinned nodes");
    }

    const totalDiffs = nodeDiffs.length + connDiffs.length + settingDiffs.length;
    process.exit(totalDiffs > 0 ? 1 : 0);
} catch(e) { console.error(e.message); process.exit(2); }
' "$file_a" "$file_b" 2>/dev/null
        return $?
    elif command_exists python3; then
        python3 -c "
import json, sys

def deep_equal(a, b):
    return json.dumps(a, sort_keys=True) == json.dumps(b, sort_keys=True)

try:
    with open(sys.argv[1]) as f: a = json.load(f)
    with open(sys.argv[2]) as f: b = json.load(f)

    diffs = 0
    if a.get('name') != b.get('name'):
        print(f'meta|modified|name: {a.get(\"name\")} → {b.get(\"name\")}')
    if str(a.get('active')) != str(b.get('active')):
        print(f'meta|modified|active: {a.get(\"active\")} → {b.get(\"active\")}')

    # Nodes
    base_nodes = {n['id']: n for n in a.get('nodes', []) if 'id' in n}
    target_nodes = {n['id']: n for n in b.get('nodes', []) if 'id' in n}
    for nid, node in base_nodes.items():
        if nid not in target_nodes:
            print(f'nodes|deleted|{node.get(\"name\", nid)}'); diffs += 1
        else:
            bc = {k:v for k,v in node.items() if k != 'position'}
            tc = {k:v for k,v in target_nodes[nid].items() if k != 'position'}
            if not deep_equal(bc, tc):
                print(f'nodes|modified|{node.get(\"name\", nid)}'); diffs += 1
    for nid, node in target_nodes.items():
        if nid not in base_nodes:
            print(f'nodes|added|{node.get(\"name\", nid)}'); diffs += 1

    # Settings
    bs = a.get('settings', {}); ts = b.get('settings', {})
    for k in set(list(bs.keys()) + list(ts.keys())):
        if k not in bs: print(f'settings|added|{k}={json.dumps(ts[k])}'); diffs += 1
        elif k not in ts: print(f'settings|deleted|{k}'); diffs += 1
        elif not deep_equal(bs[k], ts[k]):
            print(f'settings|modified|{k}: {json.dumps(bs[k])} → {json.dumps(ts[k])}'); diffs += 1

    sys.exit(1 if diffs > 0 else 0)
except Exception as e: print(f'error|compare|{e}', file=sys.stderr); sys.exit(2)
" "$file_a" "$file_b" 2>/dev/null
        return $?
    else
        log ERROR "Need node or python3 for workflow comparison"
        return 2
    fi
}

