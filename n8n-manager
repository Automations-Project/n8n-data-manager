#!/usr/bin/env bash
# n8n_schema_versions.sh — pinned-tested n8n migrations-table hashes
# Format: N8N_SCHEMA_HASHES["<n8n-version>"]="<16-hex-chars>"
# Updated by: bash scripts/refresh-pinned-shas.sh (extended in Plan 07-06)
# Hash computation: sha256sum <<< "$(migrations names | tr '\n' '|')" | head -c 16
#
# PLACEHOLDER entries: when a hash value equals "PLACEHOLDER_HASH", the schema
# drift check is skipped with a WARNING (operator has not yet run
# scripts/refresh-pinned-shas.sh for their deployed n8n version).
#
# shellcheck disable=SC2034
set -Eeuo pipefail
IFS=$'\n\t'

declare -A N8N_SCHEMA_HASHES
# Seed entry — replace PLACEHOLDER_HASH by running scripts/refresh-pinned-shas.sh
# against your deployed n8n container.  Until then, all schema drift checks
# are skipped (graceful-degradation mode, matching Phase 5 install.sh pattern).
#
# The hash is the first 16 hex chars of:
#   sha256sum <<< "$(sqlite3 db.sqlite 'SELECT name FROM migrations ORDER BY id;' | tr '\n' '|')"
# or for Postgres:
#   psql -tAc "SELECT name FROM migrations ORDER BY id;" | tr '\n' '|' | sha256sum
N8N_SCHEMA_HASHES["1.0.0"]="PLACEHOLDER_HASH"  # operator: run scripts/refresh-pinned-shas.sh
# Add entries for your deployed n8n version after running refresh-pinned-shas.sh:
# N8N_SCHEMA_HASHES["1.52.0"]="<16-hex-chars-from-refresh-script>"

# src/lib/rollback.sh

set -Eeuo pipefail
IFS=$'
	'

# Shred all files in a directory, then remove it (D-13)
# Falls back to rm -f with WARNING if shred is not available.
# Usage: _shred_dir <dir>
_shred_dir() {
    local _dir="$1"
    [ -d "$_dir" ] || return 0
    if command -v shred >/dev/null 2>&1; then
        find "$_dir" -type f -exec shred -u {} \; 2>/dev/null || true
    else
        log WARN "_shred_dir: shred not available; using rm -f (files not overwritten before deletion)"
        find "$_dir" -type f -exec rm -f {} \; 2>/dev/null || true
    fi
    rm -rf "$_dir" 2>/dev/null || true
}

rollback_restore() {
    local container_id="$1"
    local backup_dir="$2"
    local restore_type="$3"
    local is_dry_run="${4:-false}"

    log WARN "Attempting to roll back to pre-restore state..."

    local backup_workflows="${backup_dir}/workflows.json"
    local backup_credentials="${backup_dir}/credentials.json"
    local container_workflows="/tmp/rollback_workflows.json"
    local container_credentials="/tmp/rollback_credentials.json"
    local rollback_success=true

    # Validate backup files exist
    if [[ "$restore_type" == "all" || "$restore_type" == "workflows" ]]; then
        if [ ! -f "$backup_workflows" ]; then
            log ERROR "Pre-restore backup file workflows.json not found in $backup_dir. Cannot rollback workflows."
            rollback_success=false
        fi
    fi
    if [[ "$restore_type" == "all" || "$restore_type" == "credentials" ]]; then
        if [ ! -f "$backup_credentials" ]; then
            log ERROR "Pre-restore backup file credentials.json not found in $backup_dir. Cannot rollback credentials."
            rollback_success=false
        fi
    fi
    if ! $rollback_success; then return 1; fi

    # Copy pre-restore backup files back to container
    log INFO "Copying pre-restore backup files back to container..."
    local copy_failed=false
    if [[ "$restore_type" == "all" || "$restore_type" == "workflows" ]]; then
        if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
            log DRYRUN "Would copy $backup_workflows to ${container_id}:${container_workflows}"
        elif ! docker cp "$backup_workflows" "${container_id}:${container_workflows}"; then
            log ERROR "Rollback failed: Could not copy workflows back to container."
            copy_failed=true
        fi
    fi
    if [[ "$restore_type" == "all" || "$restore_type" == "credentials" ]]; then
        if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
            log DRYRUN "Would copy $backup_credentials to ${container_id}:${container_credentials}"
        elif ! docker cp "$backup_credentials" "${container_id}:${container_credentials}"; then
            log ERROR "Rollback failed: Could not copy credentials back to container."
            copy_failed=true
        fi
    fi
    if $copy_failed; then
        dockExec "$container_id" "rm -f $container_workflows $container_credentials" 2>/dev/null || true
        return 1
    fi

    # Import pre-restore data back into n8n
    log INFO "Importing pre-restore backup data into n8n..."
    if [[ "$restore_type" == "all" || "$restore_type" == "workflows" ]]; then
        if ! dockExec "$container_id" "n8n import:workflow --separate --input=$container_workflows"; then
            log ERROR "Rollback failed during workflow import."
            rollback_success=false
        fi
    fi
    if [[ "$restore_type" == "all" || "$restore_type" == "credentials" ]]; then
        if ! dockExec "$container_id" "n8n import:credentials --separate --input=$container_credentials"; then
            log ERROR "Rollback failed during credential import."
            rollback_success=false
        fi
    fi

    # Clean up rollback files in container
    log INFO "Cleaning up rollback files in container..."
    dockExec "$container_id" "rm -f $container_workflows $container_credentials" 2>/dev/null || log WARN "Could not clean up rollback files in container."

    if $rollback_success; then
        log SUCCESS "Rollback completed. n8n should be in the state before restore was attempted."
        return 0
    else
        log ERROR "Rollback failed. Manual intervention may be required."
        log WARN "Pre-restore backup files are kept at: $backup_dir"
        return 1
    fi
}

# Create a pre-restore backup of current n8n data for rollback
create_pre_restore_backup() {
    local container="$1"
    local restore_type="$2"
    local is_dry_run="${3:-false}"

    log HEADER "Creating Pre-restore Backup"
    log DEBUG "[PRE_RESTORE_BACKUP] Starting pre-restore backup to enable rollback"

    local pre_restore_dir
    pre_restore_dir=$(_safe_mktemp_dir "n8n-prerestore") || {
        log ERROR "[PRE_RESTORE_BACKUP] Failed to create safe pre-restore backup directory (D-11)"
        return 1
    }
    log DEBUG "[PRE_RESTORE_BACKUP] Created pre-restore backup directory (mode 700): $pre_restore_dir"
    # D-13: Caller MUST call _shred_dir "$pre_restore_dir" on cleanup (EXIT + INT + TERM traps)
    # The dir is returned via stdout; callers set: trap '_shred_dir "${_PRE_RESTORE_DIR:-}"' EXIT INT TERM

    local pre_workflows="${pre_restore_dir}/workflows.json"
    local pre_credentials="${pre_restore_dir}/credentials.json"
    local container_pre_workflows="/tmp/pre_workflows.json"
    local container_pre_credentials="/tmp/pre_credentials.json"

    local backup_failed=false
    local no_existing_data=false
    log INFO "Exporting current n8n data for backup..."

    if [ "$is_dry_run" != "true" ] && [ "$is_dry_run" != "1" ]; then
        if [[ "$restore_type" == "all" || "$restore_type" == "workflows" ]]; then
            log DEBUG "[PRE_RESTORE_BACKUP] Exporting current workflows for safety backup"
            if ! dockExec "$container" "n8n export:workflow --all --output=$container_pre_workflows"; then
                log WARN "[PRE_RESTORE_BACKUP] Failed to export current workflows (may be empty)"
                no_existing_data=true
            else
                if ! docker cp "${container}:${container_pre_workflows}" "$pre_workflows"; then
                    log ERROR "[PRE_RESTORE_BACKUP] Failed to copy workflows backup from container"
                    backup_failed=true
                fi
            fi
        fi

        if [[ "$restore_type" == "all" || "$restore_type" == "credentials" ]]; then
            log DEBUG "[PRE_RESTORE_BACKUP] Exporting current credentials for safety backup"
            if ! dockExec "$container" "n8n export:credentials --all --decrypted --output=$container_pre_credentials"; then
                log WARN "[PRE_RESTORE_BACKUP] Failed to export current credentials (may be empty)"
                no_existing_data=true
            else
                if ! docker cp "${container}:${container_pre_credentials}" "$pre_credentials"; then
                    log ERROR "[PRE_RESTORE_BACKUP] Failed to copy credentials backup from container"
                    backup_failed=true
                fi
            fi
        fi

        # Clean up temp files in container
        dockExec "$container" "rm -f $container_pre_workflows $container_pre_credentials" 2>/dev/null || true
    else
        log DRYRUN "Would export current data for safety backup"
    fi

    if $backup_failed; then
        log ERROR "[PRE_RESTORE_BACKUP] Failed to create pre-restore backup."
        log WARN "[PRE_RESTORE_BACKUP] Proceeding without pre-restore backup - AT YOUR OWN RISK."
    elif $no_existing_data; then
        log WARN "[PRE_RESTORE_BACKUP] No existing data found to backup (n8n instance may be empty)"
        log SUCCESS "[PRE_RESTORE_BACKUP] Pre-restore backup completed (empty instance)"
    else
        log SUCCESS "[PRE_RESTORE_BACKUP] Pre-restore backup created successfully."
    fi

    # Return the directory path via stdout
    echo "$pre_restore_dir"
}

