# --- Viewport: Framed content sections ---

# Viewport panel — renders content inside a titled bordered frame (TUI window look)
# Usage: ui_viewport "Title" "content_string"
#        echo "$text" | ui_viewport "Title"  (reads from stdin)
ui_viewport() {
    local title="${1:-}"
    local content="${2:-}"

    # Read from stdin if no content argument
    if [ -z "$content" ] && [ ! -t 0 ]; then
        content=$(cat)
    fi
    [ -z "$content" ] && return

    if $HAS_GUM; then
        local tw
        tw=$(_term_width)
        local panel_w=$((tw > 80 ? 76 : tw - 6))

        # Title bar (colored accent bar at top)
        local title_bar
        if [ -n "$title" ]; then
            title_bar=$(gum style \
                --foreground "$THEME_BG_TERTIARY" --background "$THEME_PRIMARY" \
                --bold --padding "0 2" --width "$panel_w" \
                " $title")
        fi

        # Content area
        local styled_content
        styled_content=$(gum style \
            --border rounded --border-foreground "$THEME_BORDER" \
            --foreground "$THEME_TEXT" \
            --padding "1 2" --width "$panel_w" \
            "$content")

        if [ -n "$title" ]; then
            gum join --vertical "$title_bar" "$styled_content" >&2
        else
            echo "$styled_content" >&2
        fi
    else
        if [ -n "$title" ]; then
            printf " ┌─ %s ─%s┐\n" "$title" "$(printf '─%.0s' $(seq 1 $((40 - ${#title}))))" >&2
        fi
        echo "$content" >&2
        if [ -n "$title" ]; then
            printf " └%s┘\n" "$(printf '─%.0s' $(seq 1 44))" >&2
        fi
    fi
}

# Viewport capture — captures stderr from a command block and renders in a viewport
# Usage: ui_viewport_capture "Title" command arg1 arg2 ...
#   Captures both stdout and stderr from the command, renders stderr in viewport
ui_viewport_capture() {
    local title="$1"; shift
    local tmp_stderr
    tmp_stderr=$(mktemp -t viewport-XXXXXX 2>/dev/null || mktemp)

    # Run command, capture stderr to temp file, let stdout pass through
    "$@" 2>"$tmp_stderr"
    local exit_code=$?

    # Render captured stderr in viewport if non-empty
    if [ -s "$tmp_stderr" ]; then
        ui_viewport "$title" "$(cat "$tmp_stderr")"
    fi

    rm -f "$tmp_stderr"
    return $exit_code
}

# Section header — enhanced divider with colored title bar (replaces plain ui_divider for key sections)
# Usage: ui_section_header "Git Setup" [icon] [color]
ui_section_header() {
    local title="$1"
    local icon="${2:-▸}"
    local color="${3:-$THEME_INFO}"

    if $HAS_GUM; then
        local tw
        tw=$(_term_width)
        local styled_icon styled_title styled_line

        styled_icon=$(gum style --foreground "$color" --bold "$icon")
        styled_title=$(gum style --foreground "$color" --bold " $title ")

        # Build a separator line that fills the width
        local title_len=$(( ${#icon} + ${#title} + 4 ))
        local remaining=$(( tw - title_len - 4 ))
        [ "$remaining" -lt 4 ] && remaining=4
        styled_line=$(gum style --foreground "$THEME_BORDER" "$(printf '─%.0s' $(seq 1 $remaining))")

        local header
        header=$(gum join --horizontal "$styled_icon" "$styled_title" "$styled_line")

        gum style --padding "0 1" "$header" >&2
    else
        local line_len=60
        local pad_len=$(( (line_len - ${#title} - 4) / 2 ))
        [ "$pad_len" -lt 2 ] && pad_len=2
        printf "\n%s %s %s %s\n" "$icon" "$(printf '─%.0s' $(seq 1 $pad_len))" "$title" "$(printf '─%.0s' $(seq 1 $pad_len))" >&2
    fi
}

# Dashboard header — branded app bar with version + status
# Usage: ui_dashboard_header [status_text] [status_color]
ui_dashboard_header() {
    local status_text="${1:-Ready}"
    local status_color="${2:-$THEME_SUCCESS}"

    if $HAS_GUM; then
        local tw
        tw=$(_term_width)
        local logo version_badge status_badge

        logo=$(gum style --foreground "$THEME_SECONDARY" --bold "🔧 n8n-manager")
        version_badge=$(_style_badge "v${VERSION:-5.0.0}")
        status_badge=$(gum style --foreground "$status_color" --bold "● $status_text")

        local left_part right_part
        left_part=$(gum join --horizontal "$logo" "  " "$version_badge")
        right_part="$status_badge"

        # Build the full header bar
        local header_content
        header_content=$(gum join --horizontal "$left_part" "  " "$right_part")

        gum style \
            --border rounded --border-foreground "$THEME_BORDER_ACCENT" \
            --padding "0 2" --width "$tw" \
            "$header_content" >&2
    else
        echo "" >&2
        printf "╭──────────────────────────────────────────────────────╮\n" >&2
        printf "│  🔧 n8n-manager    v%-8s     ● %-18s│\n" "${VERSION:-5.0.0}" "$status_text" >&2
        printf "╰──────────────────────────────────────────────────────╯\n" >&2
    fi
}

# Status bar — bottom bar with context info
# Usage: ui_status_bar "container" "repo" ["extra_info"]
ui_status_bar() {
    local container="${1:-}"
    local repo="${2:-}"
    local extra="${3:-$(date '+%H:%M:%S')}"

    if $HAS_GUM; then
        local parts=()
        [ -n "$container" ] && parts+=("$(gum style --foreground "$THEME_SECONDARY" "🐳 $container")")
        [ -n "$repo" ] && parts+=("$(gum style --foreground "$THEME_LINK" "📦 $repo")")
        [ -n "$extra" ] && parts+=("$(gum style --foreground "$THEME_TEXT_DIM" "🕐 $extra")")

        local bar_content=""
        for i in "${!parts[@]}"; do
            if [ "$i" -eq 0 ]; then
                bar_content="${parts[$i]}"
            else
                local sep
                sep=$(gum style --foreground "$THEME_BORDER" " │ ")
                bar_content=$(gum join --horizontal "$bar_content" "$sep" "${parts[$i]}")
            fi
        done

        _style_accent_bar "$bar_content" "$THEME_BG_TERTIARY" "$THEME_TEXT" >&2
    else
        local bar=""
        [ -n "$container" ] && bar="🐳 $container"
        [ -n "$repo" ] && bar="$bar │ 📦 $repo"
        [ -n "$extra" ] && bar="$bar │ 🕐 $extra"
        printf " %s\n" "$bar" >&2
    fi
}

# Progress panel — multi-step tracker with status indicators
# Usage: ui_progress_panel "title" "step_status1|label1" "step_status2|label2" ...
#   step_status: done, active, pending, error
ui_progress_panel() {
    local title="$1"; shift

    if $HAS_GUM; then
        local tw
        tw=$(_term_width)
        local panel_w=$((tw > 60 ? 58 : tw - 4))

        local lines=()
        for step in "$@"; do
            local status="${step%%|*}"
            local label="${step#*|}"
            local indicator=""
            local step_color="$THEME_TEXT_DIM"

            case "$status" in
                done)    indicator="✔"; step_color="$THEME_SUCCESS" ;;
                active)  indicator="▸"; step_color="$THEME_PRIMARY" ;;
                pending) indicator="·"; step_color="$THEME_TEXT_DIM" ;;
                error)   indicator="✖"; step_color="$THEME_ERROR" ;;
            esac

            local styled_indicator styled_label
            styled_indicator=$(gum style --foreground "$step_color" --bold "[$indicator]")
            styled_label=$(gum style --foreground "$step_color" "$label")
            lines+=("$(gum join --horizontal "$styled_indicator" " " "$styled_label")")
        done

        local body
        body=$(printf '%s\n' "${lines[@]}")

        _style_titled_panel "$title" "$body" "$panel_w" "rounded" "$THEME_HEADER" "$THEME_BORDER" >&2
    else
        echo "" >&2
        echo "── $title ──" >&2
        for step in "$@"; do
            local status="${step%%|*}"
            local label="${step#*|}"
            local indicator=""
            case "$status" in
                done)    indicator="✔" ;;
                active)  indicator="▸" ;;
                pending) indicator="·" ;;
                error)   indicator="✖" ;;
            esac
            printf "  [%s] %s\n" "$indicator" "$label" >&2
        done
        echo "" >&2
    fi
}

# Split summary — side-by-side config + results panels
# Usage: ui_split_summary "left_title" "right_title" "key1|val1" ... "---" "key1|val1" ...
#   Use "---" to separate left from right panel items
ui_split_summary() {
    local left_title="$1"
    local right_title="$2"
    shift 2

    local left_items=()
    local right_items=()
    local in_right=false

    for item in "$@"; do
        if [ "$item" = "---" ]; then
            in_right=true
            continue
        fi
        if $in_right; then
            right_items+=("$item")
        else
            left_items+=("$item")
        fi
    done

    if $HAS_GUM; then
        local tw
        tw=$(_term_width)
        local half_w=$(( (tw - 6) / 2 ))
        [ "$half_w" -lt 20 ] && half_w=20

        # Build left panel content
        local left_body=""
        for item in "${left_items[@]}"; do
            local key="${item%%|*}"
            local val="${item#*|}"
            local row
            row=$(_style_kv "$key" "$val")
            left_body="${left_body:+$left_body
}$row"
        done

        # Build right panel content
        local right_body=""
        for item in "${right_items[@]}"; do
            local key="${item%%|*}"
            local val="${item#*|}"
            local row
            row=$(_style_kv "$key" "$val")
            right_body="${right_body:+$right_body
}$row"
        done

        local left_panel right_panel
        left_panel=$(_style_titled_panel "$left_title" "$left_body" "$half_w" "rounded" "$THEME_INFO" "$THEME_BORDER")
        right_panel=$(_style_titled_panel "$right_title" "$right_body" "$half_w" "rounded" "$THEME_SUCCESS" "$THEME_BORDER")

        layout_columns "$left_panel" "$right_panel" >&2
    else
        echo "" >&2
        echo "── $left_title ──" >&2
        for item in "${left_items[@]}"; do
            local key="${item%%|*}"
            local val="${item#*|}"
            printf "  %-16s %s\n" "$key" "$val" >&2
        done
        echo "" >&2
        echo "── $right_title ──" >&2
        for item in "${right_items[@]}"; do
            local key="${item%%|*}"
            local val="${item#*|}"
            printf "  %-16s %s\n" "$key" "$val" >&2
        done
        echo "" >&2
    fi
}

# Card — titled card with icon, body text, and optional footer
# Usage: ui_card "icon" "title" "body" ["footer"] [border_color]
ui_card() {
    local icon="$1"
    local title="$2"
    local body="$3"
    local footer="${4:-}"
    local border_fg="${5:-$THEME_BORDER}"

    if $HAS_GUM; then
        local header_line
        header_line=$(_style_icon_text "$icon" "$title" "$THEME_PRIMARY")

        local content="$header_line"
        content=$(printf '%s\n\n%s' "$content" "$body")

        if [ -n "$footer" ]; then
            local styled_footer
            styled_footer=$(_style_dimmed "$footer")
            content=$(printf '%s\n\n%s' "$content" "$styled_footer")
        fi

        gum style \
            --border rounded --border-foreground "$border_fg" \
            --padding "1 2" --margin "0 1" \
            "$content" >&2
    else
        echo "" >&2
        printf "  %s %s\n" "$icon" "$title" >&2
        echo "  ────────────────────────────" >&2
        while IFS= read -r line; do
            printf "  %s\n" "$line" >&2
        done <<< "$body"
        [ -n "$footer" ] && printf "  %s\n" "$footer" >&2
        echo "" >&2
    fi
}

# Notification toast — floating-style alert
# Usage: ui_notification "type" "message" ["detail"]
#   type: success, error, warning, info
ui_notification() {
    local type="$1"
    local message="$2"
    local detail="${3:-}"

    local icon="" fg="" border_fg=""
    case "$type" in
        success) icon="✔"; fg="$THEME_SUCCESS"; border_fg="$THEME_SUCCESS" ;;
        error)   icon="✖"; fg="$THEME_ERROR"; border_fg="$THEME_ERROR" ;;
        warning) icon="⚠"; fg="$THEME_WARNING"; border_fg="$THEME_WARNING" ;;
        info)    icon="ℹ"; fg="$THEME_INFO"; border_fg="$THEME_INFO" ;;
    esac

    if $HAS_GUM; then
        local styled_icon styled_msg
        styled_icon=$(gum style --foreground "$fg" --bold "$icon")
        styled_msg=$(gum style --foreground "$fg" --bold "$message")
        local content
        content=$(gum join --horizontal "$styled_icon" " " "$styled_msg")

        if [ -n "$detail" ]; then
            local styled_detail
            styled_detail=$(gum style --foreground "$THEME_TEXT_DIM" "$detail")
            content=$(printf '%s\n%s' "$content" "$styled_detail")
        fi

        gum style \
            --border rounded --border-foreground "$border_fg" \
            --padding "0 2" --margin "0 2" \
            "$content" >&2
    else
        printf "  %s %s\n" "$icon" "$message" >&2
        [ -n "$detail" ] && printf "    %s\n" "$detail" >&2
    fi
}

# Data panel — structured data display with header + key-value body
# Usage: ui_data_panel "title" "key1|val1" "key2|val2" ... [--accent color]
ui_data_panel() {
    local title="$1"; shift
    local accent="$THEME_INFO"
    local items=()

    for arg in "$@"; do
        if [ "$arg" = "--accent" ]; then
            : # next arg is color
        elif [[ "$arg" =~ ^[0-9]+$ ]] && [ ${#arg} -le 3 ]; then
            accent="$arg"
        else
            items+=("$arg")
        fi
    done

    if $HAS_GUM; then
        local tw
        tw=$(_term_width)
        local panel_w=$((tw > 50 ? 48 : tw - 4))

        local body=""
        for item in "${items[@]}"; do
            local key="${item%%|*}"
            local val="${item#*|}"
            local row
            row=$(_style_kv "$key" "$val")
            body="${body:+$body
}$row"
        done

        _style_titled_panel "$title" "$body" "$panel_w" "rounded" "$accent" "$THEME_BORDER" >&2
    else
        echo "" >&2
        echo "  $title" >&2
        echo "  ────────────────────────────" >&2
        for item in "${items[@]}"; do
            local key="${item%%|*}"
            local val="${item#*|}"
            printf "  %-18s %s\n" "$key" "$val" >&2
        done
        echo "" >&2
    fi
}

# Breadcrumb — navigation trail
# Usage: ui_breadcrumb "segment1" "segment2" "segment3"
ui_breadcrumb() {
    if $HAS_GUM; then
        local parts=()
        local last_idx=$(($# - 1))
        local idx=0
        for seg in "$@"; do
            if [ "$idx" -eq "$last_idx" ]; then
                parts+=("$(gum style --foreground "$THEME_PRIMARY" --bold "$seg")")
            else
                parts+=("$(gum style --foreground "$THEME_TEXT_DIM" "$seg")")
                parts+=("$(gum style --foreground "$THEME_BORDER" " › ")")
            fi
            idx=$((idx + 1))
        done

        local trail=""
        for part in "${parts[@]}"; do
            if [ -z "$trail" ]; then
                trail="$part"
            else
                trail=$(gum join --horizontal "$trail" "$part")
            fi
        done

        gum style --padding "0 2" "$trail" >&2
    else
        local trail=""
        for seg in "$@"; do
            trail="${trail:+$trail › }$seg"
        done
        printf "  %s\n" "$trail" >&2
    fi
}

# Horizontal divider with optional label
# Usage: ui_divider ["label"] [color]
ui_divider() {
    local label="${1:-}"
    local fg="${2:-$THEME_BORDER}"

    if $HAS_GUM; then
        local tw
        tw=$(_term_width)
        if [ -n "$label" ]; then
            local left_len=$(( (tw - ${#label} - 4) / 2 ))
            local right_len=$(( tw - left_len - ${#label} - 4 ))
            local left_line right_line styled_label
            left_line=$(gum style --foreground "$fg" "$(printf '─%.0s' $(seq 1 $left_len))")
            styled_label=$(gum style --foreground "$THEME_TEXT_DIM" " $label ")
            right_line=$(gum style --foreground "$fg" "$(printf '─%.0s' $(seq 1 $right_len))")
            gum join --horizontal "$left_line" "$styled_label" "$right_line" >&2
        else
            gum style --foreground "$fg" "$(printf '─%.0s' $(seq 1 $((tw - 2))))" >&2
        fi
    else
        if [ -n "$label" ]; then
            printf "──── %s ────\n" "$label" >&2
        else
            printf "────────────────────────────────────────\n" >&2
        fi
    fi
}

