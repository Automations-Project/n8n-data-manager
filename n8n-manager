set -Eeuo pipefail
IFS=$'\n\t'

# ═══════════════════════════════════════════════════════════
# Theme Constants — n8n Brand-Aligned Color Palette
# Uses 256-color codes: https://www.ditig.com/256-colors-cheat-sheet
# Official n8n brand colors: https://n8n.io/brandguidelines/
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# n8n Brand Core Colors
# ─────────────────────────────────────────────────────────────
THEME_PRIMARY=204           # n8n Pink (#EA4B71) — brand primary, buttons, highlights
THEME_SECONDARY=141         # n8n Purple (#7D5AFF) — secondary actions, links, accents
THEME_BRAND_DARK=232        # n8n Dark (#040506) — deep backgrounds, high contrast text

# ─────────────────────────────────────────────────────────────
# Semantic State Colors (n8n Design System)
# ─────────────────────────────────────────────────────────────
THEME_SUCCESS=76            # Green (#00C851) — success states, confirmations
THEME_WARNING=214           # Orange (#FF9800) — warnings, alerts
THEME_ERROR=196             # Red (#FF5252) — errors, danger, destructive actions
THEME_INFO=81               # Sky Blue (#00B5FF) — informational messages, tips

# ─────────────────────────────────────────────────────────────
# UI Structure & Text Hierarchy
# ─────────────────────────────────────────────────────────────
THEME_TEXT=255              # White (#FFFFFF) — primary text, high emphasis
THEME_TEXT_MUTED=250        # Light Gray — secondary text, medium emphasis
THEME_TEXT_DIM=243          # Muted Gray — tertiary text, low emphasis, debug
THEME_HEADER=204            # n8n Pink — section headers, brand emphasis

# ─────────────────────────────────────────────────────────────
# Backgrounds & Borders
# ─────────────────────────────────────────────────────────────
THEME_BG_PRIMARY=232        # Very Dark Gray (#040506) — main background
THEME_BG_SECONDARY=234      # Dark Gray — elevated surfaces, cards
THEME_BG_TERTIARY=236       # Medium Dark Gray — subtle backgrounds, hover states
THEME_BORDER=240            # Medium Gray — default borders, dividers
THEME_BORDER_ACCENT=204     # n8n Pink — focused borders, active states

# ─────────────────────────────────────────────────────────────
# Interactive States
# ─────────────────────────────────────────────────────────────
THEME_HOVER=141             # Purple — hover states
THEME_ACTIVE=204            # Pink — active/pressed states
THEME_FOCUS=141             # Purple — focus indicators
THEME_DISABLED=238          # Dim Gray — disabled elements

# ─────────────────────────────────────────────────────────────
# Component-Specific
# ─────────────────────────────────────────────────────────────
THEME_LINK=141              # Purple — hyperlinks, navigation
THEME_CURSOR=204            # Pink — text cursors, selection highlights
THEME_ACCENT=204            # Pink — badges, tags, emphasis markers

# ─────────────────────────────────────────────────────────────
# Spinner Configuration
# ─────────────────────────────────────────────────────────────
THEME_SPINNER="dot"         # Spinner style: dot, line, minidot, jump, pulse, points, globe, moon, monkey, meter, hamburger
THEME_SPINNER_COLOR=204     # Pink — spinner color matches brand primary

_ui_resolve_spinner() {
    local spinner="${THEME_SPINNER:-dot}"
    case "$spinner" in
        dots) spinner="dot" ;;  # Backward-compatible alias
        line|dot|minidot|jump|pulse|points|globe|moon|monkey|meter|hamburger) ;;
        *) spinner="dot" ;;
    esac
    echo "$spinner"
}

