# Strip 'id' fields from JSON data for safe import (import-as-new mode)
strip_json_ids() {
    local input_file="$1"
    local output_file="$2"

    log DEBUG "[JSON_STRIP] Stripping IDs from: $input_file -> $output_file"

    # Method 1: Python3 (most reliable)
    if command_exists python3; then
        log DEBUG "[JSON_STRIP] Using Python3 for ID stripping"
        python3 -c "
import json, sys
try:
    with open('$input_file', 'r') as f:
        data = json.load(f)

    def strip_ids(obj):
        if isinstance(obj, dict):
            obj.pop('id', None)
            for v in obj.values():
                strip_ids(v)
        elif isinstance(obj, list):
            for item in obj:
                strip_ids(item)
        return obj

    data = strip_ids(data)

    with open('$output_file', 'w') as f:
        json.dump(data, f, indent=2)
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
    sys.exit(1)
" || return 1

    # Method 2: Node.js fallback
    elif command_exists node; then
        log DEBUG "[JSON_STRIP] Using Node.js for ID stripping"
        node -e "
const fs = require('fs');
try {
    let data = JSON.parse(fs.readFileSync('$input_file', 'utf8'));
    function stripIds(obj) {
        if (Array.isArray(obj)) { obj.forEach(stripIds); }
        else if (obj && typeof obj === 'object') {
            delete obj.id;
            Object.values(obj).forEach(stripIds);
        }
        return obj;
    }
    data = stripIds(data);
    fs.writeFileSync('$output_file', JSON.stringify(data, null, 2));
} catch(e) { console.error(e); process.exit(1); }
" || return 1

    # Method 3: sed fallback (basic)
    else
        log WARN "[JSON_STRIP] Using sed for ID stripping (less reliable)"
        sed 's/"id"[[:space:]]*:[[:space:]]*"[^"]*"[[:space:]]*,\?//g' "$input_file" > "$output_file" || return 1
    fi

    log DEBUG "[JSON_STRIP] ID stripping completed successfully"
    return 0
}

# Filter JSON data — remove items with existing IDs
filter_json_by_ids() {
    local source_file="$1"
    local dest_file="$2"
    local existing_ids="$3"
    local item_type="$4" # "workflow" or "credential"

    log DEBUG "[JSON_FILTER] Filtering $item_type data from $source_file to $dest_file"
    log DEBUG "[JSON_FILTER] Existing IDs to exclude: $existing_ids"

    if [ ! -f "$source_file" ] || [ -z "$existing_ids" ]; then
        log DEBUG "[JSON_FILTER] No filtering needed - copying source to dest"
        cp "$source_file" "$dest_file" 2>/dev/null || return 1
        return 0
    fi

    # Convert space-separated IDs to comma-separated quoted list for Python
    local ids_array=""
    local IFS_BACKUP="$IFS"
    IFS=' '

    set -- $existing_ids
    for id in "$@"; do
        if [ -n "$id" ]; then
            if [ -n "$ids_array" ]; then
                ids_array="$ids_array, "
            fi
            ids_array="$ids_array\"$id\""
        fi
    done

    IFS="$IFS_BACKUP"

    if command_exists python3; then
        python3 -c "
import json, sys
try:
    existing_ids = [$ids_array]
    with open('$source_file', 'r') as f:
        data = json.load(f)

    if isinstance(data, list):
        filtered = [item for item in data if item.get('id') not in existing_ids]
    else:
        filtered = data if data.get('id') not in existing_ids else {}

    with open('$dest_file', 'w') as f:
        json.dump(filtered, f, indent=2)

    count = len(filtered) if isinstance(filtered, list) else (1 if filtered else 0)
    print(f'Filtered: {count} new items')
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
    sys.exit(1)
" || return 1
    else
        log ERROR "[JSON_FILTER] Python3 not available for JSON filtering"
        return 1
    fi
}

# Filter separate files directory — remove files with existing IDs
filter_separate_files_by_ids() {
    local source_dir="$1"
    local dest_dir="$2"
    local existing_ids="$3"
    local item_type="$4" # "workflow" or "credential"

    log DEBUG "[FILES_FILTER] Filtering $item_type files from $source_dir to $dest_dir"
    log DEBUG "[FILES_FILTER] Existing IDs to exclude: $existing_ids"

    mkdir -p "$dest_dir" || return 1

    local copied_count=0
    local skipped_count=0

    if [ -z "$existing_ids" ]; then
        log DEBUG "[FILES_FILTER] No existing IDs - copying all files"
        cp -r "$source_dir"/* "$dest_dir"/ 2>/dev/null && return 0
        return 1
    fi

    for file in "$source_dir"/*.json; do
        if [ ! -f "$file" ]; then continue; fi

        local filename
        filename=$(basename "$file" .json)
        local should_skip=false

        for existing_id in $existing_ids; do
            if [ "$filename" = "$existing_id" ]; then
                should_skip=true
                skipped_count=$((skipped_count + 1))
                log DEBUG "[FILES_FILTER] Skipping existing $item_type: $filename"
                break
            fi
        done

        if ! $should_skip; then
            cp "$file" "$dest_dir/" && copied_count=$((copied_count + 1))
            log DEBUG "[FILES_FILTER] Copied new $item_type: $filename"
        fi
    done

    log INFO "[FILES_FILTER] Filtered $item_type files: $copied_count new, $skipped_count existing (skipped)"

    local total_source_files
    total_source_files=$(find "$source_dir" -name "*.json" -type f 2>/dev/null | wc -l)
    if [ "$total_source_files" -gt 0 ] && [ "$copied_count" -eq 0 ]; then
        log WARN "[FILES_FILTER] Warning: $total_source_files $item_type files available but 0 new files to import"
    fi

    return 0
}

# Discover linked credentials from workflow JSON
discover_linked_credentials() {
    local workflow_json_file="$1"
    local discovered_creds=""

    log DEBUG "[CREDENTIAL_DISCOVERY] Discovering linked credentials from workflow: $workflow_json_file" >&2

    if [ ! -f "$workflow_json_file" ]; then
        log ERROR "[CREDENTIAL_DISCOVERY] Workflow JSON file not found: $workflow_json_file" >&2
        return 1
    fi

    # Method 1: Python3 (most reliable)
    if command_exists python3 2>&2; then
        log DEBUG "[CREDENTIAL_DISCOVERY] Using Python3 for credential discovery" >&2
        discovered_creds=$(python3 -c "
import json, sys
try:
    with open('$workflow_json_file', 'r') as f:
        data = json.load(f)

    creds = set()
    workflows_to_process = []

    if isinstance(data, list):
        workflows_to_process = data
    elif 'workflows' in data:
        workflows_to_process = data['workflows']
    elif 'nodes' in data:
        workflows_to_process = [data]
    else:
        workflows_to_process = [data]

    for workflow in workflows_to_process:
        if 'nodes' in workflow:
            for node in workflow['nodes']:
                if 'credentials' in node:
                    for cred_type, cred_info in node['credentials'].items():
                        if isinstance(cred_info, dict) and 'id' in cred_info:
                            creds.add(cred_info['id'])

    print(' '.join(sorted(creds)))
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
    sys.exit(1)
" 2>/dev/null)

    # Method 2: grep/sed fallback
    elif command_exists grep 2>&2 && command_exists sed 2>&2; then
        log DEBUG "[CREDENTIAL_DISCOVERY] Using grep/sed for credential discovery" >&2
        discovered_creds=$(grep -o '"credentials":[^}]*"id":"[^"]*"' "$workflow_json_file" 2>/dev/null |
            sed 's/.*"id":"\([^"]*\)".*/\1/' |
            sort -u | tr '\n' ' ' | sed 's/ $//')
    else
        log WARN "[CREDENTIAL_DISCOVERY] No suitable JSON parsing tools available" >&2
        return 1
    fi

    discovered_creds=$(echo "$discovered_creds" | xargs)

    if [ -n "$discovered_creds" ]; then
        log SUCCESS "[CREDENTIAL_DISCOVERY] Discovered linked credentials: $discovered_creds" >&2
        echo "$discovered_creds"
    else
        log INFO "[CREDENTIAL_DISCOVERY] No linked credentials found in workflow" >&2
    fi
    return 0
}

