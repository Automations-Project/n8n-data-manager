# Validate GitHub access: token, repo existence, branch existence
check_github_access() {
    local github_token="$1"
    local github_repo="$2"
    local branch="$3"
    local action="${4:-backup}"

    log HEADER "Validating GitHub Access"
    log DEBUG "[GITHUB_CHECK] Validating access for repo=$github_repo branch=$branch action=$action"

    # Validate token format
    if [ -z "$github_token" ]; then
        log ERROR "GitHub token is empty."
        return 1
    fi
    log DEBUG "[GITHUB_CHECK] Token format validated (length: ${#github_token})"

    # Check if token has basic API access
    log INFO "Verifying GitHub token..."
    local http_code
    http_code=$(curl -s -o /dev/null -w "%{http_code}" \
        -H "Authorization: token $github_token" \
        -H "Accept: application/vnd.github.v3+json" \
        "https://api.github.com/user")

    if [ "$http_code" != "200" ]; then
        log ERROR "GitHub token validation failed (HTTP $http_code)."
        log INFO "Ensure your token has 'repo' scope permissions."
        return 1
    fi
    log SUCCESS "GitHub token is valid."

    # Check if repository exists and is accessible
    log INFO "Checking repository access..."
    http_code=$(curl -s -o /dev/null -w "%{http_code}" \
        -H "Authorization: token $github_token" \
        -H "Accept: application/vnd.github.v3+json" \
        "https://api.github.com/repos/$github_repo")

    if [ "$http_code" = "404" ]; then
        if [ "$action" = "backup" ]; then
            log WARN "Repository '$github_repo' not found. It will be created on first push."
        else
            log ERROR "Repository '$github_repo' not found."
            return 1
        fi
    elif [ "$http_code" != "200" ]; then
        log ERROR "Cannot access repository '$github_repo' (HTTP $http_code)."
        return 1
    else
        log SUCCESS "Repository '$github_repo' is accessible."
    fi

    # Check if branch exists (for restore actions)
    if [ "$action" = "restore" ]; then
        log INFO "Checking branch '$branch'..."
        http_code=$(curl -s -o /dev/null -w "%{http_code}" \
            -H "Authorization: token $github_token" \
            -H "Accept: application/vnd.github.v3+json" \
            "https://api.github.com/repos/$github_repo/branches/$branch")

        if [ "$http_code" = "404" ]; then
            log ERROR "Branch '$branch' not found in repository '$github_repo'."
            return 1
        elif [ "$http_code" != "200" ]; then
            log WARN "Could not verify branch '$branch' (HTTP $http_code). Proceeding anyway."
        else
            log SUCCESS "Branch '$branch' exists."
        fi
    fi

    log DEBUG "[GITHUB_CHECK] All GitHub access checks passed"
    return 0
}

