# Detect what entity files exist in a backup directory
# Args: $1=backup_dir
# Output: prints available entity types to stdout
detect_entity_files() {
    local backup_dir="$1"
    local entities_dir="$backup_dir/entities"

    if [ ! -d "$entities_dir" ]; then
        return 1
    fi

    local found=()
    for entity_file in "${ENTERPRISE_ENTITY_FILES[@]}"; do
        if [ -f "$entities_dir/$entity_file" ]; then
            local entity_name="${entity_file%.jsonl}"
            local line_count
            line_count=$(wc -l < "$entities_dir/$entity_file" 2>/dev/null || echo "0")
            line_count=$(echo "$line_count" | xargs)
            if [ "$line_count" -gt 0 ]; then
                found+=("$entity_name:$line_count")
            fi
        fi
    done

    if [ ${#found[@]} -eq 0 ]; then
        return 1
    fi

    printf '%s\n' "${found[@]}"
    return 0
}

# Count entities in a JSONL file
# Args: $1=jsonl_file
parse_jsonl_count() {
    local file="$1"
    if [ -f "$file" ]; then
        wc -l < "$file" 2>/dev/null | xargs
    else
        echo "0"
    fi
}

