    printf "    Record this command session for sharing\n"
    echo

    # :flag.usage
    printf "  %s\n" "--record-output PATH"
    printf "    Directory for session recording artifacts\n"
    echo

    # :flag.usage
    printf "  %s\n" "--container, -c NAME"
    printf "    Target Docker container ID or name\n"
    echo

    # :flag.usage
    printf "  %s\n" "--token, -t PAT"
    printf "    GitHub Personal Access Token\n"
    echo

    # :flag.usage
    printf "  %s\n" "--repo, -r REPO"
    printf "    GitHub repository (user/repo format)\n"
    echo

    # :flag.usage
    printf "  %s\n" "--branch, -b BRANCH"
    printf "    GitHub branch\n"
    printf "    %s\n" "Default: main"
    echo

    # :flag.usage
    printf "  %s\n" "--n8n-api-key KEY"
    printf "    Optional n8n API key override (auto-detect used by default)\n"
    echo

    # :flag.usage
    printf "  %s\n" "--n8n-api-url URL"
    printf "    Optional n8n API base URL override\n"
    echo

    # :flag.usage
    printf "  %s\n" "--force"
    printf "    Force push when remote conflicts are detected\n"
    echo

    # :flag.usage
    printf "  %s\n" "--backup-type TYPE"
    printf "    Type of data to backup (enterprise=enterprise-compatible metadata mode,\n    full-db=entire database)\n"
    printf "    %s\n" "Allowed: all, workflows, credentials, enterprise, full-db"
    printf "    %s\n" "Default: all"
    echo

    # :flag.usage
    printf "  %s\n" "--backup-layout MODE"
    printf "    Backup output layout (canonical=source-control directories,\n    combined=data.n8n.backups, workflow-bundles=<workflow>.n8n.backup)\n"
    printf "    %s\n" "Allowed: canonical, combined, workflow-bundles"
    printf "    %s\n" "Default: canonical"
    echo

    # :flag.usage
    printf "  %s\n" "--credential-export-mode MODE"
    printf "    Credential export format (stubs=enterprise compatible default,\n    encrypted=full encrypted payload, decrypted=full plaintext payload)\n"
    printf "    %s\n" "Allowed: stubs, encrypted, decrypted"
    printf "    %s\n" "Default: stubs"
    echo

    # :flag.usage
    printf "  %s\n" "--separate-files"
    printf "    Legacy compatibility flag (canonical backup always uses separate JSON files)\n"
    echo

    # :flag.usage
    printf "  %s\n" "--incremental"
    printf "    Only backup items changed since last backup\n"
    echo

    # :flag.usage
    printf "  %s\n" "--workflow-id ID"
    printf "    Export specific workflow ID(s), comma-separated\n"
    echo

    # :flag.usage
    printf "  %s\n" "--credential-id ID"
    printf "    Export specific credential ID(s), comma-separated\n"
    echo

    # :flag.usage
    printf "  %s\n" "--include-linked-creds"
    printf "    Auto-include linked credentials when backing up workflows\n"
    echo

    # :flag.usage
    printf "  %s\n" "--only-new"
    printf "    Only backup items not already in the GitHub repo\n"
    echo

    # :flag.usage
    printf "  %s\n" "--import-as-new"
    printf "    Strip IDs from exported data\n"
    echo

    # :flag.usage
    printf "  %s\n" "--select"
    printf "    Interactively select specific workflows/credentials to backup\n"
    echo

    # :flag.usage
    printf "  %s\n" "--token-file PATH"
    printf "    Read GitHub PAT from file (file must have mode 600). Preferred over --token\n    to avoid token leaks via /proc/cmdline.\n"
    echo

    # :flag.usage
    printf "  %s\n" "--token-stdin"
    printf "    Read GitHub PAT from stdin. Refused if stdin is /dev/null (prevents silent\n    empty-PAT passes).\n"
    echo

    # :command.usage_fixed_flags
    printf "  %s\n" "--help, -h"
    printf "    Show this help\n"
    echo

    # :command.usage_examples
    printf "%s\n" "Examples:"
    printf "  n8n-manager backup --container n8n --token ghp_xxx --repo user/backups\n"
    printf "  n8n-manager backup -c n8n -t ghp_xxx -r user/backups --backup-type workflows\n"
    printf "  n8n-manager backup -c n8n -t ghp_xxx -r user/backups --backup-layout combined\n"
    printf "  n8n-manager backup -c n8n -t ghp_xxx -r user/backups --backup-layout\n  workflow-bundles --workflow-id \"wf123\"\n"
    printf "  n8n-manager backup -c n8n -t ghp_xxx -r user/backups --backup-type credentials\n  --credential-export-mode encrypted\n"
    printf "  n8n-manager backup -c n8n -t ghp_xxx -r user/backups --backup-type credentials\n  --credential-export-mode decrypted\n"
    printf "  n8n-manager backup -c n8n -t ghp_xxx -r user/backups --workflow-id \"wf123\"\n  --include-linked-creds\n"
    printf "  n8n-manager backup -c n8n -t ghp_xxx -r user/backups --incremental\n"
    echo

  fi
}

