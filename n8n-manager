# Unified dispatcher (canonical source-control + legacy compatibility)
perform_import() {
    local container="$1"
    local backup_source_dir="$2"
    local restore_type="$3"
    local is_dry_run="${4:-false}"
    local pre_restore_dir="${5:-}"

    if declare -F sc_import_dispatch >/dev/null 2>&1; then
        if sc_import_dispatch "$container" "$backup_source_dir" "$restore_type" "$is_dry_run" "$pre_restore_dir"; then
            return 0
        fi

        local dispatch_rc=$?
        log DEBUG "[PERFORM_IMPORT] dispatcher failed (rc=$dispatch_rc); trying legacy importer"
    fi

    perform_import_legacy "$container" "$backup_source_dir" "$restore_type" "$is_dry_run" "$pre_restore_dir"
}

# Legacy importer retained for backward compatibility with old backup layouts.
perform_import_legacy() {
    local container="$1"
    local backup_source_dir="$2"
    local restore_type="$3"
    local is_dry_run="${4:-false}"
    local pre_restore_dir="${5:-}"

    log DEBUG "[PERFORM_IMPORT] Starting shared import logic"
    log DEBUG "[PERFORM_IMPORT] Parameters: container=$container, source=$backup_source_dir, type=$restore_type, dry_run=$is_dry_run"

    # Set up container import paths
    local container_import_workflows="/tmp/import_workflows.json"
    local container_import_credentials="/tmp/import_credentials.json"

    # --- File Discovery ---
    local repo_workflows=""
    local repo_credentials=""
    local using_separate_files=false

    log INFO "Looking for backup files in: $backup_source_dir"

    # Check for separate files mode (workflows/ and/or credentials/ subdirectories)
    local has_workflows_dir=false
    local has_credentials_dir=false
    [ -d "$backup_source_dir/workflows" ] && has_workflows_dir=true
    [ -d "$backup_source_dir/credentials" ] && has_credentials_dir=true

    # If user explicitly requested --separate-files, enforce separate mode
    if [ "${ARG_SEPARATE_FILES:-}" = "true" ] || [ "${ARG_SEPARATE_FILES:-}" = "1" ]; then
        using_separate_files=true
        log INFO "[RESTORE_IMPORT] Separate files mode enforced by --separate-files"
        _discover_separate_files "$backup_source_dir" "$restore_type" "$has_workflows_dir" "$has_credentials_dir"
    elif $has_workflows_dir || $has_credentials_dir; then
        # Auto-detect separate files mode
        using_separate_files=true
        log INFO "[RESTORE_IMPORT] Detected separate files backup mode"
        _discover_separate_files "$backup_source_dir" "$restore_type" "$has_workflows_dir" "$has_credentials_dir"
    fi

    if ! $using_separate_files; then
        # Single file mode
        log INFO "[RESTORE_IMPORT] Detected single file backup mode"
        _discover_single_files "$backup_source_dir" "$restore_type"
    fi

    # --- File Validation ---
    log INFO "Validating files for import..."
    local file_validation_passed=true

    if [[ "$restore_type" == "all" || "$restore_type" == "workflows" ]]; then
        if $using_separate_files; then
            if [ ! -d "$repo_workflows" ] || [ "$(find "$repo_workflows" -name "*.json" 2>/dev/null | wc -l)" -eq 0 ]; then
                log ERROR "[RESTORE_VALIDATION] Valid workflows directory with JSON files not found"
                file_validation_passed=false
            else
                local workflow_count
                workflow_count=$(find "$repo_workflows" -name "*.json" | wc -l)
                log SUCCESS "[RESTORE_VALIDATION] Workflows directory validated ($workflow_count files)"
            fi
        else
            if [ ! -f "$repo_workflows" ] || [ ! -s "$repo_workflows" ]; then
                log ERROR "[RESTORE_VALIDATION] Valid workflows.json not found"
                file_validation_passed=false
            else
                log SUCCESS "[RESTORE_VALIDATION] Workflows file validated"
            fi
        fi
    fi

    if [[ "$restore_type" == "all" || "$restore_type" == "credentials" ]]; then
        if $using_separate_files; then
            if [ ! -d "$repo_credentials" ] || [ "$(find "$repo_credentials" -name "*.json" 2>/dev/null | wc -l)" -eq 0 ]; then
                log ERROR "[RESTORE_VALIDATION] Valid credentials directory with JSON files not found"
                file_validation_passed=false
            else
                local credential_count
                credential_count=$(find "$repo_credentials" -name "*.json" | wc -l)
                log SUCCESS "[RESTORE_VALIDATION] Credentials directory validated ($credential_count files)"
            fi
        else
            if [ ! -f "$repo_credentials" ] || [ ! -s "$repo_credentials" ]; then
                log ERROR "[RESTORE_VALIDATION] Valid credentials.json not found"
                file_validation_passed=false
            else
                log SUCCESS "[RESTORE_VALIDATION] Credentials file validated"
            fi
        fi
    fi

    if ! $file_validation_passed; then
        log ERROR "[RESTORE_VALIDATION] File validation failed. Import cannot proceed."
        if [ -n "$pre_restore_dir" ]; then
            log WARN "[RESTORE_VALIDATION] Pre-restore backup kept at: $pre_restore_dir"
        fi
        return 1
    fi

    log SUCCESS "All required files validated successfully."

    # --- Copy to Container ---
    log INFO "Copying files to container..."
    local copy_status="success"

    if [[ "$restore_type" == "all" || "$restore_type" == "workflows" ]]; then
        if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
            log DRYRUN "Would copy workflows to container"
        else
            if $using_separate_files; then
                log INFO "Copying workflows directory to container..."
                if dockExec "$container" "mkdir -p /tmp/import_workflows" && \
                   docker cp "$repo_workflows/." "${container}:/tmp/import_workflows/"; then
                    local wf_count
                    wf_count=$(find "$repo_workflows" -name "*.json" | wc -l)
                    log SUCCESS "Copied $wf_count workflow files to container"
                else
                    log ERROR "Failed to copy workflows directory to container."
                    copy_status="failed"
                fi
            else
                log INFO "Copying workflows file to container..."
                if docker cp "$repo_workflows" "${container}:${container_import_workflows}"; then
                    log SUCCESS "Copied workflows.json to container"
                else
                    log ERROR "Failed to copy workflows.json to container."
                    copy_status="failed"
                fi
            fi
        fi
    fi

    if [[ "$restore_type" == "all" || "$restore_type" == "credentials" ]]; then
        if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
            log DRYRUN "Would copy credentials to container"
        else
            if $using_separate_files; then
                log INFO "Copying credentials directory to container..."
                if dockExec "$container" "mkdir -p /tmp/import_credentials" && \
                   docker cp "$repo_credentials/." "${container}:/tmp/import_credentials/"; then
                    local cred_count
                    cred_count=$(find "$repo_credentials" -name "*.json" | wc -l)
                    log SUCCESS "Copied $cred_count credential files to container"
                else
                    log ERROR "Failed to copy credentials directory to container."
                    copy_status="failed"
                fi
            else
                log INFO "Copying credentials file to container..."
                if docker cp "$repo_credentials" "${container}:${container_import_credentials}"; then
                    log SUCCESS "Copied credentials.json to container"
                else
                    log ERROR "Failed to copy credentials.json to container."
                    copy_status="failed"
                fi
            fi
        fi
    fi

    if [ "$copy_status" = "failed" ]; then
        log ERROR "Failed to copy backup files to container. Aborting import."
        if [ -n "$pre_restore_dir" ]; then
            log WARN "Pre-restore backup kept at: $pre_restore_dir"
        fi
        return 1
    fi

    log SUCCESS "All files copied to container successfully."

    # --- Execute n8n Import ---
    _execute_imports "$container" "$restore_type" "$is_dry_run" "$using_separate_files" \
        "$container_import_workflows" "$container_import_credentials" \
        "$repo_workflows" "$repo_credentials" "$backup_source_dir"
}

# Internal: Discover files in separate-files mode
_discover_separate_files() {
    local backup_source_dir="$1"
    local restore_type="$2"
    local has_workflows_dir="$3"
    local has_credentials_dir="$4"

    if [[ "$restore_type" == "workflows" || "$restore_type" == "all" ]]; then
        if [ "$has_workflows_dir" = "true" ]; then
            local wf_count
            wf_count=$(find "$backup_source_dir/workflows" -name "*.json" -type f | wc -l)
            if [ "$wf_count" -gt 0 ]; then
                repo_workflows="$backup_source_dir/workflows"
                log SUCCESS "Found workflows directory with $wf_count files"
            else
                log WARN "Workflows directory is empty"
            fi
        fi
    fi

    if [[ "$restore_type" == "credentials" || "$restore_type" == "all" ]]; then
        if [ "$has_credentials_dir" = "true" ]; then
            local cred_count
            cred_count=$(find "$backup_source_dir/credentials" -name "*.json" -type f | wc -l)
            if [ "$cred_count" -gt 0 ]; then
                repo_credentials="$backup_source_dir/credentials"
                log SUCCESS "Found credentials directory with $cred_count files"
            else
                log WARN "Credentials directory is empty"
            fi
        fi
    fi
}

# Internal: Discover files in single-file mode
_discover_single_files() {
    local backup_source_dir="$1"
    local restore_type="$2"

    if [ -f "$backup_source_dir/workflows.json" ] && [[ "$restore_type" == "all" || "$restore_type" == "workflows" ]]; then
        repo_workflows="$backup_source_dir/workflows.json"
        log SUCCESS "Found workflows.json file"
    fi

    if [ -f "$backup_source_dir/credentials.json" ] && [[ "$restore_type" == "all" || "$restore_type" == "credentials" ]]; then
        repo_credentials="$backup_source_dir/credentials.json"
        log SUCCESS "Found credentials.json file"
    fi

    # If standard files not found, analyze any JSON files to determine content
    if [ -z "$repo_workflows" ] || [ -z "$repo_credentials" ]; then
        log DEBUG "[RESTORE_IMPORT] Standard files not found, analyzing JSON files for content"
        for json_file in "$backup_source_dir"/*.json; do
            if [ -f "$json_file" ]; then
                if [ -z "$repo_workflows" ] && [[ "$restore_type" == "all" || "$restore_type" == "workflows" ]]; then
                    if grep -q '"nodes":\|"connections":\|"workflow"' "$json_file" 2>/dev/null; then
                        repo_workflows="$json_file"
                        log SUCCESS "Found workflow data in: $(basename "$json_file")"
                    fi
                fi
                if [ -z "$repo_credentials" ] && [[ "$restore_type" == "all" || "$restore_type" == "credentials" ]]; then
                    if grep -q '"credentialData":\|"nodesAccess":\|"credential"' "$json_file" 2>/dev/null; then
                        repo_credentials="$json_file"
                        log SUCCESS "Found credential data in: $(basename "$json_file")"
                    fi
                fi
            fi
        done
    fi
}

# Internal: Execute the actual n8n import commands
_execute_imports() {
    local container="$1"
    local restore_type="$2"
    local is_dry_run="$3"
    local using_separate_files="$4"
    local container_import_workflows="$5"
    local container_import_credentials="$6"
    local repo_workflows="$7"
    local repo_credentials="$8"
    local backup_source_dir="$9"

    # Import workflows
    if [ -n "$repo_workflows" ] && [[ "$restore_type" == "all" || "$restore_type" == "workflows" ]]; then
        log INFO "Importing workflows into n8n..."
        local workflow_import_cmd
        local skip_workflow_import=false

        if [ "$using_separate_files" = "true" ]; then
            workflow_import_cmd="n8n import:workflow --separate --input=/tmp/import_workflows/"
        else
            workflow_import_cmd="n8n import:workflow --input=$container_import_workflows"
        fi

        # Add user/project assignment
        if [ -n "${ARG_USER_ID:-}" ]; then
            workflow_import_cmd="$workflow_import_cmd --userId=$ARG_USER_ID"
        fi
        if [ -n "${ARG_PROJECT_ID:-}" ]; then
            workflow_import_cmd="$workflow_import_cmd --projectId=$ARG_PROJECT_ID"
        fi

        # Handle new-only import mode
        if [ "${ARG_RESTORE_MODE:-}" = "new-only" ] || [ "${ARG_ONLY_NEW:-}" = "true" ] || [ "${ARG_ONLY_NEW:-}" = "1" ]; then
            if [ "$is_dry_run" != "true" ] && [ "$is_dry_run" != "1" ]; then
                log INFO "Detecting existing workflows for new-only import mode..."
                local existing_workflows
                existing_workflows=$(detect_existing_workflows "$container" 2>/dev/null | grep -v "^\[DEBUG\]" | grep -v "^[[:space:]]*$" | head -1)

                if [ -n "$existing_workflows" ]; then
                    log INFO "Found existing workflows - filtering to import only new items"

                    if [ "$using_separate_files" = "true" ]; then
                        local filtered_dir="/tmp/import_workflows_filtered"
                        if filter_separate_files_by_ids "$repo_workflows" "$filtered_dir" "$existing_workflows" "workflow"; then
                            local wf_count
                            wf_count=$(find "$filtered_dir" -name "*.json" 2>/dev/null | wc -l)
                            if [ "$wf_count" -eq 0 ]; then
                                log INFO "No new workflows to import (all existing). Skipping."
                                skip_workflow_import=true
                            else
                                dockExec "$container" "rm -rf /tmp/import_workflows && mkdir -p /tmp/import_workflows"
                                docker cp "$filtered_dir/." "${container}:/tmp/import_workflows/"
                                log SUCCESS "Filtered workflows synced to container ($wf_count files)"
                            fi
                        fi
                    else
                        local filtered_file="/tmp/import_workflows_filtered.json"
                        if filter_json_by_ids "$repo_workflows" "$filtered_file" "$existing_workflows" "workflow"; then
                            if docker cp "$filtered_file" "$container:/tmp/import_workflows_filtered.json"; then
                                workflow_import_cmd="n8n import:workflow --input=/tmp/import_workflows_filtered.json"
                                # Re-add user/project assignment
                                [ -n "${ARG_USER_ID:-}" ] && workflow_import_cmd="$workflow_import_cmd --userId=$ARG_USER_ID"
                                [ -n "${ARG_PROJECT_ID:-}" ] && workflow_import_cmd="$workflow_import_cmd --projectId=$ARG_PROJECT_ID"
                            fi
                        fi
                    fi
                else
                    log INFO "No existing workflows found - all workflows will be imported as new"
                fi
            fi
        fi

        if [ "$skip_workflow_import" = "true" ]; then
            log SUCCESS "Nothing to import for workflows."
        elif [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
            log DRYRUN "Would execute: $workflow_import_cmd"
        else
            if dockExec "$container" "$workflow_import_cmd"; then
                log SUCCESS "Workflows imported successfully"
            else
                log ERROR "Failed to import workflows"
                return 1
            fi
        fi
    fi

    # Import credentials
    if [ -n "$repo_credentials" ] && [[ "$restore_type" == "all" || "$restore_type" == "credentials" ]]; then
        log INFO "Importing credentials into n8n..."
        local credential_import_cmd

        if [ "$using_separate_files" = "true" ]; then
            credential_import_cmd="n8n import:credentials --separate --input=/tmp/import_credentials/"
        else
            credential_import_cmd="n8n import:credentials --input=$container_import_credentials"
        fi

        # Add user/project assignment
        if [ -n "${ARG_USER_ID:-}" ]; then
            credential_import_cmd="$credential_import_cmd --userId=$ARG_USER_ID"
        fi
        if [ -n "${ARG_PROJECT_ID:-}" ]; then
            credential_import_cmd="$credential_import_cmd --projectId=$ARG_PROJECT_ID"
        fi

        if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
            log DRYRUN "Would execute: $credential_import_cmd"
        else
            if dockExec "$container" "$credential_import_cmd"; then
                log SUCCESS "Credentials imported successfully"
            else
                log ERROR "Failed to import credentials"
                return 1
            fi
        fi
    fi

    # Import enterprise entities if available
    if [[ "$restore_type" == "all" || "$restore_type" == "enterprise" ]]; then
        local entities_dir=""
        # Check multiple possible locations for entities directory
        if [ -d "$backup_source_dir/entities" ]; then
            entities_dir="$backup_source_dir/entities"
        elif [ -d "$(dirname "$backup_source_dir")/entities" ]; then
            entities_dir="$(dirname "$backup_source_dir")/entities"
        fi

        if [ -n "$entities_dir" ] && [ -d "$entities_dir" ]; then
            log INFO "Detected enterprise entity files — importing..."
            if import_enterprise_entities "$container" "$entities_dir" "$is_dry_run"; then
                log SUCCESS "Enterprise entities imported"
            else
                if [[ "$restore_type" == "enterprise" ]]; then
                    log ERROR "Enterprise entity import failed"
                    return 1
                else
                    log WARN "Enterprise entity import failed — workflow/credential import was successful"
                fi
            fi
        else
            if [[ "$restore_type" == "enterprise" ]]; then
                log ERROR "No enterprise entity files found in backup"
                return 1
            else
                log DEBUG "[PERFORM_IMPORT] No entities/ directory found — skipping enterprise import"
            fi
        fi
    fi

    log SUCCESS "All import operations completed successfully."
    return 0
}

