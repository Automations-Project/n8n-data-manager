#!/usr/bin/env bash

# :wrapper.bash3_bouncer
if ((BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 2))); then
  printf "bash version 4.2 or higher is required\n" >&2
  exit 1
fi

# :command.master_script

# :command.version_command
version_command() {
  echo "$version"
}

# :command.usage
n8n_manager_usage() {
  printf "n8n-manager - Backup & Restore manager for n8n Docker instances via GitHub\n\n"

  printf "%s\n" "Usage:"
  printf "  n8n-manager COMMAND\n"
  printf "  n8n-manager [COMMAND] --help | -h\n"
  printf "  n8n-manager --version | -v\n"
  echo
  # :command.usage_commands
  printf "%s\n" "Data Commands:"
  printf "  %s   Backup n8n data to GitHub\n" "backup        "
  printf "  %s   Restore n8n data from GitHub\n" "restore       "
  printf "  %s   Import n8n data from a direct URL (.json or .zip)\n" "import-url    "
  echo
  printf "%s\n" "System Commands:"
  printf "  %s   Install n8n-manager globally so it can be run from anywhere\n" "install       "
  printf "  %s   Check for updates and self-update n8n-manager to the latest version\n" "update        "
  printf "  %s   Remove n8n-manager from the system\n" "uninstall     "
  echo
  printf "%s\n" "Workflow Commands:"
  printf "  %s   Manage n8n workflow files (.n8n)\n" "workflow      "
  echo
  printf "%s\n" "Migration Commands:"
  printf "  %s   Convert a v4-shape backup repo to v5 canonical layout\n" "migrate       "
  printf "  %s   Translate a v4 n8n-manager config file to v5 format (atomic, idempotent)\n" "migrate-config"
  echo

  # :command.long_usage
  if [[ -n "$long_usage" ]]; then
    # :command.usage_options
    printf "%s\n" "Options:"

    # :command.usage_fixed_flags
    printf "  %s\n" "--help, -h"
    printf "    Show this help\n"
    echo
    printf "  %s\n" "--version, -v"
    printf "    Show version number\n"
    echo

  fi
}

