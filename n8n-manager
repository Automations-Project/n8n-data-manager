# Interactive file picker — returns selected file path
# Usage: selected=$(ui_file_picker "/path/to/dir" ["Pick a file"])
#        selected=$(ui_file_picker "/path" "title" "directory")  # dirs only
ui_file_picker() {
    local start_dir="${1:-.}"
    local title="${2:-Select a file}"
    local mode="${3:-file}"  # "file" or "directory"

    if $HAS_GUM; then
        local flags=(
            --height 12
            --cursor.foreground $THEME_CURSOR
            --symlink.foreground $THEME_TEXT_DIM
            --directory.foreground $THEME_LINK
            --file.foreground $THEME_TEXT
            --permissions.foreground $THEME_TEXT_DIM
            --selected.foreground $THEME_PRIMARY
            --header "$title"
            --header.foreground $THEME_INFO
        )
        [ "$mode" = "directory" ] && flags+=(--directory)
        gum file "${flags[@]}" "$start_dir"
    else
        echo "$title" >&2
        if [ "$mode" = "directory" ]; then
            local dirs=()
            while IFS= read -r d; do dirs+=("$d"); done < <(find "$start_dir" -maxdepth 2 -type d 2>/dev/null | head -20)
        else
            local dirs=()
            while IFS= read -r d; do dirs+=("$d"); done < <(find "$start_dir" -maxdepth 2 -type f 2>/dev/null | head -20)
        fi
        if [ ${#dirs[@]} -eq 0 ]; then
            echo "$start_dir"
            return
        fi
        local i=1
        for item in "${dirs[@]}"; do echo "  $i) $item" >&2; i=$((i+1)); done
        printf "Select [1-%d]: " "${#dirs[@]}" >&2
        local choice
        read -r choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#dirs[@]}" ]; then
            echo "${dirs[$((choice-1))]}"
        else
            echo "${dirs[0]}"
        fi
    fi
}

