try:
    file = sys.argv[1]
    with open(file) as f: d = json.load(f)
    before = len(d.get('nodes', []))
    d['nodes'] = [n for n in d.get('nodes', []) if n.get('name') != 'OnlyForMCP']
    removed = before - len(d['nodes'])
    with open(file, 'w') as f: json.dump(d, f, indent=2)
