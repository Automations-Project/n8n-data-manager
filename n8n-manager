_sc_import_strip_ids_in_dir() {
    local source_dir="$1"
    local output_dir="$2"
    local label="$3"
    mkdir -p "$output_dir"

    shopt -s nullglob
    local f
    for f in "$source_dir"/*.json; do
        local base tmp
        base=$(basename "$f")
        tmp="$output_dir/$base"
        if declare -F strip_json_ids >/dev/null 2>&1; then
            if ! strip_json_ids "$f" "$tmp"; then
                shopt -u nullglob
                log ERROR "[SC-IMPORT] failed stripping IDs in $f"
                return 1
            fi
        elif command_exists python3; then
            python3 - "$f" "$tmp" <<'PY'
import json, sys
src, dst = sys.argv[1], sys.argv[2]
def walk(v):
    if isinstance(v, dict):
        v.pop("id", None)
        for x in v.values():
            walk(x)
    elif isinstance(v, list):
        for x in v:
            walk(x)
with open(src, "r", encoding="utf-8") as fh:
    data = json.load(fh)
walk(data)
with open(dst, "w", encoding="utf-8") as fh:
    json.dump(data, fh, indent=2)
PY
            if [ $? -ne 0 ]; then
                shopt -u nullglob
                log ERROR "[SC-IMPORT] failed stripping IDs in $f"
                return 1
            fi
        else
            shopt -u nullglob
            log ERROR "[SC-IMPORT] import-as-new requested but no ID stripping helper is available"
            return 1
        fi
    done
    shopt -u nullglob

    log INFO "[SC-IMPORT] import-as-new applied to $label payload"
    return 0
}

_sc_import_write_desired_state() {
    local source_dir="$1"
    local output_json="$2"

    if ! command_exists python3; then
        log ERROR "python3 is required for canonical restore planner"
        return 1
    fi

    python3 - "$source_dir" > "$output_json" <<'PY'
import json, sys
from pathlib import Path

root = Path(sys.argv[1])

def ids_from_dir(path):
    p = root / path
    if not p.exists():
        return []
    return sorted([f.stem for f in p.glob('*.json') if f.is_file()])

def ids_from_json(path, key='id'):
    p = root / path
    if not p.exists():
        return []
    try:
        data = json.loads(p.read_text(encoding='utf-8'))
    except Exception:
        return []

    if isinstance(data, dict):
        if key in data:
            return [str(data.get(key))]
        out = []
        for candidate in data.values():
            if isinstance(candidate, list):
                out.extend([str(x.get(key)) for x in candidate if isinstance(x, dict) and x.get(key) is not None])
        return sorted(set([x for x in out if x]))
    if isinstance(data, list):
        return sorted(set([str(x.get(key)) for x in data if isinstance(x, dict) and x.get(key) is not None]))
    return []

def union_ids(*paths):
    out = set()
    for p in paths:
        out.update(ids_from_dir(p))
    return sorted(out)

state = {
    'workflows': ids_from_dir('workflows'),
    'credentials': union_ids('credential_stubs', 'credentials'),
    'projects': ids_from_dir('projects'),
    'tags': ids_from_json('tags.json'),
    'variables': ids_from_json('variable_stubs.json'),
    'folders': ids_from_json('folders.json'),
    'datatables': ids_from_dir('datatables'),
}
print(json.dumps(state, indent=2))
PY
}

