# ═══════════════════════════════════════════════════════════
# MCP Enable/Disable Orchestration
# ═══════════════════════════════════════════════════════════

# Enable MCP on a workflow — handles trigger injection if needed
# Args: $1=file path
# Returns: 0 on success
wf_mcp_enable() {
    local file="$1"
    local basename_file
    basename_file=$(basename "$file")

    # Check for existing triggers
    local triggers
    triggers=$(wf_mcp_check_triggers "$file")

    if [ -n "$triggers" ]; then
        log DEBUG "  Existing MCP-compatible triggers found in $basename_file"
    else
        # No triggers — need to inject stub
        log WARN "  $basename_file has no MCP-compatible trigger"

        if [ -t 0 ]; then
            local confirm
            confirm=$(ui_confirm "Inject OnlyForMCP webhook stub trigger?" "Yes" "No")
            if [ $? -ne 0 ]; then
                log WARN "  Skipping MCP enable for $basename_file (no trigger)"
                return 1
            fi
        fi

        local result
        result=$(wf_mcp_inject_trigger "$file")
        case "$result" in
            injected)       log SUCCESS "  Injected OnlyForMCP stub trigger" ;;
            already_exists) log INFO "  OnlyForMCP stub already present" ;;
            *)              log ERROR "  Failed to inject trigger stub"; return 1 ;;
        esac
    fi

    # Enable mcpEnabled setting
    wf_update_setting "$file" "mcpEnabled" "true"
    return $?
}

# Disable MCP on a workflow — offers to remove stub trigger
# Args: $1=file path
# Returns: 0 on success
wf_mcp_disable() {
    local file="$1"
    local basename_file
    basename_file=$(basename "$file")

    # Disable mcpEnabled
    wf_update_setting "$file" "mcpEnabled" "false" || return 1

    # Check for OnlyForMCP stub and offer removal
    if wf_mcp_has_stub_trigger "$file"; then
        local should_remove=true

        if [ -t 0 ]; then
            ui_confirm "Remove OnlyForMCP stub trigger?" "Yes" "No"
            if [ $? -ne 0 ]; then
                should_remove=false
            fi
        fi

        if [ "$should_remove" = "true" ]; then
            local result
            result=$(wf_mcp_remove_trigger "$file")
            case "$result" in
                removed)   log SUCCESS "  Removed OnlyForMCP stub trigger" ;;
                not_found) log DEBUG "  OnlyForMCP stub not found" ;;
                *)         log WARN "  Failed to remove stub trigger" ;;
            esac
        else
            log INFO "  OnlyForMCP stub trigger kept"
        fi
    fi

    return 0
}

