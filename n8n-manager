_sc_export_write_combined_bundle() {
    local root="$1"
    local backup_type="$2"
    local credential_mode="$3"
    local output_file="$4"

    if ! command_exists python3; then
        log ERROR "python3 is required to build combined backup bundle"
        return 1
    fi

    python3 - "$root" "$backup_type" "$credential_mode" "$output_file" <<'PY'
import json
import sys
from datetime import datetime, timezone
from pathlib import Path

root = Path(sys.argv[1])
backup_type = sys.argv[2]
credential_mode = sys.argv[3]
output_file = Path(sys.argv[4])

def load_json(path, default):
    p = root / path
    if not p.exists():
        return default
    try:
        return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        return default

def load_dir(dir_name):
    out = []
    d = root / dir_name
    if not d.exists():
        return out
    for f in sorted(d.glob("*.json")):
        try:
            out.append(json.loads(f.read_text(encoding="utf-8")))
        except Exception:
            continue
    return out

bundle = {
    "formatVersion": 1,
    "bundleType": "combined",
    "extension": "n8n.backups",
    "createdAt": datetime.now(timezone.utc).isoformat(),
    "backupType": backup_type,
    "credentialMode": credential_mode,
    "data": {
        "workflows": load_dir("workflows"),
        "credentialStubs": load_dir("credential_stubs"),
        "credentials": load_dir("credentials"),
        "projects": load_dir("projects"),
        "datatables": load_dir("datatables"),
        "tags": load_json("tags.json", {"tags": [], "mappings": []}),
        "variableStubs": load_json("variable_stubs.json", []),
        "folders": load_json("folders.json", {"folders": []}),
        "workflowOwners": load_json("workflow_owners.json", {"workflowOwners": []}),
    },
    "sidecar": {
        "manifest": load_json(".n8n-manager/manifest.json", {}),
        "capabilities": load_json(".n8n-manager/capabilities.json", {}),
        "checksums": load_json(".n8n-manager/checksums.json", {}),
        "gaps": load_json(".n8n-manager/gaps.json", []),
    },
}

output_file.write_text(json.dumps(bundle, indent=2), encoding="utf-8")
PY
}

_sc_export_write_workflow_bundles() {
    local root="$1"
    local backup_type="$2"
    local credential_mode="$3"
    local selected_csv="$4"

    if ! command_exists python3; then
        log ERROR "python3 is required to build workflow bundles"
        return 1
    fi

    python3 - "$root" "$backup_type" "$credential_mode" "$selected_csv" <<'PY'
import json
import sys
from datetime import datetime, timezone
from pathlib import Path

root = Path(sys.argv[1])
backup_type = sys.argv[2]
credential_mode = sys.argv[3]
selected_csv = sys.argv[4].strip()
selected_ids = [x.strip() for x in selected_csv.split(",") if x.strip()]

wf_dir = root / "workflows"
if not wf_dir.exists():
    raise SystemExit(0)

def load_json(path, default):
    p = root / path
    if not p.exists():
        return default
    try:
        return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        return default

def to_list(v):
    if isinstance(v, list):
        return v
    if isinstance(v, dict):
        for candidate in v.values():
            if isinstance(candidate, list):
                return candidate
    return []

workflows = {}
for f in sorted(wf_dir.glob("*.json")):
    try:
        w = json.loads(f.read_text(encoding="utf-8"))
    except Exception:
        continue
    wid = str(w.get("id") or f.stem)
    workflows[wid] = w

if not selected_ids:
    selected_ids = sorted(workflows.keys())

def collect_workflow_refs(obj, refs):
    if isinstance(obj, dict):
        for k, v in obj.items():
            if k.lower() in {"workflowid", "workflow_id"}:
                if isinstance(v, (str, int)):
                    val = str(v).strip()
                    if val:
                        refs.add(val)
                elif isinstance(v, dict):
                    cand = v.get("value") or v.get("id")
                    if cand is not None:
                        val = str(cand).strip()
                        if val:
                            refs.add(val)
            collect_workflow_refs(v, refs)
    elif isinstance(obj, list):
        for x in obj:
            collect_workflow_refs(x, refs)

outgoing = {wid: set() for wid in workflows}
for wid, wf in workflows.items():
    refs = set()
    collect_workflow_refs(wf.get("nodes", []), refs)
    for r in refs:
        if r in workflows and r != wid:
            outgoing[wid].add(r)

incoming = {wid: set() for wid in workflows}
for src, tgts in outgoing.items():
    for tgt in tgts:
        incoming[tgt].add(src)

credentials_full = {}
for f in sorted((root / "credentials").glob("*.json")):
    try:
        data = json.loads(f.read_text(encoding="utf-8"))
    except Exception:
        continue
    cid = str(data.get("id") or f.stem)
    credentials_full[cid] = data

credentials_stub = {}
for f in sorted((root / "credential_stubs").glob("*.json")):
    try:
        data = json.loads(f.read_text(encoding="utf-8"))
    except Exception:
        continue
    cid = str(data.get("id") or f.stem)
    credentials_stub[cid] = data

tags_doc = load_json("tags.json", {"tags": [], "mappings": []})
tags = to_list(tags_doc.get("tags", []))
mappings = to_list(tags_doc.get("mappings", []))

folders_doc = load_json("folders.json", {"folders": []})
folders = to_list(folders_doc.get("folders", []))
folder_map = {str(f.get("id")): f for f in folders if isinstance(f, dict) and f.get("id") is not None}

workflow_owners_doc = load_json("workflow_owners.json", {"workflowOwners": []})
workflow_owners = to_list(workflow_owners_doc.get("workflowOwners", []))

projects = {}
for f in sorted((root / "projects").glob("*.json")):
    try:
        p = json.loads(f.read_text(encoding="utf-8"))
    except Exception:
        continue
    pid = str(p.get("id") or f.stem)
    projects[pid] = p

def workflow_credential_ids(wf):
    out = set()
    for node in wf.get("nodes", []) or []:
        creds = node.get("credentials")
        if not isinstance(creds, dict):
            continue
        for info in creds.values():
            if isinstance(info, dict) and info.get("id") is not None:
                out.add(str(info.get("id")))
    return out

def connected_workflows(seed):
    if seed not in workflows:
        return set()
    seen = {seed}
    q = [seed]
    while q:
        cur = q.pop(0)
        for nxt in sorted(outgoing.get(cur, set()) | incoming.get(cur, set())):
            if nxt not in seen:
                seen.add(nxt)
                q.append(nxt)
    return seen

for seed in selected_ids:
    included_ids = sorted(connected_workflows(seed))
    if not included_ids:
        continue
    included_wf = [workflows[x] for x in included_ids]

    cred_ids = set()
    for wf in included_wf:
        cred_ids.update(workflow_credential_ids(wf))

    included_credentials = [credentials_full[c] for c in sorted(cred_ids) if c in credentials_full]
    included_credential_stubs = [credentials_stub[c] for c in sorted(cred_ids) if c in credentials_stub]

    included_mappings = [
        m for m in mappings
        if isinstance(m, dict) and str(m.get("workflowId") or m.get("workflow_id") or "") in included_ids
    ]
    tag_ids = {str(m.get("tagId") or m.get("tag_id")) for m in included_mappings if isinstance(m, dict)}
    included_tags = [t for t in tags if isinstance(t, dict) and str(t.get("id")) in tag_ids]

    folder_ids = set()
    for wf in included_wf:
        for k in ("parentFolderId", "folderId", "homeFolderId"):
            if wf.get(k) is not None:
                folder_ids.add(str(wf.get(k)))

    # include ancestor folders
    pending = list(folder_ids)
    while pending:
        fid = pending.pop()
        f = folder_map.get(fid)
        if not isinstance(f, dict):
            continue
        parent = f.get("parentFolderId") or f.get("parentId")
        if parent is not None:
            p = str(parent)
            if p not in folder_ids:
                folder_ids.add(p)
                pending.append(p)

    included_folders = [folder_map[fid] for fid in sorted(folder_ids) if fid in folder_map]

    owner_rows = [
        row for row in workflow_owners
        if isinstance(row, dict) and str(row.get("workflowId") or row.get("workflow_id") or "") in included_ids
    ]

    project_ids = set()
    for wf in included_wf:
        for k in ("projectId", "homeProjectId"):
            if wf.get(k) is not None:
                project_ids.add(str(wf.get(k)))
    for row in owner_rows:
        if row.get("projectId") is not None:
            project_ids.add(str(row.get("projectId")))
    included_projects = [projects[p] for p in sorted(project_ids) if p in projects]

    bundle = {
        "formatVersion": 1,
        "bundleType": "workflow",
        "extension": "n8n.backup",
        "createdAt": datetime.now(timezone.utc).isoformat(),
        "backupType": backup_type,
        "credentialMode": credential_mode,
        "seedWorkflowId": seed,
        "includedWorkflowIds": included_ids,
        "includedCredentialIds": sorted(cred_ids),
        "data": {
            "workflows": included_wf,
            "credentialStubs": included_credential_stubs,
            "credentials": included_credentials,
            "tags": {"tags": included_tags, "mappings": included_mappings},
            "folders": {"folders": included_folders},
            "workflowOwners": {"workflowOwners": owner_rows},
            "projects": included_projects,
        },
    }

    out_file = root / f"{seed}.n8n.backup"
    out_file.write_text(json.dumps(bundle, indent=2), encoding="utf-8")
PY
}

sc_export_finalize_layout_variant() {
    local output_root="$1"
    local backup_type="$2"
    local backup_layout="${3:-canonical}"
    local is_dry_run="${4:-false}"

    case "$backup_layout" in
        canonical|"")
            return 0
            ;;
        combined)
            if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
                log DRYRUN "Would pack canonical export into data.n8n.backups"
                return 0
            fi
            local credential_mode
            credential_mode=$(_sc_export_resolve_credential_mode)
            _sc_export_write_combined_bundle "$output_root" "$backup_type" "$credential_mode" "$output_root/data.n8n.backups" || return 1
            if [ ! -f "$output_root/data.n8n.backups" ]; then
                log ERROR "[SC-EXPORT] combined bundle file was not created"
                return 1
            fi
            _sc_export_bundle_cleanup_canonical_payload "$output_root"
            log INFO "[SC-EXPORT] created combined bundle: data.n8n.backups"
            return 0
            ;;
        workflow-bundles)
            if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
                log DRYRUN "Would generate workflow dependency bundles (*.n8n.backup)"
                return 0
            fi
            local selected_ids_csv="${ARG_WORKFLOW_ID:-}"
            local credential_mode
            credential_mode=$(_sc_export_resolve_credential_mode)
            _sc_export_write_workflow_bundles "$output_root" "$backup_type" "$credential_mode" "$selected_ids_csv" || return 1
            local bundle_count
            bundle_count=$(find "$output_root" -maxdepth 1 -type f -name '*.n8n.backup' 2>/dev/null | wc -l | xargs)
            if [ "${bundle_count:-0}" -eq 0 ]; then
                log ERROR "[SC-EXPORT] no workflow bundle files were generated"
                return 1
            fi
            _sc_export_bundle_cleanup_canonical_payload "$output_root"
            log INFO "[SC-EXPORT] created workflow bundle files (*.n8n.backup)"
            return 0
            ;;
        *)
            log ERROR "[SC-EXPORT] unsupported backup layout: $backup_layout"
            return 1
            ;;
    esac
}

sc_export_canonical_backup() {
    local container="$1"
    local output_root="$2"
    local backup_type="$3"
    local is_dry_run="${4:-false}"

    local strict_mode=false
    [ "$backup_type" = "enterprise" ] && strict_mode=true
    local credential_export_mode
    credential_export_mode=$(_sc_export_resolve_credential_mode)

    # ── Phase 3 (D-02): refuse backup writes on legacy-partial source repos.
    # If this output_root already has BOTH v4 markers (workflows.json) AND canonical
    # markers (workflows/ etc.), writing more canonical files would deepen the
    # mixed-shape ambiguity that causes downstream dispatcher misdetection.
    # The user must resolve via `migrate` first or move v4 files aside manually.
    local repo_layout
    repo_layout=$(sc_layout_detect "$output_root" 2>/dev/null || echo "unknown")
    if [ "$repo_layout" = "legacy-partial" ]; then
        log ERROR "Source repo at $output_root has both v4 (workflows.json) and v5 (workflows/) markers."
        log ERROR "Resolve with: n8n-manager migrate --source $output_root"
        log ERROR "Or move v4 files aside before backup."
        return 1
    fi

    local only_new=false
    _sc_export_is_enabled "${ARG_ONLY_NEW:-}" && only_new=true

    local repo_root="$output_root"
    if [[ "$(basename "$output_root")" == backup_* ]]; then
        repo_root="$(dirname "$output_root")"
    fi

    local existing_workflow_ids_csv=""
    local existing_credential_ids_csv=""
    if $only_new; then
        existing_workflow_ids_csv=$(_sc_export_collect_existing_ids "$repo_root" "workflows")
        existing_credential_ids_csv=$(
            _sc_export_merge_csv_ids \
                "$(_sc_export_collect_existing_ids "$repo_root" "credential_stubs")" \
                "$(_sc_export_collect_existing_ids "$repo_root" "credentials")"
        )
    fi

    n8n_probe_runtime "$container" "${ARG_N8N_API_KEY:-}" "${ARG_N8N_API_URL:-}"

    sc_layout_prepare_root "$output_root"
    n8n_probe_write_capabilities_file "$(sc_layout_capabilities_path "$output_root")"

    local export_workflows=false
    local export_credentials=false
    local export_metadata=false

    case "$backup_type" in
        all)
            export_workflows=true
            export_credentials=true
            export_metadata=true
            ;;
        workflows)
            export_workflows=true
            ;;
        credentials)
            export_credentials=true
            ;;
        enterprise)
            export_metadata=true
            ;;
        *)
            export_workflows=true
            export_credentials=true
            export_metadata=true
            ;;
    esac

    # Feature-parity behaviors for selective workflows/credentials:
    # when explicit IDs are provided in all-mode, avoid exporting unrelated scope.
    if [ -n "${ARG_WORKFLOW_ID:-}" ] && [ "$backup_type" = "all" ]; then
        export_credentials=false
    fi
    if [ -n "${ARG_CREDENTIAL_ID:-}" ] && [ "$backup_type" = "all" ]; then
        export_workflows=false
    fi
    if [ -n "${ARG_WORKFLOW_ID:-}" ] && [ "$backup_type" = "all" ] && \
       ( _sc_export_is_enabled "${ARG_INCLUDE_LINKED_CREDS:-}" || [ -n "${ARG_CREDENTIAL_ID:-}" ] ); then
        export_credentials=true
    fi
    if [ "$backup_type" = "workflows" ] && \
       ( _sc_export_is_enabled "${ARG_INCLUDE_LINKED_CREDS:-}" || [ -n "${ARG_CREDENTIAL_ID:-}" ] ); then
        export_credentials=true
    fi

    if $export_workflows; then
        if [ "${N8N_PROBE_CLI_EXPORT_WORKFLOW:-false}" != "true" ]; then
            sc_layout_add_gap "$output_root" "workflows" "n8n export:workflow unsupported"
            log WARN "[SC-EXPORT] workflow export command unavailable"
            if $strict_mode; then
                return 1
            fi
        else
            _sc_export_workflows_cli "$container" "$output_root" "$is_dry_run" "$existing_workflow_ids_csv" || return 1
        fi
    fi

    if $export_credentials; then
        local credential_filter_csv="${ARG_CREDENTIAL_ID:-}"
        log INFO "[SC-EXPORT] credential export mode: $credential_export_mode"
        if _sc_export_should_collect_linked_credentials "$backup_type"; then
            local linked_csv
            linked_csv=$(_sc_export_collect_linked_credential_ids "$output_root/workflows")
            if [ -n "$linked_csv" ]; then
                credential_filter_csv=$(_sc_export_merge_csv_ids "$credential_filter_csv" "$linked_csv")
                log INFO "[SC-EXPORT] linked credentials auto-included"
            elif [ -n "${ARG_WORKFLOW_ID:-}" ]; then
                log WARN "[SC-EXPORT] linked credential discovery found no credential IDs"
            fi
        elif _sc_export_is_enabled "${ARG_INCLUDE_LINKED_CREDS:-}" && [ "$backup_type" = "all" ] && [ -z "${ARG_WORKFLOW_ID:-}" ]; then
            log INFO "[SC-EXPORT] linked credential auto-include skipped (all credentials already in scope)"
        fi

        if [ "${N8N_PROBE_CLI_EXPORT_CREDENTIALS:-false}" != "true" ]; then
            sc_layout_add_gap "$output_root" "credentials" "n8n export:credentials unsupported"
            log WARN "[SC-EXPORT] credential export command unavailable"
            if $strict_mode; then
                return 1
            fi
        else
            case "$credential_export_mode" in
                encrypted|decrypted)
                    _sc_export_credentials_full_cli \
                        "$container" \
                        "$output_root" \
                        "$is_dry_run" \
                        "$credential_export_mode" \
                        "$credential_filter_csv" \
                        "$existing_credential_ids_csv" || return 1
                    ;;
                *)
                    _sc_export_credentials_stubs_cli \
                        "$container" \
                        "$output_root" \
                        "$is_dry_run" \
                        "$credential_filter_csv" \
                        "$existing_credential_ids_csv" || return 1
                    ;;
            esac
        fi
    fi

    if $export_metadata; then
        _sc_export_metadata_with_fallback "$container" "$output_root" "$strict_mode" "$is_dry_run" || return 1
    fi

    sc_export_ensure_defaults "$output_root"
    sc_layout_write_manifest "$output_root" "$backup_type" "$container" "cli,api,db"
    sc_layout_write_checksums "$output_root"

    return 0
}

