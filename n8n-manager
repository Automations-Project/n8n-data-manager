# Check if a command exists on the host
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Check required host dependencies — beginner-friendly error messages
# Set SKIP_DOCKER_CHECK=true before calling setup_globals to skip Docker/git checks
# (used by workflow subcommands that only need filesystem access)
check_host_dependencies() {
    log DEBUG "[DEPS] Checking host dependencies..."

    # Workflow-only mode: skip Docker and git checks
    if [ "${SKIP_DOCKER_CHECK:-false}" = "true" ]; then
        log DEBUG "[DEPS] Docker check skipped (workflow-only mode)"
        return 0
    fi

    local missing=()
    local install_hints=()

    if ! command_exists docker; then
        missing+=("docker")
        install_hints+=("  Docker — Install Docker Desktop: https://docs.docker.com/get-docker/")
    fi
    if ! command_exists git; then
        missing+=("git")
        install_hints+=("  Git    — Install from: https://git-scm.com/downloads")
    fi
    if ! command_exists curl; then
        missing+=("curl")
        install_hints+=("  curl   — Linux: apt install curl | Mac: brew install curl")
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        log ERROR "Missing required tools: ${missing[*]}"
        echo "" >&2
        log INFO "n8n-manager needs the following tools installed:"
        for hint in "${install_hints[@]}"; do
            log INFO "$hint"
        done
        exit 1
    fi

    # Verify Docker is running
    if ! docker info >/dev/null 2>&1; then
        log ERROR "Docker is installed but not running."
        log INFO "How to start Docker:"
        log INFO "  • Docker Desktop — Open the Docker Desktop app"
        log INFO "  • Linux server   — Run: sudo systemctl start docker"
        log INFO "  • Then try running n8n-manager again."
        exit 1
    fi

    log DEBUG "[DEPS] All dependencies satisfied"
}

# Determine if a container is likely an n8n instance
is_n8n_container_candidate() {
    local name="$1"
    local image="$2"
    local ports="$3"

    # Check by image name
    if [[ "$image" == *"n8n"* ]]; then
        return 0
    fi
    # Check by container name
    if [[ "$name" == *"n8n"* ]]; then
        return 0
    fi
    # Check by port (5678 is n8n's default)
    if [[ "$ports" == *"5678"* ]]; then
        return 0
    fi

    return 1
}

# Execute a command inside a Docker container
dockExec() {
    local container_id="$1"
    local cmd="$2"

    log DEBUG "[DOCKER] Executing in container $container_id: $cmd"

    if [ "${ARG_DRY_RUN:-}" = "1" ]; then
        log DRYRUN "Would execute in container: $cmd"
        return 0
    fi

    docker exec "$container_id" sh -c "$cmd"
    local exit_code=$?

    if [ $exit_code -ne 0 ]; then
        log DEBUG "[DOCKER] Command exited with code: $exit_code"
    fi

    return $exit_code
}

# Execute a command inside a Docker container using a login shell (sh -lc).
# Use this variant when the command requires a login environment (e.g. PATH from
# /etc/profile.d — needed by runtime probes that call n8n from its install path).
# Never use in dry-run-sensitive paths; probe commands are always read-only.
dockExecLogin() {
    local container_id="$1"
    local cmd="$2"

    log DEBUG "[DOCKER] Executing (login shell) in container $container_id: $cmd"

    docker exec "$container_id" sh -lc "$cmd"
    local exit_code=$?

    if [ $exit_code -ne 0 ]; then
        log DEBUG "[DOCKER] Login-shell command exited with code: $exit_code"
    fi

    return $exit_code
}

# Execute a command in a container with stdin attached (-i flag).
# Use only when piping content into the container (e.g. writing a script file via
# a heredoc). This is the sole approved pattern for docker exec -i outside
# docker_helpers.sh; callers pipe data to this function on stdin.
dockExecStdin() {
    local container_id="$1"
    local cmd="$2"

    log DEBUG "[DOCKER] Executing (stdin) in container $container_id: $cmd"

    docker exec -i "$container_id" sh -c "$cmd"
    local exit_code=$?

    if [ $exit_code -ne 0 ]; then
        log DEBUG "[DOCKER] Stdin-attached command exited with code: $exit_code"
    fi

    return $exit_code
}

