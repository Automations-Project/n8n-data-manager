          log INFO "Usage: n8n-manager workflow publish --file path.n8n"
          exit 1
      fi
  fi

  if [ ${#files_to_process[@]} -eq 0 ]; then
      log ERROR "No files to process"
      exit 1
  fi

  # ── Publish workflows ────────────────────────────

  ui_header "Publish Workflows"
  echo "" >&2

  local published=0
  local is_live=false
  [[ "$ARG_LIVE" == "1" ]] && is_live=true

  # Live mode needs Docker
  if [ "$is_live" = "true" ]; then
      if [ -z "$ARG_CONTAINER" ]; then
          log ERROR "--container is required for --live mode"
          exit 1
      fi
      if ! command_exists docker; then
          log ERROR "Docker is required for --live mode"
          exit 1
      fi
      # Confirm live activation
      if [ -t 0 ]; then
          ui_confirm "Activate ${#files_to_process[@]} workflow(s) LIVE in container $ARG_CONTAINER?" || exit 0
      fi
  fi

  for file in "${files_to_process[@]}"; do
      local basename_file
      basename_file=$(basename "$file")

      # Get workflow ID
      local wf_id
      wf_id=$(wf_get_field "$file" "id")
      if [ -z "$wf_id" ]; then
          log WARN "  ⏭ $basename_file — no workflow ID, skipping"
          continue
      fi

      # Local mode: set active=true in JSON
      wf_set_field "$file" "active" "true"
      if [ $? -eq 0 ]; then
          log SUCCESS "  ✔ $basename_file — active=true (local)"
          published=$((published + 1))
      else
          log ERROR "  ✖ $basename_file — failed to set active"
          continue
      fi

      # Live mode: also activate in running n8n container
      if [ "$is_live" = "true" ]; then
          if [[ "${ARG_DRY_RUN:-}" == "1" ]]; then
              log DRYRUN "  Would run: n8n update:workflow --id=$wf_id --active=true"
          else
              local result
              result=$(dockExec "$ARG_CONTAINER" "n8n update:workflow --id=$wf_id --active=true" 2>&1)
              if [ $? -eq 0 ]; then
                  log SUCCESS "  ✔ $basename_file — activated in container $ARG_CONTAINER"
              else
                  log WARN "  ⚠ $basename_file — live activation failed: $result"
              fi
          fi
      fi
  done

  echo "" >&2
  ui_summary "Publish Complete" \
      "Published" "$published of ${#files_to_process[@]}" \
      "Mode" "$([ "$is_live" = "true" ] && echo "local + live ($ARG_CONTAINER)" || echo "local only")"

}

# :command.function
n8n_manager_workflow_unpublish_command() {

  # src/workflow_unpublish_command.sh

  set -Eeuo pipefail
  IFS=$'\n\t'

  # Skip Docker check for local-only mode; --live will validate Docker later
  if [[ "${args[--live]:-}" != "1" ]]; then
      SKIP_DOCKER_CHECK=true
  fi

  # Initialize global flags from parsed args
  setup_globals

  ui_banner "n8n-manager" "Unpublish Workflows"

  # Map command args
  ARG_WORKFLOWS_DIR="${args[--workflows-dir]:-${ARG_WORKFLOWS_DIR:-}}"
  ARG_FILE="${args[--file]:-}"
  ARG_ALL="${args[--all]:-}"
  ARG_SELECT="${args[--select]:-}"
  ARG_CONTAINER="${args[--container]:-${ARG_CONTAINER:-}}"
  ARG_LIVE="${args[--live]:-}"

  # ── Resolve target files ─────────────────────────

  local files_to_process=()

  if [ -n "$ARG_FILE" ]; then
      if [ ! -f "$ARG_FILE" ]; then
          log ERROR "File not found: $ARG_FILE"
          exit 1
      fi
      files_to_process+=("$ARG_FILE")
  elif [[ "$ARG_ALL" == "1" ]] || [[ "$ARG_SELECT" == "1" ]]; then
      if [ -z "$ARG_WORKFLOWS_DIR" ]; then
          if [ -t 0 ]; then
              ARG_WORKFLOWS_DIR=$(ui_input "Path to .n8n workflow files directory" "")
          fi
      fi
      if [ -z "$ARG_WORKFLOWS_DIR" ] || [ ! -d "$ARG_WORKFLOWS_DIR" ]; then
          log ERROR "Workflows directory not found: ${ARG_WORKFLOWS_DIR:-<not specified>}"
          exit 1
      fi
      local workflow_data
      workflow_data=$(wf_discover_files "$ARG_WORKFLOWS_DIR")
      if [ -z "$workflow_data" ]; then
          log ERROR "No .n8n files found in: $ARG_WORKFLOWS_DIR"
          exit 1
      fi
      if [[ "$ARG_SELECT" == "1" ]]; then
          local selected
          selected=$(wf_select_interactive "$workflow_data" "unpublish")
          if [ -z "$selected" ]; then exit 0; fi
          while IFS= read -r f; do [ -n "$f" ] && files_to_process+=("$f"); done <<< "$selected"
      else
          while IFS='|' read -r wf_path _rest; do
              [ -n "$wf_path" ] && files_to_process+=("$wf_path")
          done <<< "$workflow_data"
      fi
  else
      # Interactive mode when no flags
      if [ -t 0 ]; then
          local mode
          mode=$(ui_choose "Select unpublish mode" \
              "Single file" \
              "All files in directory" \
              "Select specific files")

          case "$mode" in
              "Single"*)
                  ARG_FILE=$(ui_input "Path to .n8n file" "")
                  if [ -z "$ARG_FILE" ] || [ ! -f "$ARG_FILE" ]; then
                      log ERROR "File not found: ${ARG_FILE:-<not specified>}"
                      exit 1
                  fi
                  files_to_process+=("$ARG_FILE")
                  ;;
              "All"*)
                  ARG_WORKFLOWS_DIR=$(ui_input "Path to .n8n workflow files directory" "")
                  if [ -z "$ARG_WORKFLOWS_DIR" ] || [ ! -d "$ARG_WORKFLOWS_DIR" ]; then
                      log ERROR "Directory not found: ${ARG_WORKFLOWS_DIR:-<not specified>}"
                      exit 1
                  fi
                  for f in "$ARG_WORKFLOWS_DIR"/*.n8n; do
                      [ -f "$f" ] && files_to_process+=("$f")
                  done
                  ;;
              "Select"*)
                  ARG_WORKFLOWS_DIR=$(ui_input "Path to .n8n workflow files directory" "")
                  local wd
                  wd=$(wf_discover_files "$ARG_WORKFLOWS_DIR")
                  local sel
                  sel=$(wf_select_interactive "$wd" "unpublish")
                  while IFS= read -r f; do
                      [ -n "$f" ] && files_to_process+=("$f")
                  done <<< "$sel"
                  ;;
          esac
      else
          log ERROR "Specify --file, --all, or --select"
          log INFO "Usage: n8n-manager workflow unpublish --file path.n8n"
          exit 1
      fi
  fi

  if [ ${#files_to_process[@]} -eq 0 ]; then
      log ERROR "No files to process"
      exit 1
  fi

  # ── Unpublish workflows ──────────────────────────

  ui_header "Unpublish Workflows"
  echo "" >&2

  local unpublished=0
  local is_live=false
  [[ "$ARG_LIVE" == "1" ]] && is_live=true

  if [ "$is_live" = "true" ]; then
      if [ -z "$ARG_CONTAINER" ]; then
          log ERROR "--container is required for --live mode"
          exit 1
      fi
      if ! command_exists docker; then
          log ERROR "Docker is required for --live mode"
          exit 1
      fi
      # Confirm live deactivation
      if [ -t 0 ]; then
          ui_confirm "Deactivate ${#files_to_process[@]} workflow(s) LIVE in container $ARG_CONTAINER?" || exit 0
      fi
  fi

  for file in "${files_to_process[@]}"; do
      local basename_file
      basename_file=$(basename "$file")

      local wf_id
      wf_id=$(wf_get_field "$file" "id")
      if [ -z "$wf_id" ]; then
          log WARN "  ⏭ $basename_file — no workflow ID, skipping"
          continue
      fi

      # Local mode: set active=false in JSON
      wf_set_field "$file" "active" "false"
      if [ $? -eq 0 ]; then
          log SUCCESS "  ✔ $basename_file — active=false (local)"
          unpublished=$((unpublished + 1))
      else
          log ERROR "  ✖ $basename_file — failed to set inactive"
          continue
      fi

      # Live mode: also deactivate in running n8n container
      if [ "$is_live" = "true" ]; then
          if [[ "${ARG_DRY_RUN:-}" == "1" ]]; then
              log DRYRUN "  Would run: n8n update:workflow --id=$wf_id --active=false"
          else
              local result
              result=$(dockExec "$ARG_CONTAINER" "n8n update:workflow --id=$wf_id --active=false" 2>&1)
              if [ $? -eq 0 ]; then
                  log SUCCESS "  ✔ $basename_file — deactivated in container $ARG_CONTAINER"
              else
                  log WARN "  ⚠ $basename_file — live deactivation failed: $result"
              fi
          fi
      fi
  done

  echo "" >&2
  ui_summary "Unpublish Complete" \
      "Deactivated" "$unpublished of ${#files_to_process[@]}" \
      "Mode" "$([ "$is_live" = "true" ] && echo "local + live ($ARG_CONTAINER)" || echo "local only")"

}

# :command.function
n8n_manager_workflow_compare_command() {

  # src/workflow_compare_command.sh

  set -Eeuo pipefail
  IFS=$'\n\t'

  # Workflow commands don't need Docker — skip Docker/git dependency checks
  SKIP_DOCKER_CHECK=true

  # Initialize global flags from parsed args
  setup_globals

  ui_banner "n8n-manager" "Workflow Compare"

  # Map command args
  ARG_FILE_A="${args[--file-a]:-}"
  ARG_FILE_B="${args[--file-b]:-}"
  ARG_SELECT="${args[--select]:-}"
  ARG_WORKFLOWS_DIR="${args[--workflows-dir]:-${ARG_WORKFLOWS_DIR:-}}"

  # ── Resolve files to compare ─────────────────────

  if [[ "$ARG_SELECT" == "1" ]]; then
      if [ -z "$ARG_WORKFLOWS_DIR" ]; then
          if [ -t 0 ]; then
              ARG_WORKFLOWS_DIR=$(ui_input "Path to .n8n workflow files directory" "")
          fi
      fi
      if [ -z "$ARG_WORKFLOWS_DIR" ] || [ ! -d "$ARG_WORKFLOWS_DIR" ]; then
          log ERROR "Workflows directory not found: ${ARG_WORKFLOWS_DIR:-<not specified>}"
          exit 1
      fi

      local workflow_data
      workflow_data=$(wf_discover_files "$ARG_WORKFLOWS_DIR")
      if [ -z "$workflow_data" ]; then
          log ERROR "No .n8n files found in: $ARG_WORKFLOWS_DIR"
          exit 1
      fi

      log INFO "Select the BASE workflow (file A):"
      local sel_a
      sel_a=$(wf_select_interactive "$workflow_data" "use as base")
      if [ -z "$sel_a" ]; then
          log WARN "No base file selected"
          exit 0
      fi
      ARG_FILE_A=$(echo "$sel_a" | head -1)

      log INFO "Select the TARGET workflow (file B):"
      local sel_b
      sel_b=$(wf_select_interactive "$workflow_data" "compare against")
      if [ -z "$sel_b" ]; then
          log WARN "No target file selected"
          exit 0
      fi
      ARG_FILE_B=$(echo "$sel_b" | head -1)
  fi

  if [ -z "$ARG_FILE_A" ] || [ -z "$ARG_FILE_B" ]; then
      log ERROR "Two files required: --file-a and --file-b"
      log INFO "Usage: n8n-manager workflow compare --file-a base.n8n --file-b target.n8n"
      log INFO "       n8n-manager workflow compare --select -d ./workflows"
      exit 1
  fi

  if [ ! -f "$ARG_FILE_A" ]; then
      log ERROR "Base file not found: $ARG_FILE_A"
      exit 1
  fi

  if [ ! -f "$ARG_FILE_B" ]; then
      log ERROR "Target file not found: $ARG_FILE_B"
      exit 1
  fi

  # ── Run comparison ───────────────────────────────

  local basename_a basename_b
  basename_a=$(basename "$ARG_FILE_A")
  basename_b=$(basename "$ARG_FILE_B")

  ui_header "Workflow Comparison"
  echo "" >&2
  log INFO "Base:   $basename_a"
  log INFO "Target: $basename_b"
  echo "" >&2

  local diff_output
  diff_output=$(wf_compare_files "$ARG_FILE_A" "$ARG_FILE_B")
  local exit_code=$?

  if [ $exit_code -eq 2 ]; then
      log ERROR "Comparison failed — check file format"
      exit 1
  fi

  if [ $exit_code -eq 0 ] && [ -z "$diff_output" ]; then
      ui_success_box "Workflows are identical (ignoring node positions)"
      exit 0
  fi

  # ── Display results ──────────────────────────────

  local section_meta=() section_nodes=() section_conn=() section_settings=() section_pins=()

  while IFS='|' read -r section status detail; do
      [ -z "$section" ] && continue
      local line=""
      if $HAS_GUM; then
          case "$status" in
              added)    line="  $(gum style --foreground $THEME_SUCCESS "➕ $detail")" ;;
              deleted)  line="  $(gum style --foreground $THEME_ERROR "➖ $detail")" ;;
              modified) line="  $(gum style --foreground $THEME_WARNING "✏️  $detail")" ;;
              *)        line="  $detail" ;;
          esac
      else
          case "$status" in
              added)    line="  ➕ $detail" ;;
              deleted)  line="  ➖ $detail" ;;
              modified) line="  ✏️  $detail" ;;
              *)        line="  $detail" ;;
          esac
      fi

      case "$section" in
          meta)        section_meta+=("$line") ;;
          nodes)       section_nodes+=("$line") ;;
          connections) section_conn+=("$line") ;;
          settings)    section_settings+=("$line") ;;
          pinData)     section_pins+=("$line") ;;
      esac
  done <<< "$diff_output"

  if [ ${#section_meta[@]} -gt 0 ]; then
      ui_header "Metadata"
      for line in "${section_meta[@]}"; do echo "$line" >&2; done
      echo "" >&2
  fi

  if [ ${#section_nodes[@]} -gt 0 ]; then
      ui_header "Nodes (${#section_nodes[@]} changes)"
      for line in "${section_nodes[@]}"; do echo "$line" >&2; done
      echo "" >&2
  fi

  if [ ${#section_conn[@]} -gt 0 ]; then
      ui_header "Connections (${#section_conn[@]} changes)"
      for line in "${section_conn[@]}"; do echo "$line" >&2; done
      echo "" >&2
  fi

  if [ ${#section_settings[@]} -gt 0 ]; then
      ui_header "Settings (${#section_settings[@]} changes)"
      for line in "${section_settings[@]}"; do echo "$line" >&2; done
      echo "" >&2
  fi

  if [ ${#section_pins[@]} -gt 0 ]; then
      ui_header "Pin Data"
      for line in "${section_pins[@]}"; do echo "$line" >&2; done
      echo "" >&2
  fi

  # ── Summary ──────────────────────────────────────────

  local total_changes=$(( ${#section_meta[@]} + ${#section_nodes[@]} + ${#section_conn[@]} + ${#section_settings[@]} + ${#section_pins[@]} ))
  ui_summary "Comparison Result" \
      "Base" "$basename_a" \
      "Target" "$basename_b" \
      "Total differences" "$total_changes" \
      "Nodes" "${#section_nodes[@]}" \
      "Connections" "${#section_conn[@]}" \
      "Settings" "${#section_settings[@]}"

}

# :command.function
n8n_manager_migrate_command() {

  # src/migrate_command.sh
  #!/usr/bin/env bash
  set -Eeuo pipefail
  IFS=$'\n\t'

  # setup_globals maps args[] to ARG_MIGRATE_* namespace.
  # Called first — must not reference ${args[...]} before this invocation.
  setup_globals

  ARG_MIGRATE_SOURCE="${args[--source]:-}"
  ARG_MIGRATE_TARGET="${args[--target]:-}"
  ARG_MIGRATE_BRANCH="${args[--branch]:-}"
  ARG_MIGRATE_DRY_RUN="${args[--dry-run]:-}"
  ARG_MIGRATE_REPORT_ONLY="${args[--report-only]:-}"
  ARG_MIGRATE_FORMAT="${args[--format]:-text}"
  ARG_MIGRATE_ALLOW_DIRTY="${args[--allow-dirty]:-}"
  ARG_MIGRATE_RESUME="${args[--resume]:-}"
  ARG_MIGRATE_RESTART="${args[--restart]:-}"

  # ── Pre-flight 1: --resume + --restart mutual exclusion (D-09) ──────────────
  if [ "${ARG_MIGRATE_RESUME:-}" = "1" ] && [ "${ARG_MIGRATE_RESTART:-}" = "1" ]; then
      log ERROR "--resume and --restart are mutually exclusive; pick one"
      exit 1
  fi

  # ── Pre-flight 2: source directory existence ─────────────────────────────────
  if [ -z "${ARG_MIGRATE_SOURCE:-}" ] || [ ! -d "${ARG_MIGRATE_SOURCE:-}" ]; then
      log ERROR "Source directory not found: ${ARG_MIGRATE_SOURCE:-<empty>}"
      exit 1
  fi
  src_dir=$(realpath "$ARG_MIGRATE_SOURCE")

  # ── Pre-flight 3: source layout validation ──────────────────────────────────
  # Refuse canonical → canonical migration; accept legacy/legacy-partial/unknown.
  src_layout=$(sc_layout_detect "$src_dir" 2>/dev/null || echo "unknown")
  case "$src_layout" in
      canonical)
          log INFO "Source at ${src_dir} is already in canonical layout; nothing to migrate."
          exit 0
          ;;
      legacy|legacy-partial|unknown)
          : # proceed
          ;;
      bundle|full-db)
          log ERROR "Source at ${src_dir} has ${src_layout} layout; migrate only supports v4-shape (legacy) sources"
          exit 1
          ;;
  esac

  # ── Pre-flight 4: git dirty-tree check (D-19, --allow-dirty) ────────────────
  # Check for staged/modified tracked files only — exclude untracked (??).
  # migrate-report.json and migration.json in .n8n-manager/ are untracked artifacts
  # that persist across runs for idempotency; they must not block re-runs.
  if [ "${ARG_MIGRATE_ALLOW_DIRTY:-}" != "1" ]; then
      if [ -n "$(git -C "$src_dir" status --porcelain 2>/dev/null | grep -v '^??')" ]; then
          log ERROR "Source repo has uncommitted changes. Commit or stash them, or use --allow-dirty to skip this check."
          exit 1
      fi
  fi

  # ── Pre-flight 5a: --target path-traversal guard (D-04) ─────────────────────
  # Path-traversal guard runs BEFORE the idempotency check so we can resolve
  # target_real for the prior-target divergence comparison below.
  if [ -n "${ARG_MIGRATE_TARGET:-}" ]; then
      target_real=$(realpath -m "$ARG_MIGRATE_TARGET" 2>/dev/null || echo "$ARG_MIGRATE_TARGET")
      # Target must not be inside source tree (D-04).
      if [[ "$target_real" == "$src_dir"* ]]; then
          log ERROR "Target directory must not be inside the source repo: ${target_real}"
          exit 1
      fi
  fi

  # ── Idempotency check (D-05, D-06) ──────────────────────────────────────────
  # Patch-15: idempotency check runs BEFORE the target-non-empty guard so a
  # completed re-run is recognized as a no-op rather than aborting on the
  # (correctly-populated) prior target. When migrate-report.json records the
  # prior target and the user passes a *different* target, fail with a clear
  # explanation rather than overwriting state.
  migration_json="${src_dir}/.n8n-manager/migration.json"
  report_json="${src_dir}/.n8n-manager/migrate-report.json"
  if [ -f "$migration_json" ]; then
      completed_at=$(python3 - "$migration_json" <<'PY'
import json, sys
try:
    with open(sys.argv[1], "r", encoding="utf-8") as f:
        d = json.load(f)
    print(d.get("completed_at", ""))
except Exception:
    print("")
PY
  2>/dev/null || echo "")
      if [ -n "$completed_at" ]; then
          # Compare requested target against the prior target recorded in
          # migrate-report.json (when present). branchOrTarget holds either
          # the sibling-branch name (sibling-branch mode) or the absolute
          # target dir (target-dir mode).
          prior_output_mode=""
          prior_target=""
          if [ -f "$report_json" ]; then
              prior_output_mode=$(python3 - "$report_json" <<'PY'
import json, sys
try:
    with open(sys.argv[1], "r", encoding="utf-8") as f:
        d = json.load(f)
    print(d.get("outputMode", ""))
except Exception:
    print("")
PY
  2>/dev/null || echo "")
              prior_target=$(python3 - "$report_json" <<'PY'
import json, sys
try:
    with open(sys.argv[1], "r", encoding="utf-8") as f:
        d = json.load(f)
    print(d.get("branchOrTarget", ""))
except Exception:
    print("")
PY
  2>/dev/null || echo "")
          fi

          if [ -n "${ARG_MIGRATE_TARGET:-}" ]; then
              # User asked for target-dir mode this time.
              if [ "$prior_output_mode" = "target-dir" ] && [ -n "$prior_target" ]; then
                  # Compare requested target with prior target (realpath-normalized).
                  prior_target_real=$(realpath -m "$prior_target" 2>/dev/null || echo "$prior_target")
                  if [ "$target_real" = "$prior_target_real" ]; then
                      log INFO "Source already migrated (completed at: ${completed_at}, target: ${prior_target}). Nothing to do."
                      exit 0
                  else
                      log ERROR "Source already migrated to a different target."
                      log ERROR "  Prior target: ${prior_target}"
                      log ERROR "  Requested:    ${target_real}"
                      log ERROR "  Refusing to overwrite. Use --restart on the prior target if you intended to redo the migration, or pick a fresh source."
                      exit 1
                  fi
              elif [ "$prior_output_mode" = "sibling-branch" ]; then
                  log ERROR "Source already migrated to a sibling branch (${prior_target})."
                  log ERROR "  Switching from sibling-branch to target-dir mode after completion would create a divergent record."
                  log ERROR "  Use --restart on the source if you intended to redo the migration."
                  exit 1
              else
                  # report.json absent or unparseable — fall back to permissive idempotent skip
                  log INFO "Source already migrated (completed at: ${completed_at}). Nothing to do."
                  exit 0
              fi
          else
              # User passed no --target this run — sibling-branch mode requested.
              if [ "$prior_output_mode" = "target-dir" ] && [ -n "$prior_target" ]; then
                  log ERROR "Source already migrated to a target directory (${prior_target})."
                  log ERROR "  Switching from target-dir to sibling-branch mode after completion would create a divergent record."
                  log ERROR "  Use --restart on the source if you intended to redo the migration."
                  exit 1
              fi
              log INFO "Source already migrated (completed at: ${completed_at}). Nothing to do."
              exit 0
          fi
      fi

      # Interrupted run: started_at present, completed_at absent — D-06
      started_at_check=$(python3 - "$migration_json" <<'PY'
import json, sys
try:
    with open(sys.argv[1], "r", encoding="utf-8") as f:
        d = json.load(f)
    print(d.get("started_at", ""))
except Exception:
    print("")
PY
  2>/dev/null || echo "")
      if [ -n "$started_at_check" ]; then
          if [ "${ARG_MIGRATE_RESUME:-}" = "1" ]; then
              log INFO "Resuming interrupted migrate (started at: ${started_at_check})"
          elif [ "${ARG_MIGRATE_RESTART:-}" = "1" ]; then
              log INFO "Restarting interrupted migrate (deleting staging from: ${started_at_check})"
              rm -rf "${src_dir}/.n8n-manager/migrate-staging"
              rm -f "$migration_json"
          else
              log ERROR "Previous migrate run was interrupted on ${started_at_check}."
              log ERROR "Use --resume to retry from existing staging dir, or --restart to clean and start over."
              exit 1
          fi
      fi
  fi

  # ── Pre-flight 5b: --target non-empty guard (D-04) ──────────────────────────
  # Patch-15: this guard runs AFTER the idempotency check. A completed re-run
  # must not abort here because the prior target IS supposed to be populated
  # by definition. This guard catches first-run collisions with pre-existing
  # unrelated content in the requested target.
  if [ -n "${ARG_MIGRATE_TARGET:-}" ]; then
      if [ -d "$ARG_MIGRATE_TARGET" ] && [ -n "$(ls -A "$ARG_MIGRATE_TARGET" 2>/dev/null)" ]; then
          log ERROR "Target directory is not empty. Clean it first: ${ARG_MIGRATE_TARGET}"
          exit 1
      fi
  fi

  # ── Dry-run / report-only shortcut (no mutations) ───────────────────────────
  if [ "${ARG_MIGRATE_DRY_RUN:-}" = "1" ] || [ "${ARG_MIGRATE_REPORT_ONLY:-}" = "1" ]; then
      variant=$(v4_adapter_detect_variant "$src_dir")
      output_mode_label="${ARG_MIGRATE_TARGET:+target-dir (${ARG_MIGRATE_TARGET})}${ARG_MIGRATE_TARGET:-sibling-branch}"
      log INFO "[MIGRATE] Source variant: ${variant}"
      log INFO "[MIGRATE] Output mode: ${output_mode_label}"
      if [ "${ARG_MIGRATE_FORMAT:-text}" = "markdown" ]; then
          printf '## Migration Report (dry-run)\n\n'
          printf '| Field | Value |\n|-------|-------|\n'
          printf '| Source | %s |\n' "$src_dir"
          printf '| Source Variant | %s |\n' "$variant"
          printf '| Output Mode | %s |\n' "$output_mode_label"
          printf '| Dry Run | yes |\n'
      else
          printf 'Migration report (dry-run)\n'
          printf '  Source:       %s\n' "$src_dir"
          printf '  Variant:      %s\n' "$variant"
          printf '  Output mode:  %s\n' "$output_mode_label"
      fi
      exit 0
  fi

  # ── D-20: auto-add migrate-staging/ to .n8n-manager/.gitignore ──────────────
  gitignore_path="${src_dir}/.n8n-manager/.gitignore"
  mkdir -p "${src_dir}/.n8n-manager"
  if ! grep -qF 'migrate-staging/' "$gitignore_path" 2>/dev/null; then
      printf 'migrate-staging/\n' >> "$gitignore_path"
      log DEBUG "[MIGRATE] Added migrate-staging/ to ${gitignore_path}"
  fi

  # ── D-05: write started_at marker atomically BEFORE staging activity ─────────
  now=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
  tmp_migration=$(mktemp "${migration_json}.tmp.XXXXXX")
  # Trap covers EXIT + INT + TERM independently (Phase 3 D-08 pattern, project anti-pattern policy)
  # Each signal is listed independently.
  trap 'rm -f "$tmp_migration"' EXIT
  trap 'rm -f "$tmp_migration"; exit 130' INT
  trap 'rm -f "$tmp_migration"; exit 143' TERM
  python3 - "$tmp_migration" "$now" <<'PY'
import json, sys
out, started_at = sys.argv[1], sys.argv[2]
with open(out, "w", encoding="utf-8") as f:
    json.dump({"formatVersion": 1, "started_at": started_at}, f, ensure_ascii=False, indent=2)
PY
  mv "$tmp_migration" "$migration_json"
  trap - EXIT INT TERM

  # ── Create staging dir (D-07 --resume: reuse existing; D-08 fresh run) ───────
  stage_dir="${src_dir}/.n8n-manager/migrate-staging"
  # Trap staging cleanup on unexpected exit AFTER migration_json is written
  # (do NOT trap before — ensures migration.json persists for --resume detection)
  _migrate_cleanup_tmp() {
      rm -f "${tmp_report:-}"
      rm -f "${tmp_migration2:-}"
  }
  trap '_migrate_cleanup_tmp' EXIT

  if [ "${ARG_MIGRATE_RESUME:-}" != "1" ]; then
      rm -rf "$stage_dir"
      mkdir -p "$stage_dir"
  fi

  # ── Run adapter (FROZEN Phase 3 API — no modifications to v4_shape_adapter.sh) ─
  if ! v4_adapter_to_canonical_staging "$src_dir" "$stage_dir"; then
      log ERROR "[MIGRATE] v4 adapter failed for ${src_dir}. Check adapter output above for details."
      exit 1
  fi

  # ── Determine output branch name (D-03) ─────────────────────────────────────
  if [ -n "${ARG_MIGRATE_BRANCH:-}" ]; then
      branch_name="$ARG_MIGRATE_BRANCH"
  else
      ts=$(date -u '+%Y-%m-%d-%H%M%S')
      branch_name="migrated-canonical-${ts}"
      # Collision guard: if branch exists, append -2, -3, etc.
      suffix=2
      while git -C "$src_dir" show-ref --verify --quiet "refs/heads/${branch_name}" 2>/dev/null; do
          branch_name="migrated-canonical-${ts}-${suffix}"
          suffix=$((suffix + 1))
      done
  fi

  # ── Commit to sibling branch OR target directory (D-01, D-02) ───────────────
  if [ -n "${ARG_MIGRATE_TARGET:-}" ]; then
      # --target mode: init new repo in target dir, copy staging contents, commit
      mkdir -p "$ARG_MIGRATE_TARGET"
      git -C "$ARG_MIGRATE_TARGET" init -q
      git -C "$ARG_MIGRATE_TARGET" config user.email "n8n-manager-migrate@localhost"
      git -C "$ARG_MIGRATE_TARGET" config user.name "n8n-manager migrate"
      cp -r "${stage_dir}/." "${ARG_MIGRATE_TARGET}/"
      git -C "$ARG_MIGRATE_TARGET" checkout -b main 2>/dev/null || true
      git -C "$ARG_MIGRATE_TARGET" add -A
      git -C "$ARG_MIGRATE_TARGET" commit -m "chore(migrate): v4 to v5 canonical layout migration from $(basename "$src_dir")"
      log SUCCESS "[MIGRATE] Canonical layout committed to: ${ARG_MIGRATE_TARGET}"
  else
      # Sibling-branch mode: create new branch from HEAD, copy staging, commit (D-01)
      git -C "$src_dir" checkout -b "$branch_name"
      # Remove v4 root-level artifacts from the index only (not filesystem) so new
      # canonical layout replaces them in the sibling-branch commit.
      git -C "$src_dir" rm -rf --cached --quiet workflows.json 2>/dev/null || true
      git -C "$src_dir" rm -rf --cached --quiet credentials.json 2>/dev/null || true
      git -C "$src_dir" rm -rf --cached --quiet .env 2>/dev/null || true
      # Remove dated subdir v4 artifacts from index
      while IFS= read -r subdir; do
          [ -n "$subdir" ] && git -C "$src_dir" rm -rf --cached --quiet "$subdir" 2>/dev/null || true
      done < <(find "$src_dir" -maxdepth 1 -type d \
          \( -name 'backup_????-??-??_??-??-??' -o -name 'backup_????-??-??' \) \
          2>/dev/null)
      # Copy canonical staging output into the working tree
      cp -r "${stage_dir}/." "${src_dir}/"
      git -C "$src_dir" add -A
      git -C "$src_dir" commit -m "chore(migrate): v4 to v5 canonical layout migration"
      # Return to original branch
      git -C "$src_dir" checkout - 2>/dev/null || true
      log SUCCESS "[MIGRATE] Canonical layout committed to branch: ${branch_name}"
      log INFO "  Review: git -C ${src_dir} diff HEAD..${branch_name}"
  fi

  # ── Write migrate-report.json (D-21) ────────────────────────────────────────
  # Schema: formatVersion + generatedAt + adapterVersion + sourceDir + outputMode +
  #         branchOrTarget + startedAt  (joins {manifest,gaps,restore-report}.json family)
  report_path="${src_dir}/.n8n-manager/migrate-report.json"
  tmp_report=$(mktemp "${report_path}.tmp.XXXXXX")
  output_mode_value="${ARG_MIGRATE_TARGET:+target-dir}"
  branch_or_target="${ARG_MIGRATE_TARGET:-${branch_name}}"
  python3 - "$tmp_report" "$src_dir" "$output_mode_value" "$branch_or_target" "$now" <<'PY'
import json, sys, os
from datetime import datetime, timezone
out, src_dir, output_mode, branch_or_target, started_at = sys.argv[1:6]
if not output_mode:
    output_mode = "sibling-branch"
report = {
    "formatVersion": 1,
    "generatedAt": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "adapterVersion": "1.0",
    "sourceDir": os.path.realpath(src_dir),
    "outputMode": output_mode,
    "branchOrTarget": branch_or_target,
    "startedAt": started_at,
}
with open(out, "w", encoding="utf-8", newline="\n") as f:
    json.dump(report, f, ensure_ascii=False, indent=2)
PY
  mv "$tmp_report" "$report_path"

  # ── D-05: write completed_at marker atomically AFTER canonical commit ─────────
  tmp_migration2=$(mktemp "${migration_json}.tmp.XXXXXX")
  python3 - "$tmp_migration2" "$now" "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" <<'PY'
import json, sys
out, started_at, completed_at = sys.argv[1], sys.argv[2], sys.argv[3]
with open(out, "w", encoding="utf-8") as f:
    json.dump(
        {"formatVersion": 1, "started_at": started_at, "completed_at": completed_at},
        f, ensure_ascii=False, indent=2
    )
PY
  mv "$tmp_migration2" "$migration_json"

  # ── Clean up staging dir (no longer needed after canonical commit) ───────────
  rm -rf "$stage_dir"

  trap - EXIT

  log SUCCESS "[MIGRATE] Migration complete."
  exit 0

}

# :command.function
n8n_manager_migrate_config_command() {

  # src/migrate_config_command.sh
  #!/usr/bin/env bash
  set -Eeuo pipefail
  IFS=$'\n\t'

  setup_globals

  # Command-specific ARG_* mappings (D-24 flag surface)
  # --dry-run is also mapped to ARG_DRY_RUN by setup_globals; mirror here for clarity
  ARG_MIGRATE_CONFIG_DRY_RUN="${args[--dry-run]:-}"
  ARG_MIGRATE_CONFIG_RESTORE_FROM_BAK="${args[--restore-from-bak]:-}"
  # --config is handled by setup_globals() -> ARG_CONFIG_FILE; alias for readability
  ARG_MIGRATE_CONFIG_FILE="${ARG_CONFIG_FILE:-$CONFIG_FILE_PATH}"

  # Mutual exclusion guard: --dry-run and --restore-from-bak are mutually exclusive
  if [ "${ARG_MIGRATE_CONFIG_DRY_RUN:-}" = "1" ] && [ "${ARG_MIGRATE_CONFIG_RESTORE_FROM_BAK:-}" = "1" ]; then
      log ERROR "--dry-run and --restore-from-bak are mutually exclusive; pick one"
      exit 1
  fi

  # Path 1: --restore-from-bak
  if [ "${ARG_MIGRATE_CONFIG_RESTORE_FROM_BAK:-}" = "1" ]; then
      if _config_restore_from_bak "$ARG_MIGRATE_CONFIG_FILE"; then
          exit 0
      else
          exit 1
      fi
  fi

  # Path 2: --dry-run
  if [ "${ARG_MIGRATE_CONFIG_DRY_RUN:-}" = "1" ]; then
      local _shape
      _shape=$(_config_detect_v4_shape "$ARG_MIGRATE_CONFIG_FILE")
      case "$_shape" in
          missing)
              log ERROR "Config file not found: ${ARG_MIGRATE_CONFIG_FILE}"
              exit 1
              ;;
          already-migrated)
              log INFO "Config already translated (sentinel present) — no changes needed"
              exit 0
              ;;
          v4)
              printf '--- Proposed rewrite of: %s (DRY RUN — no changes written) ---\n' "$ARG_MIGRATE_CONFIG_FILE"
              printf '# Managed by n8n-manager v5 — translated from v4 on %s\n' "$(date -u '+%Y-%m-%d')"
              printf '# Original v4 backup at: %s.v4.bak\n' "$ARG_MIGRATE_CONFIG_FILE"
              cat "$ARG_MIGRATE_CONFIG_FILE"
              printf '--- End of proposed rewrite ---\n'
              exit 0
              ;;
      esac
  fi

  # Path 3: Normal rewrite (no flags)
  local _shape
  _shape=$(_config_detect_v4_shape "$ARG_MIGRATE_CONFIG_FILE")
  case "$_shape" in
      missing)
          log ERROR "Config file not found: ${ARG_MIGRATE_CONFIG_FILE}"
          exit 1
          ;;
      already-migrated)
          log INFO "Config already translated — nothing to do"
          exit 0
          ;;
      v4)
          if _config_atomic_rewrite "$ARG_MIGRATE_CONFIG_FILE" "explicit"; then
              exit 0
          else
              exit 1
          fi
          ;;
  esac

}

# :command.parse_requirements
parse_requirements() {
  local key

  # :command.fixed_flags_filter
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in
      --version | -v)
        version_command
        exit
        ;;

      --help | -h)
        long_usage=yes
        n8n_manager_usage
        exit
        ;;

      *)
        break
        ;;

    esac
  done

  # :command.command_filter
  action=${1:-}

  case $action in
    -*) ;;

    backup)
      action="backup"
      shift
      n8n_manager_backup_parse_requirements "$@"
      shift $#
      ;;

    restore)
      action="restore"
      shift
      n8n_manager_restore_parse_requirements "$@"
      shift $#
      ;;

    import-url | import)
      action="import-url"
      shift
      n8n_manager_import_url_parse_requirements "$@"
      shift $#
      ;;

    install)
      action="install"
      shift
      n8n_manager_install_parse_requirements "$@"
      shift $#
      ;;

    update)
      action="update"
      shift
      n8n_manager_update_parse_requirements "$@"
      shift $#
      ;;

    uninstall)
      action="uninstall"
      shift
      n8n_manager_uninstall_parse_requirements "$@"
      shift $#
      ;;

    workflow)
      action="workflow"
      shift
      n8n_manager_workflow_parse_requirements "$@"
      shift $#
      ;;

    migrate)
      action="migrate"
      shift
      n8n_manager_migrate_parse_requirements "$@"
      shift $#
      ;;

    migrate-config)
      action="migrate-config"
      shift
      n8n_manager_migrate_config_parse_requirements "$@"
      shift $#
      ;;

    # :command.command_fallback
    "")
      n8n_manager_usage >&2
      exit 1
      ;;

    *)
      printf "invalid command: %s\n" "$action" >&2
      exit 1
      ;;

  esac

  # :command.parse_requirements_while
  while [[ $# -gt 0 ]]; do
    key="$1"
    case "$key" in

      -?*)
        printf "invalid option: %s\n" "$key" >&2
        exit 1
        ;;

      *)
        # :command.parse_requirements_case
        # :command.parse_requirements_case_simple
        printf "invalid argument: %s\n" "$key" >&2
        exit 1

        ;;

    esac
  done

}

