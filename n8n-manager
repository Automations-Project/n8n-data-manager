# Config Memory — Remember last-used settings per container
# ═══════════════════════════════════════════════════════════

# Save last-used GitHub config for quick recall
# Args: $1=repo $2=branch [$3=token_hint (first 8 chars)]
github_save_last_config() {
    local repo="$1"
    local branch="$2"
    local token_hint="${3:-}"

    local memory_dir="${XDG_CONFIG_HOME:-$HOME/.config}/n8n-manager"
    mkdir -p "$memory_dir" 2>/dev/null || return 1

    local memory_file="$memory_dir/last_github"
    cat > "$memory_file" << EOF
LAST_REPO=$repo
LAST_BRANCH=$branch
LAST_TOKEN_HINT=$token_hint
LAST_USED=$(date '+%Y-%m-%d %H:%M')
EOF
    log DEBUG "[GITHUB_MEM] Saved last config: repo=$repo branch=$branch"
}

# Load last-used GitHub config
# Sets: LAST_REPO, LAST_BRANCH, LAST_TOKEN_HINT, LAST_USED
github_load_last_config() {
    local memory_file="${XDG_CONFIG_HOME:-$HOME/.config}/n8n-manager/last_github"
    LAST_REPO=""
    LAST_BRANCH=""
    LAST_TOKEN_HINT=""
    LAST_USED=""

    if [ -f "$memory_file" ]; then
        while IFS='=' read -r key value; do
            [[ -z "$key" || "$key" =~ ^[[:space:]]*# ]] && continue
            key=$(echo "$key" | xargs)
            value=$(echo "$value" | xargs)
            case "$key" in
                LAST_REPO) LAST_REPO="$value" ;;
                LAST_BRANCH) LAST_BRANCH="$value" ;;
                LAST_TOKEN_HINT) LAST_TOKEN_HINT="$value" ;;
                LAST_USED) LAST_USED="$value" ;;
            esac
        done < "$memory_file"
        log DEBUG "[GITHUB_MEM] Loaded last config: repo=$LAST_REPO branch=$LAST_BRANCH"
        return 0
    fi
    return 1
}

