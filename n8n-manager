# Terminal width detection with sensible default
_term_width() {
    local w
    w=$(tput cols 2>/dev/null || echo 80)
    # Cap at 120 to avoid absurdly wide layouts
    [ "$w" -gt 120 ] && w=120
    echo "$w"
}

# Generic bordered panel — the fundamental building block
# Usage: _style_panel "content" [width] [border] [border_color] [fg_color]
_style_panel() {
    local content="$1"
    local width="${2:-0}"
    local border="${3:-rounded}"
    local border_fg="${4:-$THEME_BORDER}"
    local fg="${5:-$THEME_TEXT}"

    if $HAS_GUM; then
        local flags=(
            --border "$border"
            --border-foreground "$border_fg"
            --foreground "$fg"
            --padding "1 2"
        )
        [ "$width" -gt 0 ] && flags+=(--width "$width")
        gum style "${flags[@]}" "$content"
    else
        local line_len=${width:-40}
        [ "$line_len" -le 0 ] && line_len=40
        local inner=$((line_len - 4))
        printf "┌%s┐\n" "$(printf '─%.0s' $(seq 1 $((inner + 2))))"
        while IFS= read -r line; do
            printf "│ %-${inner}s │\n" "$line"
        done <<< "$content"
        printf "└%s┘\n" "$(printf '─%.0s' $(seq 1 $((inner + 2))))"
    fi
}

# Titled panel — bordered box with a colored title line
# Usage: _style_titled_panel "Title" "body content" [width] [border] [title_color] [border_color]
_style_titled_panel() {
    local title="$1"
    local body="$2"
    local width="${3:-0}"
    local border="${4:-rounded}"
    local title_fg="${5:-$THEME_PRIMARY}"
    local border_fg="${6:-$THEME_BORDER}"

    if $HAS_GUM; then
        local styled_title
        styled_title=$(gum style --foreground "$title_fg" --bold "$title")
        local combined
        combined=$(printf '%s\n\n%s' "$styled_title" "$body")
        local flags=(
            --border "$border"
            --border-foreground "$border_fg"
            --padding "1 2"
        )
        [ "$width" -gt 0 ] && flags+=(--width "$width")
        gum style "${flags[@]}" "$combined"
    else
        local line_len=${width:-40}
        [ "$line_len" -le 0 ] && line_len=40
        local inner=$((line_len - 4))
        printf "┌─ %s %s┐\n" "$title" "$(printf '─%.0s' $(seq 1 $((inner - ${#title} - 1))))"
        while IFS= read -r line; do
            printf "│ %-${inner}s │\n" "$line"
        done <<< "$body"
        printf "└%s┘\n" "$(printf '─%.0s' $(seq 1 $((inner + 2))))"
    fi
}

# Full-width accent bar — colored strip for status bars / dividers
# Usage: _style_accent_bar "content" [bg_color] [fg_color]
_style_accent_bar() {
    local content="$1"
    local bg="${2:-$THEME_BG_TERTIARY}"
    local fg="${3:-$THEME_TEXT}"

    if $HAS_GUM; then
        local tw
        tw=$(_term_width)
        gum style \
            --background "$bg" --foreground "$fg" \
            --bold --padding "0 2" --width "$tw" \
            "$content"
    else
        printf " %s\n" "$content"
    fi
}

# Inline badge/pill — small colored label (e.g., "v5.0.0", "DRY-RUN")
# Usage: _style_badge "text" [fg_color] [bg_color]
_style_badge() {
    local text="$1"
    local fg="${2:-$THEME_BG_TERTIARY}"
    local bg="${3:-$THEME_PRIMARY}"

    if $HAS_GUM; then
        gum style \
            --foreground "$fg" --background "$bg" \
            --bold --padding "0 1" \
            " $text "
    else
        printf "[%s]" "$text"
    fi
}

# Styled key-value pair — dim key + bold value
# Usage: _style_kv "Key" "Value" [key_color] [val_color]
_style_kv() {
    local key="$1"
    local val="$2"
    local key_fg="${3:-$THEME_TEXT_DIM}"
    local val_fg="${4:-$THEME_TEXT}"

    if $HAS_GUM; then
        local styled_key styled_val
        styled_key=$(gum style --foreground "$key_fg" "$key")
        styled_val=$(gum style --foreground "$val_fg" --bold "$val")
        gum join --horizontal "$styled_key" " " "$styled_val"
    else
        printf "  %-16s %s" "$key" "$val"
    fi
}

# Dimmed/muted text block
# Usage: _style_dimmed "text"
_style_dimmed() {
    if $HAS_GUM; then
        gum style --foreground "$THEME_TEXT_DIM" --faint "$*"
    else
        printf "\033[2m%s\033[0m" "$*"
    fi
}

# Highlighted accent text
# Usage: _style_highlight "text" [color]
_style_highlight() {
    local text="$1"
    local fg="${2:-$THEME_PRIMARY}"
    if $HAS_GUM; then
        gum style --foreground "$fg" --bold "$text"
    else
        printf "\033[1m%s\033[0m" "$text"
    fi
}

# Icon + text combo — consistent icon rendering
# Usage: _style_icon_text "icon" "text" [color]
_style_icon_text() {
    local icon="$1"
    local text="$2"
    local fg="${3:-$THEME_TEXT}"

    if $HAS_GUM; then
        local styled_icon styled_text
        styled_icon=$(gum style --foreground "$THEME_ACCENT" --bold "$icon")
        styled_text=$(gum style --foreground "$fg" "$text")
        gum join --horizontal "$styled_icon" " " "$styled_text"
    else
        printf "%s %s" "$icon" "$text"
    fi
}

