# Inject a fake Webhook Trigger stub for MCP compatibility
# The stub is disconnected, off-canvas, and named "OnlyForMCP"
# Args: $1=file path
# Returns: 0 on success
wf_mcp_inject_trigger() {
    local file="$1"

    if [[ "${ARG_DRY_RUN:-}" == "1" ]]; then
        log DRYRUN "Would inject OnlyForMCP trigger stub into: $(basename "$file")"
        return 0
    fi

    if command_exists node; then
        node -e '
const fs = require("fs");
const crypto = require("crypto");
try {
    const file = process.argv[1];
    const d = JSON.parse(fs.readFileSync(file, "utf8"));

    // Check if already exists
    if ((d.nodes || []).some(n => n.name === "OnlyForMCP")) {
        console.log("already_exists");
        process.exit(0);
    }

    // Generate unique webhook path
    const webhookId = crypto.randomUUID().slice(0, 8);

    // Create disconnected Webhook Trigger at far-off position
    const stubNode = {
        id: crypto.randomUUID(),
        name: "OnlyForMCP",
        type: "n8n-nodes-base.webhook",
        typeVersion: 2,
        position: [-800, -800],
        parameters: {
            path: "mcp-stub-" + webhookId,
            httpMethod: "GET"
        },
        disabled: true,
        notesInFlow: true,
        notes: "Auto-injected by n8n-manager for MCP compatibility. Safe to remove when disabling MCP."
    };

    if (!d.nodes) d.nodes = [];
    d.nodes.push(stubNode);

    fs.writeFileSync(file, JSON.stringify(d, null, 2));
    console.log("injected");
} catch(e) { console.error(e.message); process.exit(1); }
' "$file" 2>/dev/null
    elif command_exists python3; then
        python3 -c "
import json, sys, uuid
try:
    file = sys.argv[1]
    with open(file) as f: d = json.load(f)
    if any(n.get('name') == 'OnlyForMCP' for n in d.get('nodes', [])):
        print('already_exists'); sys.exit(0)
    webhook_id = str(uuid.uuid4())[:8]
    stub = {
        'id': str(uuid.uuid4()),
        'name': 'OnlyForMCP',
        'type': 'n8n-nodes-base.webhook',
        'typeVersion': 2,
        'position': [-800, -800],
        'parameters': {'path': f'mcp-stub-{webhook_id}', 'httpMethod': 'GET'},
        'disabled': True,
        'notesInFlow': True,
        'notes': 'Auto-injected by n8n-manager for MCP compatibility. Safe to remove when disabling MCP.'
    }
    d.setdefault('nodes', []).append(stub)
    with open(file, 'w') as f: json.dump(d, f, indent=2)
    print('injected')
except Exception as e: print(f'Error: {e}', file=sys.stderr); sys.exit(1)
" "$file" 2>/dev/null
    else
        log ERROR "Need node or python3 for MCP trigger injection"
        return 1
    fi
}

# Remove the OnlyForMCP stub trigger when disabling MCP
# Args: $1=file path
# Returns: 0 on success
wf_mcp_remove_trigger() {
    local file="$1"

    if [[ "${ARG_DRY_RUN:-}" == "1" ]]; then
        log DRYRUN "Would remove OnlyForMCP trigger stub from: $(basename "$file")"
        return 0
    fi

    if command_exists node; then
        node -e '
const fs = require("fs");
try {
    const file = process.argv[1];
    const d = JSON.parse(fs.readFileSync(file, "utf8"));
    const before = (d.nodes || []).length;
    d.nodes = (d.nodes || []).filter(n => n.name !== "OnlyForMCP");
    const removed = before - d.nodes.length;
    fs.writeFileSync(file, JSON.stringify(d, null, 2));
    console.log(removed > 0 ? "removed" : "not_found");
} catch(e) { console.error(e.message); process.exit(1); }
' "$file" 2>/dev/null
    elif command_exists python3; then
        python3 -c "
