    if [[ "${ARG_BACKUP_TYPE:-all}" == "all" || "${ARG_BACKUP_TYPE:-all}" == "credentials" ]]; then
        credentials_in_scope=true
    elif [[ "${ARG_BACKUP_TYPE:-all}" == "workflows" ]] && \
         ([[ "${ARG_INCLUDE_LINKED_CREDS:-}" == "1" ]] || [[ "${ARG_INCLUDE_LINKED_CREDS:-}" == "true" ]] || [ -n "${ARG_CREDENTIAL_ID:-}" ]); then
        credentials_in_scope=true
    fi
    if $credentials_in_scope; then
        _select_backup_credential_export_mode
    fi

    if [[ "${ARG_BACKUP_TYPE:-all}" == "all" || "${ARG_BACKUP_TYPE:-all}" == "workflows" || "${ARG_BACKUP_TYPE:-all}" == "credentials" ]]; then
        if ui_confirm "Enable import-as-new mode (strip IDs; when import considered as new workflows)?"; then
            ARG_IMPORT_AS_NEW=true
            log DEBUG "[UI] Import-as-new mode enabled"
        fi
    fi
}

# ─── Save Settings Prompt ────────────────────────────────
# Offer to save current settings to config file after first successful run

offer_save_settings() {
    local config_dir="${HOME}/.config/n8n-manager"
    local config_file="$config_dir/config"

    # Only offer in interactive mode
    [ ! -t 0 ] && return 0

    # Skip if config file already has the same values
    if [ -f "$config_file" ]; then
        local existing_token existing_repo existing_branch
        existing_token=$(grep '^CONF_GITHUB_TOKEN=' "$config_file" 2>/dev/null | head -1 | cut -d= -f2-)
        existing_repo=$(grep '^CONF_GITHUB_REPO=' "$config_file" 2>/dev/null | head -1 | cut -d= -f2-)
        existing_branch=$(grep '^CONF_GITHUB_BRANCH=' "$config_file" 2>/dev/null | head -1 | cut -d= -f2-)

        # Remove quotes
        existing_token="${existing_token%\"}" ; existing_token="${existing_token#\"}"
        existing_repo="${existing_repo%\"}" ; existing_repo="${existing_repo#\"}"
        existing_branch="${existing_branch%\"}" ; existing_branch="${existing_branch#\"}"

        # If all match, no need to ask
        if [ "$existing_token" = "${ARG_TOKEN:-}" ] && \
           [ "$existing_repo" = "${ARG_REPO:-}" ] && \
           [ "$existing_branch" = "${ARG_BRANCH:-}" ]; then
            return 0
        fi
    fi

    echo "" >&2
    if ui_confirm "Save these settings for next time? (token, repo, branch)" "Save" "Skip"; then
        mkdir -p "$config_dir" 2>/dev/null || true

        # Build config content — preserve existing non-GitHub settings
        local new_config=""
        if [ -f "$config_file" ]; then
            # Keep lines that aren't GitHub settings
            new_config=$(grep -v '^CONF_GITHUB_TOKEN=' "$config_file" | \
                         grep -v '^CONF_GITHUB_REPO=' | \
                         grep -v '^CONF_GITHUB_BRANCH=' | \
                         grep -v '^CONF_CONTAINER=' || true)
        fi

        {
            [ -n "$new_config" ] && echo "$new_config"
            echo "CONF_GITHUB_TOKEN=\"${ARG_TOKEN:-}\""
            echo "CONF_GITHUB_REPO=\"${ARG_REPO:-}\""
            echo "CONF_GITHUB_BRANCH=\"${ARG_BRANCH:-main}\""
            [ -n "${ARG_CONTAINER:-}" ] && echo "CONF_CONTAINER=\"${ARG_CONTAINER}\""
        } > "$config_file"

        ui_notification "success" "Settings saved" "$config_file" >&2
    fi
}

