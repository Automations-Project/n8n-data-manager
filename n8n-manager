# Export enterprise entities from n8n container
# Runs export:entities, docker cp the zip out, extracts enterprise JSONL files
# Args: $1=container_id $2=output_dir $3=is_dry_run
export_enterprise_entities() {
    local container="$1"
    local output_dir="$2"
    local is_dry_run="${3:-false}"

    log DEBUG "[ENTITIES] Starting enterprise entity export"
    log DEBUG "[ENTITIES] Container: $container, Output: $output_dir"

    local container_export_dir="/tmp/n8n-entities-export"
    local container_zip="$container_export_dir/entities.zip"

    if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
        log DRYRUN "Would export enterprise entities from container"
        return 0
    fi

    # Clean any previous export
    dockExec "$container" "rm -rf $container_export_dir" 2>/dev/null || true

    # Run n8n export:entities inside the container
    log INFO "Exporting all database entities from n8n..."
    if ! dockExec "$container" "n8n export:entities --outputDir=$container_export_dir"; then
        log WARN "export:entities failed — enterprise entities will be skipped"
        log WARN "This may happen on older n8n versions that don't support export:entities"
        return 1
    fi

    # Verify entities.zip was created
    if ! dockExec "$container" "test -f $container_zip"; then
        log WARN "entities.zip not found after export — enterprise entities skipped"
        return 1
    fi

    log SUCCESS "Entity export completed inside container"

    # Create local output directory
    mkdir -p "$output_dir/entities"
    local local_zip="$output_dir/entities/entities.zip"

    # Docker cp the zip out
    log INFO "Copying entities.zip from container..."
    if ! docker cp "$container:$container_zip" "$local_zip"; then
        log ERROR "Failed to copy entities.zip from container"
        dockExec "$container" "rm -rf $container_export_dir" 2>/dev/null || true
        return 1
    fi

    # Extract enterprise JSONL files from the zip
    log INFO "Extracting enterprise entity files..."
    if ! _extract_enterprise_entities "$local_zip" "$output_dir/entities"; then
        log ERROR "Failed to extract enterprise entities from zip"
        dockExec "$container" "rm -rf $container_export_dir" 2>/dev/null || true
        return 1
    fi

    # Also keep migrations.jsonl for version compatibility checks
    if unzip -o -j "$local_zip" "$ENTITY_MIGRATIONS" -d "$output_dir/entities" 2>/dev/null; then
        log DEBUG "[ENTITIES] Extracted migrations.jsonl for compatibility checks"
    fi

    # Remove the raw zip (we've extracted what we need)
    rm -f "$local_zip"

    # Clean up container temp files
    dockExec "$container" "rm -rf $container_export_dir" 2>/dev/null || true

    # Show summary of what was exported
    _show_entity_export_summary "$output_dir/entities"

    log SUCCESS "Enterprise entity export completed"
    return 0
}

# Full database export (for migration scenarios)
# Args: $1=container_id $2=output_dir $3=is_dry_run $4=include_execution_history
export_full_database() {
    local container="$1"
    local output_dir="$2"
    local is_dry_run="${3:-false}"
    local include_history="${4:-false}"

    log DEBUG "[ENTITIES] Starting full database export"

    local container_export_dir="/tmp/n8n-fulldb-export"
    local container_zip="$container_export_dir/entities.zip"

    if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
        log DRYRUN "Would export full database from container"
        return 0
    fi

    dockExec "$container" "rm -rf $container_export_dir" 2>/dev/null || true

    local export_cmd="n8n export:entities --outputDir=$container_export_dir"
    if [ "$include_history" = "true" ]; then
        export_cmd="$export_cmd --includeExecutionHistoryDataTables=true"
        log WARN "Including execution history — export may be very large"
    fi

    log INFO "Exporting full database..."
    local export_ok=true
    if ! dockExec "$container" "$export_cmd"; then
        export_ok=false
        log WARN "n8n export:entities exited with errors (some tables may not exist in this n8n version)"
    fi

    # Check if entities.zip was created (even partial)
    if ! dockExec "$container" "test -f $container_zip" 2>/dev/null; then
        if [ "$export_ok" = "false" ]; then
            log ERROR "Full database export failed — no data was exported"
            dockExec "$container" "rm -rf $container_export_dir" 2>/dev/null || true
            return 1
        fi
    fi

    mkdir -p "$output_dir/full-db"

    log INFO "Copying full database export from container..."
    if ! docker cp "$container:$container_zip" "$output_dir/full-db/entities.zip"; then
        log ERROR "Failed to copy full database export"
        dockExec "$container" "rm -rf $container_export_dir" 2>/dev/null || true
        return 1
    fi

    dockExec "$container" "rm -rf $container_export_dir" 2>/dev/null || true

    if [ "$export_ok" = "true" ]; then
        log SUCCESS "Full database export completed"
    else
        log WARN "Partial database export saved (some tables were skipped due to errors)"
        log INFO "Tables that were exported before the error are included in the backup"
    fi
    log INFO "Saved to: $output_dir/full-db/entities.zip"
    return 0
}

