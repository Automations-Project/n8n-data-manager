# Interactive GitHub config — smart flow with auto-fetch
# Step 1: Token (manual input or from config, then validate + fetch user)
# Step 2: Repository (list user's repos as selection, or create new)
# Step 3: Branch (list repo branches as selection, or use default)
# Falls back to manual input if API calls fail
get_github_config() {
    log DEBUG "[UI] Starting interactive GitHub configuration"

    ui_header "🔐 GitHub Configuration"

    # --- Load last-used settings for smart defaults ---
    github_load_last_config 2>/dev/null || true
    local github_username=""

    # ─── Step 1: Token ────────────────────────────────────────
    if [ -z "${ARG_TOKEN:-}" ]; then
        _github_token_input_interactive
    fi

    if [ -z "$ARG_TOKEN" ]; then
        log ERROR "GitHub token is required."
        exit 1
    fi

    # Validate token + fetch username
    local _token_valid=false
    local _retry_count=0
    while ! $_token_valid && [ $_retry_count -lt 3 ]; do
        log INFO "Authenticating with GitHub..." >&2
        local user_info=""
        if user_info=$(github_get_user_info "$ARG_TOKEN" 2>/dev/null); then
            if [ -n "$user_info" ]; then
                github_username="${user_info%%|*}"
                local user_name user_email
                user_name=$(echo "$user_info" | cut -d'|' -f2)
                user_email=$(echo "$user_info" | cut -d'|' -f3)

                # Show authenticated user card
                local user_display="@${github_username}"
                [ -n "$user_name" ] && user_display="${user_name} (@${github_username})"
                ui_notification "success" "Authenticated as $user_display" "${user_email:+$user_email}" >&2
                echo "" >&2
                _token_valid=true
            fi
        fi

        # Fallback: try to get just the username
        if [ -z "$github_username" ] && ! $_token_valid; then
            github_username=$(github_get_username "$ARG_TOKEN" 2>/dev/null) || true
            if [ -n "$github_username" ]; then
                log SUCCESS "Authenticated as @${github_username}" >&2
                _token_valid=true
            fi
        fi

        if ! $_token_valid; then
            _retry_count=$((_retry_count + 1))
            if [ $_retry_count -lt 3 ]; then
                ui_notification "error" "Token authentication failed" \
                    "The token may be invalid, expired, or missing the 'repo' scope." >&2
                echo "" >&2

                local retry_action
                retry_action=$(ui_choose "  What would you like to do?" \
                    "🔑  Enter a different token" \
                    "🌐  Open token creation page (copy URL)" \
                    "⏩  Continue anyway (manual mode)")

                case "$retry_action" in
                    *"different token"*)
                        ARG_TOKEN=$(ui_input "GitHub Personal Access Token" "ghp_..." "true")
                        if [ -z "$ARG_TOKEN" ]; then
                            log ERROR "No token provided."
                            exit 1
                        fi
                        ;;
                    *"creation page"*)
                        _github_show_token_help
                        ARG_TOKEN=$(ui_input "Paste your new token here" "ghp_..." "true")
                        if [ -z "$ARG_TOKEN" ]; then
                            log ERROR "No token provided."
                            exit 1
                        fi
                        ;;
                    *"Continue"*)
                        log WARN "Proceeding without token validation — some features may not work" >&2
                        _token_valid=true
                        ;;
                esac
            else
                log WARN "Could not verify token after 3 attempts — proceeding with manual input" >&2
                _token_valid=true
            fi
        fi
    done

    # ─── Step 2: Repository ───────────────────────────────────
    if [ -z "${ARG_REPO:-}" ]; then
        local repo_selected=false

        # Try to list user's repos
        if [ -n "$github_username" ]; then
            log DEBUG "[UI] Fetching repositories for $github_username..."
            local repos_raw=""
            log INFO "Loading your repositories..." >&2
            repos_raw=$(github_list_repos "$ARG_TOKEN" 50 "owner" 2>/dev/null) || true

            if [ -n "$repos_raw" ]; then
                # Build display list for selection
                local repo_choices=()
                local repo_names=()

                # Add "Create new repo" option at top
                repo_choices+=("➕  Create new repository")
                repo_names+=("__NEW__")

                # Add last-used repo at top if it exists
                if [ -n "$LAST_REPO" ]; then
                    repo_choices+=("⭐  $LAST_REPO  (last used ${LAST_USED:-})")
                    repo_names+=("$LAST_REPO")
                fi

                # Parse repo list
                while IFS='|' read -r full_name desc visibility updated; do
                    [ -z "$full_name" ] && continue
                    # Skip if already added as last-used
                    [ "$full_name" = "$LAST_REPO" ] && continue
                    local icon="📦"
                    [ "$visibility" = "Private" ] && icon="🔒"
                    local display_line="$icon  $full_name"
                    [ -n "$desc" ] && display_line="$display_line  — $desc"
                    [ -n "$updated" ] && display_line="$display_line  ($updated)"
                    repo_choices+=("$display_line")
                    repo_names+=("$full_name")
                done <<< "$repos_raw"

                # Show repo selection
                local selected_display
                if $HAS_GUM; then
                    selected_display=$(printf '%s\n' "${repo_choices[@]}" | gum filter \
                        --placeholder "Search repositories..." \
                        --header "📦 Select Repository" \
                        --header.foreground $THEME_INFO \
                        --indicator "▸" \
                        --indicator.foreground $THEME_PRIMARY \
                        --match.foreground $THEME_PRIMARY \
                        --prompt.foreground $THEME_PRIMARY \
                        --height 15) || true
                else
                    selected_display=$(printf '%s\n' "${repo_choices[@]}" | ui_filter "Select repository")
                fi

                if [ -n "$selected_display" ]; then
                    # Find the matching repo name
                    local idx=0
                    for choice in "${repo_choices[@]}"; do
                        if [ "$choice" = "$selected_display" ]; then
                            local matched_name="${repo_names[$idx]}"
                            if [ "$matched_name" = "__NEW__" ]; then
                                # Create new repo flow
                                _github_create_repo_interactive
                                repo_selected=true
                            else
                                ARG_REPO="$matched_name"
                                repo_selected=true
                                log SUCCESS "Selected repository: $ARG_REPO" >&2
                            fi
                            break
                        fi
                        idx=$((idx + 1))
                    done
                fi
            fi
        fi

        # Fallback to manual input
        if ! $repo_selected; then
            local default_repo="${LAST_REPO:-}"
            [ -z "$default_repo" ] && [ -n "$github_username" ] && default_repo="${github_username}/n8n-backups"
            [ -z "$default_repo" ] && default_repo="username/n8n-backups"
            ARG_REPO=$(ui_input "GitHub Repository (owner/repo)" "$default_repo")
        fi
    fi

    if [ -z "$ARG_REPO" ]; then
        log ERROR "GitHub repository is required."
        exit 1
    fi

    # ─── Step 3: Branch ───────────────────────────────────────
    if [ -z "${ARG_BRANCH:-}" ] || [ "${ARG_BRANCH:-}" = "main" ]; then
        local branch_selected=false

        # Try to list branches from the selected repo
        if [ -n "$ARG_REPO" ] && [ -n "$ARG_TOKEN" ]; then
            local branches_raw=""
            log INFO "Loading branches for $ARG_REPO..." >&2
            branches_raw=$(github_list_branches "$ARG_TOKEN" "$ARG_REPO" 2>/dev/null) || true

            if [ -n "$branches_raw" ]; then
                # Get default branch
                local default_branch="main"
                default_branch=$(github_get_default_branch "$ARG_TOKEN" "$ARG_REPO" 2>/dev/null) || default_branch="main"

                # Build branch choices
                local branch_choices=()
                local seen_default=false

                # Add default branch first with marker
                while IFS= read -r branch_name; do
                    [ -z "$branch_name" ] && continue
                    if [ "$branch_name" = "$default_branch" ]; then
                        branch_choices=("⭐  $branch_name  (default)" "${branch_choices[@]}")
                        seen_default=true
                    else
                        branch_choices+=("    $branch_name")
                    fi
                done <<< "$branches_raw"

                # Add "create new branch" option
                branch_choices+=("➕  Create new branch")

                if [ ${#branch_choices[@]} -gt 0 ]; then
                    local selected_branch_display
                    if $HAS_GUM; then
                        selected_branch_display=$(printf '%s\n' "${branch_choices[@]}" | gum filter \
                            --placeholder "Search branches..." \
                            --header "🌿 Select Branch" \
                            --header.foreground $THEME_INFO \
                            --indicator "▸" \
                            --indicator.foreground $THEME_PRIMARY \
                            --match.foreground $THEME_PRIMARY \
                            --prompt.foreground $THEME_PRIMARY \
                            --height 10) || true
                    else
                        selected_branch_display=$(printf '%s\n' "${branch_choices[@]}" | ui_filter "Select branch")
                    fi

                    if [ -n "$selected_branch_display" ]; then
                        if [[ "$selected_branch_display" == *"Create new branch"* ]]; then
                            ARG_BRANCH=$(ui_input "New branch name" "n8n-backups")
                            branch_selected=true
                        else
                            # Extract branch name (strip icons and markers)
                            ARG_BRANCH=$(echo "$selected_branch_display" | sed 's/^[[:space:]⭐]*//' | sed 's/[[:space:]]*(default)$//' | xargs)
                            branch_selected=true
                        fi
                    fi
                fi
            fi
        fi

        # Fallback to manual input
        if ! $branch_selected; then
            local default_branch_val="${LAST_BRANCH:-main}"
            ARG_BRANCH=$(ui_input "GitHub Branch" "$default_branch_val")
        fi
    fi

    ARG_BRANCH="${ARG_BRANCH:-main}"

    # ─── Save config for next time ────────────────────────────
    local token_hint="${ARG_TOKEN:0:8}"
    github_save_last_config "$ARG_REPO" "$ARG_BRANCH" "$token_hint" 2>/dev/null || true

    GITHUB_TOKEN="$ARG_TOKEN"
    GITHUB_REPO="$ARG_REPO"
    GITHUB_BRANCH="$ARG_BRANCH"

    # Show final config summary
    echo "" >&2
    ui_data_panel "📋 GitHub Configuration" \
        "Repository|$GITHUB_REPO" \
        "Branch|$GITHUB_BRANCH" \
        "User|${github_username:-unknown}" >&2

    log DEBUG "[UI] GitHub config: repo=$GITHUB_REPO branch=$GITHUB_BRANCH token=[masked]"
}

# Sub-flow: Create a new GitHub repository interactively
_github_create_repo_interactive() {
    log DEBUG "[UI] Create new repository flow"

    local repo_name
    repo_name=$(ui_input "New repository name" "n8n-backups")

    if [ -z "$repo_name" ]; then
        log ERROR "Repository name is required."
        return 1
    fi

    local description
    description=$(ui_input "Repository description (optional)" "n8n backup repository managed by n8n-manager")

    local visibility="true"
    local vis_display
    vis_display=$(ui_choose "  Repository visibility" \
        "🔒  Private (recommended)" \
        "🌐  Public")
    if [[ "$vis_display" == *"Public"* ]]; then
        visibility="false"
        ui_warn_box \
            "Public repositories are visible to everyone." \
            "Workflow names, metadata, and backup structure can be exposed." \
            "Use private repos unless you intentionally need public sharing."
        if ! ui_confirm "Create PUBLIC repository '$repo_name'?" "Create Public Repo" "Switch to Private"; then
            visibility="true"
            log INFO "Switched to private repository mode for safety" >&2
        fi
    fi

    local created_repo
    log INFO "Creating repository '$repo_name' on GitHub..." >&2
    if created_repo=$(github_create_repo "$ARG_TOKEN" "$repo_name" "$description" "$visibility" 2>/dev/null); then
        if [ -n "$created_repo" ]; then
            ARG_REPO="$created_repo"
            ui_notification "success" "Repository created: $ARG_REPO" >&2
            echo "" >&2
            return 0
        fi
    fi

    log WARN "Could not create repository via API — using manual name" >&2
    local github_username
    github_username=$(github_get_username "$ARG_TOKEN" 2>/dev/null) || github_username=""
    if [ -n "$github_username" ]; then
        ARG_REPO="${github_username}/${repo_name}"
    else
        ARG_REPO=$(ui_input "Full repository path (owner/repo)" "username/${repo_name}")
    fi
    return 0
}

