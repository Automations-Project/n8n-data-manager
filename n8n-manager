check_install_mode() {
    # Non-interactive: skip entirely
    [ ! -t 0 ] && return 0

    # Already determined this session
    [ -n "$N8N_MANAGER_MODE" ] && return 0

    # Marker file exists → already installed
    if [ -f "$_NM_INSTALL_MARKER" ]; then
        N8N_MANAGER_MODE="installed"
        log DEBUG "[INSTALL] Already installed (marker found)"
        return 0
    fi

    # First run — prompt user
    _prompt_install_mode
}

# ─── Install/One-Time Prompt ─────────────────────────────

_prompt_install_mode() {
    echo "" >&2

    if $HAS_GUM; then
        gum style \
            --border rounded \
            --border-foreground "$THEME_PRIMARY" \
            --padding "1 2" \
            --margin "0 1" \
            "👋 Welcome to n8n-manager!" \
            "" \
            "  How would you like to use n8n-manager?" >&2
    else
        echo "=== Welcome to n8n-manager! ===" >&2
        echo "How would you like to use n8n-manager?" >&2
    fi

    local choice
    choice=$(ui_choose "  Usage Mode" \
        "💾  Install — keep n8n-manager as a command on this machine" \
        "⚡  One-time — run once, then remove all traces")

    case "$choice" in
        *"Install"*)
            N8N_MANAGER_MODE="installed"
            _perform_install
            ;;
        *"One-time"*|*"one-time"*)
            N8N_MANAGER_MODE="one-time"
            log DEBUG "[INSTALL] One-time mode selected — will clean up after operation"
            ui_info_box \
                "⚡ One-time mode" \
                "" \
                "  n8n-manager will run your operation normally." \
                "  Afterward, all files and settings will be removed." \
                "  Nothing will be left on your machine."
            ;;
        *)
            # Default to one-time if cancelled
            N8N_MANAGER_MODE="one-time"
            ;;
    esac
}

# ─── Install Flow ─────────────────────────────────────────

_perform_install() {
    log DEBUG "[INSTALL] Installing n8n-manager..."

    # 1. Create config directory
    mkdir -p "$_NM_CONFIG_DIR" 2>/dev/null || true

    # 2. Copy script to ~/.local/bin/
    mkdir -p "$_NM_BIN_DIR" 2>/dev/null || true

    # Find the currently running script
    local script_path
    script_path=$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")

    if [ -f "$script_path" ] && [ "$script_path" != "$_NM_INSTALL_BIN" ]; then
        cp "$script_path" "$_NM_INSTALL_BIN" 2>/dev/null || true
        chmod +x "$_NM_INSTALL_BIN" 2>/dev/null || true
        log DEBUG "[INSTALL] Copied script to $_NM_INSTALL_BIN"
    fi

    # 3. Ensure ~/.local/bin is in PATH
    _ensure_path_entry

    # 4. Create marker file
    echo "installed_at=$(date -Iseconds 2>/dev/null || date '+%Y-%m-%d %H:%M:%S')" > "$_NM_INSTALL_MARKER" 2>/dev/null || true
    echo "version=$VERSION" >> "$_NM_INSTALL_MARKER" 2>/dev/null || true

    # 5. Show success
    if $HAS_GUM; then
        gum style \
            --border rounded \
            --border-foreground "$THEME_SUCCESS" \
            --padding "1 2" \
            --margin "0 1" \
            "✅ n8n-manager installed!" \
            "" \
            "  Command:   n8n-manager" \
            "  Location:  $_NM_INSTALL_BIN" \
            "  Config:    $_NM_CONFIG_DIR/" \
            "" \
            "  You can now run 'n8n-manager' from anywhere." \
            "  Settings will be saved between sessions." >&2
    else
        echo "✅ n8n-manager installed to $_NM_INSTALL_BIN" >&2
        echo "   Run 'n8n-manager' from anywhere." >&2
    fi
}

# Ensure ~/.local/bin is in PATH (add to shell profile if needed)
_ensure_path_entry() {
    # Already in PATH?
    case ":$PATH:" in
        *":${_NM_BIN_DIR}:"*) return 0 ;;
    esac

    # Add to current session
    export PATH="${_NM_BIN_DIR}:$PATH"

    # Persist to shell profile
    local profile_file=""
    if [ -f "$HOME/.bashrc" ]; then
        profile_file="$HOME/.bashrc"
    elif [ -f "$HOME/.profile" ]; then
        profile_file="$HOME/.profile"
    elif [ -f "$HOME/.zshrc" ]; then
        profile_file="$HOME/.zshrc"
    fi

    if [ -n "$profile_file" ]; then
        # Only add if not already present
        if ! grep -q 'n8n-manager' "$profile_file" 2>/dev/null; then
            {
                echo ""
                echo "# n8n-manager — added automatically"
                echo 'export PATH="$HOME/.local/bin:$PATH"'
            } >> "$profile_file" 2>/dev/null || true
            log DEBUG "[INSTALL] Added ~/.local/bin to PATH in $profile_file"
        fi
    fi
}

# ─── One-Time Cleanup ────────────────────────────────────
# Remove ALL traces of n8n-manager from the machine

cleanup_one_time() {
    # Only run in one-time mode
    [ "$N8N_MANAGER_MODE" != "one-time" ] && return 0

    log DEBUG "[CLEANUP] One-time cleanup starting..."

    echo "" >&2
    if $HAS_GUM; then
        gum style \
            --foreground "$THEME_TEXT_DIM" \
            --italic \
            "  🧹 Cleaning up — removing all n8n-manager traces..." >&2
    else
        echo "🧹 Cleaning up..." >&2
    fi

    # 1. Remove config directory (settings, marker, last_github)
    if [ -d "$_NM_CONFIG_DIR" ]; then
        rm -rf "$_NM_CONFIG_DIR" 2>/dev/null || true
        log DEBUG "[CLEANUP] Removed config directory: $_NM_CONFIG_DIR"
    fi

    # 2. Remove data directory (gum binary, cache)
    if [ -d "$_NM_DATA_DIR" ]; then
        rm -rf "$_NM_DATA_DIR" 2>/dev/null || true
        log DEBUG "[CLEANUP] Removed data directory: $_NM_DATA_DIR"
    fi

    # 3. Remove installed binary (if we installed it)
    if [ -f "$_NM_INSTALL_BIN" ]; then
        rm -f "$_NM_INSTALL_BIN" 2>/dev/null || true
        log DEBUG "[CLEANUP] Removed installed binary: $_NM_INSTALL_BIN"
    fi

    # 4. Remove any log files we created
    if [ -n "${ARG_LOG_FILE:-}" ] && [ -f "${ARG_LOG_FILE:-}" ]; then
        rm -f "$ARG_LOG_FILE" 2>/dev/null || true
        log DEBUG "[CLEANUP] Removed log file: $ARG_LOG_FILE"
    fi

    # 5. Remove shell profile PATH entry if we added it
    local profile_file=""
    for pf in "$HOME/.bashrc" "$HOME/.profile" "$HOME/.zshrc"; do
        if [ -f "$pf" ] && grep -q 'n8n-manager' "$pf" 2>/dev/null; then
            profile_file="$pf"
            break
        fi
    done
    if [ -n "$profile_file" ]; then
        # Remove the n8n-manager PATH lines
        local tmp_profile
        tmp_profile=$(mktemp 2>/dev/null) || true
        if [ -n "$tmp_profile" ]; then
            grep -v 'n8n-manager' "$profile_file" | grep -v '# n8n-manager' > "$tmp_profile" 2>/dev/null
            mv "$tmp_profile" "$profile_file" 2>/dev/null || rm -f "$tmp_profile"
            log DEBUG "[CLEANUP] Removed PATH entry from $profile_file"
        fi
    fi

    # 6. Clean any temp files from this session
    local tmp_pattern="/tmp/n8n-backup-*"
    rm -rf $tmp_pattern 2>/dev/null || true
    local tmp_gum_pattern="/tmp/gum-install-*"
    rm -rf $tmp_gum_pattern 2>/dev/null || true

    if $HAS_GUM; then
        gum style \
            --foreground "$THEME_SUCCESS" \
            "  ✅ All traces removed. Goodbye!" >&2
    else
        echo "✅ All traces removed. Goodbye!" >&2
    fi

    log DEBUG "[CLEANUP] One-time cleanup complete"
}

