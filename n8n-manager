# ═══════════════════════════════════════════════════════════
# Mermaid Diagram Generation (pure bash, no deps)
# ═══════════════════════════════════════════════════════════

# Generate a Mermaid dependency diagram
# Must be called after wf_build_dep_graph()
# Args: $1=output file (optional, stdout if omitted)
# Returns: 0 on success
wf_generate_mermaid() {
    local output_file="${1:-}"

    log DEBUG "[WF_GRAPH] Generating Mermaid diagram"

    local mermaid="graph LR"
    mermaid="${mermaid}"$'\n'

    # Define nodes with categories
    local categories
    categories=$(wf_categorize_nodes)

    while IFS='|' read -r wf_id wf_name category; do
        [ -z "$wf_id" ] && continue
        # Sanitize ID for Mermaid (alphanumeric + underscore only)
        local safe_id
        safe_id=$(echo "$wf_id" | sed 's/[^a-zA-Z0-9_]/_/g')
        # Escape name for Mermaid
        local safe_name
        safe_name=$(echo "$wf_name" | sed 's/"/\\"/g')

        case "$category" in
            entry)      mermaid="${mermaid}    ${safe_id}[\"🟢 ${safe_name}\"]"$'\n' ;;
            middle)     mermaid="${mermaid}    ${safe_id}[\"🟡 ${safe_name}\"]"$'\n' ;;
            leaf)       mermaid="${mermaid}    ${safe_id}[\"🔴 ${safe_name}\"]"$'\n' ;;
            standalone) mermaid="${mermaid}    ${safe_id}[\"⚪ ${safe_name}\"]"$'\n' ;;
        esac
    done <<< "$categories"

    # Define edges
    for src_id in "${!WF_GRAPH_CALLS_TO[@]}"; do
        local safe_src
        safe_src=$(echo "$src_id" | sed 's/[^a-zA-Z0-9_]/_/g')
        local targets="${WF_GRAPH_CALLS_TO[$src_id]}"
        local IFS_BAK="$IFS"
        IFS=','
        for target_id in $targets; do
            local safe_tgt
            safe_tgt=$(echo "$target_id" | sed 's/[^a-zA-Z0-9_]/_/g')
            mermaid="${mermaid}    ${safe_src} --> ${safe_tgt}"$'\n'
        done
        IFS="$IFS_BAK"
    done

    # Style classes
    mermaid="${mermaid}"$'\n'"    classDef entry fill:#b2f2bb,stroke:#2f9e44"
    mermaid="${mermaid}"$'\n'"    classDef middle fill:#ffec99,stroke:#e8590c"
    mermaid="${mermaid}"$'\n'"    classDef leaf fill:#ffc9c9,stroke:#c92a2a"
    mermaid="${mermaid}"$'\n'"    classDef standalone fill:#e9ecef,stroke:#868e96"

    if [ -n "$output_file" ]; then
        echo '```mermaid' > "$output_file"
        echo "$mermaid" >> "$output_file"
        echo '```' >> "$output_file"
        log SUCCESS "Mermaid diagram saved to: $output_file"
    else
        echo "$mermaid"
    fi

    return 0
}

# ═══════════════════════════════════════════════════════════
# Excalidraw Generation (self-contained Node.js)
# ═══════════════════════════════════════════════════════════

# Generate an Excalidraw diagram from the dependency graph
# Must be called after wf_build_dep_graph()
# Args: $1=workflows directory, $2=output file path
# Returns: 0 on success
wf_generate_excalidraw() {
    local workflows_dir="$1"
    local output_file="$2"

    if ! command_exists node; then
        log ERROR "Node.js is required for Excalidraw generation. Install node or use --format mermaid"
        return 1
    fi

    log INFO "Generating Excalidraw diagram..."

    # Build JSON input for the Node.js script:
    # { workflows: {id: {name, file, category}}, edges: [{source, target}] }
    local graph_json
    graph_json=$(_wf_build_graph_json "$workflows_dir")

    if [ -z "$graph_json" ]; then
        log ERROR "Failed to build graph data"
        return 1
    fi

    # Write the Node.js script to a temp file and run it
    local tmp_script
    tmp_script=$(mktemp /tmp/wf_excalidraw_XXXXXX.js)
    local tmp_input
    tmp_input=$(mktemp /tmp/wf_graph_input_XXXXXX.json)

    echo "$graph_json" > "$tmp_input"

    _wf_write_excalidraw_script > "$tmp_script"

    node "$tmp_script" "$tmp_input" "$output_file" 2>/dev/null
    local exit_code=$?

    rm -f "$tmp_script" "$tmp_input" 2>/dev/null

    if [ $exit_code -ne 0 ]; then
        log ERROR "Excalidraw generation failed"
        return 1
    fi

    if [ -f "$output_file" ]; then
        local size
        size=$(wc -c < "$output_file" | xargs)
        log SUCCESS "Excalidraw file generated: $output_file ($size bytes)"
        return 0
    else
        log ERROR "Excalidraw output file not created"
        return 1
    fi
}

# Build JSON input for the Excalidraw generator
# Args: $1=workflows directory
# Output: JSON string to stdout
_wf_build_graph_json() {
    local dir="$1"

    if command_exists node; then
        # Build the complete graph JSON using Node.js for proper escaping
        local categories
        categories=$(wf_categorize_nodes)

        # Build a temporary data file with all info
        local tmp_data
        tmp_data=$(mktemp /tmp/wf_data_XXXXXX.txt)

        # Write categories
        echo "---CATEGORIES---" > "$tmp_data"
        echo "$categories" >> "$tmp_data"

        # Write edges
        echo "---EDGES---" >> "$tmp_data"
        for src_id in "${!WF_GRAPH_CALLS_TO[@]}"; do
            local targets="${WF_GRAPH_CALLS_TO[$src_id]}"
            local IFS_BAK="$IFS"
            IFS=','
            for target_id in $targets; do
                echo "${src_id}|${target_id}" >> "$tmp_data"
            done
            IFS="$IFS_BAK"
        done

        # Write file paths
        echo "---FILES---" >> "$tmp_data"
        for wf_id in "${!WF_GRAPH_FILES[@]}"; do
            echo "${wf_id}|${WF_GRAPH_FILES[$wf_id]}" >> "$tmp_data"
        done

        node -e '
const fs = require("fs");
const data = fs.readFileSync(process.argv[1], "utf8");
const sections = data.split(/---\w+---\n?/).filter(Boolean);

const workflows = {};
const edges = [];
const files = {};

// Parse categories
if (sections[0]) {
    for (const line of sections[0].trim().split("\n")) {
        if (!line) continue;
        const [id, name, category] = line.split("|");
        if (id) workflows[id] = { name, category };
    }
}

// Parse edges
if (sections[1]) {
    for (const line of sections[1].trim().split("\n")) {
        if (!line) continue;
        const [source, target] = line.split("|");
        if (source && target) edges.push({ source, target });
    }
}

// Parse files
if (sections[2]) {
    for (const line of sections[2].trim().split("\n")) {
        if (!line) continue;
        const [id, filepath] = line.split("|");
        if (id && filepath) files[id] = filepath;
    }
}

// Add file paths to workflows
for (const [id, path] of Object.entries(files)) {
    if (workflows[id]) workflows[id].file = path;
}

console.log(JSON.stringify({ workflows, edges }, null, 2));
' "$tmp_data" 2>/dev/null

        rm -f "$tmp_data" 2>/dev/null
    fi
}

