# Import enterprise entities into n8n container
# Creates a partial entities.zip with only selected JSONL files, runs import:entities
# Args: $1=container_id $2=entities_dir $3=is_dry_run
import_enterprise_entities() {
    local container="$1"
    local entities_dir="$2"
    local is_dry_run="${3:-false}"

    log DEBUG "[ENTITIES] Starting enterprise entity import"
    log DEBUG "[ENTITIES] Container: $container, Source: $entities_dir"

    if [ ! -d "$entities_dir" ]; then
        log DEBUG "[ENTITIES] No entities directory found — skipping enterprise import"
        return 0
    fi

    # Check migration compatibility
    if [ -f "$entities_dir/$ENTITY_MIGRATIONS" ]; then
        if ! _check_migration_compatibility "$container" "$entities_dir/$ENTITY_MIGRATIONS"; then
            log WARN "Migration version mismatch detected — enterprise entity import may fail"
            log WARN "Source and target n8n instances may be different versions"
            if [ -t 0 ]; then
                if ! ui_confirm "Proceed with enterprise entity import despite version mismatch?" "Proceed" "Skip"; then
                    log INFO "Enterprise entity import skipped by user"
                    return 0
                fi
            fi
        fi
    fi

    # Import entities in dependency order (Projects → Folders → Tags → Variables → Shared*)
    local any_imported=false

    for entity_file in "${ENTITY_RESTORE_ORDER[@]}"; do
        if [ -f "$entities_dir/$entity_file" ]; then
            local entity_name="${entity_file%.jsonl}"
            local line_count
            line_count=$(wc -l < "$entities_dir/$entity_file" 2>/dev/null || echo "0")
            line_count=$(echo "$line_count" | xargs)

            if [ "$line_count" = "0" ]; then
                log DEBUG "[ENTITIES] $entity_name is empty — skipping"
                continue
            fi

            if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
                log DRYRUN "Would import $entity_name ($line_count entities)"
                any_imported=true
                continue
            fi

            log INFO "Importing $entity_name ($line_count entities)..."

            if _import_single_entity "$container" "$entities_dir" "$entity_file"; then
                log SUCCESS "$entity_name imported successfully"
                any_imported=true
            else
                log WARN "Failed to import $entity_name — continuing with remaining entities"
            fi
        fi
    done

    if $any_imported; then
        log SUCCESS "Enterprise entity import completed"
    else
        log INFO "No enterprise entities found to import"
    fi

    return 0
}

# Import full database (migration mode)
# Args: $1=container_id $2=fulldb_dir $3=is_dry_run $4=truncate_tables
import_full_database() {
    local container="$1"
    local fulldb_dir="$2"
    local is_dry_run="${3:-false}"
    local truncate="${4:-true}"

    if [ ! -f "$fulldb_dir/entities.zip" ]; then
        log ERROR "Full database backup not found at $fulldb_dir/entities.zip"
        return 1
    fi

    if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
        log DRYRUN "Would import full database (truncate=$truncate)"
        return 0
    fi

    local container_import_dir="/tmp/n8n-fulldb-import"
    dockExec "$container" "rm -rf $container_import_dir && mkdir -p $container_import_dir" 2>/dev/null || true

    log INFO "Copying full database export to container..."
    if ! docker cp "$fulldb_dir/entities.zip" "$container:$container_import_dir/entities.zip"; then
        log ERROR "Failed to copy entities.zip to container"
        return 1
    fi

    local import_cmd="n8n import:entities --inputDir=$container_import_dir"
    if [ "$truncate" = "true" ]; then
        import_cmd="$import_cmd --truncateTables true"
    fi

    log INFO "Importing full database (this may take a while)..."
    if ! dockExec "$container" "$import_cmd"; then
        log ERROR "Full database import failed"
        dockExec "$container" "rm -rf $container_import_dir" 2>/dev/null || true
        return 1
    fi

    dockExec "$container" "rm -rf $container_import_dir" 2>/dev/null || true
    log SUCCESS "Full database import completed"
    return 0
}

