#!/usr/bin/env bash
set -Eeuo pipefail
IFS=$'\n\t'
# v4 -> v5 config file translator. Atomic, idempotent, SIGINT-safe.
# Per Phase 4 CONTEXT.md D-10..D-18, D-25.
# Library only -- sourced by utils.sh (auto-trigger) and migrate_config_command.sh.
# NEVER log values of CONF_GITHUB_TOKEN or CONF_N8N_API_KEY (D-12; project anti-pattern policy).

# Sentinel detection string (D-25 locked).
_CONFIG_MIGRATOR_SENTINEL="# Managed by n8n-manager v5"

# Public: Detect whether a config file is v4 (no sentinel), already migrated
# (sentinel present), or missing.
# Args: $1 = config_file path
# Echoes: "v4" | "already-migrated" | "missing"
# Return: 0 always
_config_detect_v4_shape() {
    local config_file="$1"

    if [ ! -f "$config_file" ]; then
        echo "missing"
        return 0
    fi

    if grep -qE '^# Managed by n8n-manager v5' "$config_file"; then
        echo "already-migrated"
        return 0
    fi

    echo "v4"
    return 0
}

# Public: Atomically rewrite a v4 config file to add the v5 sentinel header,
# preserving all original lines byte-for-byte (D-14), creating a .v4.bak before
# atomic mv (D-17), with SIGINT/SIGTERM survival via EXIT/INT/TERM trap (D-18).
#
# Args: $1 = config_file (original path), $2 = mode ("auto" or "explicit")
# Return: 0 on success, 1 on failure or collision guard
#
# D-13 collision guard: if .v4.bak already exists in "auto" mode, log WARN and
# return 1 (caller falls through). In "explicit" mode, also return 1 (caller exits 1).
#
# D-17 step ordering (LOCKED):
#   1. mktemp -> tmpfile
#   2. Write sentinel + banner at top; cat original file verbatim
#   3. bash -n tmpfile (syntax validation)
#   4. chmod --reference="${original}" tmpfile (preserve mode bits)
#   5. cp -p "${original}" "${original}.v4.bak" (backup BEFORE atomic replace)
#   6. mv tmpfile original (atomic replace)
_config_atomic_rewrite() {
    local config_file="$1"
    local mode="${2:-explicit}"
    local tmpfile=""

    # D-13: .v4.bak collision guard
    if [ -f "${config_file}.v4.bak" ]; then
        log WARN "[CONFIG-MIGRATOR] ${config_file}.v4.bak already exists; run 'n8n-manager migrate-config --restore-from-bak' first or remove it manually"
        return 1
    fi

    # Step 1: Create temp file; set trap immediately after so SIGINT cleans up
    tmpfile=$(mktemp -t n8n-manager-config-XXXXXX)
    # D-18: SIGINT survival — trap EXIT, INT, and TERM independently
    trap 'rm -f "$tmpfile"' EXIT INT TERM

    # Step 2: Write sentinel + banner at top, then all original lines verbatim (D-14)
    {
        printf '# Managed by n8n-manager v5 — translated from v4 on %s\n' "$(date -u '+%Y-%m-%d')"
        printf '# Original v4 backup at: %s.v4.bak\n' "$config_file"
        cat "$config_file"
    } > "$tmpfile"

    # Step 3: Syntax validation — ensure bash can parse the result
    if ! bash -n "$tmpfile"; then
        rm -f "$tmpfile"
        log ERROR "[CONFIG-MIGRATOR] Rewritten config failed syntax check: ${config_file}"
        trap - EXIT INT TERM
        tmpfile=""
        return 1
    fi

    # Step 4: Preserve original mode bits (acceptable degradation if unsupported)
    if ! chmod --reference="$config_file" "$tmpfile" 2>/dev/null; then
        log WARN "[CONFIG-MIGRATOR] chmod --reference not supported on this platform; mode bits not preserved"
    fi

    # Step 5: Create backup BEFORE atomic replace (D-17 ordering: backup before mv)
    cp -p "$config_file" "${config_file}.v4.bak"

    # Step 6: Atomic replace
    mv "$tmpfile" "$config_file"

    # Clear trap — temp file is gone (replaced original), nothing to clean up
    trap - EXIT INT TERM
    tmpfile=""

    # D-12: exactly one INFO log line on success
    log INFO "Config translated v4 → v5: backup at ${config_file}.v4.bak"
    return 0
}

# Public: Restore a config file from its .v4.bak backup, atomically.
# Refuses if .v4.bak is absent.
# Args: $1 = config_file path
# Return: 0 on success, 1 if .v4.bak absent
_config_restore_from_bak() {
    local config_file="$1"
    local tmpfile=""

    if [ ! -f "${config_file}.v4.bak" ]; then
        log ERROR "[CONFIG-MIGRATOR] No .v4.bak backup found at ${config_file}.v4.bak"
        return 1
    fi

    # Atomic swap via tmp to avoid partial state
    tmpfile=$(mktemp -t n8n-manager-config-restore-XXXXXX)
    trap 'rm -f "$tmpfile"' EXIT INT TERM

    cp -p "${config_file}.v4.bak" "$tmpfile"
    mv "$tmpfile" "$config_file"
    rm -f "${config_file}.v4.bak"

    trap - EXIT INT TERM
    tmpfile=""

    log INFO "Config restored from .v4.bak: ${config_file}"
    return 0
}

# src/lib/db_fallback_postgres.sh

set -Eeuo pipefail
IFS=$'
	'

DB_PG_RUNNER=""
DB_PG_NETWORK=""

# ── Schema-drift check for Postgres (D-01/D-03/D-04/D-05) ───────────────────
# Must be called AFTER _db_pg_prepare_runner so DB_PG_RUNNER is set.
_db_postgres_check_schema_drift() {
    local allow_drift="${1:-false}"

    # No pinned hashes at all — skip silently (graceful degradation)
    if [ "${#N8N_SCHEMA_HASHES[@]}" -eq 0 ]; then
        log DEBUG "[DB-PG] no known schema hashes provided; schema check skipped"
        return 0
    fi

    # All entries are PLACEHOLDER_HASH — operator has not run refresh-pinned-shas.sh yet
    local _all_placeholder=true
    local _ver
    for _ver in "${!N8N_SCHEMA_HASHES[@]}"; do
        if [ "${N8N_SCHEMA_HASHES[$_ver]}" != "PLACEHOLDER_HASH" ]; then
            _all_placeholder=false
            break
        fi
    done
    if [ "$_all_placeholder" = "true" ]; then
        log WARN "[DB-PG] all pinned schema hashes are PLACEHOLDER_HASH — run scripts/refresh-pinned-shas.sh; schema check skipped"
        return 0
    fi

    # Query migration names in order (D-03 Postgres equivalent)
    local _mig_names
    _mig_names=$(_db_pg_exec_sql "SELECT name FROM migrations ORDER BY id" 2>/dev/null || echo "QUERY_FAILED")

    if [ "$_mig_names" = "QUERY_FAILED" ] || [ -z "$_mig_names" ]; then
        log WARN "[DB-PG] Could not read migrations table — schema check skipped"
        return 0
    fi

    # Compute hash: pipe-delimited names → sha256 → first 16 hex chars (D-03)
    local _hash
    _hash=$(printf "%s" "$_mig_names" | tr '\n' '|' | sha256sum 2>/dev/null | cut -c1-16 || echo "000000000000")

    # Check if computed hash appears in the pinned set (skipping PLACEHOLDER_HASH entries)
    local _found=false
    for _ver in "${!N8N_SCHEMA_HASHES[@]}"; do
        if [ "${N8N_SCHEMA_HASHES[$_ver]}" = "PLACEHOLDER_HASH" ]; then
            continue
        fi
        if [ "${N8N_SCHEMA_HASHES[$_ver]}" = "$_hash" ]; then
            _found=true
            break
        fi
    done

    if [ "$_found" = "true" ]; then
        return 0
    fi

    # Hash not in pinned set — apply drift policy (D-01/D-04/D-05)
    local _pinned_versions
    _pinned_versions=$(printf '%s\n' "${!N8N_SCHEMA_HASHES[@]}" | sort | tr '\n' ',' | sed 's/,$//')

    if [ "$allow_drift" = "true" ] || [ "$allow_drift" = "1" ]; then
        log WARN "[DB-PG] Schema drift detected (hash=$_hash) — proceeding with --allow-schema-drift"
        return 0
    fi

    log ERROR "[DB-PG] SCHEMA DRIFT DETECTED: hash=$_hash not in tested set ($_pinned_versions). Pass --allow-schema-drift to override (WARNING: may corrupt data)."
    return 1
}

_db_pg_require_conn() {
    [ -z "${N8N_PROBE_DB_POSTGRES_HOST:-}" ] && return 1
    [ -z "${N8N_PROBE_DB_POSTGRES_USER:-}" ] && return 1
    [ -z "${N8N_PROBE_DB_POSTGRES_DB:-}" ] && return 1
    return 0
}

_db_pg_prepare_runner() {
    local container="$1"

    if ! _db_pg_require_conn; then
        log ERROR "[DB-PG] missing postgres connection details from runtime probe"
        return 1
    fi

    if command_exists psql; then
        DB_PG_RUNNER="host"
        return 0
    fi

    DB_PG_NETWORK=$(docker inspect -f "{{range \$k,\$v := .NetworkSettings.Networks}}{{println \$k}}{{end}}" "$container" 2>/dev/null | head -n1)
    if [ -z "$DB_PG_NETWORK" ]; then
        log ERROR "[DB-PG] could not detect container network for postgres client"
        return 1
    fi

    if ! docker run --rm --network "$DB_PG_NETWORK" postgres:16-alpine psql --version >/dev/null 2>&1; then
        log ERROR "[DB-PG] unable to run postgres client container"
        return 1
    fi

    DB_PG_RUNNER="docker"
    return 0
}

_db_pg_exec_sql() {
    local sql="$1"

    if [ "$DB_PG_RUNNER" = "host" ]; then
        PGPASSWORD="${N8N_PROBE_DB_POSTGRES_PASSWORD:-}" psql \
            -h "$N8N_PROBE_DB_POSTGRES_HOST" \
            -p "${N8N_PROBE_DB_POSTGRES_PORT:-5432}" \
            -U "$N8N_PROBE_DB_POSTGRES_USER" \
            -d "$N8N_PROBE_DB_POSTGRES_DB" \
            -tA -c "$sql"
        return $?
    fi

    docker run --rm --network "$DB_PG_NETWORK" \
        -e PGPASSWORD="${N8N_PROBE_DB_POSTGRES_PASSWORD:-}" \
        postgres:16-alpine psql \
        -h "$N8N_PROBE_DB_POSTGRES_HOST" \
        -p "${N8N_PROBE_DB_POSTGRES_PORT:-5432}" \
        -U "$N8N_PROBE_DB_POSTGRES_USER" \
        -d "$N8N_PROBE_DB_POSTGRES_DB" \
        -tA -c "$sql"
}

_db_pg_exec_file() {
    local sql_file="$1"

    if [ "$DB_PG_RUNNER" = "host" ]; then
        PGPASSWORD="${N8N_PROBE_DB_POSTGRES_PASSWORD:-}" psql \
            -h "$N8N_PROBE_DB_POSTGRES_HOST" \
            -p "${N8N_PROBE_DB_POSTGRES_PORT:-5432}" \
            -U "$N8N_PROBE_DB_POSTGRES_USER" \
            -d "$N8N_PROBE_DB_POSTGRES_DB" \
            -v ON_ERROR_STOP=1 -f "$sql_file"
        return $?
    fi

    docker run --rm --network "$DB_PG_NETWORK" \
        -e PGPASSWORD="${N8N_PROBE_DB_POSTGRES_PASSWORD:-}" \
        -v "$sql_file:/tmp/apply.sql:ro" \
        postgres:16-alpine psql \
        -h "$N8N_PROBE_DB_POSTGRES_HOST" \
        -p "${N8N_PROBE_DB_POSTGRES_PORT:-5432}" \
        -U "$N8N_PROBE_DB_POSTGRES_USER" \
        -d "$N8N_PROBE_DB_POSTGRES_DB" \
        -v ON_ERROR_STOP=1 -f /tmp/apply.sql
}

