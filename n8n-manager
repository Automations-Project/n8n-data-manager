# Generate a full dependency report in the specified format
# Args: $1=format (console|md|html), $2=output file (optional)
# Uses global WF_GRAPH_* arrays
wf_generate_report() {
    local format="${1:-console}"
    local output_file="${2:-}"
    local report=""

    case "$format" in
        md)  report=$(_wf_report_markdown) ;;
        html) report=$(_wf_report_html) ;;
        *)   _wf_report_console; return 0 ;;
    esac

    if [ -n "$output_file" ]; then
        echo "$report" > "$output_file"
        log SUCCESS "Report saved to: $output_file"
    else
        echo "$report"
    fi
}

# Console report — uses log functions and gum styling
_wf_report_console() {
    local stats
    stats=$(wf_graph_stats)
    local total edges entry middle leaf standalone
    IFS='|' read -r total edges entry middle leaf standalone <<< "$stats"

    ui_header "Workflow Dependency Report"
    echo "" >&2
    log INFO "Total workflows: $total"
    log INFO "Total dependencies: $edges"
    log INFO "Entry points: $entry | Middle tier: $middle | Leaves: $leaf | Standalone: $standalone"

    # Summary table
    echo "" >&2
    log HEADER "Workflow Categories"
    local categories
    categories=$(wf_categorize_nodes)
    while IFS='|' read -r wf_id wf_name category; do
        [ -z "$wf_id" ] && continue
        local icon="⚪"
        case "$category" in
            entry) icon="🟢" ;; middle) icon="🟡" ;; leaf) icon="🔴" ;;
        esac
        log INFO "  $icon $wf_name ($wf_id) — $category"
    done <<< "$categories"

    # Missing dependencies
    echo "" >&2
    log HEADER "Missing Dependencies"
    local missing
    missing=$(wf_find_missing_deps)
    if [ -z "$missing" ]; then
        log SUCCESS "  No missing dependencies"
    else
        while IFS='|' read -r src_id src_name target_id; do
            log WARN "  $src_name → $target_id (not found)"
        done <<< "$missing"
    fi

    # Circular dependencies
    echo "" >&2
    log HEADER "Circular Dependencies"
    local cycles
    cycles=$(wf_find_circular_deps)
    if [ -z "$cycles" ]; then
        log SUCCESS "  No circular dependencies"
    else
        while IFS= read -r cycle; do
            local display=""
            local IFS_BAK="$IFS"
            IFS='|'
            for cid in $cycle; do
                local cname="${WF_GRAPH_NAMES[$cid]:-$cid}"
                display="${display:+$display → }$cname"
            done
            IFS="$IFS_BAK"
            log WARN "  ↻ $display"
        done <<< "$cycles"
    fi

    # Orphan workflows
    echo "" >&2
    log HEADER "Orphan Workflows (no connections)"
    local orphans
    orphans=$(wf_find_orphan_workflows)
    if [ -z "$orphans" ]; then
        log SUCCESS "  All workflows are connected"
    else
        while IFS='|' read -r oid oname; do
            log INFO "  ⚪ $oname ($oid)"
        done <<< "$orphans"
    fi
}

