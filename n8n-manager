" "$file" 2>/dev/null
    else
        log ERROR "Need node or python3 for settings operations"
        return 1
    fi
}

# Update a single setting in a .n8n file
# Args: $1=file path, $2=key, $3=value (JSON-encoded)
# Returns: 0 on success
wf_update_setting() {
    local file="$1"
    local key="$2"
    local value="$3"

    if [[ "${ARG_DRY_RUN:-}" == "1" ]]; then
        log DRYRUN "Would set settings.$key=$value in: $(basename "$file")"
        return 0
    fi

    if command_exists node; then
        node -e '
const fs = require("fs");
try {
    const file = process.argv[1];
    const key = process.argv[2];
    const rawVal = process.argv[3];
    const d = JSON.parse(fs.readFileSync(file, "utf8"));
    if (!d.settings) d.settings = {};
    try { d.settings[key] = JSON.parse(rawVal); } catch { d.settings[key] = rawVal; }
    fs.writeFileSync(file, JSON.stringify(d, null, 2));
} catch(e) { console.error(e.message); process.exit(1); }
' "$file" "$key" "$value" 2>/dev/null
    elif command_exists python3; then
        python3 -c "
