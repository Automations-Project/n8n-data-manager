# JSON Structure Validation
# ═══════════════════════════════════════════════════════════

# Validate basic JSON structure of a .n8n file
# Args: $1=file path
# Output: pipe-delimited issues: severity|category|message
# Returns: 0 if valid, 1 if issues found
wf_validate_structure() {
    local file="$1"
    local issues=0

    if command_exists node; then
        node -e '
const fs = require("fs");
const file = process.argv[1];
let issues = 0;
try {
    const raw = fs.readFileSync(file, "utf8");
    let d;
    try { d = JSON.parse(raw); } catch(e) {
        console.log("error|json|Invalid JSON: " + e.message);
        process.exit(1);
    }
    // Required top-level fields
    if (!d.name) { console.log("warn|structure|Missing workflow name"); issues++; }
    if (!d.id) { console.log("warn|structure|Missing workflow ID"); issues++; }
    if (!Array.isArray(d.nodes)) { console.log("error|structure|Missing or invalid nodes array"); issues++; }
    if (typeof d.connections !== "object") { console.log("warn|structure|Missing connections object"); issues++; }
    if (typeof d.settings !== "object") { console.log("warn|structure|Missing settings object"); issues++; }
    // Check for empty workflow
    if (Array.isArray(d.nodes) && d.nodes.length === 0) {
        console.log("warn|structure|Workflow has no nodes");
        issues++;
    }
    process.exit(issues > 0 ? 1 : 0);
} catch(e) {
    if (issues === 0) { console.log("error|json|" + e.message); }
    process.exit(1);
}
' "$file" 2>/dev/null
        return $?
    elif command_exists python3; then
        python3 -c "
import json, sys
issues = 0
try:
    with open(sys.argv[1]) as f:
        try: d = json.load(f)
        except json.JSONDecodeError as e:
            print(f'error|json|Invalid JSON: {e}')
            sys.exit(1)
    if not d.get('name'): print('warn|structure|Missing workflow name'); issues += 1
    if not d.get('id'): print('warn|structure|Missing workflow ID'); issues += 1
    if not isinstance(d.get('nodes'), list): print('error|structure|Missing or invalid nodes array'); issues += 1
    if not isinstance(d.get('connections'), dict): print('warn|structure|Missing connections object'); issues += 1
    if not isinstance(d.get('settings'), dict): print('warn|structure|Missing settings object'); issues += 1
    if isinstance(d.get('nodes'), list) and len(d['nodes']) == 0:
        print('warn|structure|Workflow has no nodes'); issues += 1
    sys.exit(1 if issues > 0 else 0)
except SystemExit: raise
except Exception as e: print(f'error|json|{e}'); sys.exit(1)
" "$file" 2>/dev/null
        return $?
    else
        # Basic check — is it valid-looking JSON?
        if ! head -c 1 "$file" | grep -q '{' 2>/dev/null; then
            echo "error|json|File does not start with {"
            return 1
        fi
        return 0
    fi
}

# ═══════════════════════════════════════════════════════════
# Node Validation
# ═══════════════════════════════════════════════════════════

# Validate individual nodes in a workflow
# Args: $1=file path
# Output: pipe-delimited issues: severity|category|message
wf_validate_nodes() {
    local file="$1"

    if command_exists node; then
        node -e '
const fs = require("fs");
try {
    const d = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    const nodes = d.nodes || [];
    const ids = new Set();
    for (const node of nodes) {
        // Check for duplicate node IDs
        if (node.id && ids.has(node.id)) {
            console.log("error|nodes|Duplicate node ID: " + node.id + " (" + node.name + ")");
        }
        if (node.id) ids.add(node.id);
        // Check for missing type
        if (!node.type) {
            console.log("error|nodes|Node missing type: " + (node.name || node.id || "unknown"));
        }
        // Check for missing name
        if (!node.name) {
            console.log("warn|nodes|Node missing name: " + (node.id || "unknown"));
        }
        // Check for disabled nodes
        if (node.disabled === true) {
            console.log("info|nodes|Disabled node: " + node.name);
        }
        // Check for nodes with no position
        if (!node.position || !Array.isArray(node.position)) {
            console.log("warn|nodes|Node missing position: " + (node.name || node.id));
        }
    }
} catch(e) { console.log("error|nodes|" + e.message); }
' "$file" 2>/dev/null
    elif command_exists python3; then
        python3 -c "
import json, sys
try:
    with open(sys.argv[1]) as f: d = json.load(f)
    nodes = d.get('nodes', [])
    ids = set()
    for n in nodes:
        nid = n.get('id', '')
        if nid and nid in ids:
            print(f'error|nodes|Duplicate node ID: {nid} ({n.get(\"name\",\"\")})')
        if nid: ids.add(nid)
        if not n.get('type'):
            print(f'error|nodes|Node missing type: {n.get(\"name\", n.get(\"id\", \"unknown\"))}')
        if not n.get('name'):
            print(f'warn|nodes|Node missing name: {n.get(\"id\", \"unknown\")}')
        if n.get('disabled') is True:
            print(f'info|nodes|Disabled node: {n.get(\"name\",\"\")}')
        if not isinstance(n.get('position'), list):
            print(f'warn|nodes|Node missing position: {n.get(\"name\", n.get(\"id\",\"\"))}')
except: pass
" "$file" 2>/dev/null
    fi
}

# ═══════════════════════════════════════════════════════════
# Connection Validation
# ═══════════════════════════════════════════════════════════

# Validate connections reference existing nodes
# Args: $1=file path
# Output: pipe-delimited issues: severity|category|message
wf_validate_connections() {
    local file="$1"

    if command_exists node; then
        node -e '
const fs = require("fs");
try {
    const d = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    const nodeNames = new Set((d.nodes || []).map(n => n.name));
    const connections = d.connections || {};
    for (const [srcName, outputs] of Object.entries(connections)) {
        if (!nodeNames.has(srcName)) {
            console.log("error|connections|Connection references missing source node: " + srcName);
        }
        if (typeof outputs !== "object") continue;
        for (const [outputType, conns] of Object.entries(outputs)) {
            if (!Array.isArray(conns)) continue;
            for (const connGroup of conns) {
                if (!Array.isArray(connGroup)) continue;
                for (const conn of connGroup) {
                    if (conn.node && !nodeNames.has(conn.node)) {
                        console.log("warn|connections|Connection references missing target node: " + conn.node);
                    }
                }
            }
        }
    }
} catch(e) { console.log("error|connections|" + e.message); }
' "$file" 2>/dev/null
    elif command_exists python3; then
        python3 -c "
import json, sys
try:
    with open(sys.argv[1]) as f: d = json.load(f)
    node_names = {n.get('name') for n in d.get('nodes', [])}
    connections = d.get('connections', {})
    for src_name, outputs in connections.items():
        if src_name not in node_names:
            print(f'error|connections|Connection references missing source node: {src_name}')
        if not isinstance(outputs, dict): continue
        for out_type, conns in outputs.items():
            if not isinstance(conns, list): continue
            for conn_group in conns:
                if not isinstance(conn_group, list): continue
                for conn in conn_group:
                    if isinstance(conn, dict) and conn.get('node') and conn['node'] not in node_names:
                        print(f'warn|connections|Connection references missing target node: {conn[\"node\"]}')
except: pass
" "$file" 2>/dev/null
    fi
}

# ═══════════════════════════════════════════════════════════
# Credential Validation
# ═══════════════════════════════════════════════════════════

# Check for credential references in workflow nodes
# Args: $1=file path
# Output: pipe-delimited issues: severity|category|message
wf_validate_credentials() {
    local file="$1"

    if command_exists node; then
        node -e '
const fs = require("fs");
try {
    const d = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    const credIds = new Set();
    for (const node of d.nodes || []) {
        const creds = node.credentials || {};
        for (const [type, cred] of Object.entries(creds)) {
            if (cred && cred.id) {
                if (credIds.has(cred.id + "_" + type)) continue;
                credIds.add(cred.id + "_" + type);
            } else {
                console.log("warn|credentials|Node \"" + node.name + "\" has credential without ID (" + type + ")");
            }
        }
    }
    if (credIds.size > 0) {
        console.log("info|credentials|Workflow references " + credIds.size + " credential(s)");
    }
} catch(e) { console.log("error|credentials|" + e.message); }
' "$file" 2>/dev/null
    fi
}

# ═══════════════════════════════════════════════════════════
# ExecuteWorkflow Reference Validation
# ═══════════════════════════════════════════════════════════

# Validate executeWorkflow node references
# Args: $1=file path
# Output: pipe-delimited issues: severity|category|message
wf_validate_execute_workflow() {
    local file="$1"

    if command_exists node; then
        node -e '
const fs = require("fs");
try {
    const d = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    for (const node of d.nodes || []) {
        if (node.type !== "n8n-nodes-base.executeWorkflow") continue;
        const wfId = node.parameters?.workflowId;
        if (!wfId) {
            console.log("error|execute|Node \"" + node.name + "\" has no workflowId parameter");
            continue;
        }
        if (typeof wfId === "string" && wfId.startsWith("={{")) {
            console.log("info|execute|Node \"" + node.name + "\" uses dynamic workflowId expression");
        } else if (typeof wfId === "object") {
            if (!wfId.value) {
                console.log("warn|execute|Node \"" + node.name + "\" has empty workflowId value");
            }
        }
    }
} catch(e) { console.log("error|execute|" + e.message); }
' "$file" 2>/dev/null
    fi
}

# ═══════════════════════════════════════════════════════════
# Full Validation Runner
# ═══════════════════════════════════════════════════════════

# Run all validation checks on a single file
# Args: $1=file path, $2=strict mode (true/false)
# Output: pipe-delimited issues: severity|category|message
# Returns: 0 if clean, 1 if errors found
wf_validate_full() {
    local file="$1"
    local strict="${2:-false}"

    local all_issues=""
    local has_errors=false

    # Structure check
    local struct_issues
    struct_issues=$(wf_validate_structure "$file")
    if [ -n "$struct_issues" ]; then
        all_issues="${all_issues}${all_issues:+$'\n'}${struct_issues}"
        if echo "$struct_issues" | grep -q '^error|'; then
            has_errors=true
        fi
    fi

    # If JSON is broken, skip further checks
    if echo "$struct_issues" | grep -q '^error|json|'; then
        echo "$all_issues"
        return 1
    fi

    # Node checks
    local node_issues
    node_issues=$(wf_validate_nodes "$file")
    if [ -n "$node_issues" ]; then
        all_issues="${all_issues}${all_issues:+$'\n'}${node_issues}"
        if echo "$node_issues" | grep -q '^error|'; then
            has_errors=true
        fi
    fi

    # Connection checks
    local conn_issues
    conn_issues=$(wf_validate_connections "$file")
    if [ -n "$conn_issues" ]; then
        all_issues="${all_issues}${all_issues:+$'\n'}${conn_issues}"
        if echo "$conn_issues" | grep -q '^error|'; then
            has_errors=true
        fi
    fi

    # Credential checks
    local cred_issues
    cred_issues=$(wf_validate_credentials "$file")
    if [ -n "$cred_issues" ]; then
        all_issues="${all_issues}${all_issues:+$'\n'}${cred_issues}"
    fi

    # ExecuteWorkflow checks
    local exec_issues
    exec_issues=$(wf_validate_execute_workflow "$file")
    if [ -n "$exec_issues" ]; then
        all_issues="${all_issues}${all_issues:+$'\n'}${exec_issues}"
    fi

    # In strict mode, warnings become errors
    if [ "$strict" = "true" ] && echo "$all_issues" | grep -q '^warn|'; then
        has_errors=true
    fi

    [ -n "$all_issues" ] && echo "$all_issues"

    if [ "$has_errors" = "true" ]; then
        return 1
    fi
    return 0
}

