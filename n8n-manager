# ═══════════════════════════════════════════════════════════
# Self-contained Node.js Excalidraw Generator
# ═══════════════════════════════════════════════════════════

# Write the complete Node.js Excalidraw generator script to stdout
_wf_write_excalidraw_script() {
    cat << 'EXCALIDRAW_SCRIPT'
/**
 * Self-contained Excalidraw dependency graph generator
 * No npm dependencies — pure Node.js
 * Input: JSON file with { workflows: {id: {name, category, file}}, edges: [{source, target}] }
 * Output: .excalidraw JSON file
 */
const fs = require("fs");
const path = require("path");

// ─── Configuration ───────────────────────────────
const NODE_SIZE = 75;
const NODE_SPACING = 30;
const FRAME_PADDING = 40;
const FRAME_TITLE_HEIGHT = 50;
const FRAME_CHROME_HEIGHT = 30;
const LAYER_SPACING_X = 350;
const NODE_SPACING_Y = 250;
const TRAFFIC_LIGHT_R = 5;

// Colors
const COLORS = {
    entry:      { frame: "#b2f2bb", stroke: "#2f9e44", text: "#2f9e44" },
    middle:     { frame: "#ffec99", stroke: "#e8590c", text: "#e8590c" },
    leaf:       { frame: "#ffc9c9", stroke: "#c92a2a", text: "#c92a2a" },
    standalone: { frame: "#e9ecef", stroke: "#868e96", text: "#868e96" },
    trigger:    "#2f9e44",
    action:     "#1e1e1e",
    arrow:      "#868e96",
    trafficRed:    "#ff5f57",
    trafficYellow: "#febc2e",
    trafficGreen:  "#28c840",
};

let elementId = 1;
function nextId(prefix) { return `${prefix}_${elementId++}`; }

// ─── Layered Layout Algorithm ────────────────────

function buildAdjacency(workflows, edges) {
    const adj = new Map();
    const inDeg = new Map();
    for (const id of Object.keys(workflows)) {
        adj.set(id, []);
        inDeg.set(id, 0);
    }
    for (const { source, target } of edges) {
        if (adj.has(source) && adj.has(target) && source !== target) {
            adj.get(source).push(target);
            inDeg.set(target, (inDeg.get(target) || 0) + 1);
        }
    }
    return { adj, inDeg };
}

function topologicalSort(adj, inDeg) {
    const queue = [];
    const order = [];
    for (const [id, deg] of inDeg.entries()) {
        if (deg === 0) queue.push(id);
    }
    while (queue.length > 0) {
        const node = queue.shift();
        order.push(node);
        for (const neighbor of adj.get(node) || []) {
            const newDeg = inDeg.get(neighbor) - 1;
            inDeg.set(neighbor, newDeg);
            if (newDeg === 0) queue.push(neighbor);
        }
    }
    // Add any remaining nodes (cycles or disconnected)
    for (const id of adj.keys()) {
        if (!order.includes(id)) order.push(id);
    }
    return order;
}

function assignLayers(order, adj) {
    const layers = new Map();
    for (const id of order) {
        let maxParentLayer = -1;
        // Check all nodes that point to this one
        for (const [srcId, targets] of adj.entries()) {
            if (targets.includes(id) && layers.has(srcId)) {
                maxParentLayer = Math.max(maxParentLayer, layers.get(srcId));
            }
        }
        layers.set(id, maxParentLayer + 1);
    }
    return layers;
}

function computePositions(workflows, edges) {
    const ids = Object.keys(workflows);
    if (ids.length === 0) return new Map();

    const { adj, inDeg } = buildAdjacency(workflows, edges);
    const order = topologicalSort(adj, new Map(inDeg));
    const layers = assignLayers(order, adj);

    // Group by layer
    const layerGroups = new Map();
    for (const [id, layer] of layers.entries()) {
        if (!layerGroups.has(layer)) layerGroups.set(layer, []);
        layerGroups.get(layer).push(id);
    }

    // Assign positions
    const positions = new Map();
    for (const [layer, nodeIds] of layerGroups.entries()) {
        for (let i = 0; i < nodeIds.length; i++) {
            positions.set(nodeIds[i], {
                x: layer * LAYER_SPACING_X,
                y: i * NODE_SPACING_Y,
            });
        }
    }

    return positions;
}

// ─── Excalidraw Element Builders ─────────────────

function makeRect(id, x, y, w, h, opts = {}) {
    return {
        id,
        type: "rectangle",
        x, y, width: w, height: h,
        angle: 0,
        strokeColor: opts.stroke || "#000",
        backgroundColor: opts.fill || "transparent",
        fillStyle: opts.fillStyle || "solid",
        strokeWidth: opts.strokeWidth || 1,
        roughness: 0,
        roundness: opts.roundness || null,
        frameId: opts.frameId || null,
        groupIds: opts.groupIds || [],
        boundElements: opts.boundElements || [],
    };
}

function makeText(id, x, y, text, opts = {}) {
    return {
        id,
        type: "text",
        x, y,
        width: opts.width || 200,
        height: opts.height || 20,
        angle: 0,
        strokeColor: opts.color || "#000",
        backgroundColor: "transparent",
        fillStyle: "solid",
        strokeWidth: 1,
        roughness: 0,
        text,
        fontSize: opts.fontSize || 14,
        fontFamily: opts.fontFamily || 1,
        textAlign: opts.textAlign || "left",
        verticalAlign: opts.verticalAlign || "top",
        lineHeight: 1.25,
        frameId: opts.frameId || null,
        groupIds: opts.groupIds || [],
    };
}

function makeEllipse(id, x, y, w, h, opts = {}) {
    return {
        id,
        type: "ellipse",
        x, y, width: w, height: h,
        angle: 0,
        strokeColor: "transparent",
        backgroundColor: opts.fill || "#ccc",
        fillStyle: "solid",
        strokeWidth: 0,
        roughness: 0,
        frameId: opts.frameId || null,
        groupIds: opts.groupIds || [],
    };
}

function makeArrow(id, startX, startY, endX, endY, opts = {}) {
    return {
        id,
        type: "arrow",
        x: startX,
        y: startY,
        width: endX - startX,
        height: endY - startY,
        angle: 0,
        strokeColor: opts.color || COLORS.arrow,
        backgroundColor: "transparent",
        fillStyle: "solid",
        strokeWidth: opts.strokeWidth || 2,
        strokeStyle: "solid",
        roughness: 0,
        points: [[0, 0], [endX - startX, endY - startY]],
        startArrowhead: null,
        endArrowhead: "arrow",
        startBinding: opts.startBinding || null,
        endBinding: opts.endBinding || null,
        frameId: null,
        groupIds: [],
    };
}

function makeLine(id, x, y, w, opts = {}) {
    return {
        id,
        type: "line",
        x, y,
        width: w,
        height: 0,
        angle: 0,
        strokeColor: opts.color || "#ccc",
        backgroundColor: "transparent",
        fillStyle: "solid",
        strokeWidth: opts.strokeWidth || 1,
        roughness: 0,
        points: [[0, 0], [w, 0]],
        frameId: opts.frameId || null,
        groupIds: opts.groupIds || [],
    };
}

// ─── Workflow Frame Renderer ─────────────────────

function renderWorkflowFrame(wfId, wfData, position, workflowJson) {
    const elements = [];
    const { x, y } = position;
    const cat = wfData.category || "standalone";
    const colors = COLORS[cat] || COLORS.standalone;

    // Calculate frame size from internal nodes
    const nodes = workflowJson ? (workflowJson.nodes || []) : [];
    const regularNodes = nodes.filter(n => n.type !== "n8n-nodes-base.stickyNote");
    const nodeCount = regularNodes.length;

    const cols = Math.max(1, Math.min(6, Math.ceil(Math.sqrt(nodeCount))));
    const rows = Math.max(1, Math.ceil(nodeCount / cols));

    const innerW = cols * (NODE_SIZE + NODE_SPACING) + NODE_SPACING;
    const innerH = rows * (NODE_SIZE + NODE_SPACING + 20) + NODE_SPACING;

    const frameW = Math.max(250, innerW + FRAME_PADDING * 2);
    const frameH = FRAME_CHROME_HEIGHT + FRAME_TITLE_HEIGHT + innerH + FRAME_PADDING;

    const groupId = nextId("frame_group");
    const frameRectId = nextId("frame_rect");

    // Frame background
    elements.push(makeRect(frameRectId, x, y, frameW, frameH, {
        fill: colors.frame,
        stroke: colors.stroke,
        strokeWidth: 2,
        roundness: { type: 3, value: 12 },
        groupIds: [groupId],
        boundElements: [],
    }));

    // Traffic lights
    const tlY = y + FRAME_CHROME_HEIGHT / 2 - TRAFFIC_LIGHT_R;
    elements.push(makeEllipse(nextId("tl_red"), x + 12, tlY, TRAFFIC_LIGHT_R * 2, TRAFFIC_LIGHT_R * 2,
        { fill: COLORS.trafficRed, groupIds: [groupId] }));
    elements.push(makeEllipse(nextId("tl_yel"), x + 28, tlY, TRAFFIC_LIGHT_R * 2, TRAFFIC_LIGHT_R * 2,
        { fill: COLORS.trafficYellow, groupIds: [groupId] }));
    elements.push(makeEllipse(nextId("tl_grn"), x + 44, tlY, TRAFFIC_LIGHT_R * 2, TRAFFIC_LIGHT_R * 2,
        { fill: COLORS.trafficGreen, groupIds: [groupId] }));

    // Separator line below chrome
    elements.push(makeLine(nextId("sep"), x, y + FRAME_CHROME_HEIGHT, frameW,
        { color: colors.stroke, strokeWidth: 1, groupIds: [groupId] }));

    // Title text
    const titleName = wfData.name || wfId;
    const truncTitle = titleName.length > 35 ? titleName.slice(0, 33) + "..." : titleName;
    elements.push(makeText(nextId("title"), x + 12, y + FRAME_CHROME_HEIGHT + 10, truncTitle, {
        color: colors.text,
        fontSize: 16,
        fontFamily: 1,
        width: frameW - 24,
        groupIds: [groupId],
    }));

    // Separator line below title
    elements.push(makeLine(nextId("sep2"), x, y + FRAME_CHROME_HEIGHT + FRAME_TITLE_HEIGHT, frameW,
        { color: colors.stroke, strokeWidth: 0.5, groupIds: [groupId] }));

    // Render internal nodes
    const contentY = y + FRAME_CHROME_HEIGHT + FRAME_TITLE_HEIGHT + FRAME_PADDING / 2;
    const contentX = x + FRAME_PADDING;

    for (let i = 0; i < regularNodes.length; i++) {
        const node = regularNodes[i];
        const col = i % cols;
        const row = Math.floor(i / cols);
        const nx = contentX + col * (NODE_SIZE + NODE_SPACING);
        const ny = contentY + row * (NODE_SIZE + NODE_SPACING + 20);

        const isTrigger = node.type && (node.type.includes("Trigger") || node.type.includes("trigger"));
        const nodeBg = isTrigger ? COLORS.trigger : COLORS.action;
        const nodeStroke = isTrigger ? COLORS.trigger : "#666";

        const nodeGroupId = nextId("ngroup");

        // Node rectangle
        elements.push(makeRect(nextId("nrect"), nx, ny, NODE_SIZE, NODE_SIZE, {
            fill: nodeBg,
            stroke: nodeStroke,
            roundness: { type: 3, value: 8 },
            groupIds: [groupId, nodeGroupId],
        }));

        // Node label
        const nodeName = (node.name || "Node").slice(0, 15);
        elements.push(makeText(nextId("nlabel"), nx - 5, ny + NODE_SIZE + 4, nodeName, {
            color: nodeStroke,
            fontSize: 11,
            width: NODE_SIZE + 10,
            textAlign: "center",
            groupIds: [groupId, nodeGroupId],
        }));
    }

    return {
        elements,
        frameRectId,
        bounds: { x, y, width: frameW, height: frameH },
    };
}

// ─── Legend ───────────────────────────────────────

function renderLegend(x, y) {
    const elements = [];
    const groupId = nextId("legend_group");
    const items = [
        { label: "Entry Point (no callers)", color: COLORS.entry },
        { label: "Middle Tier (calls & called)", color: COLORS.middle },
        { label: "Leaf (called, no outgoing)", color: COLORS.leaf },
        { label: "Standalone (no connections)", color: COLORS.standalone },
    ];

    elements.push(makeText(nextId("legend_title"), x, y, "Legend", {
        fontSize: 16, color: "#333", groupIds: [groupId],
    }));

    for (let i = 0; i < items.length; i++) {
        const item = items[i];
        const iy = y + 30 + i * 28;
        elements.push(makeRect(nextId("legend_box"), x, iy, 18, 18, {
            fill: item.color.frame,
            stroke: item.color.stroke,
            roundness: { type: 3, value: 4 },
            groupIds: [groupId],
        }));
        elements.push(makeText(nextId("legend_text"), x + 26, iy, item.label, {
            fontSize: 13, color: "#333", groupIds: [groupId],
        }));
    }

    return elements;
}

// ─── Main ────────────────────────────────────────

function main() {
    const inputFile = process.argv[2];
    const outputFile = process.argv[3];

    if (!inputFile || !outputFile) {
        console.error("Usage: node script.js <input.json> <output.excalidraw>");
        process.exit(1);
    }

    const input = JSON.parse(fs.readFileSync(inputFile, "utf8"));
    const { workflows, edges } = input;

    // Compute layout positions
    const positions = computePositions(workflows, edges);

    // Load workflow JSONs for internal node rendering
    const workflowJsons = {};
    for (const [id, wf] of Object.entries(workflows)) {
        if (wf.file && fs.existsSync(wf.file)) {
            try {
                workflowJsons[id] = JSON.parse(fs.readFileSync(wf.file, "utf8"));
            } catch { /* skip */ }
        }
    }

    const allElements = [];
    const frameRects = {}; // id -> { rectId, bounds }

    // Render workflow frames
    for (const [id, wf] of Object.entries(workflows)) {
        const pos = positions.get(id) || { x: 0, y: 0 };
        const result = renderWorkflowFrame(id, wf, pos, workflowJsons[id]);
        allElements.push(...result.elements);
        frameRects[id] = { rectId: result.frameRectId, bounds: result.bounds };
    }

    // Render cross-frame arrows for dependencies
    for (const { source, target } of edges) {
        const srcFrame = frameRects[source];
        const tgtFrame = frameRects[target];
        if (!srcFrame || !tgtFrame) continue;

        const startX = srcFrame.bounds.x + srcFrame.bounds.width;
        const startY = srcFrame.bounds.y + srcFrame.bounds.height / 2;
        const endX = tgtFrame.bounds.x;
        const endY = tgtFrame.bounds.y + tgtFrame.bounds.height / 2;

        const arrowId = nextId("dep_arrow");
        allElements.push(makeArrow(arrowId, startX, startY, endX, endY, {
            color: COLORS.arrow,
            strokeWidth: 2,
            startBinding: { elementId: srcFrame.rectId, focus: 0, gap: 8 },
            endBinding: { elementId: tgtFrame.rectId, focus: 0, gap: 8 },
        }));

        // Add arrow to frame's boundElements
        const srcRect = allElements.find(e => e.id === srcFrame.rectId);
        if (srcRect && srcRect.boundElements) {
            srcRect.boundElements.push({ id: arrowId, type: "arrow" });
        }
        const tgtRect = allElements.find(e => e.id === tgtFrame.rectId);
        if (tgtRect && tgtRect.boundElements) {
            tgtRect.boundElements.push({ id: arrowId, type: "arrow" });
        }
    }

    // Render legend at bottom
    let maxY = 0;
    for (const { bounds } of Object.values(frameRects)) {
        maxY = Math.max(maxY, bounds.y + bounds.height);
    }
    allElements.push(...renderLegend(0, maxY + 60));

    // Build Excalidraw file
    const excalidrawData = {
        type: "excalidraw",
        version: 2,
        source: "n8n-manager",
        elements: allElements,
        appState: {
            gridSize: null,
            viewBackgroundColor: "#ffffff",
        },
        files: {},
    };

    fs.writeFileSync(outputFile, JSON.stringify(excalidrawData, null, 2));
}

main();
EXCALIDRAW_SCRIPT
}

