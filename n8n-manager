_n8n_probe_detect_api_url() {
    local container="$1"
    local explicit_url="$2"

    if [ -n "$explicit_url" ]; then
        printf '%s' "$explicit_url"
        return 0
    fi

    if [ -n "${ARG_N8N_API_URL:-}" ]; then
        printf '%s' "$ARG_N8N_API_URL"
        return 0
    fi

    if [ -n "${N8N_API_URL:-}" ]; then
        printf '%s' "$N8N_API_URL"
        return 0
    fi

    local mapped
    mapped=$(docker port "$container" 5678/tcp 2>/dev/null | head -n1)
    if [ -n "$mapped" ]; then
        local host="${mapped%:*}"
        local port="${mapped##*:}"
        case "$host" in
            ""|"0.0.0.0"|"::") host="127.0.0.1" ;;
        esac
        printf 'http://%s:%s' "$host" "$port"
        return 0
    fi

    printf ''
}

_n8n_probe_command_supported() {
    local container="$1"
    local cmd="$2"
    _n8n_probe_exec "$container" "$cmd --help >/dev/null 2>&1"
}

_n8n_probe_route_supported() {
    local route="$1"
    local status="$2"
    local swagger_blob="$3"

    if printf '%s' "$swagger_blob" | grep -q "$route" 2>/dev/null; then
        echo "true"
        return 0
    fi

    case "$status" in
        200|201|202|204|400|401|403|405|409|422|500)
            echo "true"
            ;;
        *)
            echo "false"
            ;;
    esac
}

_n8n_probe_sqlite_api_key_count() {
    local container="$1"
    local sqlite_path="$2"

    if ! command_exists python3; then
        echo "-1"
        return 0
    fi

    local tmp
    tmp=$(mktemp -d -t n8n-probe-sqlite-XXXXXXXXXX)
    local db_file
    db_file="$tmp/database.sqlite"

    if ! docker cp "$container:$sqlite_path" "$db_file" 2>/dev/null; then
        rm -rf "$tmp"
        echo "-1"
        return 0
    fi

    local db_dir
    db_dir=$(dirname "$sqlite_path")
    local db_base
    db_base=$(basename "$sqlite_path")

    docker cp "$container:$db_dir/$db_base-wal" "$tmp/$db_base-wal" 2>/dev/null || true
    docker cp "$container:$db_dir/$db_base-shm" "$tmp/$db_base-shm" 2>/dev/null || true

    local count
    count=$(python3 - "$db_file" <<'PY'
import sqlite3
import sys

path = sys.argv[1]
count = -1
try:
    conn = sqlite3.connect(path)
    cur = conn.cursor()
    for table in ("user_api_keys", "api_keys", "public_api_keys"):
        try:
            cur.execute(f"SELECT COUNT(*) FROM {table}")
            row = cur.fetchone()
            if row is not None:
                count = int(row[0])
                break
        except Exception:
            pass
    conn.close()
except Exception:
    pass
print(count)
PY
)

    rm -rf "$tmp"
    echo "${count:--1}"
}

_n8n_probe_postgres_api_key_count() {
    local host="$1"
    local port="$2"
    local user="$3"
    local db_name="$4"
    local password="$5"

    [ -z "$host" ] && { echo "-1"; return 0; }
    [ -z "$user" ] && { echo "-1"; return 0; }
    [ -z "$db_name" ] && { echo "-1"; return 0; }

    if command_exists psql; then
        PGPASSWORD="$password" psql -h "$host" -p "$port" -U "$user" -d "$db_name" -tAc \
            "SELECT COUNT(*) FROM user_api_keys" 2>/dev/null | xargs || echo "-1"
        return 0
    fi

    echo "-1"
}

n8n_probe_runtime() {
    local container="$1"
    local api_key_override="${2:-}"
    local api_url_override="${3:-}"

    N8N_PROBE_CONTAINER="$container"
    N8N_PROBE_CONTAINER_ENV="$(_n8n_probe_env_dump "$container")"

    N8N_PROBE_VERSION=$(_n8n_probe_exec "$container" "n8n --version 2>/dev/null | head -n1" 2>/dev/null | head -n1)
    N8N_PROBE_VERSION="${N8N_PROBE_VERSION:-unknown}"

    _n8n_probe_command_supported "$container" "n8n export:workflow" && N8N_PROBE_CLI_EXPORT_WORKFLOW="true"
    _n8n_probe_command_supported "$container" "n8n import:workflow" && N8N_PROBE_CLI_IMPORT_WORKFLOW="true"
    _n8n_probe_command_supported "$container" "n8n export:credentials" && N8N_PROBE_CLI_EXPORT_CREDENTIALS="true"
    _n8n_probe_command_supported "$container" "n8n import:credentials" && N8N_PROBE_CLI_IMPORT_CREDENTIALS="true"
    _n8n_probe_command_supported "$container" "n8n export:entities" && N8N_PROBE_CLI_EXPORT_ENTITIES="true"
    _n8n_probe_command_supported "$container" "n8n import:entities" && N8N_PROBE_CLI_IMPORT_ENTITIES="true"

    local db_type
    db_type="$(_n8n_probe_env_get "DB_TYPE")"
    case "${db_type,,}" in
        postgres*|postgre*)
            N8N_PROBE_DB_BACKEND="postgres"
            ;;
        *)
            N8N_PROBE_DB_BACKEND="sqlite"
            ;;
    esac

    local sqlite_path
    sqlite_path="$(_n8n_probe_env_get "DB_SQLITE_DATABASE")"
    N8N_PROBE_DB_SQLITE_PATH="${sqlite_path:-/home/node/.n8n/database.sqlite}"

    N8N_PROBE_DB_POSTGRES_HOST="$(_n8n_probe_env_get "DB_POSTGRESDB_HOST")"
    [ -z "$N8N_PROBE_DB_POSTGRES_HOST" ] && N8N_PROBE_DB_POSTGRES_HOST="$(_n8n_probe_env_get "DB_POSTGRES_HOST")"
    N8N_PROBE_DB_POSTGRES_PORT="$(_n8n_probe_env_get "DB_POSTGRESDB_PORT")"
    [ -z "$N8N_PROBE_DB_POSTGRES_PORT" ] && N8N_PROBE_DB_POSTGRES_PORT="$(_n8n_probe_env_get "DB_POSTGRES_PORT")"
    N8N_PROBE_DB_POSTGRES_PORT="${N8N_PROBE_DB_POSTGRES_PORT:-5432}"
    N8N_PROBE_DB_POSTGRES_DB="$(_n8n_probe_env_get "DB_POSTGRESDB_DATABASE")"
    [ -z "$N8N_PROBE_DB_POSTGRES_DB" ] && N8N_PROBE_DB_POSTGRES_DB="$(_n8n_probe_env_get "DB_POSTGRES_DATABASE")"
    N8N_PROBE_DB_POSTGRES_USER="$(_n8n_probe_env_get "DB_POSTGRESDB_USER")"
    [ -z "$N8N_PROBE_DB_POSTGRES_USER" ] && N8N_PROBE_DB_POSTGRES_USER="$(_n8n_probe_env_get "DB_POSTGRES_USER")"
    N8N_PROBE_DB_POSTGRES_PASSWORD="$(_n8n_probe_env_get "DB_POSTGRESDB_PASSWORD")"
    [ -z "$N8N_PROBE_DB_POSTGRES_PASSWORD" ] && N8N_PROBE_DB_POSTGRES_PASSWORD="$(_n8n_probe_env_get "DB_POSTGRES_PASSWORD")"

    N8N_PROBE_API_URL="$(_n8n_probe_detect_api_url "$container" "$api_url_override")"

    N8N_PROBE_API_KEY=""
    N8N_PROBE_API_KEY_SOURCE="none"
    if [ -n "$api_key_override" ]; then
        N8N_PROBE_API_KEY="$api_key_override"
        N8N_PROBE_API_KEY_SOURCE="flag"
    elif [ -n "${ARG_N8N_API_KEY:-}" ]; then
        N8N_PROBE_API_KEY="$ARG_N8N_API_KEY"
        N8N_PROBE_API_KEY_SOURCE="config-or-cli"
    elif [ -n "${N8N_API_KEY:-}" ]; then
        N8N_PROBE_API_KEY="$N8N_API_KEY"
        N8N_PROBE_API_KEY_SOURCE="host-env"
    else
        local container_api_key
        container_api_key="$(_n8n_probe_env_get "N8N_API_KEY")"
        if [ -n "$container_api_key" ]; then
            N8N_PROBE_API_KEY="$container_api_key"
            N8N_PROBE_API_KEY_SOURCE="container-env"
        fi
    fi

    if [ "$N8N_PROBE_DB_BACKEND" = "sqlite" ]; then
        N8N_PROBE_DB_API_KEY_ROWS="$(_n8n_probe_sqlite_api_key_count "$container" "$N8N_PROBE_DB_SQLITE_PATH")"
    else
        N8N_PROBE_DB_API_KEY_ROWS="$(_n8n_probe_postgres_api_key_count \
            "$N8N_PROBE_DB_POSTGRES_HOST" \
            "$N8N_PROBE_DB_POSTGRES_PORT" \
            "$N8N_PROBE_DB_POSTGRES_USER" \
            "$N8N_PROBE_DB_POSTGRES_DB" \
            "$N8N_PROBE_DB_POSTGRES_PASSWORD")"
    fi

    local swagger_blob=""
    if [ -n "$N8N_PROBE_API_URL" ]; then
        swagger_blob=$(curl -sS --connect-timeout 3 --max-time 10 \
            "$N8N_PROBE_API_URL/api/v1/docs/swagger-ui-init.js" 2>/dev/null || true)
        if [ -n "$swagger_blob" ]; then
            N8N_PROBE_SWAGGER_AVAILABLE="true"
        fi

        local workflows_status projects_status variables_status tags_status folders_status datatables_status source_pull_status source_push_status
        workflows_status=$(_n8n_probe_http_status "$N8N_PROBE_API_URL/api/v1/workflows")
        projects_status=$(_n8n_probe_http_status "$N8N_PROBE_API_URL/api/v1/projects")
        variables_status=$(_n8n_probe_http_status "$N8N_PROBE_API_URL/api/v1/variables")
        tags_status=$(_n8n_probe_http_status "$N8N_PROBE_API_URL/api/v1/tags")
        folders_status=$(_n8n_probe_http_status "$N8N_PROBE_API_URL/api/v1/folders")
        datatables_status=$(_n8n_probe_http_status "$N8N_PROBE_API_URL/api/v1/data-tables")
        source_pull_status=$(_n8n_probe_http_status "$N8N_PROBE_API_URL/api/v1/source-control/pull")
        source_push_status=$(_n8n_probe_http_status "$N8N_PROBE_API_URL/api/v1/source-control/push")

        N8N_PROBE_API_WORKFLOWS=$(_n8n_probe_route_supported "/api/v1/workflows" "$workflows_status" "$swagger_blob")
        N8N_PROBE_API_PROJECTS=$(_n8n_probe_route_supported "/api/v1/projects" "$projects_status" "$swagger_blob")
        N8N_PROBE_API_VARIABLES=$(_n8n_probe_route_supported "/api/v1/variables" "$variables_status" "$swagger_blob")
        N8N_PROBE_API_TAGS=$(_n8n_probe_route_supported "/api/v1/tags" "$tags_status" "$swagger_blob")
        N8N_PROBE_API_FOLDERS=$(_n8n_probe_route_supported "/api/v1/folders" "$folders_status" "$swagger_blob")
        N8N_PROBE_API_DATATABLES=$(_n8n_probe_route_supported "/api/v1/data-tables" "$datatables_status" "$swagger_blob")
        N8N_PROBE_API_SOURCE_PULL=$(_n8n_probe_route_supported "/api/v1/source-control/pull" "$source_pull_status" "$swagger_blob")
        N8N_PROBE_API_SOURCE_PUSH=$(_n8n_probe_route_supported "/api/v1/source-control/push" "$source_push_status" "$swagger_blob")
    fi

    log DEBUG "[PROBE] n8n_version=$N8N_PROBE_VERSION db_backend=$N8N_PROBE_DB_BACKEND api_url=${N8N_PROBE_API_URL:-none}"
    log DEBUG "[PROBE] api_key_source=$N8N_PROBE_API_KEY_SOURCE db_api_key_rows=$N8N_PROBE_DB_API_KEY_ROWS"
}

