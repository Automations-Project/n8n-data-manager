# ║  LAYER 2 — Layout Primitives (composition helpers)                     ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Join 2-3 blocks side-by-side
# Usage: layout_columns "block1" "block2" ["block3"] [--align top|center|bottom]
layout_columns() {
    if $HAS_GUM; then
        local align="top"
        local blocks=()
        for arg in "$@"; do
            case "$arg" in
                --align) : ;;  # next arg is alignment
                top|center|bottom) align="$arg" ;;
                *) blocks+=("$arg") ;;
            esac
        done
        case ${#blocks[@]} in
            0) return ;;
            1) echo "${blocks[0]}" ;;
            2) gum join --horizontal --align "$align" "${blocks[0]}" "  " "${blocks[1]}" ;;
            *) gum join --horizontal --align "$align" "${blocks[0]}" "  " "${blocks[1]}" "  " "${blocks[2]}" ;;
        esac
    else
        # Fallback: stack vertically
        for arg in "$@"; do
            case "$arg" in top|center|bottom|--align) continue ;; esac
            echo "$arg"
        done
    fi
}

# Stack blocks vertically
# Usage: layout_stack "block1" "block2" ...
layout_stack() {
    if $HAS_GUM; then
        gum join --vertical "$@"
    else
        for block in "$@"; do
            echo "$block"
        done
    fi
}

# Sidebar layout — narrow left panel + wide right panel
# Usage: layout_sidebar "left_block" "right_block" [sidebar_width]
layout_sidebar() {
    local left="$1"
    local right="$2"
    local sidebar_w="${3:-24}"

    if $HAS_GUM; then
        local styled_left
        styled_left=$(gum style --width "$sidebar_w" "$left")
        gum join --horizontal --align top "$styled_left" "  " "$right"
    else
        echo "$left"
        echo ""
        echo "$right"
    fi
}

# Center content in terminal
# Usage: layout_centered "content" [width]
layout_centered() {
    local content="$1"
    local width="${2:-0}"

    if $HAS_GUM; then
        local tw
        tw=$(_term_width)
        [ "$width" -le 0 ] && width=$((tw - 4))
        gum style --align center --width "$width" "$content"
    else
        echo "$content"
    fi
}

# Add consistent outer padding
# Usage: layout_padded "content" [v_pad] [h_pad]
layout_padded() {
    local content="$1"
    local vpad="${2:-1}"
    local hpad="${3:-2}"

    if $HAS_GUM; then
        gum style --padding "$vpad $hpad" "$content"
    else
        local i
        for ((i=0; i<vpad; i++)); do echo ""; done
        while IFS= read -r line; do
            printf "%*s%s\n" "$hpad" "" "$line"
        done <<< "$content"
        for ((i=0; i<vpad; i++)); do echo ""; done
    fi
}

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  LAYER 3 — Composite Components (ready-to-use UI widgets)             ║
