# Welcome screen — branded landing with action menu hint
# Usage: screen_welcome
screen_welcome() {
    if $HAS_GUM; then
        local tw
        tw=$(_term_width)

        # Logo block
        local logo_art
        logo_art=$(gum style --foreground "$THEME_SECONDARY" --bold --align center --width "$tw" \
            "███╗   ██╗ █████╗ ███╗   ██╗" \
            "████╗  ██║██╔══██╗████╗  ██║" \
            "██╔██╗ ██║╚█████╔╝██╔██╗ ██║" \
            "██║╚██╗██║██╔══██╗██║╚██╗██║" \
            "██║ ╚████║╚█████╔╝██║ ╚████║" \
            "╚═╝  ╚═══╝ ╚════╝ ╚═╝  ╚═══╝")

        # Subtitle
        local subtitle
        subtitle=$(gum style --foreground "$THEME_SECONDARY" --italic --align center --width "$tw" \
            "Backup & Restore Manager for n8n Docker")

        # Version + status line
        local version_line
        local ver_badge
        ver_badge=$(_style_badge "v${VERSION:-5.0.0}")
        local gum_indicator
        if $HAS_GUM; then
            gum_indicator=$(gum style --foreground "$THEME_SUCCESS" "● gum enabled")
        fi
        version_line=$(gum join --horizontal "$ver_badge" "  " "$gum_indicator")
        version_line=$(gum style --align center --width "$tw" "$version_line")

        # Compose screen
        local screen
        screen=$(layout_stack "" "$logo_art" "" "$subtitle" "" "$version_line" "")
        echo "$screen" >&2

        ui_divider >&2
    else
        echo "" >&2
        echo "  ╔══════════════════════════════════════╗" >&2
        echo "  ║       n8n-manager v${VERSION:-5.0.0}            ║" >&2
        echo "  ║  Backup & Restore for n8n Docker     ║" >&2
        echo "  ╚══════════════════════════════════════╝" >&2
        echo "" >&2
    fi
}

# Backup progress screen — header + progress tracker + status bar
# Usage: screen_backup_progress "container" "repo" "branch" "step_status1|label1" ...
screen_backup_progress() {
    local container="$1"
    local repo="$2"
    local branch="$3"
    shift 3

    ui_dashboard_header "Backing up..." "$THEME_WARNING"
    echo "" >&2
    ui_breadcrumb "n8n-manager" "backup" "in progress..."
    echo "" >&2
    ui_progress_panel "📦 Backup Progress" "$@"
    echo "" >&2
    ui_status_bar "$container" "$repo ($branch)"
}

# Restore progress screen — header + progress tracker + status bar
# Usage: screen_restore_progress "container" "repo" "branch" "step_status1|label1" ...
screen_restore_progress() {
    local container="$1"
    local repo="$2"
    local branch="$3"
    shift 3

    ui_dashboard_header "Restoring..." "$THEME_WARNING"
    echo "" >&2
    ui_breadcrumb "n8n-manager" "restore" "in progress..."
    echo "" >&2
    ui_progress_panel "📥 Restore Progress" "$@"
    echo "" >&2
    ui_status_bar "$container" "$repo ($branch)"
}

# Completion screen — header + split summary + footer
# Usage: screen_completion "action" "container" "repo" "branch" \
#        "config_kv1" ... "---" "result_kv1" ...
screen_completion() {
    local action="$1"
    local container="$2"
    local repo="$3"
    local branch="$4"
    shift 4

    local icon=""
    case "$action" in
        backup)  icon="📦" ;;
        restore) icon="📥" ;;
        import)  icon="🔗" ;;
        *)       icon="✅" ;;
    esac

    ui_dashboard_header "Complete" "$THEME_SUCCESS"
    echo "" >&2
    ui_breadcrumb "n8n-manager" "$action" "complete"
    echo "" >&2
    ui_notification "success" "$icon ${action^} completed successfully!"
    echo "" >&2
    ui_split_summary "Configuration" "Results" "$@"
    echo "" >&2
    ui_status_bar "$container" "$repo ($branch)" "$(date '+%Y-%m-%d %H:%M:%S')"
}

# Error screen — header + error card + optional rollback status
# Usage: screen_error "action" "error_msg" ["detail"] ["rollback_status"]
screen_error() {
    local action="$1"
    local error_msg="$2"
    local detail="${3:-}"
    local rollback="${4:-}"

    ui_dashboard_header "Error" "$THEME_ERROR"
    echo "" >&2
    ui_breadcrumb "n8n-manager" "$action" "failed"
    echo "" >&2
    ui_notification "error" "$error_msg" "$detail"

    if [ -n "$rollback" ]; then
        echo "" >&2
        case "$rollback" in
            success)
                ui_notification "success" "Rollback completed" "Previous state has been restored"
                ;;
            failed)
                ui_notification "warning" "Rollback failed" "Manual intervention may be required"
                ;;
            *)
                ui_notification "info" "Rollback: $rollback"
                ;;
        esac
    fi

    echo "" >&2
    ui_divider
}

