_db_sqlite_require_python() {
    if ! command_exists python3; then
        log ERROR "python3 is required for SQLite fallback engine"
        return 1
    fi
    return 0
}

_db_sqlite_path() {
    echo "${N8N_PROBE_DB_SQLITE_PATH:-/home/node/.n8n/database.sqlite}"
}

# Build --known-hashes args from the N8N_SCHEMA_HASHES associative array (D-02/D-03)
_db_sqlite_known_hashes_args() {
    local _args=()
    local _ver
    for _ver in "${!N8N_SCHEMA_HASHES[@]}"; do
        _args+=(--known-hashes "${_ver}=${N8N_SCHEMA_HASHES[$_ver]}")
    done
    printf '%s\0' "${_args[@]}"
}

# Build --allow-schema-drift flag array when ARG_ALLOW_SCHEMA_DRIFT is set (D-04)
_db_sqlite_drift_flag() {
    if [ "${ARG_ALLOW_SCHEMA_DRIFT:-}" = "1" ] || [ "${ARG_ALLOW_SCHEMA_DRIFT:-}" = "true" ]; then
        printf '%s\0' "--allow-schema-drift"
    fi
}

_db_sqlite_copy_db() {
    local container="$1"
    local out_dir="$2"

    local sqlite_path
    sqlite_path="$(_db_sqlite_path)"
    local db_dir
    db_dir=$(dirname "$sqlite_path")
    local db_name
    db_name=$(basename "$sqlite_path")

    mkdir -p "$out_dir"

    if ! docker cp "$container:$sqlite_path" "$out_dir/$db_name" 2>/dev/null; then
        log ERROR "[DB-SQLITE] failed to copy sqlite database from container path: $sqlite_path"
        return 1
    fi

    docker cp "$container:$db_dir/$db_name-wal" "$out_dir/$db_name-wal" 2>/dev/null || true
    docker cp "$container:$db_dir/$db_name-shm" "$out_dir/$db_name-shm" 2>/dev/null || true

    log DEBUG "[DB-SQLITE] copied database snapshot to $out_dir/$db_name"
    return 0
}

_db_sqlite_clear_wal_files() {
    local container="$1"
    local sqlite_path
    sqlite_path="$(_db_sqlite_path)"

    local dir
    dir=$(dirname "$sqlite_path")
    local name
    name=$(basename "$sqlite_path")

    docker run --rm --volumes-from "$container" alpine sh -lc \
        "rm -f '$dir/$name-wal' '$dir/$name-shm'" >/dev/null 2>&1 || true
}

db_sqlite_export_metadata() {
    local container="$1"
    local output_root="$2"
    local keep_variable_values="${3:-false}"
    local is_dry_run="${4:-false}"

    _db_sqlite_require_python || return 1

    if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
        log DRYRUN "Would export metadata via sqlite fallback"
        return 0
    fi

    local tmp
    tmp=$(mktemp -d -t n8n-sqlite-export-XXXXXXXXXX)
    local sqlite_path
    sqlite_path="$(_db_sqlite_path)"
    local db_name
    db_name=$(basename "$sqlite_path")

    if ! _db_sqlite_copy_db "$container" "$tmp"; then
        rm -rf "$tmp"
        return 1
    fi

    # Build export flag array (export is read-only; drift is tolerated per D-01)
    local _export_flags=()
    [ "$keep_variable_values" = "true" ] && _export_flags+=(--retain-variable-values)

    local _kh_args=()
    while IFS= read -r -d '' _arg; do
        _kh_args+=("$_arg")
    done < <(_db_sqlite_known_hashes_args)
    # Export path: no --allow-schema-drift needed; Python engine treats export as read-only

    _db_sqlite_engine_path >/dev/null || return 1
    if ! python3 "$DB_SQLITE_PY_SCRIPT" "${_kh_args[@]}" export \
            --db "$tmp/$db_name" --out "$output_root" "${_export_flags[@]}" >/dev/null; then
        log ERROR "[DB-SQLITE] metadata export failed"
        rm -rf "$tmp"
        return 1
    fi

    rm -rf "$tmp"
    return 0
}

db_sqlite_collect_state() {
    local container="$1"
    local output_json="$2"

    _db_sqlite_require_python || return 1

    local tmp
    tmp=$(mktemp -d -t n8n-sqlite-state-XXXXXXXXXX)
    local sqlite_path
    sqlite_path="$(_db_sqlite_path)"
    local db_name
    db_name=$(basename "$sqlite_path")

    if ! _db_sqlite_copy_db "$container" "$tmp"; then
        rm -rf "$tmp"
        return 1
    fi

    # Build schema-drift args
    local _kh_args=()
    while IFS= read -r -d '' _arg; do
        _kh_args+=("$_arg")
    done < <(_db_sqlite_known_hashes_args)

    _db_sqlite_engine_path >/dev/null || return 1
    if ! python3 "$DB_SQLITE_PY_SCRIPT" "${_kh_args[@]}" state --db "$tmp/$db_name" > "$output_json"; then
        log ERROR "[DB-SQLITE] failed to read current DB state"
        rm -rf "$tmp"
        return 1
    fi

    rm -rf "$tmp"
    return 0
}

db_sqlite_apply_metadata() {
    local container="$1"
    local input_root="$2"
    local delete_missing="${3:-false}"
    local is_dry_run="${4:-false}"
    local report_json="${5:-}"
    local keep_variable_values="${6:-false}"

    _db_sqlite_require_python || return 1

    local tmp
    tmp=$(mktemp -d -t n8n-sqlite-import-XXXXXXXXXX)
    local sqlite_path
    sqlite_path="$(_db_sqlite_path)"
    local db_name
    db_name=$(basename "$sqlite_path")

    if ! _db_sqlite_copy_db "$container" "$tmp"; then
        rm -rf "$tmp"
        return 1
    fi

    # Build import flag array (avoids eval — arrays preserve whitespace/symbols)
    local _import_flags=()
    [ "$delete_missing" = "true" ] && _import_flags+=(--delete-missing)
    [ "$is_dry_run" = "true" ]     && _import_flags+=(--dry-run)
    [ "$keep_variable_values" = "true" ] && _import_flags+=(--retain-variable-values)
    [ -n "$report_json" ]          && _import_flags+=(--report "$report_json")

    # Build schema-drift args for import (write path — enforce check per D-01/D-04)
    local _kh_args=()
    while IFS= read -r -d '' _arg; do
        _kh_args+=("$_arg")
    done < <(_db_sqlite_known_hashes_args)

    local _drift_args=()
    while IFS= read -r -d '' _arg; do
        _drift_args+=("$_arg")
    done < <(_db_sqlite_drift_flag)

    _db_sqlite_engine_path >/dev/null || return 1
    if ! python3 "$DB_SQLITE_PY_SCRIPT" "${_drift_args[@]}" "${_kh_args[@]}" import \
            --db "$tmp/$db_name" --input "$input_root" "${_import_flags[@]}" >/dev/null; then
        log ERROR "[DB-SQLITE] metadata apply failed"
        rm -rf "$tmp"
        return 1
    fi

    if [ "$is_dry_run" != "true" ] && [ "$is_dry_run" != "1" ]; then
        _db_sqlite_clear_wal_files "$container"
        if ! docker cp "$tmp/$db_name" "$container:$sqlite_path" 2>/dev/null; then
            log ERROR "[DB-SQLITE] failed to write updated sqlite db back to container"
            rm -rf "$tmp"
            return 1
        fi
        log INFO "[DB-SQLITE] metadata changes written to sqlite database"
    fi

    rm -rf "$tmp"
    return 0
}

