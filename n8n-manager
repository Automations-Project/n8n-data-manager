select_workflows_interactive() {
    local workflow_data="$1"
    local context="${2:-backup}"

    if [ -z "$workflow_data" ]; then
        log WARN "No workflows available for selection"
        return 1
    fi

    # Count workflows
    local total_count
    total_count=$(echo "$workflow_data" | wc -l | xargs)

    # Display workflow table in a viewport
    echo "" >&2
    ui_section_header "Workflow Discovery" "🔍" "$THEME_INFO"
    log INFO "Found $total_count workflow(s) in container"
    echo "" >&2

    # Show the table (manual render to avoid gum table first-row highlight quirk)
    _render_workflow_discovery_table "$workflow_data"
    echo "" >&2

    # Offer selection mode
    if [ ! -t 0 ]; then
        # Non-interactive: select all
        log INFO "Non-interactive mode — selecting all $total_count workflows"
        echo "$workflow_data" | cut -d'|' -f1 | tr '\n' ',' | sed 's/,$//'
        return 0
    fi

    # Interactive: ask user what to do
    local mode
    mode=$(ui_choose "📦 Select workflows to $context" \
        "✅ All workflows ($total_count)" \
        "🔘 Select specific workflows" \
        "🟢 Active workflows only" \
        "❌ Cancel")

    case "$mode" in
        "✅ All"*|"All"*)
            log SUCCESS "Selected all $total_count workflows"
            # Return empty string to signal "all" (no --workflow-id filter needed)
            echo ""
            return 0
            ;;
        "🔘 Select"*|"Select"*)
            _select_specific_workflows "$workflow_data"
            return $?
            ;;
        "🟢 Active"*|"Active"*)
            local active_ids
            active_ids=$(echo "$workflow_data" | grep '|Active|' | cut -d'|' -f1 | tr '\n' ',' | sed 's/,$//')
            local active_count
            active_count=$(echo "$workflow_data" | grep -c '|Active|' || echo "0")
            if [ -z "$active_ids" ]; then
                log WARN "No active workflows found"
                return 1
            fi
            log SUCCESS "Selected $active_count active workflows"
            echo "$active_ids"
            return 0
            ;;
        *)
            log INFO "Workflow selection cancelled"
            return 1
            ;;
    esac
}

# Internal: Let user pick specific workflows via multi-select
_select_specific_workflows() {
    local workflow_data="$1"

    # Build display items for gum choose: "ID — Name (Status)"
    local display_items=()

    while IFS='|' read -r wf_id wf_name wf_active wf_updated wf_nodes; do
        [ -z "$wf_id" ] && continue
        local status_icon="⏸"
        [ "$wf_active" = "Active" ] && status_icon="🟢"
        display_items+=("${wf_id} — ${wf_name} (${status_icon} ${wf_active}, ${wf_nodes} nodes)")
    done <<< "$workflow_data"

    if [ ${#display_items[@]} -eq 0 ]; then
        log WARN "No workflows to select"
        return 1
    fi

    # Gum flow: one searchable multi-select screen, then review + confirm.
    if $HAS_GUM; then
        local selected=""
        local selected_ids=""
        local review_lines=""
        while true; do
            selected=$(ui_multi_select \
                "🔘 Select workflows (type to search, toggle items, enter submit)" \
                "${display_items[@]}")

            if [ -z "$selected" ]; then
                if ui_confirm "No workflows selected. Cancel selection?" "Cancel" "Back"; then
                    log INFO "Workflow selection cancelled"
                    return 1
                fi
                continue
            fi

            selected_ids=""
            review_lines=""
            local selected_count=0
            local -a selected_id_list=()
            local -A selected_id_map=()
            local line=""
            local id=""

            # Primary parse path: match selected items against known workflow IDs.
            # This is resilient if gum returns results in non-line-delimited formats.
            local item=""
            for item in "${display_items[@]}"; do
                id="${item%% *}"
                if [[ "$selected" == *"$id — "* ]]; then
                    selected_id_list+=("$id")
                    selected_id_map["$id"]=1
                    review_lines+="$item"$'\n'
                fi
            done
            selected_count=${#selected_id_list[@]}

            # Fallback parse path: legacy line parsing.
            if [ "$selected_count" -eq 0 ]; then
                while IFS= read -r line; do
                    [ -z "$line" ] && continue
                    id="${line%% *}"
                    [ -z "$id" ] && continue
                    if [ -z "${selected_id_map[$id]:-}" ]; then
                        for item in "${display_items[@]}"; do
                            if [[ "$item" == "$id "* ]]; then
                                selected_id_list+=("$id")
                                selected_id_map["$id"]=1
                                review_lines+="$item"$'\n'
                                break
                            fi
                        done
                    fi
                done <<< "$selected"
                selected_count=${#selected_id_list[@]}
            fi

            # Compatibility parse path: some gum builds may return selections
            # as whitespace/comma-delimited tokens instead of one line per item.
            if [ "$selected_count" -le 1 ]; then
                local selected_flat=""
                selected_flat=" $(printf '%s' "$selected" | tr '\r\n\t,;' '     ') "
                for item in "${display_items[@]}"; do
                    id="${item%% *}"
                    [ -n "${selected_id_map[$id]:-}" ] && continue
                    if [[ "$selected_flat" == *" $id "* ]]; then
                        selected_id_list+=("$id")
                        selected_id_map["$id"]=1
                        review_lines+="$item"$'\n'
                    fi
                done
                selected_count=${#selected_id_list[@]}
            fi

            if [ "$selected_count" -eq 0 ]; then
                log WARN "No workflows selected"
                continue
            fi

            local _sid=""
            for _sid in "${selected_id_list[@]}"; do
                selected_ids="${selected_ids:+${selected_ids},}${_sid}"
            done

            if [ -n "$review_lines" ] && declare -F ui_pager >/dev/null 2>&1; then
                printf '%s' "$review_lines" | ui_pager "Review selected workflows ($selected_count)"
            else
                printf '%s\n' "$review_lines" >&2
            fi

            if ui_confirm "Use these $selected_count workflow(s)?" "Confirm" "Reselect"; then
                log SUCCESS "Selected $selected_count workflow(s)"
                echo "$selected_ids"
                return 0
            fi
        done
    fi

    # Non-gum fallback: keep simple one-pass selection.
    local selected
    selected=$(ui_multi_select "🔘 Select workflows (space to toggle, enter to confirm)" "${display_items[@]}")
    if [ -z "$selected" ]; then
        log WARN "No workflows selected"
        return 1
    fi

    local selected_ids=""
    local selected_count
    local id
    while IFS= read -r line; do
        id="${line%% *}"
        if [ -n "$id" ]; then
            selected_ids="${selected_ids:+${selected_ids},}${id}"
        fi
    done <<< "$selected"
    selected_count=$(echo "$selected" | wc -l | xargs)

    log SUCCESS "Selected $selected_count workflow(s)"
    echo "$selected_ids"
    return 0
}

