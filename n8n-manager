          local mode
          mode=$(ui_choose "Select validation mode" \
              "Single file" \
              "All files in directory" \
              "Select specific files")

          case "$mode" in
              "Single"*)
                  ARG_FILE=$(ui_input "Path to .n8n file" "")
                  if [ -z "$ARG_FILE" ] || [ ! -f "$ARG_FILE" ]; then
                      log ERROR "File not found: ${ARG_FILE:-<not specified>}"
                      exit 1
                  fi
                  files_to_process+=("$ARG_FILE")
                  ;;
              "All"*)
                  ARG_WORKFLOWS_DIR=$(ui_input "Path to .n8n workflow files directory" "")
                  if [ -z "$ARG_WORKFLOWS_DIR" ] || [ ! -d "$ARG_WORKFLOWS_DIR" ]; then
                      log ERROR "Directory not found: ${ARG_WORKFLOWS_DIR:-<not specified>}"
                      exit 1
                  fi
                  for f in "$ARG_WORKFLOWS_DIR"/*.n8n; do
                      [ -f "$f" ] && files_to_process+=("$f")
                  done
                  ;;
              "Select"*)
                  ARG_WORKFLOWS_DIR=$(ui_input "Path to .n8n workflow files directory" "")
                  local wd
                  wd=$(wf_discover_files "$ARG_WORKFLOWS_DIR")
                  local sel
                  sel=$(wf_select_interactive "$wd" "validate")
                  while IFS= read -r f; do
                      [ -n "$f" ] && files_to_process+=("$f")
                  done <<< "$sel"
                  ;;
          esac
      else
          log ERROR "Specify --file, --all, or --select"
          log INFO "Usage: n8n-manager workflow validate --file path.n8n"
          log INFO "       n8n-manager workflow validate --all --workflows-dir ./workflows"
          exit 1
      fi
  fi

  if [ ${#files_to_process[@]} -eq 0 ]; then
      log ERROR "No files to process"
      exit 1
  fi

  # ── Run validation ───────────────────────────────

  local strict=false
  [[ "$ARG_STRICT" == "1" ]] && strict=true

  ui_header "Workflow Validation"
  echo "" >&2

  local total_files=${#files_to_process[@]}
  local files_passed=0
  local files_failed=0
  local total_errors=0
  local total_warnings=0
  local total_info=0

  for file in "${files_to_process[@]}"; do
      local basename_file
      basename_file=$(basename "$file")

      local issues
      issues=$(wf_validate_full "$file" "$strict")
      local exit_code=$?

      if [ -z "$issues" ]; then
          log SUCCESS "  ✔ $basename_file — clean"
          files_passed=$((files_passed + 1))
          continue
      fi

      if [ $exit_code -ne 0 ]; then
          files_failed=$((files_failed + 1))
      else
          files_passed=$((files_passed + 1))
      fi

      # Display issues
      local file_errors=0 file_warnings=0 file_info=0
      while IFS='|' read -r severity category message; do
          [ -z "$severity" ] && continue
          case "$severity" in
              error)
                  log ERROR "  ✖ $basename_file [$category] $message"
                  file_errors=$((file_errors + 1))
                  total_errors=$((total_errors + 1))
                  ;;
              warn)
                  log WARN "  ⚠ $basename_file [$category] $message"
                  file_warnings=$((file_warnings + 1))
                  total_warnings=$((total_warnings + 1))
                  ;;
              info)
                  log INFO "  ℹ $basename_file [$category] $message"
                  file_info=$((file_info + 1))
                  total_info=$((total_info + 1))
                  ;;
          esac
      done <<< "$issues"
  done

  # ── Summary ──────────────────────────────────────

  echo "" >&2
  local strict_note=""
  [ "$strict" = "true" ] && strict_note=" (strict mode)"

  if [ "$files_failed" -eq 0 ]; then
      ui_success_box "All $total_files file(s) passed validation${strict_note}"
  else
      ui_error_box "$files_failed of $total_files file(s) failed validation${strict_note}"
  fi

  ui_summary "Validation Summary" \
      "Files scanned" "$total_files" \
      "Passed" "$files_passed" \
      "Failed" "$files_failed" \
      "Errors" "$total_errors" \
      "Warnings" "$total_warnings" \
      "Info" "$total_info"

  if [ "$files_failed" -gt 0 ]; then
      exit 1
  fi

}

