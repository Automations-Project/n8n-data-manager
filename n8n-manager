# Interactive container selection with smart auto-detect
# Auto-selects if only one n8n container is running; shows styled table otherwise
select_container() {
    log DEBUG "[UI] Starting interactive container selection"

    local containers_raw
    containers_raw=$(docker ps --format "{{.ID}}\t{{.Names}}\t{{.Image}}\t{{.Status}}\t{{.Ports}}")

    if [ -z "$containers_raw" ]; then
        ui_error_box "No running Docker containers found." "Start a container and try again."
        exit 1
    fi

    # Build arrays + detect n8n containers
    local display_items=()
    local container_ids=()
    local n8n_ids=()
    local n8n_names=()
    local csv_data="ID,Name,Image,Status,Type"

    # Column widths for aligned display (matches table columns)
    local _cw_id=14 _cw_name=39 _cw_image=44 _cw_status=13 _cw_type=9
    local _row_fmt="%-${_cw_id}s %-${_cw_name}s %-${_cw_image}s %-${_cw_status}s"

    # ANSI styling for n8n vs other containers in gum filter
    local _ansi_bold=$'\033[1m'
    local _ansi_n8n=$'\033[1;38;5;'"$THEME_SECONDARY"'m'  # Bold + n8n brand purple
    local _ansi_dim=$'\033[2;38;5;'"$THEME_TEXT_DIM"'m'  # Faint + dim text
    local _ansi_reset=$'\033[0m'

    while IFS=$'\t' read -r id name image status ports; do
        local short_id="${id:0:12}"
        local short_status="${status%% (*}" # trim "(X hours ago)"
        local ctype="other"
        local is_n8n=false
        if is_n8n_container_candidate "$name" "$image" "$ports"; then
            ctype="n8n"
            is_n8n=true
            n8n_ids+=("$id")
            n8n_names+=("$name")
        fi
        # Truncate long values to fit columns
        local disp_name="$name" disp_image="$image"
        if [ ${#disp_name} -gt $((_cw_name - 2)) ]; then
            disp_name="${disp_name:0:$((_cw_name - 3))}…"
        fi
        if [ ${#disp_image} -gt $((_cw_image - 2)) ]; then
            disp_image="${disp_image:0:$((_cw_image - 3))}…"
        fi
        # Build aligned row prefix (ID, Name, Image, Status)
        # SC2059: $_row_fmt is an intentional printf format string built dynamically from
        # column widths — it cannot be a literal and must be passed as the format argument.
        # shellcheck disable=SC2059
        local row_base
        row_base=$(printf "$_row_fmt" "$short_id" "$disp_name" "$disp_image" "$short_status")
        # Apply gum-inspired ANSI highlighting: bold+orange for n8n, dim for other
        if $is_n8n; then
            display_items+=("${_ansi_bold}${row_base} ${_ansi_n8n}⚡𝗻𝟴𝗻 ⚡${_ansi_reset}")
        else
            display_items+=("${_ansi_dim}${row_base} · other${_ansi_reset}")
        fi
        container_ids+=("$id")
        csv_data="${csv_data}
${short_id},${disp_name},${disp_image},${short_status},${ctype}"
    done <<< "$containers_raw"

    if [ ${#display_items[@]} -eq 0 ]; then
        ui_error_box "No running Docker containers found."
        exit 1
    fi

    # Auto-select if exactly one n8n container
    if [ ${#n8n_ids[@]} -eq 1 ]; then
        SELECTED_CONTAINER_ID="${n8n_ids[0]}"
        log SUCCESS "Auto-detected n8n container: ${n8n_names[0]} (${SELECTED_CONTAINER_ID:0:12})"
        # Show quick confirmation card
        ui_notification "info" "🐳 Container: ${n8n_names[0]}" "${SELECTED_CONTAINER_ID:0:12}" >&2
        echo "" >&2
        return 0
    fi

    # Show bordered table (non-interactive, stays in terminal)
    ui_section_header "Container Selection" "🐳" "$THEME_INFO"
    if $HAS_GUM; then
        # Manual table rendering — avoids gum table first-row highlight quirk
        local _tb=$'\033[38;5;'"$THEME_BORDER"'m'
        local _th=$'\033[1;38;5;'"$THEME_INFO"'m'
        local _tc=$'\033[38;5;'"$THEME_TEXT"'m'
        local _tn=$'\033[1;38;5;'"$THEME_SECONDARY"'m'
        local _tr=$'\033[0m'

        # Horizontal rule segments per column
        local _hl_segs=()
        for _w in $_cw_id $_cw_name $_cw_image $_cw_status $_cw_type; do
            local _seg=""; for ((_j=0; _j<_w+2; _j++)); do _seg+="─"; done
            _hl_segs+=("$_seg")
        done

        {
            # Top border
            printf '%s╭%s┬%s┬%s┬%s┬%s╮%s\n' "$_tb" "${_hl_segs[0]}" "${_hl_segs[1]}" "${_hl_segs[2]}" "${_hl_segs[3]}" "${_hl_segs[4]}" "$_tr"
            # Header row (bold + colored)
            printf '%s│ %s%-*s %s│ %s%-*s %s│ %s%-*s %s│ %s%-*s %s│ %s%-*s %s│%s\n' \
                "$_tb" "$_th" $_cw_id "ID" \
                "$_tb" "$_th" $_cw_name "Name" \
                "$_tb" "$_th" $_cw_image "Image" \
                "$_tb" "$_th" $_cw_status "Status" \
                "$_tb" "$_th" $_cw_type "Type" "$_tb" "$_tr"
            # Separator
            printf '%s├%s┼%s┼%s┼%s┼%s┤%s\n' "$_tb" "${_hl_segs[0]}" "${_hl_segs[1]}" "${_hl_segs[2]}" "${_hl_segs[3]}" "${_hl_segs[4]}" "$_tr"
            # Data rows (uniform color — no first-row highlight)
            local _csv_first=true
            while IFS=',' read -r _r_id _r_name _r_image _r_status _r_type; do
                if $_csv_first; then _csv_first=false; continue; fi
                # Highlight n8n type in orange, others in default text color
                local _type_c="$_tc"
                [[ "$_r_type" == "n8n" ]] && _type_c="$_tn"
                printf '%s│ %s%-*s %s│ %s%-*s %s│ %s%-*s %s│ %s%-*s %s│ %s%-*s %s│%s\n' \
                    "$_tb" "$_tc" $_cw_id "$_r_id" \
                    "$_tb" "$_tc" $_cw_name "$_r_name" \
                    "$_tb" "$_tc" $_cw_image "$_r_image" \
                    "$_tb" "$_tc" $_cw_status "$_r_status" \
                    "$_tb" "$_type_c" $_cw_type "$_r_type" "$_tb" "$_tr"
            done <<< "$csv_data"
            # Bottom border
            printf '%s╰%s┴%s┴%s┴%s┴%s╯%s\n' "$_tb" "${_hl_segs[0]}" "${_hl_segs[1]}" "${_hl_segs[2]}" "${_hl_segs[3]}" "${_hl_segs[4]}" "$_tr"
        } >&2
    fi
    echo "" >&2

    # Inline searchable filter below the table (no viewport)
    local selected
    if $HAS_GUM; then
        selected=$(printf '%s\n' "${display_items[@]}" | gum filter \
            --placeholder "Type to search containers..." \
            --indicator "▸" \
            --indicator.foreground $THEME_PRIMARY \
            --match.foreground $THEME_PRIMARY \
            --prompt.foreground $THEME_PRIMARY \
            --height $((${#display_items[@]} + 4)) \
            --width 120)
    else
        selected=$(printf '%s\n' "${display_items[@]}" | ui_filter "Select n8n container")
    fi

    if [ -z "$selected" ]; then
        log ERROR "No container selected."
        exit 1
    fi

    # Strip ANSI escape codes before extracting container ID
    SELECTED_CONTAINER_ID=$(echo "$selected" | sed $'s/\033\[[0-9;]*m//g' | awk '{print $1}')
    # Resolve short→full ID
    for full_id in "${container_ids[@]}"; do
        if [[ "$full_id" == "${SELECTED_CONTAINER_ID}"* ]]; then
            SELECTED_CONTAINER_ID="$full_id"
            break
        fi
    done
    log SUCCESS "Selected container: ${SELECTED_CONTAINER_ID:0:12}"
}

