_recording_write_repo_context() {
    local token="$1"
    local repo="$2"
    local branch="$3"

    [ -n "${N8N_MANAGER_RECORD_CONTEXT_FILE:-}" ] || return 0
    [ -n "$token" ] || return 1
    [ -n "$repo" ] || return 1
    [ -n "$branch" ] || return 1

    local ctx_dir
    ctx_dir="$(dirname "$N8N_MANAGER_RECORD_CONTEXT_FILE")"
    mkdir -p "$ctx_dir" 2>/dev/null || return 1

    {
        printf 'RECORD_REPO=%s\n' "$repo"
        printf 'RECORD_BRANCH=%s\n' "$branch"
        printf 'RECORD_TOKEN=%s\n' "$token"
        printf 'RECORD_ACTION=%s\n' "${action:-session}"
    } > "$N8N_MANAGER_RECORD_CONTEXT_FILE" || return 1

    chmod 600 "$N8N_MANAGER_RECORD_CONTEXT_FILE" 2>/dev/null || true
    return 0
}

_recording_load_repo_context() {
    local context_file="$1"

    RECORD_REPO=""
    RECORD_BRANCH=""
    RECORD_TOKEN=""
    RECORD_ACTION=""

    [ -f "$context_file" ] || return 1

    local key value
    while IFS='=' read -r key value; do
        case "$key" in
            RECORD_REPO) RECORD_REPO="$value" ;;
            RECORD_BRANCH) RECORD_BRANCH="$value" ;;
            RECORD_TOKEN) RECORD_TOKEN="$value" ;;
            RECORD_ACTION) RECORD_ACTION="$value" ;;
        esac
    done < "$context_file"

    [ -n "$RECORD_REPO" ] || return 1
    [ -n "$RECORD_BRANCH" ] || return 1
    [ -n "$RECORD_TOKEN" ] || return 1
    return 0
}

_recording_install_github_actions_workflow() {
    local repo_root="$1"
    local workflow_name="n8n-manager-render-recordings.yml"

    if ! declare -F github_actions_install_or_update_known_workflow >/dev/null 2>&1; then
        log ERROR "GitHub Actions helper functions are unavailable."
        return 1
    fi

    # D-15: Workflow template is now centralized in github_actions.sh as WORKFLOW_RENDER_RECORDINGS_TEMPLATE
    # SHA-verified before inject by github_actions_manage_workflow (no longer passed via stdin heredoc)
    github_actions_install_or_update_known_workflow "$repo_root" "$workflow_name"
}

_recording_publish_to_backup_repo() {
    local session_dir="$1"
    local status_code="$2"
    local context_file="$3"

    _recording_load_repo_context "$context_file" || return 1

    local tmp_repo_dir=""
    tmp_repo_dir=$(mktemp -d -t n8n-record-repo-XXXXXXXX 2>/dev/null) || return 1

    local git_repo_url="https://${RECORD_TOKEN}@github.com/${RECORD_REPO}.git"
    if ! git clone --depth 1 --branch "$RECORD_BRANCH" "$git_repo_url" "$tmp_repo_dir" >/dev/null 2>&1; then
        rm -rf "$tmp_repo_dir" 2>/dev/null || true
        return 1
    fi

    local record_slug
    record_slug="$(basename "$session_dir")"
    local record_repo_dir="$tmp_repo_dir/Backups/records/$record_slug"
    mkdir -p "$record_repo_dir" 2>/dev/null || {
        rm -rf "$tmp_repo_dir" 2>/dev/null || true
        return 1
    }

    local required_artifacts=(
        "session.typescript"
        "session.console.txt"
        "session.timing"
        "replay.tape"
        "README.txt"
    )
    local artifact=""
    for artifact in "${required_artifacts[@]}"; do
        if [ ! -f "$session_dir/$artifact" ]; then
            log ERROR "Recording artifact missing: $session_dir/$artifact"
            rm -rf "$tmp_repo_dir" 2>/dev/null || true
            return 1
        fi
        if ! cp "$session_dir/$artifact" "$record_repo_dir/" 2>/dev/null; then
            log ERROR "Failed to copy recording artifact: $artifact"
            rm -rf "$tmp_repo_dir" 2>/dev/null || true
            return 1
        fi
    done

    cat > "$record_repo_dir/metadata.json" <<EOF
{
  "recording": "$record_slug",
  "action": "${RECORD_ACTION:-session}",
  "status_code": $status_code,
  "recorded_at": "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
}
EOF

    _recording_install_github_actions_workflow "$tmp_repo_dir" || {
        rm -rf "$tmp_repo_dir" 2>/dev/null || true
        return 1
    }

    git -C "$tmp_repo_dir" config user.email "n8n-recording@localhost" >/dev/null 2>&1 || true
    git -C "$tmp_repo_dir" config user.name "n8n Recording Bot" >/dev/null 2>&1 || true

    if ! git -C "$tmp_repo_dir" add Backups/records .github/workflows >/dev/null 2>&1; then
        rm -rf "$tmp_repo_dir" 2>/dev/null || true
        return 1
    fi

    # Use staged diff so new/untracked files are detected correctly.
    if git -C "$tmp_repo_dir" diff --cached --quiet; then
        rm -rf "$tmp_repo_dir" 2>/dev/null || true
        return 2
    fi

    if ! git -C "$tmp_repo_dir" commit -m "🧾 Add n8n-manager session recording artifacts [$record_slug]" >/dev/null 2>&1; then
        rm -rf "$tmp_repo_dir" 2>/dev/null || true
        return 1
    fi

    if ! git -C "$tmp_repo_dir" push origin "$RECORD_BRANCH" >/dev/null 2>&1; then
        rm -rf "$tmp_repo_dir" 2>/dev/null || true
        return 1
    fi

    rm -rf "$tmp_repo_dir" 2>/dev/null || true
    return 0
}

_recording_local_vhs_ready() {
    command -v vhs >/dev/null 2>&1 || return 1
    command -v ffmpeg >/dev/null 2>&1 || return 1
    command -v ttyd >/dev/null 2>&1 || return 1
    command -v scriptreplay >/dev/null 2>&1 || return 1
    _recording_browser_ready || return 1
    return 0
}

_RECORDING_TEMP_VHS_DIR=""
_RECORDING_TEMP_SYSTEM_PACKAGES=()
_RECORDING_SYSTEM_PKG_MANAGER=""

_recording_missing_local_tools() {
    local missing=()

    command -v vhs >/dev/null 2>&1 || missing+=("vhs")
    command -v ffmpeg >/dev/null 2>&1 || missing+=("ffmpeg")
    command -v ttyd >/dev/null 2>&1 || missing+=("ttyd")
    command -v scriptreplay >/dev/null 2>&1 || missing+=("scriptreplay")
    _recording_browser_ready || missing+=("browser")

    if [ "${#missing[@]}" -gt 0 ]; then
        printf '%s\n' "${missing[*]}"
    fi
}

_recording_cleanup_temp_deps() {
    _recording_cleanup_temp_system_packages

    if [ -n "$_RECORDING_TEMP_VHS_DIR" ] && [ -d "$_RECORDING_TEMP_VHS_DIR" ]; then
        rm -rf "$_RECORDING_TEMP_VHS_DIR" 2>/dev/null || true
    fi
    _RECORDING_TEMP_VHS_DIR=""
}

_recording_detect_arch() {
    if declare -F _detect_release_arch >/dev/null 2>&1; then
        _detect_release_arch "vhs"
        return $?
    fi

    local arch
    arch=$(uname -m 2>/dev/null || echo "unknown")
    case "$arch" in
        x86_64|amd64) echo "x86_64" ;;
        aarch64|arm64) echo "arm64" ;;
        armv7l|armhf) echo "arm" ;;
        i386|i686) echo "i386" ;;
        *) return 1 ;;
    esac
}

_recording_detect_os() {
    if declare -F _detect_release_os >/dev/null 2>&1; then
        _detect_release_os
        return $?
    fi

    local os
    os=$(uname -s 2>/dev/null || echo "unknown")
    case "$os" in
        Linux) echo "Linux" ;;
        Darwin) echo "Darwin" ;;
        *) return 1 ;;
    esac
}

_recording_install_temp_vhs() {
    local arch
    arch="$(_recording_detect_arch)" || return 1
    local os
    os="$(_recording_detect_os)" || return 1
    local version="${VHS_VERSION:-0.10.0}"
    local tarball="vhs_${version}_${os}_${arch}.tar.gz"
    local url="https://github.com/charmbracelet/vhs/releases/download/v${version}/${tarball}"

    local tmp_dir
    tmp_dir=$(mktemp -d -t n8n-vhs-XXXXXX 2>/dev/null) || return 1

    if ! curl -fsSL --connect-timeout 10 --max-time 90 -o "$tmp_dir/$tarball" "$url" 2>/dev/null; then
        rm -rf "$tmp_dir" 2>/dev/null || true
        return 1
    fi
    if ! tar -xzf "$tmp_dir/$tarball" -C "$tmp_dir" --strip-components=1 2>/dev/null; then
        rm -rf "$tmp_dir" 2>/dev/null || true
        return 1
    fi
    if [ ! -f "$tmp_dir/vhs" ]; then
        rm -rf "$tmp_dir" 2>/dev/null || true
        return 1
    fi

    chmod +x "$tmp_dir/vhs" 2>/dev/null || true
    export PATH="$tmp_dir:$PATH"
    _RECORDING_TEMP_VHS_DIR="$tmp_dir"
    return 0
}

_recording_browser_ready() {
    local candidate=""

    for candidate in \
        "${CHROME_BIN:-}" \
        "${CHROMIUM_BIN:-}" \
        google-chrome-stable \
        google-chrome \
        chromium \
        chromium-browser \
        chrome \
        microsoft-edge; do
        [ -n "$candidate" ] || continue

        if [ -x "$candidate" ]; then
            return 0
        fi
        if command -v "$candidate" >/dev/null 2>&1; then
            return 0
        fi
    done

    return 1
}

_recording_collect_system_packages() {
    local missing_local="$1"
    local packages=()

    [[ "$missing_local" == *"scriptreplay"* ]] && packages+=("util-linux")
    [[ "$missing_local" == *"ffmpeg"* ]] && packages+=("ffmpeg")
    [[ "$missing_local" == *"ttyd"* ]] && packages+=("ttyd")

    local unique=()
    local pkg
    for pkg in "${packages[@]}"; do
        local seen=false
        local existing
        for existing in "${unique[@]}"; do
            [ "$existing" = "$pkg" ] && { seen=true; break; }
        done
        $seen || unique+=("$pkg")
    done

    if [ "${#unique[@]}" -gt 0 ]; then
        printf '%s\n' "${unique[@]}"
    fi
    return 0
}

_recording_browser_package_candidates() {
    local package_manager="$1"

    case "$package_manager" in
        apt) printf '%s\n' chromium chromium-browser google-chrome-stable ;;
        apk|dnf|yum|pacman|zypper) printf '%s\n' chromium ;;
        *) return 1 ;;
    esac
}

_recording_array_contains() {
    local needle="$1"
    shift
    local item
    for item in "$@"; do
        [ "$item" = "$needle" ] && return 0
    done
    return 1
}

_recording_detect_package_manager() {
    if command -v apt-get >/dev/null 2>&1; then
        echo "apt"
        return 0
    fi
    if command -v apk >/dev/null 2>&1; then
        echo "apk"
        return 0
    fi
    if command -v dnf >/dev/null 2>&1; then
        echo "dnf"
        return 0
    fi
    if command -v yum >/dev/null 2>&1; then
        echo "yum"
        return 0
    fi
    if command -v pacman >/dev/null 2>&1; then
        echo "pacman"
        return 0
    fi
    if command -v zypper >/dev/null 2>&1; then
        echo "zypper"
        return 0
    fi

    return 1
}

_recording_command_prefix() {
    if [ "$(id -u 2>/dev/null || echo 1)" != "0" ]; then
        command -v sudo >/dev/null 2>&1 || return 1
        echo "sudo "
        return 0
    fi
    echo ""
}

_recording_is_package_installed() {
    local package_manager="$1"
    local package_name="$2"

    case "$package_manager" in
        apt) dpkg -s "$package_name" >/dev/null 2>&1 ;;
        apk) apk info -e "$package_name" >/dev/null 2>&1 ;;
        dnf|yum) rpm -q "$package_name" >/dev/null 2>&1 ;;
        pacman) pacman -Q "$package_name" >/dev/null 2>&1 ;;
        zypper) rpm -q "$package_name" >/dev/null 2>&1 ;;
        *) return 1 ;;
    esac
}

_recording_track_temp_system_package() {
    local package_name="$1"
    local existing

    for existing in "${_RECORDING_TEMP_SYSTEM_PACKAGES[@]}"; do
        [ "$existing" = "$package_name" ] && return 0
    done

    _RECORDING_TEMP_SYSTEM_PACKAGES+=("$package_name")
}

_recording_build_install_command() {
    local package_manager="$1"
    local prefix="$2"
    local browser_required="${3:-false}"
    shift 3
    local packages=("$@")
    local cmd=""

    case "$package_manager" in
        apt)
            cmd="${prefix}apt-get update"
            if [ "${#packages[@]}" -gt 0 ]; then
                cmd="$cmd && ${prefix}apt-get install -y ${packages[*]}"
            fi
            if [ "$browser_required" = "true" ]; then
                cmd="$cmd && (${prefix}apt-get install -y chromium || ${prefix}apt-get install -y chromium-browser || ${prefix}apt-get install -y google-chrome-stable)"
            fi
            ;;
        apk)
            [ "$browser_required" = "true" ] && packages+=("chromium")
            [ "${#packages[@]}" -gt 0 ] || return 1
            cmd="${prefix}apk add ${packages[*]}"
            ;;
        dnf)
            [ "$browser_required" = "true" ] && packages+=("chromium")
            [ "${#packages[@]}" -gt 0 ] || return 1
            cmd="${prefix}dnf install -y ${packages[*]}"
            ;;
        yum)
            [ "$browser_required" = "true" ] && packages+=("chromium")
            [ "${#packages[@]}" -gt 0 ] || return 1
            cmd="${prefix}yum install -y ${packages[*]}"
            ;;
        pacman)
            [ "$browser_required" = "true" ] && packages+=("chromium")
            [ "${#packages[@]}" -gt 0 ] || return 1
            cmd="${prefix}pacman -Sy --noconfirm --needed ${packages[*]}"
            ;;
        zypper)
            [ "$browser_required" = "true" ] && packages+=("chromium")
            [ "${#packages[@]}" -gt 0 ] || return 1
            cmd="${prefix}zypper --non-interactive install ${packages[*]}"
            ;;
        *)
            return 1
            ;;
    esac

    [ -n "$cmd" ] || return 1
    echo "$cmd"
}

_recording_build_remove_command() {
    local package_manager="$1"
    local prefix="$2"
    shift 2
    local packages=("$@")

    [ "${#packages[@]}" -gt 0 ] || return 1

    case "$package_manager" in
        apt) echo "${prefix}apt-get remove -y ${packages[*]}" ;;
        apk) echo "${prefix}apk del ${packages[*]}" ;;
        dnf) echo "${prefix}dnf remove -y ${packages[*]}" ;;
        yum) echo "${prefix}yum remove -y ${packages[*]}" ;;
        pacman) echo "${prefix}pacman -R --noconfirm ${packages[*]}" ;;
        zypper) echo "${prefix}zypper --non-interactive remove ${packages[*]}" ;;
        *) return 1 ;;
    esac
}

_recording_cleanup_temp_system_packages() {
    [ "${N8N_MANAGER_MODE:-}" = "one-time" ] || return 0
    [ "${#_RECORDING_TEMP_SYSTEM_PACKAGES[@]}" -gt 0 ] || return 0

    local package_manager="${_RECORDING_SYSTEM_PKG_MANAGER:-}"
    [ -n "$package_manager" ] || return 0

    local prefix
    prefix="$(_recording_command_prefix)" || prefix=""

    local remove_cmd=""
    remove_cmd="$(_recording_build_remove_command "$package_manager" "$prefix" "${_RECORDING_TEMP_SYSTEM_PACKAGES[@]}")" || return 0

    log INFO "Portable mode: removing temporary recording dependencies..."
    if _recording_run_with_progress "Removing temporary dependencies..." sh -c "$remove_cmd"; then
        log SUCCESS "Temporary recording dependencies removed."
    else
        log WARN "Could not remove temporary dependencies: ${_RECORDING_TEMP_SYSTEM_PACKAGES[*]}"
    fi

    _RECORDING_TEMP_SYSTEM_PACKAGES=()
    _RECORDING_SYSTEM_PKG_MANAGER=""
}

_recording_install_missing_system_tools() {
    local missing_local="$1"

    if [ ! -t 0 ] || [ ! -t 1 ]; then
        return 1
    fi

    local packages=()
    local package_name=""
    while IFS= read -r package_name; do
        [ -n "$package_name" ] && packages+=("$package_name")
    done < <(_recording_collect_system_packages "$missing_local")

    local browser_required="false"
    [[ "$missing_local" == *"browser"* ]] && browser_required="true"
    if [ "${#packages[@]}" -eq 0 ] && [ "$browser_required" != "true" ]; then
        return 1
    fi

    local package_manager=""
    package_manager="$(_recording_detect_package_manager)" || return 1

    local prefix=""
    prefix="$(_recording_command_prefix)" || return 1

    local install_cmd=""
    install_cmd="$(_recording_build_install_command "$package_manager" "$prefix" "$browser_required" "${packages[@]}")" || return 1

    local prompt_suffix=""
    if [ "${N8N_MANAGER_MODE:-}" = "one-time" ]; then
        prompt_suffix=" (portable mode removes newly installed deps after completion)"
    fi

    local newly_installed=()
    local browser_candidates=()
    local browser_preinstalled=()
    if [ "${N8N_MANAGER_MODE:-}" = "one-time" ]; then
        for package_name in "${packages[@]}"; do
            if ! _recording_is_package_installed "$package_manager" "$package_name"; then
                newly_installed+=("$package_name")
            fi
        done

        if [ "$browser_required" = "true" ]; then
            while IFS= read -r package_name; do
                [ -n "$package_name" ] && browser_candidates+=("$package_name")
            done < <(_recording_browser_package_candidates "$package_manager")

            for package_name in "${browser_candidates[@]}"; do
                if _recording_is_package_installed "$package_manager" "$package_name"; then
                    browser_preinstalled+=("$package_name")
                fi
            done
        fi
    fi

    if ! ui_confirm "Install missing recording dependencies now? ($missing_local)$prompt_suffix" "Install" "Skip"; then
        return 1
    fi

    log INFO "Installing recording dependencies..."
    if _recording_run_with_progress "Installing dependencies..." sh -c "$install_cmd"; then
        if [ "${N8N_MANAGER_MODE:-}" = "one-time" ]; then
            for package_name in "${newly_installed[@]}"; do
                _recording_track_temp_system_package "$package_name"
            done

            if [ "$browser_required" = "true" ] && [ "${#browser_candidates[@]}" -gt 0 ]; then
                for package_name in "${browser_candidates[@]}"; do
                    if _recording_is_package_installed "$package_manager" "$package_name" && \
                       ! _recording_array_contains "$package_name" "${browser_preinstalled[@]}"; then
                        _recording_track_temp_system_package "$package_name"
                    fi
                done
            fi

            if [ "${#_RECORDING_TEMP_SYSTEM_PACKAGES[@]}" -gt 0 ]; then
                _RECORDING_SYSTEM_PKG_MANAGER="$package_manager"
                log INFO "Portable mode: will remove temporary dependencies: ${_RECORDING_TEMP_SYSTEM_PACKAGES[*]}"
            fi
        fi
        log SUCCESS "Recording dependencies installed."
        return 0
    fi

    log WARN "Dependency installation command failed."
    return 1
}

_recording_try_install_vhs() {
    if command -v vhs >/dev/null 2>&1; then
        return 0
    fi

    if ! declare -F _ensure_vhs >/dev/null 2>&1; then
        return 1
    fi

    if [ ! -t 0 ] || [ ! -t 1 ]; then
        return 1
    fi
    if ! ui_confirm "VHS binary is missing. Install VHS v${VHS_VERSION:-0.10.0} now?" "Install" "Skip"; then
        return 1
    fi

    log INFO "Installing VHS binary..."
    if [ "${N8N_MANAGER_MODE:-}" = "one-time" ]; then
        if _recording_install_temp_vhs; then
            log SUCCESS "Temporary VHS installed for this session."
            return 0
        fi
    else
        if _ensure_vhs; then
            log SUCCESS "VHS installed successfully."
            return 0
        fi
    fi

    log WARN "VHS auto-install failed."
    return 1
}

_recording_print_install_help() {
    local missing_local="$1"
    local os_id=""

    if [ -f /etc/os-release ]; then
        os_id="$(awk -F= '/^ID=/{gsub(/"/, "", $2); print tolower($2)}' /etc/os-release 2>/dev/null)"
    fi

    echo "" >&2
    echo "Recording GIF requirements:" >&2
    echo "  Local stack: vhs + ffmpeg + ttyd + scriptreplay + chromium/chrome" >&2

    if [ -n "$missing_local" ]; then
        echo "  Missing local tools: $missing_local" >&2
    fi

    case "$os_id" in
        ubuntu|debian)
            echo "" >&2
            echo "Install local dependencies (Debian/Ubuntu):" >&2
            echo "  sudo apt-get update && sudo apt-get install -y util-linux ffmpeg ttyd chromium" >&2
            ;;
        alpine)
            echo "" >&2
            echo "Install local dependencies (Alpine):" >&2
            echo "  sudo apk add util-linux ffmpeg ttyd chromium" >&2
            ;;
        *)
            echo "" >&2
            echo "Install local dependencies using your distro packages:" >&2
            echo "  util-linux (for scriptreplay), ffmpeg, ttyd, chromium/chrome" >&2
            ;;
    esac

    echo "" >&2
    echo "Install VHS binary:" >&2
    echo "  n8n-manager can auto-install VHS when prompted during --record" >&2
    echo "  OR install manually:" >&2
    echo "  https://github.com/charmbracelet/vhs#installation" >&2

    if [ "${N8N_MANAGER_MODE:-}" = "one-time" ]; then
        echo "" >&2
        echo "Portable mode note:" >&2
        echo "  Auto-installed VHS and recording deps are removed after completion." >&2
    fi
}

_recording_preflight_requirements() {
    local missing_local=""
    _recording_try_install_vhs || true
    missing_local="$(_recording_missing_local_tools)"
    [ -z "$missing_local" ] && return 0

    _recording_install_missing_system_tools "$missing_local" || true
    missing_local="$(_recording_missing_local_tools)"
    [ -z "$missing_local" ] && return 0

    if [ -t 0 ] && [ -t 1 ]; then
        if ui_confirm "Recording dependencies missing ($missing_local). Show install commands?" "Show" "Skip"; then
            _recording_print_install_help "$missing_local"
        fi
        log WARN "No GIF renderer available with current dependencies."
        if ! ui_confirm "Continue with raw transcript recording only?" "Continue" "Cancel"; then
            return 1
        fi
    else
        _recording_print_install_help "$missing_local"
        log WARN "No GIF renderer available with current dependencies."
    fi

    return 0
}

_recording_post_render_failure() {
    local session_dir="$1"
    local timing_file="$2"
    local typescript_file="$3"

    local missing_local=""
    missing_local="$(_recording_missing_local_tools)"
    local render_log="$session_dir/render.log"

    log WARN "Recorded raw session only. GIF render failed."
    [ -n "$missing_local" ] && log INFO "Missing local tools: $missing_local"
    [ -f "$render_log" ] && log INFO "Renderer log: $render_log"
    if [ -s "$render_log" ]; then
        log WARN "Renderer error details (tail):"
        tail -n 20 "$render_log" >&2 || true
    fi

    if [ -z "$missing_local" ]; then
        if [ -t 0 ] && [ -t 1 ]; then
            if ui_confirm "Retry GIF render now?" "Retry" "Skip"; then
                if _recording_render_gif "$session_dir"; then
                    log SUCCESS "Session recording complete: $session_dir/session.gif"
                    return 0
                fi
                log WARN "GIF render retry failed."
            fi
        fi
        log INFO "Replay command: scriptreplay --timing $timing_file $typescript_file"
        return 1
    fi

    if [ -t 0 ] && [ -t 1 ]; then
        if ui_confirm "Show install commands for recording dependencies?" "Show" "Skip"; then
            _recording_print_install_help "$missing_local"
        fi

        if [[ "$missing_local" == *"vhs"* ]]; then
            _recording_try_install_vhs || true
        fi

        _recording_install_missing_system_tools "$missing_local" || true
        missing_local="$(_recording_missing_local_tools)"

        if _recording_local_vhs_ready; then
            if ui_confirm "Retry GIF render now?" "Retry" "Skip"; then
                if _recording_render_gif "$session_dir"; then
                    log SUCCESS "Session recording complete: $session_dir/session.gif"
                    return 0
                fi
                log WARN "GIF render retry failed."
            fi
        fi
    else
        _recording_print_install_help "$missing_local"
    fi

    log INFO "Replay command: scriptreplay --timing $timing_file $typescript_file"
    return 1
}

_recording_total_seconds() {
    local timing_file="$1"
    local total_seconds="2"

    if [ -s "$timing_file" ]; then
        total_seconds="$(awk '
            $1 ~ /^[0-9]+([.][0-9]+)?$/ {sum += $1}
            END {
                if (sum < 1) sum = 1
                rounded = int(sum)
                if (sum > rounded) rounded += 1
                print rounded + 1
            }
        ' "$timing_file" 2>/dev/null)"
    fi

    if ! [[ "$total_seconds" =~ ^[0-9]+$ ]]; then
        total_seconds="2"
    fi

    echo "$total_seconds"
}

_recording_terminal_size() {
    local typescript_file="$1"
    local header=""
    local cols=""
    local lines=""

    header="$(head -n 1 "$typescript_file" 2>/dev/null || true)"

    if [[ "$header" =~ COLUMNS=\"([0-9]+)\" ]]; then
        cols="${BASH_REMATCH[1]}"
    fi
    if [[ "$header" =~ LINES=\"([0-9]+)\" ]]; then
        lines="${BASH_REMATCH[1]}"
    fi

    if ! [[ "$cols" =~ ^[0-9]+$ ]]; then
        cols=170
    fi
    if ! [[ "$lines" =~ ^[0-9]+$ ]]; then
        lines=50
    fi

    printf '%s %s\n' "$cols" "$lines"
}

_recording_content_size() {
    local transcript_file="$1"
    local max_cols=""
    local max_rows=""

    read -r max_cols max_rows <<EOF
$(awk '
    NR == 1 { next }
    {
        line = $0
        gsub(/\033\[[0-9;?]*[@-~]/, "", line)
        gsub(/\033\][^\007]*\007/, "", line)
        n = split(line, parts, "\r")

        for (i = 1; i <= n; i++) {
            seg = parts[i]
            gsub(/\t/, "    ", seg)
            sub(/[[:space:]]+$/, "", seg)
            seg_len = length(seg)

            if (seg_len > max_cols) {
                max_cols = seg_len
            }

            if (seg_len > 0) {
                current_rows++
                if (current_rows > max_rows) {
                    max_rows = current_rows
                }
            } else {
                current_rows = 0
            }
        }
    }
    END {
        if (max_cols < 80) max_cols = 80
        if (max_cols > 170) max_cols = 170
        if (max_rows < 20) max_rows = 20
        if (max_rows > 48) max_rows = 48
        printf "%d %d\n", max_cols, max_rows
    }
' "$transcript_file" 2>/dev/null)
EOF

    if ! [[ "$max_cols" =~ ^[0-9]+$ ]]; then
        max_cols=120
    fi
    if ! [[ "$max_rows" =~ ^[0-9]+$ ]]; then
        max_rows=32
    fi

    printf '%s %s\n' "$max_cols" "$max_rows"
}

_recording_tape_geometry() {
    local typescript_file="$1"
    local transcript_file="${2:-$typescript_file}"

    local term_cols term_lines
    read -r term_cols term_lines <<< "$(_recording_terminal_size "$typescript_file")"

    local content_cols content_rows
    read -r content_cols content_rows <<< "$(_recording_content_size "$transcript_file")"

    local target_cols=$((content_cols + 8))
    local target_rows=$((content_rows + 4))

    ((target_cols < 90)) && target_cols=90
    ((target_cols > term_cols)) && target_cols="$term_cols"
    ((target_cols > 180)) && target_cols=180

    ((target_rows < 24)) && target_rows=24
    ((target_rows > term_lines)) && target_rows="$term_lines"
    ((target_rows > 52)) && target_rows=52

    local safe_padding=16
    local width=$((target_cols * 8 + safe_padding * 2 + 24))
    local height=$((target_rows * 18 + safe_padding * 2 + 24))

    ((width < 960)) && width=960
    ((width > 2000)) && width=2000
    ((height < 620)) && height=620
    ((height > 1250)) && height=1250

    printf '%s %s %s\n' "$width" "$height" "$safe_padding"
}

_recording_generate_replay_transcript() {
    local typescript_file="$1"
    local replay_transcript_file="$2"

    [ -f "$typescript_file" ] || return 1

    if ! awk '
        BEGIN {
            esc = sprintf("%c", 27)
            in_picker = 0
            started = 0
            blank_rows = 0
            count = 0
        }
        {
            line = $0
            gsub(/\r/, "", line)
            row_count = split(line, rows, /\n/)

            for (idx = 1; idx <= row_count; idx++) {
                row = rows[idx]

                if (row ~ /^Script started on / || row ~ /^Script done on /) {
                    continue
                }

                if (index(row, esc "[?25l") > 0 && index(row, esc "[?2004h") > 0) {
                    in_picker = 1
                }

                if (in_picker) {
                    if (index(row, esc "[?2004l") > 0) {
                        in_picker = 0
                        sub("^.*" esc "\\[\\?2004l", "", row)
                        gsub(esc "\\[\\?25h", "", row)
                        gsub(esc "\\[\\?1002l", "", row)
                        gsub(esc "\\[\\?1003l", "", row)
                        gsub(esc "\\[\\?1004l", "", row)
                        gsub(esc "\\[\\?1006l", "", row)
                    } else {
                        continue
                    }
                }

                gsub(esc "\\][^\007]*\007", "", row)
                gsub(esc "\\][^\033]*" esc "\\\\", "", row)
                gsub(esc "\\[[0-9;?]*[ -/]*[@-~]", "", row)
                gsub(esc "[@-_]", "", row)
                gsub(/[\001-\010\013-\037\177]/, "", row)
                sub(/[[:space:]]+$/, "", row)

                if (row ~ /^GitHub Personal Access Token$/) continue
                if (row ~ /^Search (repositories|branches)\.\.\.$/) continue
                if (row ~ /^Type to search /) continue
                if (row ~ /^[[:space:]]*Configure advanced backup options\?$/) continue
                if (row ~ /^[[:space:]]*Save these settings for next time\?/ ) continue
                if (row ~ /^[[:space:]]*Yes[[:space:]]+No, use defaults[[:space:]]*$/) continue
                if (row ~ /(navigate •|toggle •|enter submit)/) continue
                if (row ~ /^>[[:space:]]*(ghp_|•|\.{3}|$)/) continue
                if (row ~ /^▸ /) continue

                if (!started && row == "") {
                    continue
                }
                started = 1

                if (row == "") {
                    blank_rows++
                    if (blank_rows > 2) {
                        continue
                    }
                } else {
                    blank_rows = 0
                }

                output[++count] = row
            }
        }
        END {
            while (count > 0 && output[count] == "") {
                count--
            }
            for (idx = 1; idx <= count; idx++) {
                print output[idx]
            }
        }
    ' "$typescript_file" > "$replay_transcript_file" 2>/dev/null; then
        rm -f "$replay_transcript_file" 2>/dev/null || true
        return 1
    fi

    [ -s "$replay_transcript_file" ]
}

_recording_escape_tape() {
    local raw="$1"
    raw="${raw//\\/\\\\}"
    raw="${raw//\"/\\\"}"
    echo "$raw"
}

_recording_make_tape() {
    local session_dir="$1"
    local typescript_file="$2"
    local replay_transcript_file="$3"
    local timing_file="$4"
    local replay_cmd_name="$5"
    local replay_display_cmd="$6"

    local sleep_seconds
    sleep_seconds="$(_recording_total_seconds "$timing_file")"

    local dimensions
    dimensions="$(_recording_tape_geometry "$typescript_file" "$replay_transcript_file")"
    local width="${dimensions%% *}"
    local rest="${dimensions#* }"
    local height="${rest%% *}"
    local safe_padding="${dimensions##* }"

    local replay_transcript_name
    replay_transcript_name="$(basename "$replay_transcript_file")"

    local escaped_cmd_name
    escaped_cmd_name="$(_recording_escape_tape "$replay_cmd_name")"
    local escaped_display_cmd
    escaped_display_cmd="$(_recording_escape_tape "$replay_display_cmd")"

    cat > "$session_dir/replay.tape" <<EOF
Output session.gif

Set Shell "bash"
Set FontSize 14
Set Width $width
Set Height $height
Set Padding $safe_padding

Hide
Type "__n8n_replay(){ cat $replay_transcript_name; }"
Enter
Type "$escaped_cmd_name(){ __n8n_replay; }"
Enter
Show

Type "$escaped_display_cmd"
Enter
Sleep ${sleep_seconds}s
EOF
}

_recording_run_with_progress() {
    local title="$1"
    shift

    if [ -t 1 ] && ${HAS_GUM:-false} && command -v gum >/dev/null 2>&1; then
        local spinner="${THEME_SPINNER:-dot}"
        case "$spinner" in
            dots) spinner="dot" ;;
            line|dot|minidot|jump|pulse|points|globe|moon|monkey|meter|hamburger) ;;
            *) spinner="dot" ;;
        esac

        gum spin \
            --spinner "$spinner" \
            --spinner.foreground "${THEME_SPINNER_COLOR:-204}" \
            --title.foreground "${THEME_INFO:-81}" \
            --title "$title" \
            -- "$@"
    else
        "$@"
    fi
}

_recording_render_gif() {
    local session_dir="$1"
    local tape_file="$session_dir/replay.tape"
    local render_log="$session_dir/render.log"
    : > "$render_log"

    if _recording_local_vhs_ready; then
        _recording_run_with_progress \
            "Rendering session video..." \
            sh -c '
                cd "$1" || exit 1
                if [ "$(id -u 2>/dev/null || echo 1)" = "0" ]; then
                    VHS_NO_SANDBOX=1 vhs "$2" >>"$3" 2>&1
                else
                    vhs "$2" >>"$3" 2>&1
                fi
            ' sh "$session_dir" "$tape_file" "$render_log"
        return $?
    fi

    return 1
}

_recording_write_summary() {
    local session_dir="$1"
    local status_code="$2"
    local self_path="$3"
    shift 3
    local cmd=("$@")

    local cmd_str=""
    printf -v cmd_str '%q ' "$self_path" "${cmd[@]}"
    cmd_str="${cmd_str% }"

    cat > "$session_dir/README.txt" <<EOF
n8n-manager session recording

Command:
  $cmd_str

Exit status:
  $status_code

Artifacts:
  session.typescript  Raw terminal transcript
  session.console.txt Cleaned terminal transcript used for GIF replay
  session.timing      Timing metadata for replay
  replay.tape         VHS tape for conversion
  metadata.json       Recording metadata (when exported to backup repo)

Replay:
  cat session.console.txt

Raw replay (debug):
  scriptreplay --timing session.timing session.typescript
EOF
}

setup_session_recording() {
    # Skip nested invocation to prevent recursion.
    if [[ "${N8N_MANAGER_RECORDING_ACTIVE:-0}" == "1" ]]; then
        return 0
    fi

    # Ensure install/portable mode is known before recording dependency decisions.
    if [ -t 0 ] && [ -t 1 ] && declare -F check_install_mode >/dev/null 2>&1; then
        check_install_mode
    fi

    # Interactive prompt when user did not pass an explicit flag.
    if [ -t 0 ] && [ -t 1 ] && [[ -z "${ARG_RECORD:-}" ]]; then
        if ui_confirm "Record this session for sharing?" "Record" "Skip"; then
            ARG_RECORD=1
        fi
    fi

    [[ "${ARG_RECORD:-}" == "1" ]] || return 0

    if ! command -v script >/dev/null 2>&1; then
        log WARN "Recording requested, but 'script' is not installed. Skipping recording."
        return 0
    fi

    local records_root="${XDG_DATA_HOME:-$HOME/.local/share}/n8n-manager/records"
    local action_slug="${action:-session}"
    action_slug="${action_slug// /-}"
    local stamp
    stamp="$(date '+%Y%m%d-%H%M%S')"

    local session_dir=""
    if [ -n "${ARG_RECORD_OUTPUT:-}" ]; then
        session_dir="$ARG_RECORD_OUTPUT"
    else
        session_dir="$records_root/$action_slug-$stamp"
    fi

    if [[ "$session_dir" == "~/"* ]]; then
        session_dir="$HOME/${session_dir#~/}"
    fi

    if ! mkdir -p "$session_dir"; then
        log WARN "Could not create recording directory: $session_dir"
        return 0
    fi

    local typescript_file="$session_dir/session.typescript"
    local replay_transcript_file="$session_dir/session.console.txt"
    local timing_file="$session_dir/session.timing"
    local context_file="$session_dir/recording-context.env"

    local self_path
    self_path=$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")

    local cmd_args=()
    if [ "${#command_line_args[@]}" -gt 0 ]; then
        cmd_args=("${command_line_args[@]}")
    else
        cmd_args=("${input[@]}")
    fi

    local quoted_cmd=""
    printf -v quoted_cmd '%q ' "$self_path" "${cmd_args[@]}"
    quoted_cmd="${quoted_cmd% }"

    local replay_cmd_name
    replay_cmd_name="$(basename "$self_path")"
    local replay_display_cmd=""
    printf -v replay_display_cmd '%q ' "$replay_cmd_name" "${cmd_args[@]}"
    replay_display_cmd="${replay_display_cmd% }"
    log INFO "Recording session to: $session_dir"

    N8N_MANAGER_RECORDING_ACTIVE=1 N8N_MANAGER_MODE="${N8N_MANAGER_MODE:-}" \
    N8N_MANAGER_RECORD_CONTEXT_FILE="$context_file" \
    script -q -e -f \
        -T "$timing_file" \
        -c "$quoted_cmd" \
        "$typescript_file"
    local status_code=$?

    if ! _recording_generate_replay_transcript "$typescript_file" "$replay_transcript_file"; then
        log WARN "Could not sanitize replay transcript; falling back to raw transcript."
        cp "$typescript_file" "$replay_transcript_file" 2>/dev/null || true
    fi

    _recording_make_tape \
        "$session_dir" \
        "$typescript_file" \
        "$replay_transcript_file" \
        "$timing_file" \
        "$replay_cmd_name" \
        "$replay_display_cmd"
    _recording_write_summary "$session_dir" "$status_code" "$self_path" "${cmd_args[@]}"
    log INFO "Preparing session artifacts for repository-based rendering..."

    if [ -f "$context_file" ]; then
        if _recording_publish_to_backup_repo "$session_dir" "$status_code" "$context_file"; then
            log SUCCESS "Session artifacts pushed to backup repository."
            log INFO "GitHub Actions in the backup repo will render session GIFs."
        else
            local publish_status=$?
            if [ "$publish_status" = "2" ]; then
                log INFO "No repository changes detected for session artifacts."
                log INFO "Local artifacts remain at: $session_dir"
            else
                log WARN "Could not push session artifacts to backup repository."
                log INFO "Local artifacts remain at: $session_dir"
            fi
        fi
    else
        log INFO "No backup repository context found for this run."
        log INFO "Local artifacts available at: $session_dir"
    fi

    rm -f "$context_file" 2>/dev/null || true

    _recording_cleanup_temp_deps
    exit "$status_code"
}

