# Add, commit, and push backup files
git_commit_and_push() {
    local tmp_dir="$1"
    local branch="$2"
    local backup_dir="$3"
    local container="$4"
    local backup_type="$5"
    local is_dry_run="${6:-false}"
    local force_push="${7:-false}"

    # Add files to Git
    log INFO "Adding files to Git..."
    if [ "$is_dry_run" != "true" ] && [ "$is_dry_run" != "1" ]; then
        if ! _git_run_with_loading "Staging changed backup files..." git -C "$tmp_dir" add -A; then
            log ERROR "Failed to add backup files to Git"
            return 1
        fi
    else
        log DRYRUN "Would add backup files to Git"
    fi

    # Create timestamp and commit
    log INFO "Committing changes..."
    if [ "$is_dry_run" != "true" ] && [ "$is_dry_run" != "1" ]; then
        mkdir -p "$tmp_dir/.n8n-manager"
        echo "$(timestamp)" > "$tmp_dir/.n8n-manager/.n8n-backup-timestamp"
        if ! _git_run_with_loading "Updating staged files before commit..." git -C "$tmp_dir" add -A; then
            log ERROR "Failed to add backup files to Git"
            return 1
        fi

        # Get n8n version for commit message
        local n8n_ver="unknown"
        n8n_ver=$(dockExec "$container" "n8n --version" 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -n1) || n8n_ver="unknown"

        # Determine commit backup type
        local commit_backup_type="full"
        if [[ "$backup_type" == "workflows" ]]; then
            commit_backup_type="workflows-only"
        elif [[ "$backup_type" == "credentials" ]]; then
            commit_backup_type="credentials-only"
        elif [[ "$backup_type" == "enterprise" ]]; then
            commit_backup_type="enterprise-entities"
        elif [[ "$backup_type" == "full-db" ]]; then
            commit_backup_type="full-database"
        elif [ -n "${ARG_WORKFLOW_ID:-}" ]; then
            commit_backup_type="workflow-specific"
        elif [ -n "${ARG_CREDENTIAL_ID:-}" ]; then
            commit_backup_type="credential-specific"
        elif [ "${ARG_INCREMENTAL:-}" = "true" ] || [ "${ARG_INCREMENTAL:-}" = "1" ]; then
            commit_backup_type="incremental"
        fi

        # Build commit message
        local backup_identifier rel_backup_dir
        rel_backup_dir="${backup_dir#$tmp_dir/}"
        if [ "$backup_dir" = "$tmp_dir" ] || [ -z "$rel_backup_dir" ] || [ "$rel_backup_dir" = "$backup_dir" ]; then
            backup_identifier="[root]"
        else
            backup_identifier="[$rel_backup_dir]"
        fi

        local commit_message="🔄 n8n Backup (v$n8n_ver) - $(timestamp) $backup_identifier"
        if [ "$commit_backup_type" != "full" ]; then
            commit_message="$commit_message ($commit_backup_type)"
        fi

        # Interactive: offer to edit commit message (only in verbose/power-user mode)
        if [ -t 0 ] && $HAS_GUM && [[ "${ARG_VERBOSE:-}" == "1" ]]; then
            if ui_confirm "Edit commit message?" "Edit" "Use default"; then
                local custom_msg
                custom_msg=$(ui_write "✏️  Edit Commit Message" "$commit_message" 500)
                if [ -n "$custom_msg" ]; then
                    commit_message="$custom_msg"
                fi
            fi
        fi

        if ! _git_run_with_loading "Creating Git commit..." git -C "$tmp_dir" commit -m "$commit_message"; then
            if git -C "$tmp_dir" diff --cached --quiet 2>/dev/null; then
                log INFO "No changes detected - backup already up to date"
                return 0
            else
                log ERROR "Git commit failed with changes present"
                return 1
            fi
        fi
    else
        log DRYRUN "Would commit backup with timestamped message"
    fi

    # Push to GitHub
    log INFO "Pushing backup to GitHub..."
    if [ "$is_dry_run" != "true" ] && [ "$is_dry_run" != "1" ]; then
        local push_cmd=(git -C "$tmp_dir" push origin "$branch")
        if [ "$force_push" = "true" ] || [ "$force_push" = "1" ]; then
            push_cmd=(git -C "$tmp_dir" push --force-with-lease origin "$branch")
            log WARN "[GIT] Force push enabled for backup branch update"
        fi

        if ! _git_run_with_loading "Pushing backup commit to GitHub..." "${push_cmd[@]}"; then
            log ERROR "Failed to push backup to GitHub"
            return 1
        fi
        log SUCCESS "Backup successfully pushed to GitHub"
    else
        log DRYRUN "Would push backup to GitHub repository branch '$branch'"
    fi

    return 0
}

