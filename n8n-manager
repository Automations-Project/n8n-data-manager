# Initialize a git repository for backup operations
git_init_backup_repo() {
    local tmp_dir="$1"
    local github_token="$2"
    local github_repo="$3"
    local branch="$4"

    log INFO "Preparing Git repository for backup..."
    local git_repo_url="https://${github_token}@github.com/${github_repo}.git"
    local git_repo_url_log="https://<TOKEN>@github.com/${github_repo}.git"

    log DEBUG "[GIT] Initializing Git repository in $tmp_dir"
    log DEBUG "[GIT] Remote URL (token redacted): $git_repo_url_log"
    if ! git -C "$tmp_dir" init -q; then
        log ERROR "Git init failed."
        return 1
    fi

    if ! git -C "$tmp_dir" remote add origin "$git_repo_url" 2>/dev/null; then
        log WARN "Git remote 'origin' already exists. Setting URL..."
        if ! git -C "$tmp_dir" remote set-url origin "$git_repo_url"; then
            log ERROR "Git set-url failed."
            return 1
        fi
    fi

    log INFO "Configuring Git user identity for commit..."
    git -C "$tmp_dir" config user.email "n8n-backup-script@localhost" || { log ERROR "Failed to set Git user email."; return 1; }
    git -C "$tmp_dir" config user.name "n8n Backup Script" || { log ERROR "Failed to set Git user name."; return 1; }

    log INFO "Fetching remote branch '$branch'..."
    local branch_exists=true
    if ! git -C "$tmp_dir" fetch --depth 1 origin "$branch" 2>/dev/null; then
        log WARN "Branch '$branch' not found on remote or repo is empty. Will create branch."
        branch_exists=false
    fi

    if $branch_exists; then
        log DEBUG "[GIT] Checking out existing branch: $branch"
        if ! git -C "$tmp_dir" checkout -B "$branch" "origin/$branch" 2>/dev/null; then
            log WARN "[GIT] Failed to checkout branch, trying alternate method..."
            if ! git -C "$tmp_dir" checkout "$branch" 2>/dev/null; then
                log WARN "[GIT] Creating new local branch: $branch"
                git -C "$tmp_dir" checkout -b "$branch" || { log ERROR "Failed to create branch."; return 1; }
            fi
        fi
    else
        log DEBUG "[GIT] Creating new orphan branch: $branch"
        git -C "$tmp_dir" checkout -b "$branch" || { log ERROR "Failed to create branch."; return 1; }
    fi

    log SUCCESS "Git repository prepared successfully."
    return 0
}

# Clone a GitHub repository for restore operations
git_clone_for_restore() {
    local github_token="$1"
