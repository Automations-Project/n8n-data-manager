_sc_export_workflows_cli() {
    local container="$1"
    local output_root="$2"
    local is_dry_run="${3:-false}"
    local existing_workflow_ids_csv="${4:-}"

    local out_dir="$output_root/workflows"
    mkdir -p "$out_dir"

    if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
        log DRYRUN "Would export workflows into canonical layout"
        return 0
    fi

    local tmp_dir="/tmp/n8n-manager-sc-workflows"
    dockExec "$container" "rm -rf '$tmp_dir' && mkdir -p '$tmp_dir'" || return 1

    if [ -n "${ARG_WORKFLOW_ID:-}" ]; then
        while IFS= read -r wf_id; do
            [ -z "$wf_id" ] && continue
            if ! dockExec "$container" "n8n export:workflow --id='$wf_id' --output='$tmp_dir/$wf_id.json'"; then
                log WARN "[SC-EXPORT] failed exporting workflow id=$wf_id"
                sc_layout_add_gap "$output_root" "workflows" "failed exporting workflow $wf_id"
            fi
        done < <(_sc_export_split_csv_ids "$ARG_WORKFLOW_ID")
    else
        # Patch-20: empty-source tolerance. n8n CLI's `export:workflow --backup`
        # exits non-zero with "No workflows found with specified filters"
        # when the source DB has zero workflows (fresh install / pre-data
        # state). An empty backup is a valid operator state — operators
        # who upgrade to v5 with no workflows yet must be able to take a
        # baseline backup without the pipeline aborting fatally.
        local _wf_export_capture _wf_export_rc
        _wf_export_capture=$(mktemp)
        _wf_export_rc=0
        _sc_export_run_with_loading \
            "Exporting workflows from n8n (this can take a while)..." \
            dockExec "$container" "n8n export:workflow --backup --output='$tmp_dir/' 2>&1" \
            >"$_wf_export_capture" || _wf_export_rc=$?
        if [ "$_wf_export_rc" -ne 0 ]; then
            if grep -qE "No workflows found|No workflow with id" "$_wf_export_capture" 2>/dev/null; then
                log INFO "[SC-EXPORT] source has no workflows — empty backup is valid"
            else
                cat "$_wf_export_capture" >&2 2>/dev/null || true
                rm -f "$_wf_export_capture"
                log ERROR "[SC-EXPORT] workflow export command failed"
                return 1
            fi
        fi
        rm -f "$_wf_export_capture"
    fi

    _sc_export_run_with_loading \
        "Copying workflows into backup workspace..." \
        docker cp "$container:$tmp_dir/." "$out_dir/" || true
    dockExec "$container" "rm -rf '$tmp_dir'" 2>/dev/null || true

    if [ -n "${existing_workflow_ids_csv:-}" ]; then
        _sc_export_filter_dir_only_new "$out_dir" "$existing_workflow_ids_csv" "workflows"
    fi

    if _sc_export_is_enabled "${ARG_IMPORT_AS_NEW:-}"; then
        _sc_export_strip_ids_in_dir "$out_dir" "workflows"
    fi

    local count
    count=$(find "$out_dir" -type f -name '*.json' 2>/dev/null | wc -l | xargs)
    log INFO "[SC-EXPORT] workflows exported: ${count:-0}"
    return 0
}

_sc_export_credentials_stub_transform() {
    local input_file="$1"
    local output_dir="$2"

    if ! command_exists python3; then
        log ERROR "python3 is required to transform credential stubs"
        return 1
    fi

    python3 - "$input_file" "$output_dir" <<'PY'
import json, sys
from pathlib import Path

input_file = Path(sys.argv[1])
out_dir = Path(sys.argv[2])
out_dir.mkdir(parents=True, exist_ok=True)

def keep_or_redact(v):
    if isinstance(v, dict):
        return {k: keep_or_redact(x) for k, x in v.items()}
    if isinstance(v, list):
        return [keep_or_redact(x) for x in v]
    if isinstance(v, str):
        if v.strip().startswith("={{"):
            return v
        return ""
    if v is None:
        return None
    return ""

raw = json.loads(input_file.read_text(encoding="utf-8"))
items = raw if isinstance(raw, list) else [raw]

for cred in items:
    cid = str(cred.get("id") or "")
    if not cid:
        continue
    payload = {
        "id": cid,
        "name": cred.get("name") or cid,
        "type": cred.get("type") or "unknown",
        "ownedBy": cred.get("ownedBy"),
        "isGlobal": bool(cred.get("isGlobal", False)),
        "isResolvable": bool(cred.get("isResolvable", False)),
        "resolvableAllowFallback": bool(cred.get("resolvableAllowFallback", False)),
        "resolverId": cred.get("resolverId"),
        "data": keep_or_redact(cred.get("data", {})),
    }
    (out_dir / f"{cid}.json").write_text(json.dumps(payload, indent=2), encoding="utf-8")
PY
}

_sc_export_credentials_stubs_cli() {
    local container="$1"
    local output_root="$2"
    local is_dry_run="${3:-false}"
    local allowed_credential_ids_csv="${4:-}"
    local existing_credential_ids_csv="${5:-}"

    _sc_export_prepare_credentials_layout "$output_root" "stubs"
    local out_dir="$output_root/credential_stubs"

    if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
        log DRYRUN "Would export credential stubs into canonical layout"
        return 0
    fi

    local container_file="/tmp/n8n-manager-credentials-export.json"
    local tmp_file
    tmp_file=$(mktemp -t n8n-credentials-export-XXXXXXXXXX.json)

    # Patch-20: empty-source tolerance for credentials. Same pattern as the
    # workflows path above — n8n CLI's export:credentials --all exits
    # non-zero on a source with zero credentials. An empty credentials
    # backup is a valid operator state.
    local _cred_export_capture _cred_export_rc
    _cred_export_capture=$(mktemp)
    _cred_export_rc=0
    _sc_export_run_with_loading \
        "Exporting credential stubs from n8n..." \
        dockExec "$container" "n8n export:credentials --all --decrypted --output='$container_file' 2>&1" \
        >"$_cred_export_capture" || _cred_export_rc=$?
    if [ "$_cred_export_rc" -ne 0 ]; then
        if grep -qE "No credentials found|No credential with id" "$_cred_export_capture" 2>/dev/null; then
            log INFO "[SC-EXPORT] source has no credentials — empty stubs export is valid"
            rm -f "$_cred_export_capture" "$tmp_file"
            # Create empty credential_stubs/ directory so canonical layout is consistent.
            local out_dir="$output_root/credential_stubs"
            mkdir -p "$out_dir"
            log INFO "[SC-EXPORT] credential stubs exported: 0"
            return 0
        else
            cat "$_cred_export_capture" >&2 2>/dev/null || true
            rm -f "$_cred_export_capture" "$tmp_file"
            log ERROR "[SC-EXPORT] credential export command failed"
            return 1
        fi
    fi
    rm -f "$_cred_export_capture"

    if ! _sc_export_run_with_loading \
        "Copying credential export payload..." \
        docker cp "$container:$container_file" "$tmp_file"; then
        log ERROR "[SC-EXPORT] failed copying credential export file"
        dockExec "$container" "rm -f '$container_file'" 2>/dev/null || true
        rm -f "$tmp_file"
        return 1
    fi

    if ! _sc_export_credentials_stub_transform "$tmp_file" "$out_dir"; then
        log ERROR "[SC-EXPORT] failed transforming credential stubs"
        dockExec "$container" "rm -f '$container_file'" 2>/dev/null || true
        rm -f "$tmp_file"
        return 1
    fi

    dockExec "$container" "rm -f '$container_file'" 2>/dev/null || true
    rm -f "$tmp_file"

    if [ -n "${allowed_credential_ids_csv:-}" ]; then
        _sc_export_filter_dir_by_allowed_ids "$out_dir" "$allowed_credential_ids_csv" "credential stubs"
    fi

    if [ -n "${existing_credential_ids_csv:-}" ]; then
        _sc_export_filter_dir_only_new "$out_dir" "$existing_credential_ids_csv" "credential stubs"
    fi

    if _sc_export_is_enabled "${ARG_IMPORT_AS_NEW:-}"; then
        _sc_export_strip_ids_in_dir "$out_dir" "credential stubs"
    fi

    local count
    count=$(find "$out_dir" -type f -name '*.json' 2>/dev/null | wc -l | xargs)
    log INFO "[SC-EXPORT] credential stubs exported: ${count:-0}"
    return 0
}

_sc_export_credentials_full_cli() {
    local container="$1"
    local output_root="$2"
    local is_dry_run="${3:-false}"
    local credential_mode="${4:-encrypted}"
    local allowed_credential_ids_csv="${5:-}"
    local existing_credential_ids_csv="${6:-}"

    local decrypted_flag=""
    local mode_label="encrypted"
    if [ "$credential_mode" = "decrypted" ]; then
        decrypted_flag="--decrypted"
        mode_label="decrypted"
    fi

    _sc_export_prepare_credentials_layout "$output_root" "$credential_mode"
    local out_dir="$output_root/credentials"

    if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
        log DRYRUN "Would export full credentials ($mode_label) into canonical layout"
        return 0
    fi

    local tmp_dir="/tmp/n8n-manager-sc-credentials"
    dockExec "$container" "rm -rf '$tmp_dir' && mkdir -p '$tmp_dir'" || return 1

    # Patch-20: empty-source tolerance for full credential export. Same
    # rationale as the stubs path — empty source is valid.
    local _fc_export_capture _fc_export_rc
    _fc_export_capture=$(mktemp)
    _fc_export_rc=0
    _sc_export_run_with_loading \
        "Exporting full credentials ($mode_label) from n8n..." \
        dockExec "$container" "n8n export:credentials --all --separate $decrypted_flag --output='$tmp_dir/' 2>&1" \
        >"$_fc_export_capture" || _fc_export_rc=$?
    if [ "$_fc_export_rc" -ne 0 ]; then
        if grep -qE "No credentials found|No credential with id" "$_fc_export_capture" 2>/dev/null; then
            log INFO "[SC-EXPORT] source has no credentials — empty full export is valid"
            rm -f "$_fc_export_capture"
            dockExec "$container" "rm -rf '$tmp_dir'" 2>/dev/null || true
            log INFO "[SC-EXPORT] full credentials exported ($mode_label): 0"
            return 0
        else
            cat "$_fc_export_capture" >&2 2>/dev/null || true
            rm -f "$_fc_export_capture"
            dockExec "$container" "rm -rf '$tmp_dir'" 2>/dev/null || true
            log ERROR "[SC-EXPORT] full credential export command failed"
            return 1
        fi
    fi
    rm -f "$_fc_export_capture"

    _sc_export_run_with_loading \
        "Copying credential files into backup workspace..." \
        docker cp "$container:$tmp_dir/." "$out_dir/" || true
    dockExec "$container" "rm -rf '$tmp_dir'" 2>/dev/null || true

    if [ -n "${allowed_credential_ids_csv:-}" ]; then
        _sc_export_filter_dir_by_allowed_ids "$out_dir" "$allowed_credential_ids_csv" "credentials"
    fi

    if [ -n "${existing_credential_ids_csv:-}" ]; then
        _sc_export_filter_dir_only_new "$out_dir" "$existing_credential_ids_csv" "credentials"
    fi

    if _sc_export_is_enabled "${ARG_IMPORT_AS_NEW:-}"; then
        _sc_export_strip_ids_in_dir "$out_dir" "credentials"
    fi

    local count
    count=$(find "$out_dir" -type f -name '*.json' 2>/dev/null | wc -l | xargs)
    log INFO "[SC-EXPORT] full credentials exported ($mode_label): ${count:-0}"
    return 0
}

_sc_export_metadata_with_fallback() {
    local container="$1"
    local output_root="$2"
    local strict_mode="${3:-false}"
    local is_dry_run="${4:-false}"

    local metadata_ok=false

    # API engine is attempted only if an API key was already auto-discovered.
    if n8n_probe_has_api_auth; then
        log INFO "[SC-EXPORT] API key auto-detected; API engine probing enabled"
        # Current implementation relies on DB fallback for canonical metadata shape.
    fi

    if [ "${N8N_PROBE_DB_BACKEND:-sqlite}" = "sqlite" ]; then
        if db_sqlite_export_metadata "$container" "$output_root" "false" "$is_dry_run"; then
            metadata_ok=true
        fi
    else
        if db_pg_export_metadata "$container" "$output_root" "false" "$is_dry_run"; then
            metadata_ok=true
        fi
    fi

    if ! $metadata_ok; then
        sc_layout_add_gap "$output_root" "metadata" "db fallback export unavailable"
        if [ "$strict_mode" = "true" ]; then
            log ERROR "[SC-EXPORT] metadata export is required for enterprise mode"
            return 1
        fi
        log WARN "[SC-EXPORT] metadata export unavailable; continuing with warnings"
        return 0
    fi

    return 0
}

