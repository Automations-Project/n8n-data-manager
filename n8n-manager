    "conversionTimestamp": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "adapterVersion": adapter_ver,
}
with open(out_path, "w", encoding="utf-8", newline="\n") as f:
    json.dump(payload, f, ensure_ascii=False, indent=2)
PY

    mv "$tmp" "$out_path"
    return 0
}

