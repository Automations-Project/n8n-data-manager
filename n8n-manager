# ═══════════════════════════════════════════════════════════
# Workflow Listing — Extract metadata from n8n container
# ═══════════════════════════════════════════════════════════

# List all workflows from an n8n container with metadata
# Exports all workflows, parses JSON via node inside container
# Args: $1=container_id
# Output: pipe-delimited lines to stdout: id|name|active|updatedAt|nodeCount
# Returns: 0 on success, 1 on failure
list_container_workflows() {
    local container="$1"

    log DEBUG "[WORKFLOW_LIST] Listing workflows from container: $container"

    # Export all workflows to a temp JSON file inside the container.
    # Read-only discovery — runs via dockExec (dry-run guard in dockExec is intentional;
    # workflow listing is called only from interactive/read paths, not restore paths).
    local container_tmp="/tmp/_n8n_wf_list.json"
    local container_script="/tmp/_n8n_wf_parse.js"

    if ! dockExec "$container" "n8n export:workflow --all --output=$container_tmp" >/dev/null 2>&1; then
        log ERROR "[WORKFLOW_LIST] Failed to export workflows from container"
        return 1
    fi

    # Write Node.js parser script into the container via stdin (dockExecStdin pipes heredoc).
    dockExecStdin "$container" "cat > $container_script" << 'NODESCRIPT'
const fs = require("fs");
try {
    const raw = fs.readFileSync("/tmp/_n8n_wf_list.json", "utf8");
    let data = JSON.parse(raw);
    if (!Array.isArray(data)) data = [data];
    data.forEach(w => {
        const id = w.id || "unknown";
        const name = (w.name || "Untitled").replace(/\|/g, "-").replace(/,/g, " ");
        const active = w.active ? "Active" : "Inactive";
        const updated = (w.updatedAt || w.createdAt || "").substring(0, 19).replace("T", " ");
        const nodes = Array.isArray(w.nodes) ? w.nodes.length : 0;
        console.log([id, name, active, updated, nodes].join("|"));
    });
} catch(e) { console.error(e.message); process.exit(1); }
NODESCRIPT

    local workflow_data
    workflow_data=$(dockExec "$container" "node $container_script" 2>/dev/null)
    local exit_code=$?

    # Clean up temp files
    dockExec "$container" "rm -f $container_tmp $container_script" 2>/dev/null || true

    if [ $exit_code -ne 0 ] || [ -z "$workflow_data" ]; then
        log DEBUG "[WORKFLOW_LIST] No workflows found or parse failed"
        return 1
    fi

    echo "$workflow_data"
    return 0
}

# List workflows from a local backup directory (for restore selection)
# Handles both single-file (workflows.json) and separate-files modes
# Args: $1=backup_source_dir
# Output: pipe-delimited lines to stdout: id|name|active|updatedAt|nodeCount
list_backup_workflows() {
    local backup_dir="$1"

    log DEBUG "[WORKFLOW_LIST] Listing workflows from backup: $backup_dir"

    local workflows_file=""
    local using_separate=false

    # Detect backup format
    if [ -d "$backup_dir/workflows" ]; then
        using_separate=true
        log DEBUG "[WORKFLOW_LIST] Detected separate-files backup"
    elif [ -f "$backup_dir/workflows.json" ]; then
        workflows_file="$backup_dir/workflows.json"
        log DEBUG "[WORKFLOW_LIST] Detected single-file backup"
    else
        # Search for any JSON with workflow structure
        for f in "$backup_dir"/*.json; do
            if [ -f "$f" ] && grep -q '"nodes"' "$f" 2>/dev/null; then
                workflows_file="$f"
                break
            fi
        done
    fi

    if $using_separate; then
        # Parse each separate workflow JSON file with grep/sed
        for wf_file in "$backup_dir/workflows"/*.json; do
            [ -f "$wf_file" ] || continue
            _parse_workflow_metadata_basic "$wf_file"
        done
    elif [ -n "$workflows_file" ] && [ -f "$workflows_file" ]; then
        # Parse single JSON array file — try node on host, fallback to grep
        if command -v node >/dev/null 2>&1; then
            _parse_workflows_json_node "$workflows_file"
        else
            _parse_workflows_json_grep "$workflows_file"
        fi
    else
        log DEBUG "[WORKFLOW_LIST] No workflow files found in backup"
        return 1
    fi
}

