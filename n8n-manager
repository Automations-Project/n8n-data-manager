_sc_import_conflict_check() {
    local desired_json="$1"
    local existing_json="$2"
    local restore_type="$3"
    local force_flag="$4"
    local delete_missing="$5"

    if [ "$delete_missing" = "true" ] && [ "$force_flag" != "true" ]; then
        log ERROR "--delete-missing requires --force"
        return 2
    fi

    local mode="${ARG_RESTORE_MODE:-overwrite}"
    if [ "$mode" = "new-only" ] || [ "${ARG_ONLY_NEW:-}" = "1" ]; then
        return 0
    fi

    local import_as_new="$6"

    python3 - "$desired_json" "$existing_json" "$restore_type" "$force_flag" "$import_as_new" <<'PY'
import json, sys

desired = json.loads(open(sys.argv[1], 'r', encoding='utf-8').read())
existing = json.loads(open(sys.argv[2], 'r', encoding='utf-8').read())
restore_type = sys.argv[3]
force = sys.argv[4] == 'true'
import_as_new = sys.argv[5] == 'true'

resource_sets = {
    'workflows': restore_type in ('all', 'workflows') and not import_as_new,
    'credentials': restore_type in ('all', 'credentials') and not import_as_new,
    'projects': restore_type in ('all', 'enterprise'),
    'tags': restore_type in ('all', 'enterprise'),
    'variables': restore_type in ('all', 'enterprise'),
    'folders': restore_type in ('all', 'enterprise'),
    'datatables': restore_type in ('all', 'enterprise'),
}

conflicts = {}
for key, enabled in resource_sets.items():
    if not enabled:
        continue
    d = set(desired.get(key, []))
    e = set(existing.get(key, []))
    inter = sorted(d & e)
    if inter:
        conflicts[key] = inter

if conflicts and not force:
    preview = []
    for key, vals in conflicts.items():
        preview.append(f"{key}:{', '.join(vals[:5])}{' ...' if len(vals) > 5 else ''}")
    print('\n'.join(preview))
    sys.exit(2)

sys.exit(0)
PY
}

_sc_import_workflows_cli() {
    local container="$1"
    local source_dir="$2"
    local is_dry_run="$3"

    local workflows_dir="$source_dir/workflows"
    [ -d "$workflows_dir" ] || return 0

    if [ "$is_dry_run" = "true" ] || [ "$is_dry_run" = "1" ]; then
        log DRYRUN "Would import workflows from canonical layout"
        return 0
    fi

    local copy_source="$workflows_dir"
    local selected_tmp=""
    local filtered_tmp=""
    local stripped_tmp=""
    if [ -n "${ARG_WORKFLOW_ID:-}" ]; then
        selected_tmp=$(mktemp -d -t n8n-import-workflow-select-XXXXXXXXXX)
        while IFS= read -r wf_id; do
            [ -z "$wf_id" ] && continue
            if [ -f "$workflows_dir/$wf_id.json" ]; then
                cp "$workflows_dir/$wf_id.json" "$selected_tmp/$wf_id.json"
            fi
        done < <(_sc_import_split_csv_ids "$ARG_WORKFLOW_ID")
        copy_source="$selected_tmp"
    fi

    if _sc_import_is_new_only_mode; then
        local existing_workflows
        existing_workflows=$(detect_existing_workflows "$container" 2>/dev/null || true)
        existing_workflows=$(printf '%s' "$existing_workflows" | xargs)
        if [ -n "$existing_workflows" ]; then
            filtered_tmp=$(mktemp -d -t n8n-import-workflow-newonly-XXXXXXXXXX)
            filter_separate_files_by_ids "$copy_source" "$filtered_tmp" "$existing_workflows" "workflow" || {
                [ -n "$selected_tmp" ] && rm -rf "$selected_tmp"
                [ -n "$filtered_tmp" ] && rm -rf "$filtered_tmp"
                return 1
            }
            copy_source="$filtered_tmp"
        fi
    fi

    if _sc_import_is_import_as_new_mode; then
        stripped_tmp=$(mktemp -d -t n8n-import-workflow-asnew-XXXXXXXXXX)
        _sc_import_strip_ids_in_dir "$copy_source" "$stripped_tmp" "workflow" || {
            [ -n "$selected_tmp" ] && rm -rf "$selected_tmp"
            [ -n "$filtered_tmp" ] && rm -rf "$filtered_tmp"
            [ -n "$stripped_tmp" ] && rm -rf "$stripped_tmp"
            return 1
        }
        copy_source="$stripped_tmp"
    fi

    local file_count
    file_count=$(find "$copy_source" -maxdepth 1 -type f -name '*.json' 2>/dev/null | wc -l | xargs)
    if [ "${file_count:-0}" -eq 0 ]; then
        log INFO "[SC-IMPORT] no workflow files to import after filters"
        [ -n "$selected_tmp" ] && rm -rf "$selected_tmp"
        [ -n "$filtered_tmp" ] && rm -rf "$filtered_tmp"
        [ -n "$stripped_tmp" ] && rm -rf "$stripped_tmp"
        return 0
    fi

    dockExec "$container" "rm -rf /tmp/import_workflows && mkdir -p /tmp/import_workflows" || return 1
    docker cp "$copy_source/." "$container:/tmp/import_workflows/" || {
        [ -n "$selected_tmp" ] && rm -rf "$selected_tmp"
        [ -n "$filtered_tmp" ] && rm -rf "$filtered_tmp"
        [ -n "$stripped_tmp" ] && rm -rf "$stripped_tmp"
        return 1
    }

    local cmd="n8n import:workflow --separate --input=/tmp/import_workflows"
    [ -n "${ARG_USER_ID:-}" ] && cmd="$cmd --userId=$ARG_USER_ID"
    [ -n "${ARG_PROJECT_ID:-}" ] && cmd="$cmd --projectId=$ARG_PROJECT_ID"

    dockExec "$container" "$cmd" || {
        [ -n "$selected_tmp" ] && rm -rf "$selected_tmp"
        [ -n "$filtered_tmp" ] && rm -rf "$filtered_tmp"
        [ -n "$stripped_tmp" ] && rm -rf "$stripped_tmp"
        return 1
    }
    dockExec "$container" "rm -rf /tmp/import_workflows" 2>/dev/null || true
    [ -n "$selected_tmp" ] && rm -rf "$selected_tmp"
    [ -n "$filtered_tmp" ] && rm -rf "$filtered_tmp"
    [ -n "$stripped_tmp" ] && rm -rf "$stripped_tmp"
    return 0
}

