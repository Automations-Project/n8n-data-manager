  local setting_key="" setting_value=""

  if [ -n "$ARG_SETTING" ]; then
      is_update=true
      setting_key="${ARG_SETTING%%=*}"
      setting_value="${ARG_SETTING#*=}"

      if [ "$setting_key" = "$ARG_SETTING" ]; then
          log ERROR "Invalid --setting format. Use: --setting key=value"
          exit 1
      fi
  fi

  # ── Interactive mode: choose operation ───────────

