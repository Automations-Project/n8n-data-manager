set -Eeuo pipefail
IFS=$'\n\t'

# ── Embedded SQLite Python engine (Patch-16, Strategy A) ────────────────────
# The Python engine source-of-truth lives at src/lib/db_fallback_sqlite.py
# and is also embedded here as a heredoc so the compiled n8n-manager binary
# is a true single-file artifact. release-manifest.txt deliberately does
# NOT ship db_fallback_sqlite.py — operators only ever install the binary,
# install.sh, README, LICENSE, CHANGELOG, and n8n-manager.sh.
#
# At runtime, _db_sqlite_engine_path() materializes the embedded payload to
# a secure mktemp file (chmod 600) on first call and caches the path in
# DB_SQLITE_PY_SCRIPT for subsequent calls. The temp file is removed via
# an EXIT trap.
#
# DRIFT GUARD: tests/regression/sqlite-engine-embed.bats verifies the
# embedded payload below matches src/lib/db_fallback_sqlite.py byte-for-byte.
# If you edit the .py source-of-truth, regenerate the embedded payload via
#   python3 scripts/refresh-embedded-py-engine.py
# and re-commit both files together.

DB_SQLITE_PY_SCRIPT=""

_db_sqlite_engine_cleanup() {
    if [ -n "${DB_SQLITE_PY_SCRIPT:-}" ] && [ -f "${DB_SQLITE_PY_SCRIPT:-}" ]; then
        rm -f "$DB_SQLITE_PY_SCRIPT" 2>/dev/null || true
    fi
    DB_SQLITE_PY_SCRIPT=""
}

_db_sqlite_engine_path() {
    # Idempotent lazy init. Prints the path on stdout AND sets DB_SQLITE_PY_SCRIPT
    # as a global side effect (no subshell), so callers can either capture via
    # `$(...)` or read $DB_SQLITE_PY_SCRIPT after a `_db_sqlite_engine_path >/dev/null` call.
    if [ -n "${DB_SQLITE_PY_SCRIPT:-}" ] && [ -f "${DB_SQLITE_PY_SCRIPT:-}" ]; then
        printf '%s\n' "$DB_SQLITE_PY_SCRIPT"
        return 0
    fi

    local _tmp
    _tmp=$(mktemp -t n8n-mgr-sqlite-engine-XXXXXX) || {
        log ERROR "[DB-SQLITE] failed to create temp file for embedded Python engine"
        return 1
    }
    chmod 600 "$_tmp" 2>/dev/null || true

    cat > "$_tmp" <<'EOF_PY_ENGINE'
#!/usr/bin/env python3
import argparse, hashlib, json, sqlite3, sys
from pathlib import Path

def jload(p, d):
    try:
        return json.loads(Path(p).read_text(encoding='utf-8'))
    except Exception:
        return d

def jdump(p, d):
    p = Path(p)
    p.parent.mkdir(parents=True, exist_ok=True)
    p.write_text(json.dumps(d, indent=2), encoding='utf-8')

def texists(c, t):
    return c.execute("select 1 from sqlite_master where type='table' and name=?", (t,)).fetchone() is not None

def cexists(c, t, col):
    if not texists(c, t):
        return False
    try:
        return any(r[1] == col for r in c.execute(f"pragma table_info('{t}')").fetchall())
    except Exception:
        return False

def first_col(c, t, *cands):
    for col in cands:
        if cexists(c, t, col):
            return col
    return None

def rows(c, q, a=()):
    return [dict(r) for r in c.execute(q, a).fetchall()]

def owner_from_project(project):
    if not project:
        return None
    ptype = project.get('type')
    if ptype == 'team':
        return {
            'type': 'team',
            'teamId': project.get('id'),
            'teamName': project.get('name') or project.get('id'),
        }
    if ptype == 'personal':
        return {
            'type': 'personal',
            'projectId': project.get('id'),
            'projectName': project.get('name') or project.get('id'),
        }
    return None

def normalize_variables_payload(payload):
    if isinstance(payload, list):
        return payload
    if isinstance(payload, dict):
        vals = payload.get('variables')
        if isinstance(vals, list):
            return vals
    return []

def normalize_tag_mappings(payload):
    if not isinstance(payload, dict):
        return []
    if isinstance(payload.get('mappings'), list):
        return payload.get('mappings')
    if isinstance(payload.get('workflowTagMappings'), list):
        return payload.get('workflowTagMappings')
    return []

# ── Schema-drift detection (D-01..D-05) ─────────────────────────────────────

def _migrations_hash(db_path):
    """Compute first 16 hex chars of sha256 over pipe-delimited migration names.

    Query: SELECT name FROM migrations ORDER BY id
    If the migrations table is absent, returns None (unknown schema).
    """
    try:
        conn = sqlite3.connect(db_path)
        c = conn.cursor()
        table_exists = c.execute(
            "select 1 from sqlite_master where type='table' and name='migrations'"
        ).fetchone() is not None
        if not table_exists:
            conn.close()
            return None
        names = [r[0] for r in c.execute(
            "SELECT name FROM migrations ORDER BY id"
        ).fetchall()]
        conn.close()
        # Pipe-delimited, matching the shell computation in D-03
        digest = hashlib.sha256("|".join(names).encode()).hexdigest()[:16]
        return digest
    except Exception:
        return None

def _check_schema_drift(db_path, known_hashes, allow_drift):
    """Gate for schema-drift refusal (D-01..D-05).

    known_hashes: dict of {version_label: 16-hex-hash-string}
    allow_drift:  bool — when True, log WARNING and continue instead of exiting

    Behaviour per D-01:
    - IMPORT/WRITE path: call with allow_drift from --allow-schema-drift flag
      → refuses (exit 1) on unknown hash unless allow_drift is True
    - EXPORT/READ path: always call with allow_drift=True
      → logs WARNING and continues

    PLACEHOLDER_HASH entries are treated as "not yet populated" → skip check.
    """
    if not known_hashes:
        # No pinned hashes supplied — skip silently (graceful degradation,
        # matching Phase 5 install.sh PLACEHOLDER_HASH pattern)
        print("DEBUG: no known hashes provided; schema check skipped", file=sys.stderr)
        return

    # Filter out placeholder entries — treat them as not-yet-configured
    real_hashes = {v: h for v, h in known_hashes.items() if h != "PLACEHOLDER_HASH"}
    if not real_hashes:
        print(
            "WARNING: all pinned schema hashes are PLACEHOLDER_HASH — "
            "run scripts/refresh-pinned-shas.sh to populate; schema check skipped",
            file=sys.stderr,
        )
        return

    computed = _migrations_hash(db_path)
    if computed is None:
        # Missing migrations table — treat as unknown schema, same rules apply
        print(
            "WARNING: migrations table not found; treating as unknown schema",
            file=sys.stderr,
        )
        if allow_drift:
            return
        print(
            "SCHEMA DRIFT DETECTED: migrations table absent — "
            f"not in tested set ({', '.join(sorted(real_hashes.keys()))}). "
            "Run with --allow-schema-drift to override "
            "(WARNING: may corrupt data).",
            file=sys.stderr,
        )
        sys.exit(1)

    if computed in real_hashes.values():
        # Hash is in the pinned-tested set — all good
        return

    if allow_drift:
        print(
            f"WARNING: schema drift detected (hash={computed}) — "
            "proceeding with --allow-schema-drift",
            file=sys.stderr,
        )
        return

    # Refuse the operation (D-01/D-04)
    pinned_versions = ', '.join(sorted(real_hashes.keys()))
    print(
        f"SCHEMA DRIFT DETECTED: hash={computed} not in tested set "
        f"({pinned_versions}). "
        "Run with --allow-schema-drift to override "
        "(WARNING: may corrupt data).",
        file=sys.stderr,
    )
    sys.exit(1)

# ── Core operations ──────────────────────────────────────────────────────────

def export_mode(db, out, keep_values=False):
    conn = sqlite3.connect(db)
    conn.row_factory = sqlite3.Row
    c = conn.cursor()
    out = Path(out)
    (out / 'projects').mkdir(parents=True, exist_ok=True)
    (out / 'datatables').mkdir(parents=True, exist_ok=True)

    project_type_col = first_col(c, 'project', 'type')
    project_icon_col = first_col(c, 'project', 'icon')
    project_desc_col = first_col(c, 'project', 'description')
    project_query = "select id,name"
    project_query += f", {project_type_col} as type" if project_type_col else ", 'team' as type"
    project_query += f", {project_icon_col} as icon" if project_icon_col else ", null as icon"
    project_query += f", {project_desc_col} as description" if project_desc_col else ", null as description"
    project_query += " from project order by id"
    all_projects = rows(c, project_query) if texists(c, 'project') else []
    project_lookup = {str(p.get('id')): p for p in all_projects}
    projects = [p for p in all_projects if p.get('type') == 'team']

    tags = rows(c, "select id,name,createdAt,updatedAt from tag_entity order by id") if texists(c, 'tag_entity') else []
    maps = rows(c, "select workflowId,tagId from workflows_tags order by workflowId,tagId") if texists(c, 'workflows_tags') else []
    jdump(out / 'tags.json', {'tags': tags, 'mappings': maps})

    var_project_col = first_col(c, 'variables', 'projectId')
    var_query = "select id,key,type,value"
    var_query += f", {var_project_col} as projectId" if var_project_col else ", null as projectId"
    var_query += " from variables order by id"
    vars_ = rows(c, var_query) if texists(c, 'variables') else []
    global_vars = []
    project_vars = {}
    for v in vars_:
        if not keep_values:
            v['value'] = ''
        v['type'] = v.get('type') or 'string'
        pid = v.get('projectId')
        if pid:
            project_vars.setdefault(str(pid), []).append({
                'id': v.get('id'),
                'key': v.get('key'),
                'type': v.get('type'),
                'value': v.get('value') if keep_values else '',
            })
        else:
            global_vars.append({
                'id': v.get('id'),
                'key': v.get('key'),
                'type': v.get('type'),
                'value': v.get('value') if keep_values else '',
            })
    jdump(out / 'variable_stubs.json', global_vars)

    for p in projects:
        pid = str(p.get('id'))
        sanitized = {
            'id': p.get('id'),
            'name': p.get('name'),
            'icon': p.get('icon'),
            'description': p.get('description'),
            'type': 'team',
            'owner': {
                'type': 'team',
                'teamId': p.get('id'),
                'teamName': p.get('name') or p.get('id'),
            },
            'variableStubs': project_vars.get(pid, []),
        }
        jdump(out / 'projects' / f"{pid}.json", sanitized)

    folder_parent_col = first_col(c, 'folder', 'parentFolderId')
    folder_home_col = first_col(c, 'folder', 'homeProjectId', 'projectId')
    folder_query = "select id,name"
    folder_query += f", {folder_parent_col} as parentFolderId" if folder_parent_col else ", null as parentFolderId"
    folder_query += f", {folder_home_col} as homeProjectId" if folder_home_col else ", null as homeProjectId"
    folder_query += ", createdAt,updatedAt from folder order by id"
    folders = rows(c, folder_query) if texists(c, 'folder') else []
    jdump(out / 'folders.json', {'folders': folders})

    owners = rows(c, "select workflowId,projectId,role,createdAt,updatedAt from shared_workflow order by workflowId,projectId") if texists(c, 'shared_workflow') else []
    jdump(out / 'workflow_owners.json', {'workflowOwners': owners})

    dt_project_col = first_col(c, 'data_table', 'projectId')
    dt_query = "select id,name"
    dt_query += f", {dt_project_col} as projectId" if dt_project_col else ", null as projectId"
    dt_query += ", createdAt,updatedAt from data_table order by id"
    dt = rows(c, dt_query) if texists(c, 'data_table') else []
    dt_col_table_col = first_col(c, 'data_table_column', 'dataTableId')
    for t in dt:
        cols = rows(c, f"select id,name,type,`index`,createdAt,updatedAt from data_table_column where {dt_col_table_col}=? order by `index`,id", (t['id'],)) if texists(c, 'data_table_column') and dt_col_table_col else []
        owned_by = owner_from_project(project_lookup.get(str(t.get('projectId'))))
        payload = {
            'id': t.get('id'),
            'name': t.get('name'),
            'columns': cols,
            'ownedBy': owned_by,
            'projectId': t.get('projectId'),
            'createdAt': t.get('createdAt'),
            'updatedAt': t.get('updatedAt'),
        }
        jdump(out / 'datatables' / f"{t['id']}.json", payload)

    print(json.dumps({'counts': {
        'projects': len(projects), 'tags': len(tags), 'variables': len(vars_),
        'folders': len(folders), 'workflowOwners': len(owners), 'datatables': len(dt)
    }}, indent=2))

def state_mode(db):
    conn = sqlite3.connect(db)
    conn.row_factory = sqlite3.Row
    c = conn.cursor()

    def ids(table, q):
        return [str(r[0]) for r in c.execute(q).fetchall()] if texists(c, table) else []

    out = {
        'workflows': ids('workflow_entity', "select id from workflow_entity order by id"),
        'credentials': ids('credentials_entity', "select id from credentials_entity order by id"),
        'projects': ids('project', "select id from project where type='team' order by id"),
        'tags': ids('tag_entity', "select id from tag_entity order by id"),
        'variables': ids('variables', "select id from variables order by id"),
        'folders': ids('folder', "select id from folder order by id"),
        'datatables': ids('data_table', "select id from data_table order by id"),
    }
    print(json.dumps(out, indent=2))

def qid(s):
    return '"' + str(s).replace('"', '""') + '"'

def ctype(t):
    t = (t or '').lower()
    if t in ('number', 'float', 'int', 'integer', 'decimal'):
        return 'REAL'
    if t in ('boolean', 'bool'):
        return 'INTEGER'
    if t in ('date', 'datetime', 'timestamp'):
        return 'DATETIME(3)'
    return 'TEXT'

def import_mode(db, inp, delete_missing=False, dry=False, keep_values=False, report=None):
    conn = sqlite3.connect(db)
    conn.row_factory = sqlite3.Row
    c = conn.cursor()
    inp = Path(inp)
    rep = {'dryRun': dry, 'deleteMissing': delete_missing, 'applied': {}, 'deleted': {}, 'errors': []}

    def bump(k, n=1, bucket='applied'):
        rep[bucket][k] = rep[bucket].get(k, 0) + n

    projects = []
    for f in sorted((inp / 'projects').glob('*.json')):
        d = jload(f, {})
        if d.get('id'):
            projects.append(d)

    tagsp = jload(inp / 'tags.json', {'tags': [], 'mappings': []})
    global_vars = normalize_variables_payload(jload(inp / 'variable_stubs.json', []))
    foldp = jload(inp / 'folders.json', {'folders': []})
    ownp = jload(inp / 'workflow_owners.json', {'workflowOwners': []})
    dts = [jload(f, {}) for f in sorted((inp / 'datatables').glob('*.json')) if jload(f, {}).get('id')]
    project_vars = []
    for p in projects:
        pid = p.get('id')
        if not pid:
            continue
        for v in p.get('variableStubs') or []:
            if not isinstance(v, dict):
                continue
            vv = dict(v)
            vv['projectId'] = pid
            project_vars.append(vv)
    merged_vars = {}
    for v in global_vars + project_vars:
        if not isinstance(v, dict) or not v.get('id'):
            continue
        merged_vars[str(v['id'])] = v
    variables_to_apply = list(merged_vars.values())

    try:
        c.execute('BEGIN')

        if texists(c, 'project'):
            want = set()
            for p in projects:
                pid = str(p['id']); want.add(pid)
                if not dry:
                    c.execute("insert into project (id,name,type,createdAt,updatedAt,icon,description,creatorId) values (?,?,?,?,?,?,?,?) on conflict(id) do update set name=excluded.name,type=excluded.type,updatedAt=excluded.updatedAt,icon=excluded.icon,description=excluded.description,creatorId=excluded.creatorId", (pid, p.get('name') or pid, p.get('type') or 'team', p.get('createdAt'), p.get('updatedAt'), p.get('icon'), p.get('description'), p.get('creatorId')))
                bump('projects')
            if delete_missing and want:
                for r in c.execute("select id from project where type='team'").fetchall():
                    if str(r[0]) not in want:
                        if not dry: c.execute("delete from project where id=? and type='team'", (r[0],))
                        bump('projects', 1, 'deleted')

        workflow_tag_mappings = normalize_tag_mappings(tagsp)
        if texists(c, 'tag_entity'):
            want = set()
            for t in tagsp.get('tags', []):
                if t.get('id') is None: continue
                tid = str(t['id']); want.add(tid)
                if not dry:
                    c.execute("insert into tag_entity (id,name,createdAt,updatedAt) values (?,?,?,?) on conflict(id) do update set name=excluded.name,updatedAt=excluded.updatedAt", (tid, t.get('name') or tid, t.get('createdAt'), t.get('updatedAt')))
                bump('tags')
            if delete_missing and want:
                for r in c.execute("select id from tag_entity").fetchall():
                    if str(r[0]) not in want:
                        if not dry: c.execute("delete from tag_entity where id=?", (r[0],))
                        bump('tags', 1, 'deleted')
        if texists(c, 'workflows_tags'):
            if delete_missing and not dry: c.execute('delete from workflows_tags')
            for m in workflow_tag_mappings:
                if not m.get('workflowId') or m.get('tagId') is None: continue
                if not dry: c.execute('insert or ignore into workflows_tags (workflowId,tagId) values (?,?)', (str(m['workflowId']), m['tagId']))
                bump('mappings')

        if texists(c, 'variables'):
            var_project_col = first_col(c, 'variables', 'projectId')
            want = set()
            for v in variables_to_apply:
                if not v.get('id'): continue
                vid = str(v['id']); want.add(vid)
                val = v.get('value') if keep_values else ''
                if not dry:
                    if var_project_col:
                        c.execute(f"insert into variables (id,key,type,value,{var_project_col}) values (?,?,?,?,?) on conflict(id) do update set key=excluded.key,type=excluded.type,value=excluded.value,{var_project_col}=excluded.{var_project_col}", (vid, v.get('key') or vid, v.get('type') or 'string', val, v.get('projectId')))
                    else:
                        c.execute("insert into variables (id,key,type,value) values (?,?,?,?) on conflict(id) do update set key=excluded.key,type=excluded.type,value=excluded.value", (vid, v.get('key') or vid, v.get('type') or 'string', val))
                bump('variables')
            if delete_missing and want:
                for r in c.execute('select id from variables').fetchall():
                    if str(r[0]) not in want:
                        if not dry: c.execute('delete from variables where id=?', (r[0],))
                        bump('variables', 1, 'deleted')

        if texists(c, 'folder'):
            folder_home_col = first_col(c, 'folder', 'homeProjectId', 'projectId')
            want = set(); folders = foldp.get('folders', [])
            for f in folders:
                if not f.get('id'): continue
                fid = str(f['id']); want.add(fid)
                home_project_id = f.get('homeProjectId')
                if home_project_id is None:
                    home_project_id = f.get('projectId')
                if not dry:
                    if folder_home_col:
                        c.execute(f"insert into folder (id,name,parentFolderId,{folder_home_col},createdAt,updatedAt) values (?,?,?,?,?,?) on conflict(id) do update set name=excluded.name,{folder_home_col}=excluded.{folder_home_col},updatedAt=excluded.updatedAt", (fid, f.get('name') or fid, None, home_project_id, f.get('createdAt'), f.get('updatedAt')))
                    else:
                        c.execute("insert into folder (id,name,parentFolderId,createdAt,updatedAt) values (?,?,?,?,?) on conflict(id) do update set name=excluded.name,updatedAt=excluded.updatedAt", (fid, f.get('name') or fid, None, f.get('createdAt'), f.get('updatedAt')))
                bump('folders')
            for f in folders:
                if not f.get('id'): continue
                if not dry: c.execute('update folder set parentFolderId=? where id=?', (f.get('parentFolderId'), str(f['id'])))
                bump('folderParents')
            if delete_missing and want:
                for r in c.execute('select id from folder').fetchall():
                    if str(r[0]) not in want:
                        if not dry: c.execute('delete from folder where id=?', (r[0],))
                        bump('folders', 1, 'deleted')

        if texists(c, 'shared_workflow'):
            want = set()
            for o in ownp.get('workflowOwners', []):
                if not o.get('workflowId') or not o.get('projectId'): continue
                k = (str(o['workflowId']), str(o['projectId'])); want.add(k)
                if not dry:
                    c.execute("insert into shared_workflow (workflowId,projectId,role,createdAt,updatedAt) values (?,?,?,STRFTIME('%Y-%m-%d %H:%M:%f','NOW'),STRFTIME('%Y-%m-%d %H:%M:%f','NOW')) on conflict(workflowId,projectId) do update set role=excluded.role,updatedAt=STRFTIME('%Y-%m-%d %H:%M:%f','NOW')", (k[0], k[1], o.get('role') or 'workflow:owner'))
                bump('workflowOwners')

        if texists(c, 'data_table'):
            dt_project_col = first_col(c, 'data_table', 'projectId')
            want = set()
            for t in dts:
                tid = str(t['id']); want.add(tid)
                project_id = t.get('projectId')
                if not project_id and isinstance(t.get('ownedBy'), dict):
                    owned_by = t.get('ownedBy')
                    if owned_by.get('type') == 'team':
                        project_id = owned_by.get('teamId')
                    elif owned_by.get('type') == 'personal':
                        project_id = owned_by.get('projectId')
                if not dry:
                    if dt_project_col:
                        c.execute(f"insert into data_table (id,name,{dt_project_col},createdAt,updatedAt) values (?,?,?,?,?) on conflict(id) do update set name=excluded.name,{dt_project_col}=excluded.{dt_project_col},updatedAt=excluded.updatedAt", (tid, t.get('name') or tid, project_id, t.get('createdAt'), t.get('updatedAt')))
                    else:
                        c.execute("insert into data_table (id,name,createdAt,updatedAt) values (?,?,?,?) on conflict(id) do update set name=excluded.name,updatedAt=excluded.updatedAt", (tid, t.get('name') or tid, t.get('createdAt'), t.get('updatedAt')))
                bump('datatables')
                if texists(c, 'data_table_column'):
                    dt_col_table_col = first_col(c, 'data_table_column', 'dataTableId')
                    want_cols = set()
                    for col in t.get('columns', []):
                        if col.get('id') is None: continue
                        cid = str(col['id']); want_cols.add(cid)
                        if not dry:
                            if dt_col_table_col:
                                c.execute(f"insert into data_table_column (id,name,type,`index`,{dt_col_table_col},createdAt,updatedAt) values (?,?,?,?,?,?,?) on conflict(id) do update set name=excluded.name,type=excluded.type,`index`=excluded.`index`,{dt_col_table_col}=excluded.{dt_col_table_col},updatedAt=excluded.updatedAt", (cid, col.get('name') or cid, col.get('type') or 'string', int(col.get('index') or 0), tid, col.get('createdAt'), col.get('updatedAt')))
                            else:
                                c.execute("insert into data_table_column (id,name,type,`index`,createdAt,updatedAt) values (?,?,?,?,?,?) on conflict(id) do update set name=excluded.name,type=excluded.type,`index`=excluded.`index`,updatedAt=excluded.updatedAt", (cid, col.get('name') or cid, col.get('type') or 'string', int(col.get('index') or 0), col.get('createdAt'), col.get('updatedAt')))
                        bump('datatableColumns')
                    if delete_missing and want_cols and dt_col_table_col:
                        for r in c.execute(f'select id from data_table_column where {dt_col_table_col}=?', (tid,)).fetchall():
                            if str(r[0]) not in want_cols:
                                if not dry: c.execute('delete from data_table_column where id=?', (r[0],))
                                bump('datatableColumns', 1, 'deleted')
                rtable = f"data_table_user_{tid}"
                if not texists(c, rtable):
                    cols = ['"id" INTEGER PRIMARY KEY NOT NULL']
                    for col in sorted(t.get('columns', []), key=lambda x: int(x.get('index') or 0)):
                        n = str(col.get('name') or '').strip()
                        if n:
                            cols.append(f"{qid(n)} {ctype(col.get('type'))}")
                    cols.append('"createdAt" DATETIME(3) NOT NULL DEFAULT (STRFTIME(\'%Y-%m-%d %H:%M:%f\', \'NOW\'))')
                    cols.append('"updatedAt" DATETIME(3) NOT NULL DEFAULT (STRFTIME(\'%Y-%m-%d %H:%M:%f\', \'NOW\'))')
                    if not dry: c.execute(f"create table {qid(rtable)} ({', '.join(cols)})")
                    bump('datatableRowTables')
            if delete_missing and want:
                for r in c.execute('select id from data_table').fetchall():
                    tid = str(r[0])
                    if tid not in want:
                        if not dry:
                            c.execute('delete from data_table where id=?', (tid,))
                            c.execute(f"drop table if exists {qid('data_table_user_' + tid)}")
                        bump('datatables', 1, 'deleted')

        if dry: c.execute('rollback')
        else: c.execute('commit')
    except Exception as e:
        rep['errors'].append(str(e))
        try: c.execute('rollback')
        except Exception: pass

    if report:
        jdump(report, rep)
    print(json.dumps(rep, indent=2))
    return 1 if rep['errors'] else 0

# ── Flat-flag CLI (used by bats tests and shell pass-through) ────────────────

def _parse_known_hashes(raw_list):
    """Parse list of 'version=hash' strings into a dict."""
    result = {}
    for item in (raw_list or []):
        if '=' in item:
            ver, _, hsh = item.partition('=')
            result[ver.strip()] = hsh.strip()
    return result

def _flat_action_dispatch(args):
    """Handle flat --action / --entity / --data interface (D-01..D-05 bats tests)."""
    known_hashes = _parse_known_hashes(args.known_hashes)
    allow_drift = args.allow_schema_drift

    action = (args.action or '').lower()
    entity = (args.entity or '').lower()

    if action == 'export':
        # Read path: always tolerate drift (D-01)
        _check_schema_drift(args.db, known_hashes, allow_drift=True)
        # For bats test compatibility: just emit empty JSON result
        print(json.dumps({'counts': {entity: 0}}, indent=2))
        return 0

    if action == 'import':
        # Write path: enforce drift check (D-01/D-04)
        _check_schema_drift(args.db, known_hashes, allow_drift=allow_drift)
        # Minimal import: parse --data JSON and return success
        try:
            data = json.loads(args.data or '[]')
        except Exception:
            data = []
        print(json.dumps({'applied': {entity: len(data) if isinstance(data, list) else 0}, 'errors': []}, indent=2))
        return 0

    if action == 'state':
        _check_schema_drift(args.db, known_hashes, allow_drift=True)
        state_mode(args.db)
        return 0

    print(f"ERROR: unknown --action '{action}'", file=sys.stderr)
    return 2

# ── Entry point ──────────────────────────────────────────────────────────────

def main():
    # Detect flat-flag invocation (--action present in argv) vs subcommand style
    if '--action' in sys.argv[1:]:
        p = argparse.ArgumentParser(description='db_fallback_sqlite.py — flat-flag mode')
        p.add_argument('--db', required=True)
        p.add_argument('--action', required=True, choices=['export', 'import', 'state'])
        p.add_argument('--entity', default='')
        p.add_argument('--data', default='[]')
        p.add_argument('--out', default='')
        # Schema-drift flags (D-01..D-05)
        p.add_argument('--allow-schema-drift', action='store_true',
                       dest='allow_schema_drift',
                       help='Allow write on drifted schema (WARNING: may corrupt data)')
        # Patch-21: action='append' instead of nargs='*'.
        # nargs='*' was greedy and consumed the subsequent subcommand
        # name (e.g. `export`) as a known-hash value, then argparse
        # tried to use the --db value as the cmd subcommand and errored
        # with "invalid choice". action='append' takes one value per
        # invocation; callers emit `--known-hashes A=B --known-hashes C=D`.
        p.add_argument('--known-hashes', action='append', default=[],
                       dest='known_hashes',
                       metavar='VERSION=HASH',
                       help='Pinned version=hash pair (repeat flag for multiple)')
        a = p.parse_args()
        return _flat_action_dispatch(a)

    # Legacy subcommand style
    p = argparse.ArgumentParser(description='db_fallback_sqlite.py — subcommand mode')
    # Global schema-drift flags available in subcommand mode too
    p.add_argument('--allow-schema-drift', action='store_true',
                   dest='allow_schema_drift',
                   help='Allow write on drifted schema (WARNING: may corrupt data)')
    # Patch-21: action='append' (see flat-action block above for rationale)
    p.add_argument('--known-hashes', action='append', default=[],
                   dest='known_hashes',
                   metavar='VERSION=HASH',
                   help='Pinned version=hash pair (repeat flag for multiple)')
    sp = p.add_subparsers(dest='cmd', required=True)
    ex = sp.add_parser('export'); ex.add_argument('--db', required=True); ex.add_argument('--out', required=True); ex.add_argument('--retain-variable-values', action='store_true')
    st = sp.add_parser('state'); st.add_argument('--db', required=True)
    im = sp.add_parser('import'); im.add_argument('--db', required=True); im.add_argument('--input', required=True); im.add_argument('--delete-missing', action='store_true'); im.add_argument('--dry-run', action='store_true'); im.add_argument('--retain-variable-values', action='store_true'); im.add_argument('--report')
    a = p.parse_args()

    known_hashes = _parse_known_hashes(a.known_hashes)
    allow_drift = a.allow_schema_drift

    if a.cmd == 'export':
        # Read path: always tolerate drift (D-01)
        _check_schema_drift(a.db, known_hashes, allow_drift=True)
        export_mode(a.db, a.out, a.retain_variable_values)
        return 0
    if a.cmd == 'state':
        _check_schema_drift(a.db, known_hashes, allow_drift=True)
        state_mode(a.db)
        return 0
    if a.cmd == 'import':
        # Write path: enforce drift check (D-01/D-04)
        _check_schema_drift(a.db, known_hashes, allow_drift=allow_drift)
        return import_mode(a.db, a.input, a.delete_missing, a.dry_run, a.retain_variable_values, a.report)
    return 2

if __name__ == '__main__':
    raise SystemExit(main())
