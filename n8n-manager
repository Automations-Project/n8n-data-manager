# ═══════════════════════════════════════════════════════════
# Dependency Scanning
# ═══════════════════════════════════════════════════════════

# Scan a single .n8n file for executeWorkflow dependencies
# Args: $1=file path
# Output: pipe-delimited lines: sourceId|sourceName|targetId|nodeName
# Returns: 0 on success
wf_scan_dependencies() {
    local file="$1"

    if command_exists node; then
        node -e '
const fs = require("fs");
try {
    const d = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
    const srcId = d.id || "unknown";
    const srcName = (d.name || "Untitled").replace(/\|/g, "-");
    for (const node of d.nodes || []) {
        if (node.type === "n8n-nodes-base.executeWorkflow") {
            const wfId = node.parameters?.workflowId;
            let targetId = null;
            if (typeof wfId === "string" && !wfId.startsWith("={{")) {
                targetId = wfId;
            } else if (typeof wfId === "object" && wfId && wfId.value) {
                const val = String(wfId.value);
                if (!val.startsWith("={{")) targetId = val;
            }
            if (targetId) {
                const nodeName = (node.name || "").replace(/\|/g, "-");
                console.log([srcId, srcName, targetId, nodeName].join("|"));
            }
        }
    }
} catch(e) { /* skip invalid files */ }
' "$file" 2>/dev/null
    elif command_exists python3; then
        python3 -c "
import json, sys
try:
    with open(sys.argv[1]) as f: d = json.load(f)
    src_id = d.get('id', 'unknown')
    src_name = (d.get('name') or 'Untitled').replace('|', '-')
    for node in d.get('nodes', []):
        if node.get('type') == 'n8n-nodes-base.executeWorkflow':
            wf_id = node.get('parameters', {}).get('workflowId')
            target_id = None
            if isinstance(wf_id, str) and not wf_id.startswith('={{'):
                target_id = wf_id
            elif isinstance(wf_id, dict) and wf_id.get('value'):
                val = str(wf_id['value'])
                if not val.startswith('={{'):
                    target_id = val
            if target_id:
                node_name = (node.get('name') or '').replace('|', '-')
                print(f'{src_id}|{src_name}|{target_id}|{node_name}')
except: pass
" "$file" 2>/dev/null
    else
        # sed/awk fallback — works on busybox/Alpine (no grep -oP)
        local src_id src_name
        src_id=$(sed -n 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$file" 2>/dev/null | head -1)
        src_name=$(sed -n 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$file" 2>/dev/null | head -1)
        src_name=$(echo "${src_name:-Untitled}" | sed 's/|/-/g')

        # Check if file contains executeWorkflow at all
        if ! grep -q 'executeWorkflow' "$file" 2>/dev/null; then
            return 0
        fi

        # Extract workflowId targets — handles both formats:
        #   "workflowId": "plainId"           (simple string)
        #   "workflowId":{"value":"objId",...} (object with value field)
        # Since .n8n files are single-line JSON, split on workflowId and limit context
        {
            # Split file content at each "workflowId" boundary, take first 200 chars per chunk
            sed 's/"workflowId"/\n"workflowId"/g' "$file" 2>/dev/null | \
                grep '"workflowId"' | \
                while IFS= read -r chunk; do
                    local snippet
                    snippet=$(echo "$chunk" | cut -c1-200)
                    # Pattern 1: plain string — "workflowId":"id"
                    echo "$snippet" | sed -n 's/.*"workflowId"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p'
                    # Pattern 2: object — "workflowId":{..."value":"id"...}
                    echo "$snippet" | sed -n 's/.*"value"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p'
                done
        } | sort -u | while read -r target_id; do
            # Validate: skip expressions, empty, and non-ID strings
            [ -z "$target_id" ] && continue
            [[ "$target_id" == "={{"* ]] && continue
            [[ "$target_id" == *'$'* ]] && continue
            [[ "$target_id" == *" "* ]] && continue
            [[ "$target_id" == *"."* ]] && continue
            [[ "$target_id" == *"("* ]] && continue
            [[ "$target_id" == *"{"* ]] && continue
            # Valid workflow IDs are alphanumeric (5-50 chars)
            if echo "$target_id" | grep -qE '^[a-zA-Z0-9_-]{5,50}$' 2>/dev/null; then
                echo "${src_id:-unknown}|${src_name}|${target_id}|unknown"
            fi
        done
    fi
}

# ═══════════════════════════════════════════════════════════
# Dependency Graph Building
# ═══════════════════════════════════════════════════════════

# Build complete dependency graph from all .n8n files in a directory
# Args: $1=workflows directory
# Output: Sets global associative arrays (must be declared by caller):
#   WF_GRAPH_CALLS_TO[sourceId]="targetId1,targetId2,..."
#   WF_GRAPH_CALLED_BY[targetId]="sourceId1,sourceId2,..."
#   WF_GRAPH_NAMES[id]="name"
#   WF_GRAPH_FILES[id]="filepath"
# Returns: 0 on success
wf_build_dep_graph() {
    local dir="$1"

    log DEBUG "[WF_DEPS] Building dependency graph from: $dir"

    # First pass: collect all workflow IDs and names
    for f in "$dir"/*.n8n; do
        [ -f "$f" ] || continue
        local meta
        meta=$(_wf_extract_metadata "$f") 2>/dev/null || continue
        if [ -n "$meta" ]; then
            local wf_name wf_id
            wf_name=$(echo "$meta" | cut -d'|' -f1)
            wf_id=$(echo "$meta" | cut -d'|' -f2)
            if [ -n "$wf_id" ] && [ "$wf_id" != "unknown" ]; then
                WF_GRAPH_NAMES["$wf_id"]="$wf_name"
                WF_GRAPH_FILES["$wf_id"]="$f"
            fi
        fi
    done

    local total_workflows=${#WF_GRAPH_NAMES[@]}
    log DEBUG "[WF_DEPS] Indexed $total_workflows workflows"

    # Second pass: scan dependencies
    local total_edges=0
    for f in "$dir"/*.n8n; do
        [ -f "$f" ] || continue
        local deps
        deps=$(wf_scan_dependencies "$f")
        [ -z "$deps" ] && continue

        while IFS='|' read -r src_id src_name target_id node_name; do
            [ -z "$src_id" ] && continue

            # Add to callsTo
            local existing="${WF_GRAPH_CALLS_TO[$src_id]:-}"
            if [ -z "$existing" ]; then
                WF_GRAPH_CALLS_TO["$src_id"]="$target_id"
            elif [[ ",$existing," != *",$target_id,"* ]]; then
                WF_GRAPH_CALLS_TO["$src_id"]="${existing},${target_id}"
            fi

            # Add to calledBy
            existing="${WF_GRAPH_CALLED_BY[$target_id]:-}"
            if [ -z "$existing" ]; then
                WF_GRAPH_CALLED_BY["$target_id"]="$src_id"
            elif [[ ",$existing," != *",$src_id,"* ]]; then
                WF_GRAPH_CALLED_BY["$target_id"]="${existing},${src_id}"
            fi

            total_edges=$((total_edges + 1))
        done <<< "$deps"
    done

    log DEBUG "[WF_DEPS] Graph built: $total_workflows workflows, $total_edges edges"
    return 0
}

# ═══════════════════════════════════════════════════════════
# Node Categorization
# ═══════════════════════════════════════════════════════════

# Categorize workflows by role in the dependency graph
# Must be called after wf_build_dep_graph()
# Args: none (uses global WF_GRAPH_* arrays)
# Output: pipe-delimited lines: id|name|category
#   category: entry|middle|leaf|standalone
wf_categorize_nodes() {
    for wf_id in "${!WF_GRAPH_NAMES[@]}"; do
        local name="${WF_GRAPH_NAMES[$wf_id]}"
        local calls_to="${WF_GRAPH_CALLS_TO[$wf_id]:-}"
        local called_by="${WF_GRAPH_CALLED_BY[$wf_id]:-}"

        local category="standalone"
        if [ -n "$calls_to" ] && [ -z "$called_by" ]; then
            category="entry"
        elif [ -z "$calls_to" ] && [ -n "$called_by" ]; then
            category="leaf"
        elif [ -n "$calls_to" ] && [ -n "$called_by" ]; then
            category="middle"
        fi

        echo "${wf_id}|${name}|${category}"
    done
}

# Get graph summary stats
# Output: pipe-delimited: totalWorkflows|totalEdges|entryCount|middleCount|leafCount|standaloneCount
wf_graph_stats() {
    local total=${#WF_GRAPH_NAMES[@]}
    local edges=0 entry=0 middle=0 leaf=0 standalone=0

    for wf_id in "${!WF_GRAPH_NAMES[@]}"; do
        local calls_to="${WF_GRAPH_CALLS_TO[$wf_id]:-}"
        local called_by="${WF_GRAPH_CALLED_BY[$wf_id]:-}"

        if [ -n "$calls_to" ]; then
            local IFS_BAK="$IFS"
            IFS=','
            for _ in $calls_to; do edges=$((edges + 1)); done
            IFS="$IFS_BAK"
        fi

        if [ -n "$calls_to" ] && [ -z "$called_by" ]; then
            entry=$((entry + 1))
        elif [ -z "$calls_to" ] && [ -n "$called_by" ]; then
            leaf=$((leaf + 1))
        elif [ -n "$calls_to" ] && [ -n "$called_by" ]; then
            middle=$((middle + 1))
        else
            standalone=$((standalone + 1))
        fi
    done

    echo "${total}|${edges}|${entry}|${middle}|${leaf}|${standalone}"
}

# ═══════════════════════════════════════════════════════════
# Advanced Analysis — Circular Dependencies
# ═══════════════════════════════════════════════════════════

# Detect circular dependencies using DFS
# Must be called after wf_build_dep_graph()
# Output: pipe-delimited cycle chains: id1|id2|...|id1 (one per line)
# Returns: 0 if no cycles, 1 if cycles found
wf_find_circular_deps() {
    local -A visited
    local -A in_stack
    local cycles_found=0

    _wf_dfs_cycle() {
        local node="$1"
        local path="$2"

        visited["$node"]=1
        in_stack["$node"]=1

        local targets="${WF_GRAPH_CALLS_TO[$node]:-}"
        if [ -n "$targets" ]; then
            local IFS_BAK="$IFS"
            IFS=','
            for target in $targets; do
                if [ "${in_stack[$target]:-}" = "1" ]; then
                    # Cycle found — extract cycle from path
                    echo "${path}|${target}"
                    cycles_found=1
                elif [ "${visited[$target]:-}" != "1" ]; then
                    _wf_dfs_cycle "$target" "${path}|${target}"
                fi
            done
            IFS="$IFS_BAK"
        fi

        in_stack["$node"]=""
    }

    for wf_id in "${!WF_GRAPH_NAMES[@]}"; do
        if [ "${visited[$wf_id]:-}" != "1" ]; then
            _wf_dfs_cycle "$wf_id" "$wf_id"
        fi
    done

    return $cycles_found
}

# ═══════════════════════════════════════════════════════════
# Advanced Analysis — Orphan Workflows
# ═══════════════════════════════════════════════════════════

# Find workflows that are never called by any other workflow
# and don't call any other workflow (completely disconnected)
# Must be called after wf_build_dep_graph()
# Output: pipe-delimited lines: id|name
wf_find_orphan_workflows() {
    for wf_id in "${!WF_GRAPH_NAMES[@]}"; do
        local calls_to="${WF_GRAPH_CALLS_TO[$wf_id]:-}"
        local called_by="${WF_GRAPH_CALLED_BY[$wf_id]:-}"

        if [ -z "$calls_to" ] && [ -z "$called_by" ]; then
            echo "${wf_id}|${WF_GRAPH_NAMES[$wf_id]}"
        fi
    done
}

# ═══════════════════════════════════════════════════════════
# Advanced Analysis — Missing Dependencies
# ═══════════════════════════════════════════════════════════

# Find executeWorkflow references that point to workflow IDs
# not present in the scanned directory
# Must be called after wf_build_dep_graph()
# Output: pipe-delimited lines: sourceId|sourceName|missingTargetId
wf_find_missing_deps() {
    for src_id in "${!WF_GRAPH_CALLS_TO[@]}"; do
        local targets="${WF_GRAPH_CALLS_TO[$src_id]}"
        local src_name="${WF_GRAPH_NAMES[$src_id]:-unknown}"
        local IFS_BAK="$IFS"
        IFS=','
        for target_id in $targets; do
            if [ -z "${WF_GRAPH_NAMES[$target_id]:-}" ]; then
                echo "${src_id}|${src_name}|${target_id}"
            fi
        done
        IFS="$IFS_BAK"
    done
}

# ═══════════════════════════════════════════════════════════
# Advanced Analysis — Impact Analysis
# ═══════════════════════════════════════════════════════════

# Show all workflows that would be affected if a given workflow changes
# Traverses calledBy graph recursively (upstream impact)
# and callsTo graph (downstream dependencies)
# Args: $1=workflow ID or name
# Output: pipe-delimited lines: id|name|direction|depth
#   direction: upstream (callers) or downstream (callees)
wf_impact_analysis() {
    local target="$1"

    # Resolve name to ID if needed
    local target_id=""
    if [ -n "${WF_GRAPH_NAMES[$target]:-}" ]; then
        target_id="$target"
    else
        for wf_id in "${!WF_GRAPH_NAMES[@]}"; do
            if [ "${WF_GRAPH_NAMES[$wf_id]}" = "$target" ]; then
                target_id="$wf_id"
                break
            fi
        done
    fi

    if [ -z "$target_id" ]; then
        log ERROR "Workflow not found: $target"
        return 1
    fi

    local -A impact_visited

    # Traverse upstream (who calls this workflow?)
    _wf_traverse_impact() {
        local node="$1"
        local direction="$2"
        local depth="$3"

        impact_visited["${node}_${direction}"]=1

        local neighbors=""
        if [ "$direction" = "upstream" ]; then
            neighbors="${WF_GRAPH_CALLED_BY[$node]:-}"
        else
            neighbors="${WF_GRAPH_CALLS_TO[$node]:-}"
        fi

        if [ -n "$neighbors" ]; then
            local IFS_BAK="$IFS"
            IFS=','
            for neighbor in $neighbors; do
                local name="${WF_GRAPH_NAMES[$neighbor]:-$neighbor}"
                echo "${neighbor}|${name}|${direction}|${depth}"
                if [ "${impact_visited[${neighbor}_${direction}]:-}" != "1" ]; then
                    _wf_traverse_impact "$neighbor" "$direction" $((depth + 1))
                fi
            done
            IFS="$IFS_BAK"
        fi
    }

    _wf_traverse_impact "$target_id" "upstream" 1
    _wf_traverse_impact "$target_id" "downstream" 1
}

# ═══════════════════════════════════════════════════════════
# Dependency Tree Display
# ═══════════════════════════════════════════════════════════

# Show a text tree of dependencies for a workflow
# Args: $1=workflow ID, $2=indent prefix (internal), $3=direction (callsTo|calledBy)
# Output: indented tree to stdout
wf_show_dep_tree() {
    local wf_id="$1"
    local prefix="${2:-}"
    local direction="${3:-callsTo}"
    local -A tree_visited

    _wf_tree_recurse() {
        local node="$1"
        local indent="$2"
        local depth="$3"

        tree_visited["$node"]=1
        local name="${WF_GRAPH_NAMES[$node]:-$node}"
        local cat_icon="⚪"
        local calls_to="${WF_GRAPH_CALLS_TO[$node]:-}"
        local called_by="${WF_GRAPH_CALLED_BY[$node]:-}"
        if [ -n "$calls_to" ] && [ -z "$called_by" ]; then cat_icon="🟢"
        elif [ -z "$calls_to" ] && [ -n "$called_by" ]; then cat_icon="🔴"
        elif [ -n "$calls_to" ] && [ -n "$called_by" ]; then cat_icon="🟡"
        fi

        echo "${indent}${cat_icon} ${name} (${node})"

        local neighbors=""
        if [ "$direction" = "callsTo" ]; then
            neighbors="${WF_GRAPH_CALLS_TO[$node]:-}"
        else
            neighbors="${WF_GRAPH_CALLED_BY[$node]:-}"
        fi

        if [ -n "$neighbors" ] && [ "$depth" -lt 10 ]; then
            local IFS_BAK="$IFS"
            IFS=','
            for neighbor in $neighbors; do
                if [ "${tree_visited[$neighbor]:-}" = "1" ]; then
                    local nname="${WF_GRAPH_NAMES[$neighbor]:-$neighbor}"
                    echo "${indent}  ↻ ${nname} (circular)"
                else
                    _wf_tree_recurse "$neighbor" "${indent}  " $((depth + 1))
                fi
            done
            IFS="$IFS_BAK"
        fi
    }

    _wf_tree_recurse "$wf_id" "$prefix" 0
}

