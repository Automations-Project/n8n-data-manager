# Map global flags to ARG_* variables and run startup tasks.
# Must be called at the top of every command file after args are parsed.
setup_globals() {
    ARG_VERBOSE="${args[--verbose]:-}"
    ARG_DRY_RUN="${args[--dry-run]:-}"
    ARG_LOG_FILE="${args[--log-file]:-}"
    ARG_CONFIG_FILE="${args[--config]:-}"
    ARG_RECORD="${args[--record]:-}"
    ARG_RECORD_OUTPUT="${args[--record-output]:-}"

    if [[ "${args[--trace]:-}" == "1" ]]; then
        DEBUG_TRACE=true
        set -x
    fi

    # Load config (may set additional ARG_* vars)
    load_config

    # Session recording wrapper (may re-exec and exit)
    setup_session_recording

    # Verify host dependencies
    check_host_dependencies

    if [[ "$ARG_DRY_RUN" == "1" ]]; then
        log WARN "DRY RUN MODE ENABLED"
    fi
    if [[ "$ARG_VERBOSE" == "1" ]]; then
        log DEBUG "[MAIN] Verbose mode enabled."
    fi
}

# Load configuration from file
load_config() {
    local config_file="${ARG_CONFIG_FILE:-$CONFIG_FILE_PATH}"
    log DEBUG "[CONFIG] Loading configuration from: $config_file"

    if [ -f "$config_file" ]; then
        log DEBUG "[CONFIG] Configuration file found, parsing..."
        # Phase 4 MIG-02: v4 -> v5 config auto-trigger (D-10).
        # Fires before CONF_* parsing so the rewritten file is what gets parsed.
        # Non-fatal: failure logs WARN and falls through to reading the original.
        local _cfg_shape
        _cfg_shape=$(_config_detect_v4_shape "$config_file" 2>/dev/null || echo "missing")
        if [ "$_cfg_shape" = "v4" ]; then
            if ! _config_atomic_rewrite "$config_file" "auto" 2>/dev/null; then
                log WARN "[CONFIG] Auto-translate failed for ${config_file}; proceeding with original (run 'n8n-manager migrate-config' to retry)"
            fi
        fi
        while IFS='=' read -r key value; do
            # Skip comments and empty lines
            [[ -z "$key" || "$key" =~ ^[[:space:]]*# ]] && continue
            # Trim whitespace
            key=$(echo "$key" | xargs)
            value=$(echo "$value" | xargs)
            # Remove surrounding quotes from value
            value="${value%\"}"
            value="${value#\"}"
            value="${value%\'}"
            value="${value#\'}"

            log DEBUG "[CONFIG] Read config: $key = [value present]"

            case "$key" in
                CONF_GITHUB_TOKEN) [ -z "${ARG_TOKEN:-}" ] && ARG_TOKEN="$value" ;;
                CONF_GITHUB_REPO) [ -z "${ARG_REPO:-}" ] && ARG_REPO="$value" ;;
                CONF_GITHUB_BRANCH) [ -z "${ARG_BRANCH:-}" ] && ARG_BRANCH="$value" ;;
                CONF_CONTAINER) [ -z "${ARG_CONTAINER:-}" ] && ARG_CONTAINER="$value" ;;
                CONF_BACKUP_TYPE) [ -z "${ARG_BACKUP_TYPE:-}" ] && ARG_BACKUP_TYPE="$value" ;;
                CONF_BACKUP_LAYOUT) [ -z "${ARG_BACKUP_LAYOUT:-}" ] && ARG_BACKUP_LAYOUT="$value" ;;
                CONF_CREDENTIAL_EXPORT_MODE) [ -z "${ARG_CREDENTIAL_EXPORT_MODE:-}" ] && ARG_CREDENTIAL_EXPORT_MODE="$value" ;;
                CONF_RESTORE_TYPE) [ -z "${ARG_RESTORE_TYPE:-}" ] && ARG_RESTORE_TYPE="$value" ;;
                CONF_SEPARATE_FILES) [ "$value" = "true" ] && ARG_SEPARATE_FILES=true ;;
                CONF_N8N_API_KEY) [ -z "${ARG_N8N_API_KEY:-}" ] && ARG_N8N_API_KEY="$value" ;;
                CONF_N8N_API_URL) [ -z "${ARG_N8N_API_URL:-}" ] && ARG_N8N_API_URL="$value" ;;
                CONF_VERBOSE) [ "$value" = "true" ] && ARG_VERBOSE=1 ;;
                CONF_LOG_FILE) [ -z "${ARG_LOG_FILE:-}" ] && ARG_LOG_FILE="$value" ;;
                CONF_RECORD) [ "$value" = "true" ] && ARG_RECORD=1 ;;
                CONF_RECORD_OUTPUT) [ -z "${ARG_RECORD_OUTPUT:-}" ] && ARG_RECORD_OUTPUT="$value" ;;
                CONF_WORKFLOWS_DIR) [ -z "${ARG_WORKFLOWS_DIR:-}" ] && ARG_WORKFLOWS_DIR="$value" ;;
            esac
        done < "$config_file"
        log DEBUG "[CONFIG] Configuration file loaded successfully"
    else
        log DEBUG "[CONFIG] No configuration file found at: $config_file"
    fi
}

# Generate ISO-format timestamp
timestamp() {
    date '+%Y-%m-%d_%H-%M-%S'
}

# Safe temp directory creation with enforced 0700 mode (D-11)
# Usage: _safe_mktemp_dir <prefix>
# Example: TMP_DIR=$(_safe_mktemp_dir "n8n-prerestore") || exit 1
# Creates dir with umask 077, verifies mode 700, returns 1 on failure.
_safe_mktemp_dir() {
    local _prefix="${1:-n8n-tmp}"
    local _saved_umask
    _saved_umask=$(umask)
    umask 077
    local _dir
    _dir=$(mktemp -d -t "${_prefix}-XXXXXX" 2>/dev/null) || {
        umask "$_saved_umask"
        log ERROR "_safe_mktemp_dir: mktemp failed (prefix: $_prefix)"
        return 1
    }
    umask "$_saved_umask"
    local _mode
    _mode=$(stat -c '%a' "$_dir" 2>/dev/null || stat -f '%A' "$_dir" 2>/dev/null || echo "unknown")
    if [ "$_mode" != "700" ]; then
        log ERROR "_safe_mktemp_dir: created dir has unsafe mode $_mode: $_dir"
        rm -rf "$_dir" 2>/dev/null || true
        return 1
    fi
    printf '%s' "$_dir"
}

# Build n8n import command with appropriate flags
build_import_command() {
    local import_type="$1"    # workflow or credential
    local input_path="$2"
    local is_separate_files="${3:-false}"

    local cmd="n8n import:${import_type}"

    if [ "$is_separate_files" = "true" ]; then
        cmd="$cmd --separate --input=$input_path"
    else
        cmd="$cmd --input=$input_path"
    fi

    # Add user-id if specified
    if [ -n "${ARG_USER_ID:-}" ]; then
        cmd="$cmd --userId=$ARG_USER_ID"
        log DEBUG "[BUILD_CMD] Adding user-id: $ARG_USER_ID"
    fi

    # Add project-id if specified
    if [ -n "${ARG_PROJECT_ID:-}" ]; then
        cmd="$cmd --projectId=$ARG_PROJECT_ID"
        log DEBUG "[BUILD_CMD] Adding project-id: $ARG_PROJECT_ID"
    fi

    log DEBUG "[BUILD_CMD] Built import command: $cmd"
    echo "$cmd"
}

# src/lib/v4_shape_adapter.sh
#!/usr/bin/env bash
set -Eeuo pipefail
IFS=$'\n\t'
# v4 backup-repo shape adapter. Converts v4 layout (workflows.json + credentials.json
# at root, optional dated subdirs) -> canonical v5 staging directory.
# Library only -- sourced explicitly by source_control_import.sh; no command surface.
# Per Phase 3 CONTEXT.md decisions D-05..D-18.

V4_ADAPTER_VERSION="1.0"

# Internal helper: normalize a JSON file -- strip BOM, convert CRLF to LF,
# decode \uXXXX escapes to UTF-8. Writes result to <output_file> atomically.
# Original <input_file> is NEVER modified (D-11 lossless preservation).
# Args: $1 = input_file, $2 = output_file
# Return: 0 success; 1 normalization failure (invalid JSON, IO error)
_v4_normalize_json() {
    local input="$1" output="$2"
    local tmp
    tmp=$(mktemp "$output.tmp.XXXXXX") || return 1
    python3 - "$input" "$tmp" <<'PY' || { rm -f "$tmp"; return 1; }
import json, sys
src, dst = sys.argv[1], sys.argv[2]
with open(src, "rb") as f:
    raw = f.read()
if raw.startswith(b"\xef\xbb\xbf"):
    raw = raw[3:]
text = raw.decode("utf-8").replace("\r\n", "\n")
data = json.loads(text)
with open(dst, "w", encoding="utf-8", newline="\n") as f:
    json.dump(data, f, ensure_ascii=False, indent=2)
PY
    mv "$tmp" "$output"
}

# Public: detect the v4 shape variant of a backup directory.
# Args: $1 = src_dir (path to v4 backup repo root)
# Echoes ONE of: flat | dated_subdir_full | dated_subdir_short | unknown
# Return: 0 always (caller compares the echoed string)
#
# Detection rules (checked in order):
#   flat              -> workflows.json OR credentials.json directly under <src_dir>
#   dated_subdir_full -> backup_YYYY-MM-DD_HH-MM-SS/ subdir containing workflows.json
#   dated_subdir_short-> backup_YYYY-MM-DD/ subdir (not matching full pattern) containing workflows.json
#   unknown           -> no v4 markers found
#
# NOTE: flat is intentionally lenient (workflows.json OR credentials.json) because
# some v4 setups export credentials separately or not at all (D-15 + D-17).
v4_adapter_detect_variant() {
    local src_dir="$1"

    if [ ! -d "$src_dir" ]; then
        echo "unknown"
        return 0
    fi

    # Variant 1: flat -- workflows.json OR credentials.json directly under <src_dir>
    if [ -f "$src_dir/workflows.json" ] || [ -f "$src_dir/credentials.json" ]; then
        echo "flat"
        return 0
    fi

    # Variant 2: dated_subdir_full -- backup_YYYY-MM-DD_HH-MM-SS/ subdir
    local dated_full
    dated_full=$(find "$src_dir" -maxdepth 1 -type d -name 'backup_????-??-??_??-??-??' 2>/dev/null | head -n 1)
    if [ -n "$dated_full" ] && [ -f "$dated_full/workflows.json" ]; then
        echo "dated_subdir_full"
        return 0
    fi

    # Variant 3: dated_subdir_short -- backup_YYYY-MM-DD/ subdir (NOT matching the full timestamp pattern)
    local dated_short
    dated_short=$(find "$src_dir" -maxdepth 1 -type d -name 'backup_????-??-??' -not -name 'backup_????-??-??_*' 2>/dev/null | head -n 1)
    if [ -n "$dated_short" ] && [ -f "$dated_short/workflows.json" ]; then
        echo "dated_subdir_short"
        return 0
    fi

    # Variant 4 reserved (nested): returns "unknown" until Phase 6 fixture evidence
    echo "unknown"
    return 0
}

# Internal helper: locate the v4 source files for a given variant.
# Args: $1 = src_dir, $2 = variant
# Prints (newline-separated): <workflows_json_path>\n<credentials_json_path_or_empty>
# Returns 1 if workflows.json is missing entirely for dated variants (hard-fail signal).
_v4_resolve_variant_paths() {
    local src_dir="$1"
    local variant="$2"
    local wf_path=""
    local cr_path=""

    case "$variant" in
        flat)
            wf_path="$src_dir/workflows.json"
            cr_path="$src_dir/credentials.json"
            ;;
        dated_subdir_full)
            local sub
            sub=$(find "$src_dir" -maxdepth 1 -type d -name 'backup_????-??-??_??-??-??' 2>/dev/null | head -n 1)
            if [ -z "$sub" ]; then
                return 1
            fi
            wf_path="$sub/workflows.json"
            cr_path="$sub/credentials.json"
            ;;
        dated_subdir_short)
            local sub
            sub=$(find "$src_dir" -maxdepth 1 -type d -name 'backup_????-??-??' -not -name 'backup_????-??-??_*' 2>/dev/null | head -n 1)
            if [ -z "$sub" ]; then
                return 1
            fi
            wf_path="$sub/workflows.json"
            cr_path="$sub/credentials.json"
            ;;
        *)
            return 1
            ;;
    esac

    # For dated subdirs, workflows.json is required
    if [ "$variant" != "flat" ] && [ ! -f "$wf_path" ]; then
        return 1
    fi

    # cr_path may not exist -- caller handles that by stubbing credential_stubs/
    printf '%s\n%s\n' "$wf_path" "$cr_path"
    return 0
}

# Internal helper: split a v4 array-shaped JSON file into per-entity files in <out_dir>.
# Args: $1 = normalized_array_json (already passed through _v4_normalize_json)
#       $2 = out_dir (created if missing)
#       $3 = entity_label (workflow|credential -- for log messages, NEVER for values)
# Each output file is <out_dir>/<entity.id>.json.
# Prints the count of written entities to stdout.
#
# T-3-02 hardening (per WARNING 6 of revision 1/3):
# Crafted v4 entities can carry malicious `id` values like "../../etc/passwd"
# that would os.path.join out of <out_dir>. Two layers of defense:
#   (1) reject entity ids containing "/", "..", or "\" -- substitute "<label>-<count>"
#   (2) realpath assertion: refuse the write if the resolved output path is not
#       a strict descendant of <out_dir>. This catches symlink-traversal too.
_v4_split_array_to_files() {
    local input="$1"
    local out_dir="$2"
    local label="$3"

    [ -f "$input" ] || return 1
    mkdir -p "$out_dir"

    python3 - "$input" "$out_dir" "$label" <<'PY' || return 1
import json, sys, os, re
src, out_dir, label = sys.argv[1], sys.argv[2], sys.argv[3]
with open(src, "r", encoding="utf-8") as f:
    data = json.load(f)
if not isinstance(data, list):
    # Some v4 dumps use {"workflows":[...]} or single-object form
    if isinstance(data, dict):
        if isinstance(data.get(label + "s"), list):
            data = data[label + "s"]
        else:
            data = [data]
    else:
        sys.stderr.write(f"v4 adapter: {label} JSON is not an array or object\n")
        sys.exit(1)
count = 0
real_out_dir = os.path.realpath(out_dir)
for entity in data:
    if not isinstance(entity, dict):
        sys.stderr.write(f"v4 adapter: skipping non-dict {label} entry\n")
        continue
    eid = entity.get("id")
    if not eid:
        # Fall back to slug from name
        nm = entity.get("name", f"unnamed-{count}")
        eid = re.sub(r"[^A-Za-z0-9_-]+", "-", str(nm))
    # T-3-02 path-traversal guard (per WARNING 6 of revision 1/3).
    # Reject any id containing path separators or parent-dir refs; substitute
    # a safe fallback derived from the loop counter. Preserves count ordering
    # so downstream logs can correlate.
    eid_str = str(eid)
    if "/" in eid_str or ".." in eid_str or "\\" in eid_str:
        sys.stderr.write(
            f"v4 adapter: rejecting unsafe {label} id {eid_str!r}; "
            f"substituting safe fallback '{label}-{count}'\n"
        )
        eid = f"{label}-{count}"
        eid_str = str(eid)
    out_path = os.path.join(out_dir, f"{eid_str}.json")
    # T-3-02 defense-in-depth: realpath assertion. Refuse writes that escape
    # out_dir even after the eid sanitization above (catches symlink-traversal,
    # absolute-path eids that bypass the substring check, etc.).
    real_out_path = os.path.realpath(out_path)
    if not real_out_path.startswith(real_out_dir + os.sep):
        sys.stderr.write(
            f"v4 adapter: refusing write outside staging dir "
            f"(eid={eid_str!r}, attempted={real_out_path!r}, root={real_out_dir!r})\n"
        )
        sys.exit(1)
    with open(out_path, "w", encoding="utf-8", newline="\n") as f:
        json.dump(entity, f, ensure_ascii=False, indent=2)
    count += 1
sys.stdout.write(str(count))
PY
}

# Public: convert a v4 backup repo at <src_dir> to a canonical staging dir at <stage_dir>.
# The <stage_dir> must already exist (caller creates it via mktemp -d).
# Args: $1 = src_dir, $2 = stage_dir
# Side effects: writes canonical layout files + .n8n-manager/migrated-from.json + gaps.json
# Return: 0 success; 1 hard-fail (unrecognized variant, malformed JSON, missing required fields)
# On hard-fail: stderr MUST contain the source path + "migrate" suggestion banner.
v4_adapter_to_canonical_staging() {
    local src_dir="$1"
    local stage_dir="$2"

    if [ -z "$src_dir" ] || [ -z "$stage_dir" ]; then
        printf '[V4-ADAPTER] usage: v4_adapter_to_canonical_staging <src_dir> <stage_dir>\n' >&2
        return 1
    fi

    if [ ! -d "$src_dir" ]; then
        printf '[V4-ADAPTER] source dir not found: %s\n' "$src_dir" >&2
        printf '[V4-ADAPTER] suggestion: run `n8n-manager migrate --source <path>` after providing a valid v4 repo\n' >&2
        return 1
    fi

    if ! command -v python3 >/dev/null 2>&1; then
        printf '[V4-ADAPTER] python3 required for normalization; not found on PATH\n' >&2
        printf '[V4-ADAPTER] suggestion: install python3 OR re-run with --legacy-fallback for the pre-v5 import path\n' >&2
        return 1
    fi

    local variant
    variant=$(v4_adapter_detect_variant "$src_dir")
    if [ "$variant" = "unknown" ]; then
        printf '[V4-ADAPTER] no v4 markers found in %s\n' "$src_dir" >&2
        printf '[V4-ADAPTER] suggestion: confirm the source contains workflows.json or a backup_YYYY-MM-DD/ subdir, then re-run; or run `n8n-manager migrate --source <path>` to migrate manually\n' >&2
        return 1
    fi

    local paths
    if ! paths=$(_v4_resolve_variant_paths "$src_dir" "$variant"); then
        printf '[V4-ADAPTER] failed to resolve variant paths for %s in %s\n' "$variant" "$src_dir" >&2
        printf '[V4-ADAPTER] suggestion: run `n8n-manager migrate --source <path>` to upgrade the source repo manually\n' >&2
        return 1
    fi

    local wf_src cr_src
    wf_src=$(printf '%s' "$paths" | sed -n '1p')
    cr_src=$(printf '%s' "$paths" | sed -n '2p')

    # Scaffold canonical staging dir using existing helper (idempotent).
    if declare -F sc_layout_prepare_root >/dev/null 2>&1; then
        sc_layout_prepare_root "$stage_dir"
    else
        # Fallback: when adapter is sourced standalone in unit tests without source_control_layout.sh
        mkdir -p "$stage_dir/workflows" "$stage_dir/credential_stubs" "$stage_dir/projects" "$stage_dir/datatables" "$stage_dir/.n8n-manager"
        echo "[]" > "$stage_dir/.n8n-manager/gaps.json"
    fi

    # Track stubbed entities for the gap report
    local stubbed_entities=()

    # Normalize and split workflows.json (if it exists)
    if [ -n "$wf_src" ] && [ -f "$wf_src" ]; then
        local wf_normalized
        wf_normalized=$(mktemp -t v4-wf-normalized-XXXXXX)
        if ! _v4_normalize_json "$wf_src" "$wf_normalized"; then
            rm -f "$wf_normalized"
            printf '[V4-ADAPTER] normalization failed on workflows: %s\n' "$wf_src" >&2
            printf '[V4-ADAPTER] suggestion: inspect the file or run `n8n-manager migrate --source <path>` for guided repair\n' >&2
            return 1
        fi
        if ! _v4_split_array_to_files "$wf_normalized" "$stage_dir/workflows" "workflow" >/dev/null; then
            rm -f "$wf_normalized"
            printf '[V4-ADAPTER] failed splitting workflows.json into per-entity files (path: %s)\n' "$wf_src" >&2
            printf '[V4-ADAPTER] suggestion: confirm file is valid JSON; or run `n8n-manager migrate --source <path>` for guided repair\n' >&2
            return 1
        fi
        rm -f "$wf_normalized"
    else
        stubbed_entities+=("workflows.json")
    fi

    # Credentials are optional in some v4 setups (D-17 -> empty stub + record in stubbedEntities)
    if [ -n "$cr_src" ] && [ -f "$cr_src" ]; then
        local cr_normalized
        cr_normalized=$(mktemp -t v4-cr-normalized-XXXXXX)
        if ! _v4_normalize_json "$cr_src" "$cr_normalized"; then
            rm -f "$cr_normalized"
            printf '[V4-ADAPTER] normalization failed on credentials: %s\n' "$cr_src" >&2
            printf '[V4-ADAPTER] suggestion: inspect or run `n8n-manager migrate --source <path>`\n' >&2
            return 1
        fi
        if ! _v4_split_array_to_files "$cr_normalized" "$stage_dir/credential_stubs" "credential" >/dev/null; then
            rm -f "$cr_normalized"
            printf '[V4-ADAPTER] failed splitting credentials.json (path: %s)\n' "$cr_src" >&2
            printf '[V4-ADAPTER] suggestion: confirm file is valid JSON; or run `n8n-manager migrate --source <path>`\n' >&2
            return 1
        fi
        rm -f "$cr_normalized"
    else
        stubbed_entities+=("credentials.json")
    fi

    # Stub the v4-missing canonical entity types (D-17)
    [ -f "$stage_dir/tags.json" ]            || { echo "[]" > "$stage_dir/tags.json";            stubbed_entities+=("tags.json"); }
    [ -f "$stage_dir/folders.json" ]         || { echo "[]" > "$stage_dir/folders.json";         stubbed_entities+=("folders.json"); }
    [ -f "$stage_dir/variable_stubs.json" ]  || { echo "[]" > "$stage_dir/variable_stubs.json";  stubbed_entities+=("variable_stubs.json"); }
    [ -f "$stage_dir/workflow_owners.json" ] || { echo "[]" > "$stage_dir/workflow_owners.json"; stubbed_entities+=("workflow_owners.json"); }
    # Empty dirs already created by sc_layout_prepare_root; record them as stubbed
    stubbed_entities+=("projects/" "datatables/")

    # Build CSV of source paths for the gap report
    local source_paths_csv=""
    [ -n "$wf_src" ] && [ -f "$wf_src" ] && source_paths_csv="$wf_src"
    if [ -n "$cr_src" ] && [ -f "$cr_src" ]; then
        if [ -n "$source_paths_csv" ]; then
            source_paths_csv="$source_paths_csv,$cr_src"
        else
            source_paths_csv="$cr_src"
        fi
    fi

    # Build CSV of stubbed entities for the gap report
    local stubbed_csv=""
    if [ "${#stubbed_entities[@]}" -gt 0 ]; then
        stubbed_csv=$(printf '%s,' "${stubbed_entities[@]}")
        stubbed_csv="${stubbed_csv%,}"
    fi

    if ! v4_adapter_emit_gap_report "$src_dir" "$stage_dir" "$variant" "$source_paths_csv" "$stubbed_csv"; then
        printf '[V4-ADAPTER] failed writing migrated-from.json\n' >&2
        return 1
    fi

    return 0
}

# Public: write <stage_dir>/.n8n-manager/migrated-from.json with the full D-06 schema.
# Args: $1 = src_dir, $2 = stage_dir, $3 = variant_string, $4 = source_paths_csv, $5 = stubbed_csv
# Uses atomic temp-then-rename (mktemp + mv).
# Return: 0 success; 1 write failure
v4_adapter_emit_gap_report() {
    local src_dir="$1"
    local stage_dir="$2"
    local variant="$3"
    local source_paths_csv="$4"
    local stubbed_csv="$5"

    local meta_dir="$stage_dir/.n8n-manager"
    mkdir -p "$meta_dir"
    local out_path="$meta_dir/migrated-from.json"
    local tmp
    tmp=$(mktemp "$out_path.tmp.XXXXXX") || return 1

    # Use Python for robust JSON emission -- avoids shell-escaping bugs with paths
    # containing special chars. Pass csv lists; let Python build the arrays.
    python3 - "$tmp" "$variant" "$source_paths_csv" "$stubbed_csv" "$V4_ADAPTER_VERSION" <<'PY' || { rm -f "$tmp"; return 1; }
